{"summary_id": "scene-00001", "scene_id": "scene-00001", "source_file": "CSV/cidol/amao/adv_cidol-amao-3-001_01.csv", "source_kind": "cidol", "chapter": "cidol/amao", "scene": "adv_cidol-amao-3-001_01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "43", "line_count": 43}], "source_refs": ["CSV/cidol/amao/adv_cidol-amao-3-001_01.csv:1-43"], "line_count": 43, "speakers": ["制作人", "麻央"], "topics": ["team_story", "relationships", "dialogue_style", "worldbuilding"], "title": "宿舍夏日活动企划", "summary": "麻央计划为适应宿舍生活的新生举办夏日活动，因意见分散而苦恼。她提及咲季提议举办迷你演唱会，但因担心噪音问题且姫崎莉波事务繁忙而暂不考虑。制作人建议烧烤或流水素面，双方讨论中庭使用及竹林砍伐许可事宜。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "琴音", "手毬", "清夏", "麻央", "广", "莉波", "美铃"], "worldbuilding_signals": ["学园", "演唱会", "工作"], "dialogue_style_signals": ["制作人", "啦"], "key_evidence": [{"source_row": "20", "speaker": "麻央", "text_zh": "咲季说要办迷你演唱会啊。"}, {"source_row": "22", "speaker": "麻央", "text_zh": "莉波光是学生会的工作就已经忙得不可开交了。"}, {"source_row": "37", "speaker": "制作人", "text_zh": "校舍后面的森林里，说不定有竹林。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["麻央计划为新生举办宿舍夏日活动。", "咲季提议举办迷你演唱会。", "姫崎莉波因学生会工作和演唱会筹备无法参与。", "制作人提议去森林砍竹制作流水素面。"], "relationship_facts": ["麻央与制作人是同事关系。", "咲季是麻央的同事或同学。", "姫崎莉波是学生会成员。"], "worldbuilding_facts": ["初星学园宿舍内设有中庭。", "学园校舍后方有森林和竹林。", "学园内禁止随意砍伐树木。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00002", "scene_id": "scene-00002", "source_file": "CSV/cidol/amao/adv_cidol-amao-3-001_03.csv", "source_kind": "cidol", "chapter": "cidol/amao", "scene": "adv_cidol-amao-3-001_03", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "32", "line_count": 32}], "source_refs": ["CSV/cidol/amao/adv_cidol-amao-3-001_03.csv:1-32"], "line_count": 32, "speakers": ["佑芽", "制作人", "咲季", "广", "手毬", "清夏", "琴音", "美铃", "莉波", "莉莉娅", "麻央"], "topics": ["team_story", "relationships", "dialogue_style", "plot"], "title": "夏日宿舍的回忆", "summary": "新生们在宿舍举办烧烤、卡拉OK等夏日活动，气氛混沌热闹。咲季曾霸占麦克风唱歌，后让位给琴音。制作人带来慰劳品，麻央坦言这是她作为三年级生想留下的最后回忆。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "琴音", "手毬", "清夏", "麻央", "广", "莉波", "美铃", "莉莉娅"], "worldbuilding_signals": ["演唱会"], "dialogue_style_signals": ["制作人", "啦"], "key_evidence": [{"source_row": "6", "speaker": "手毬", "text_zh": "咲季，你一直霸占着麦克风吧。"}, {"source_row": "17", "speaker": "麻央", "text_zh": "烧烤也好，卡拉OK演唱会也好，劈西瓜也好"}, {"source_row": "26", "speaker": "麻央", "text_zh": "因为是最后一个夏天了"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季曾霸占麦克风唱歌，被手毬提醒该换人了。", "麻央为新生们举办烧烤、卡拉OK、劈西瓜等混合活动。", "麻央透露这是她作为三年级生想在宿舍留下的最后回忆。"], "relationship_facts": ["咲季与佑芽是姐妹关系。", "麻央是琴音的学姐。", "制作人与麻央是上下级关系。"], "worldbuilding_facts": ["活动包含劈西瓜、烧烤、卡拉OK、放烟花、流水素面等。", "现场准备了充气泳池。", "参与者包括新生与三年级生，宿舍是共同生活场所。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00003", "scene_id": "scene-00003", "source_file": "CSV/cidol/amao/adv_cidol-amao-3-009_01.csv", "source_kind": "cidol", "chapter": "cidol/amao", "scene": "adv_cidol-amao-3-009_01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "37", "line_count": 37}], "source_refs": ["CSV/cidol/amao/adv_cidol-amao-3-009_01.csv:1-37"], "line_count": 37, "speakers": ["制作人", "麻央"], "topics": ["team_story", "relationships", "dialogue_style", "worldbuilding"], "title": "麻央的雏人偶与守护", "summary": "休息日，制作人协助麻央筹备女儿节活动。麻央展示了参考『初』风格并融入学妹特征的雏人偶，感慨曾丢弃玩偶的过往。她立志像照顾自己的学姐们一样守护学妹们，制作人则承诺守护麻央，两人互诉心意。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人", "琴音", "手毬", "麻央", "莉波", "朋友"], "worldbuilding_signals": ["学园", "偶像", "演唱会", "工作"], "dialogue_style_signals": ["制作人"], "key_evidence": [{"source_row": "22", "speaker": "麻央", "text_zh": "琴音和咲季和手毬组成的热闹三人组呢。"}, {"source_row": "12", "speaker": "麻央", "text_zh": "全都扔掉了……真是做了件错事呢。"}, {"source_row": "31", "speaker": "麻央", "text_zh": "至少要对宿舍的学妹们一个个好好关注。"}, {"source_row": "34", "speaker": "制作人", "text_zh": "麻央同学就由我来好好守护。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["麻央制作了女儿节活动的偶像雏人偶。", "麻央曾认为玩偶太孩子气而将其全部扔掉。", "麻央立志像曾经关照她的学姐们一样守护学妹们。", "制作人承诺今后会好好守护麻央。"], "relationship_facts": ["麻央是宿舍舍长，负责关照学妹们。", "藤田琴音、咲季和手毬组成了热闹的三人组。", "制作人承诺守护麻央。"], "worldbuilding_facts": ["活动为初星学园举办的女儿节活动。", "麻央参考了『初』的服装风格制作雏人偶。", "藤田琴音是一年级的学妹。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00004", "scene_id": "scene-00004", "source_file": "CSV/cidol/amao/adv_cidol-amao-3-009_03.csv", "source_kind": "cidol", "chapter": "cidol/amao", "scene": "adv_cidol-amao-3-009_03", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "75", "line_count": 75}], "source_refs": ["CSV/cidol/amao/adv_cidol-amao-3-009_03.csv:1-75"], "line_count": 75, "speakers": ["制作人", "女孩子", "清夏", "琴音", "莉莉娅", "麻央"], "topics": ["team_story", "relationships", "dialogue_style", "worldbuilding"], "title": "雏人偶与初星光芒", "summary": "雪后初晴，麻央与制作人展示以琴音等人为原型的雏人偶。清夏、琴音、莉莉娅前来应援，众人协助拍摄写真。演出结束后，大家发现雪人玩偶，麻央感慨能将初星光芒传递给未来，众人约定明日再见。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人", "琴音", "手毬", "清夏", "麻央", "莉莉娅"], "worldbuilding_signals": ["学园", "演唱会"], "dialogue_style_signals": ["呵呵", "制作人", "啦"], "key_evidence": [{"source_row": "24", "speaker": "琴音", "text_zh": "待会儿也让咲季和手毬看看好了。"}, {"source_row": "21", "speaker": "麻央", "text_zh": "是以琴音她们为原型制作的哦。"}, {"source_row": "71", "speaker": "麻央", "text_zh": "如果能将初星的光芒传递给未来的学弟学妹们，我会很开心的。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["麻央与制作人共同制作了以琴音等人为原型的雏人偶。", "清夏、琴音、莉莉娅三人组协助拍摄了陪在天子大人身边的雏姬大人写真。", "演出结束后，众人发现孩子们制作的雪人玩偶，麻央为此感到开心。", "麻央希望将初星学园的光芒传递给未来的学弟学妹们。"], "relationship_facts": ["麻央是琴音、清夏、莉莉娅的前辈，在宿舍中拥有声望。", "清夏、琴音、莉莉娅是负责活跃气氛的三人组。", "制作人是活动的组织者，负责召集大家并协助拍摄。"], "worldbuilding_facts": ["活动场地为初星学园，参与者穿着女儿节服饰。", "场景中有积雪残留，孩子们制作了模仿角色的雪人玩偶。", "麻央是即将举办演唱会的偶像，深受孩子们喜爱。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00005", "scene_id": "scene-00005", "source_file": "CSV/cidol/fktn/adv_cidol-fktn-3-000_02.csv", "source_kind": "cidol", "chapter": "cidol/fktn", "scene": "adv_cidol-fktn-3-000_02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "45", "line_count": 45}], "source_refs": ["CSV/cidol/fktn/adv_cidol-fktn-3-000_02.csv:1-45"], "line_count": 45, "speakers": ["咲季", "琴音"], "topics": ["team_story", "relationships", "dialogue_style", "worldbuilding"], "title": "咲季指导琴音唱自我赞歌", "summary": "咲季发现琴音因无法融入歌曲而烦恼，指出其缺乏强烈的自我赞美之心。咲季鼓励琴音以偶像自信，用热情唱响属于自我的歌，帮助琴音理解创作者的思念并找到共鸣，最终琴音决定练习这首‘我的歌’。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["琴音", "姐姐"], "worldbuilding_signals": ["偶像", "演唱会"], "dialogue_style_signals": ["真是的", "哼", "不是吗", "啦"], "key_evidence": [{"source_row": "35", "speaker": "咲季", "text_zh": "你缺少的是比任何人都强烈的自我赞美之心！"}, {"source_row": "31", "speaker": "咲季", "text_zh": "这首歌就是在歌颂琴音才是世界第一可爱啊！"}, {"source_row": "45", "speaker": "琴音", "text_zh": "来练习『我的歌』吧～～！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季指出琴音烦恼的根源是缺乏强烈的自我赞美之心。", "咲季强调这首歌是歌颂琴音世界第一可爱的作品。", "琴音在咲季的鼓励下理解了歌曲含义并决定练习。"], "relationship_facts": ["咲季是琴音的姐姐，主动关心并指导她。", "咲季认为琴音是‘世界第一可爱’的偶像。", "咲季与琴音关系亲密，咲季能直接打断琴音的烦恼。"], "worldbuilding_facts": ["咲季和琴音都是偶像，需要面对演唱会。", "歌曲创作包含创作者希望偶像世界第一可爱的思念。", "偶像表演需要配合欢快曲子的自信与热情。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00006", "scene_id": "scene-00006", "source_file": "CSV/cidol/fktn/adv_cidol-fktn-3-011_02.csv", "source_kind": "cidol", "chapter": "cidol/fktn", "scene": "adv_cidol-fktn-3-011_02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "47", "line_count": 47}], "source_refs": ["CSV/cidol/fktn/adv_cidol-fktn-3-011_02.csv:1-47"], "line_count": 47, "speakers": ["制作人", "琴音"], "topics": ["relationships", "team_story", "dialogue_style", "worldbuilding"], "title": "咲季缺席的梦境与才", "summary": "琴音向制作人倾诉梦见咲季与手毬照顾自己、教唱歌的亲密场景，醒来后对现实感到失落。制作人肯定琴音歌唱进步巨大，并指出其视觉与舞蹈才能远超常人，令琴音既开心又因被比较而生气，最终表白心意。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人", "琴音", "手毬", "星南", "朋友", "伙伴"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["嘿嘿", "制作人", "啦"], "key_evidence": [{"source_row": "4", "speaker": "琴音", "text_zh": "咲季无微不至地照顾我……"}, {"source_row": "5", "speaker": "琴音", "text_zh": "那个手毬居然……认真教我唱歌了。"}, {"source_row": "35", "speaker": "制作人", "text_zh": "进步很大。再也不会说你唱得差了。"}, {"source_row": "47", "speaker": "琴音", "text_zh": "我喜欢你！！！！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["琴音梦见咲季无微不至地照顾自己并教手毬唱歌。", "制作人确认琴音的歌唱才能进步巨大，已是很厉害的武器。", "制作人评价琴音的视觉与舞蹈才能远超普通偶像。", "琴音因制作人比较两人才能而生气并表白。"], "relationship_facts": ["琴音与咲季在梦中关系亲密，现实中是朋友。", "制作人与琴音是搭档关系，制作人负责评价与指导。", "琴音对制作人怀有超越搭档的喜欢之情。"], "worldbuilding_facts": ["评价偶像的标准包括歌唱、舞蹈和视觉三项。", "普通偶像的三项才能设定为1，1，1。", "琴音的歌唱才能估算为0.4，视觉与舞蹈为100。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00007", "scene_id": "scene-00007", "source_file": "CSV/cidol/fktn/adv_cidol-fktn-3-016_01.csv", "source_kind": "cidol", "chapter": "cidol/fktn", "scene": "adv_cidol-fktn-3-016_01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "49", "line_count": 49}], "source_refs": ["CSV/cidol/fktn/adv_cidol-fktn-3-016_01.csv:1-49"], "line_count": 49, "speakers": ["制作人", "咲季", "手毬", "琴音"], "topics": ["relationships", "team_story", "dialogue_style", "worldbuilding"], "title": "咲季与手毬共演风波", "summary": "琴音得知将与咲季和手毬共演，既兴奋又因自身差距感而焦虑。制作人指出共演旨在实现粉丝共享，要求琴音展现能吸引咲季挑剔粉丝的舞蹈实力及手毬粉丝认可的歌喉，鼓励她超越自我。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人", "琴音", "手毬"], "worldbuilding_signals": ["偶像", "演唱会"], "dialogue_style_signals": ["当然", "哼", "制作人", "啦"], "key_evidence": [{"source_row": "5", "speaker": "咲季", "text_zh": "就是这么回事。请多指教啦，琴音！"}, {"source_row": "13", "speaker": "琴音", "text_zh": "咲季是入学考试第一的精英偶像，超级自信满满……"}, {"source_row": "45", "speaker": "制作人", "text_zh": "甚至连眼光挑剔的花海咲季粉丝都能被吸引的舞蹈实力……"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["下一次的演唱会将是咲季、手毬与琴音的三人共演。", "琴音因过去与咲季、手毬比较产生的自卑感而感到不安。", "制作人认为琴音具备让咲季粉丝认可的舞蹈实力。"], "relationship_facts": ["咲季是入学考试第一的精英偶像，性格自信。", "手毬是初中部的顶尖偶像，眼光挑剔。", "琴音视咲季和手毬为偶像榜样，渴望获得认可。"], "worldbuilding_facts": ["偶像共演的目的是让粉丝享受快乐并获得不同体验。", "共演还旨在实现粉丝群体的共享化，让彼此粉丝互相喜爱。", "咲季的粉丝群体以眼光挑剔著称，对舞蹈实力要求高。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00008", "scene_id": "scene-00008", "source_file": "CSV/cidol/fktn/adv_cidol-fktn-3-016_02.csv", "source_kind": "cidol", "chapter": "cidol/fktn", "scene": "adv_cidol-fktn-3-016_02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "39", "line_count": 39}], "source_refs": ["CSV/cidol/fktn/adv_cidol-fktn-3-016_02.csv:1-39"], "line_count": 39, "speakers": ["制作人", "琴音"], "topics": ["relationships", "team_story", "dialogue_style", "worldbuilding"], "title": "制定偶像粉丝攻略作战", "summary": "制作人提议让琴音吸收咲季与手毬的优点以攻略其粉丝。琴音虽自信能应对危机，但面对直接比较感到压力。两人决定从技术能力外的优点入手，重新审视如何制定不让人难为情的作战计划，旨在通过展现自身长处赢得粉丝喜爱。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人", "琴音", "手毬"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["当然", "制作人", "啦"], "key_evidence": [{"source_row": "22", "speaker": "琴音", "text_zh": "吸收她们的优点"}, {"source_row": "19", "speaker": "琴音", "text_zh": "都是因为非常喜欢她们"}, {"source_row": "25", "speaker": "琴音", "text_zh": "要是用她们的强项来一决胜负的话，根本赢不了嘛～"}, {"source_row": "39", "speaker": "琴音", "text_zh": "这个作战……不会让人觉得超级难为情吗？"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["制作人提议让琴音吸收咲季和手毬的优点来攻略粉丝。", "琴音认为直接比较技术能力无法获胜，决定从其他优点入手。", "制作人指出偶像粉丝喜欢偶像是因为了解其优点。", "琴音对需要重新审视咲季和手毬优点的作战计划感到些许难为情。"], "relationship_facts": ["制作人与琴音是同事兼朋友关系。", "咲季是琴音的竞争对手或同僚偶像。", "琴音与手毬同为偶像团体成员。"], "worldbuilding_facts": ["偶像粉丝喜欢偶像是因为非常了解她们的优点。", "偶像之间可以通过吸收对方的优点来制定作战计划。", "藤田琴音的歌唱能力和舞蹈能力都在进步。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00009", "scene_id": "scene-00009", "source_file": "CSV/cidol/fktn/adv_cidol-fktn-3-016_03.csv", "source_kind": "cidol", "chapter": "cidol/fktn", "scene": "adv_cidol-fktn-3-016_03", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "48", "line_count": 48}], "source_refs": ["CSV/cidol/fktn/adv_cidol-fktn-3-016_03.csv:1-48"], "line_count": 48, "speakers": ["咲季", "手毬", "琴音"], "topics": ["team_story", "relationships", "dialogue_style", "worldbuilding"], "title": "咲季与队友的共演练习", "summary": "咲季、手毬与琴音结束训练后讨论共演。咲季分享练习心得并感谢队友夸奖，手毬与琴音也坦承在观察并学习彼此魅力。三人确认因共演契机羁绊加深，约定互相学习以让演唱会大成功，气氛热烈融洽。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["琴音", "手毬"], "worldbuilding_signals": ["偶像", "训练", "演唱会"], "dialogue_style_signals": ["当然", "哼", "呵呵", "嘿嘿", "啦"], "key_evidence": [{"source_row": "9", "speaker": "咲季", "text_zh": "自从确定要和你们同台演出后，就开始一起练习同一首曲子。"}, {"source_row": "17", "speaker": "咲季", "text_zh": "我们……难道是因为这次共演的契机，羁绊变得更深了吗？"}, {"source_row": "35", "speaker": "琴音", "text_zh": "所以我想重新好好看看咲季和手毬的魅力——"}, {"source_row": "41", "speaker": "咲季", "text_zh": "无论什么歌曲都能可爱地演唱并舞蹈之处，让我好好学习了。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季与手毬、琴音因共演契机开始练习同一首曲子。", "咲季认为与队友的羁绊因共演而变得更深。", "手毬和琴音坦承在观察并学习咲季的魅力。"], "relationship_facts": ["咲季、手毬、琴音是即将同台演出的队友。", "咲季与手毬、琴音之间因共演建立了更深的羁绊。", "三人互相欣赏对方的才能与魅力，关系亲密。"], "worldbuilding_facts": ["咲季拥有能立刻模仿任何事物的灵巧才能。", "咲季擅长将学到的东西慢慢变成自己的东西。", "咲季无论什么歌曲都能可爱地演唱并舞蹈。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00010", "scene_id": "scene-00010", "source_file": "CSV/cidol/hrnm/adv_cidol-hrnm-3-002_02.csv", "source_kind": "cidol", "chapter": "cidol/hrnm", "scene": "adv_cidol-hrnm-3-002_02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "48", "line_count": 48}], "source_refs": ["CSV/cidol/hrnm/adv_cidol-hrnm-3-002_02.csv:1-48"], "line_count": 48, "speakers": ["制作人", "莉波"], "topics": ["team_story", "dialogue_style", "relationships", "worldbuilding"], "title": "蛋糕后的谈心时刻", "summary": "莉波与制作人结束会议后享用蛋糕，莉波提及咲季与手毬在测验中的表现。制作人因疏忽未能及时与咲季沟通而致歉，莉波表示理解并提议带咲季去某处，三人关系在轻松氛围中升温。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人", "手毬", "麻央", "莉波", "星南"], "worldbuilding_signals": ["训练", "演唱会"], "dialogue_style_signals": ["制作人", "啦"], "key_evidence": [{"source_row": "16", "speaker": "莉波", "text_zh": "咲季同学和手毬同学就……"}, {"source_row": "39", "speaker": "制作人", "text_zh": "最近都没能找到时间和姬崎同学好好说话。"}, {"source_row": "47", "speaker": "莉波", "text_zh": "有个地方想带你去，可以吗——？"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["莉波提到咲季和手毬同学在小测验中出现了麻央学姐教的内容。", "制作人承认最近没时间和咲季好好说话，并为此道歉。", "莉波提议带咲季去一个特别的地方，认为今天是重要日子。", "制作人与咲季的关系因沟通不足而略显紧张，正在修复中。"], "relationship_facts": ["莉波与咲季关系亲密，莉波主动关心咲季的情绪。", "制作人与咲季存在因工作忙碌导致的沟通隔阂。", "莉波与制作人关系融洽，共同照顾咲季。"], "worldbuilding_facts": ["明日有舞蹈训练，需要消耗卡路里。", "莉波会制作蛋糕，如草莓奶油蛋糕、蒙布朗等。", "星南会长（或相关人物）教授了莉波某些知识。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00011", "scene_id": "scene-00011", "source_file": "CSV/cidol/hrnm/adv_cidol-hrnm-3-012_02.csv", "source_kind": "cidol", "chapter": "cidol/hrnm", "scene": "adv_cidol-hrnm-3-012_02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "47", "line_count": 47}], "source_refs": ["CSV/cidol/hrnm/adv_cidol-hrnm-3-012_02.csv:1-47"], "line_count": 47, "speakers": ["咲季", "手毬", "星南", "燕", "琴音", "莉波", "麻央", "？？？"], "topics": ["team_story", "dialogue_style", "relationships"], "title": "咲季在基地的遭遇", "summary": "咲季因粮食系统被Mother控制而抱怨饮食单调。星南队长提及寻找idol是最后希望。制作人受莉波歌声影响情绪失控，被燕误认为敌方机器人。莉波为保护失忆受伤的制作人，在麻央协助下试图逃离基地。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人", "琴音", "手毬", "麻央", "莉波", "星南"], "worldbuilding_signals": [], "dialogue_style_signals": ["哼", "制作人"], "key_evidence": [{"source_row": "3", "speaker": "咲季", "text_zh": "没办法啊。粮食生产系统都被『Mother』控制了。"}, {"source_row": "6", "speaker": "星南", "text_zh": "必须尽快找到传说中的『idol』才行……"}, {"source_row": "30", "speaker": "星南", "text_zh": "难道是敌方的机器人？莉波，这到底是……？"}, {"source_row": "47", "speaker": "莉波", "text_zh": "走吧，制作人！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["粮食生产系统被Mother控制，导致食物单调。", "星南队长认为寻找传说中的idol是人类最后希望。", "制作人受莉波歌声影响情绪失控，被误认为敌方机器人。", "莉波为保护失忆的制作人，在麻央协助下试图逃离基地。"], "relationship_facts": ["咲季与手毬、琴音同为基地成员，共同面对生存困境。", "星南是队长，负责指挥并强调纪律，莉波是受其管教的成员。", "麻央协助莉波保护制作人，两人共同对抗燕的追捕。"], "worldbuilding_facts": ["基地粮食生产系统被名为Mother的存在控制。", "基地内存在名为idol的传说级存在，被视为人类最后希望。", "基地内存在敌方机器人，且藏匿其属于严重违纪行为。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00012", "scene_id": "scene-00012", "source_file": "CSV/cidol/hski/adv_cidol-hski-3-000_01.csv", "source_kind": "cidol", "chapter": "cidol/hski", "scene": "adv_cidol-hski-3-000_01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "32", "line_count": 32}], "source_refs": ["CSV/cidol/hski/adv_cidol-hski-3-000_01.csv:1-32"], "line_count": 32, "speakers": ["制作人", "咲季"], "topics": ["dialogue_style", "relationships", "worldbuilding", "plot"], "title": "咲季索要原创歌曲", "summary": "咲季慌张地找到制作人，震惊于自己作为成熟偶像竟无原创歌曲。她要求制作人立刻创作一首兼具可爱、帅气与性感风格的歌曲，以便在下次演唱会演唱。制作人随后透露歌曲其实已完成，令咲季惊喜不已。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人"], "worldbuilding_signals": ["偶像", "演唱会"], "dialogue_style_signals": ["真是的", "制作人"], "key_evidence": [{"source_row": "5-6", "speaker": "咲季", "text_zh": "一个成熟的偶像啊，大家都——拥有属于自己的原创歌曲！！"}, {"source_row": "20-21", "speaker": "咲季", "text_zh": "要可爱～帅气～还要带点成熟的性感……我想要像我这样的歌曲！"}, {"source_row": "28-30", "speaker": "制作人", "text_zh": "如果是咲季同学的歌曲，其实已经完成了哦。本来打算今天交给你的。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季认为成熟偶像必须拥有原创歌曲。", "咲季要求歌曲风格需包含可爱、帅气与性感。", "咲季计划在下次演唱会上演唱该歌曲。", "制作人的原创歌曲实际上已经完成。"], "relationship_facts": ["咲季称呼对方为制作人。", "咲季视制作人为值得信赖的伙伴。", "制作人与咲季是偶像与制作人的工作关系。"], "worldbuilding_facts": ["咲季自视为未来的顶级偶像。", "偶像拥有原创歌曲被视为成熟标志。", "咲季计划在演唱会进行表演。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00013", "scene_id": "scene-00013", "source_file": "CSV/cidol/hski/adv_cidol-hski-3-000_02.csv", "source_kind": "cidol", "chapter": "cidol/hski", "scene": "adv_cidol-hski-3-000_02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "35", "line_count": 35}], "source_refs": ["CSV/cidol/hski/adv_cidol-hski-3-000_02.csv:1-35"], "line_count": 35, "speakers": ["制作人", "咲季"], "topics": ["dialogue_style", "relationships", "worldbuilding", "plot"], "title": "咲季接受裸唱挑战", "summary": "制作人向咲季展示新曲试听，咲季虽认可曲风却因歌词过于贴合其“死不认输”的性格而羞于开口。制作人指出此歌旨在助其立于不败之地，最终说服咲季为了获胜，愿意在新曲演唱会上豁出去进行“裸唱”。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人"], "worldbuilding_signals": ["偶像", "演唱会"], "dialogue_style_signals": ["制作人", "啦"], "key_evidence": [{"source_row": "17", "speaker": "咲季", "text_zh": "贴切到根本唱不出口啦笨蛋！"}, {"source_row": "25", "speaker": "咲季", "text_zh": "简直就像裸体唱歌一样。"}, {"source_row": "28", "speaker": "制作人", "text_zh": "是为了成为无敌顶级偶像的歌。"}, {"source_row": "35", "speaker": "咲季", "text_zh": "我就豁出去裸唱给你看！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季认为歌词贴切到根本唱不出口", "咲季担心倾注真心会显露软弱一面", "制作人强调此歌是为了让咲季立于不败之地", "咲季最终决定接受挑战进行裸唱"], "relationship_facts": ["制作人是咲季的新曲制作人", "制作人是咲季的说服者", "咲季视制作人为能理解其性格的人"], "worldbuilding_facts": ["咲季的目标是成为无敌的顶级偶像", "咲季习惯向他人展示坚强的自己", "新曲演唱会是咲季的重要舞台"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00014", "scene_id": "scene-00014", "source_file": "CSV/cidol/hski/adv_cidol-hski-3-000_03.csv", "source_kind": "cidol", "chapter": "cidol/hski", "scene": "adv_cidol-hski-3-000_03", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "33", "line_count": 33}], "source_refs": ["CSV/cidol/hski/adv_cidol-hski-3-000_03.csv:1-33"], "line_count": 33, "speakers": ["制作人", "咲季"], "topics": ["dialogue_style", "relationships", "character_arc", "plot"], "title": "咲季面对妹妹的演出", "summary": "咲季因妹妹佑芽将亲临演出而烦恼，担心自己饱含复杂感情的歌词会被发现。制作人指出这是咲季自找的，并鼓励她挺起胸膛展现真实的自我。咲季最终被激励，决心作为未来顶级偶像高唱胜利之歌。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "妹妹", "姐姐"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["当然", "真是的", "哼", "嘿嘿", "制作人", "啦"], "key_evidence": [{"source_row": "2", "speaker": "咲季", "text_zh": "妹妹她……佑芽她……来看我的演出了……！"}, {"source_row": "7", "speaker": "咲季", "text_zh": "这首饱含着我对妹妹复杂感情的歌——"}, {"source_row": "23", "speaker": "制作人", "text_zh": "真实的咲季同学虽然总是怯懦又爱逞强死要面子。"}, {"source_row": "32", "speaker": "咲季", "text_zh": "未来的顶级偶像——花海咲季！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季担心佑芽听到她歌词中复杂的感情。", "制作人认为咲季邀请妹妹是理所当然的。", "咲季承认自己怯懦爱逞强但值得骄傲。", "咲季决定勇敢展现自我并高唱胜利之歌。"], "relationship_facts": ["咲季是佑芽的姐姐。", "咲季与制作人关系亲密，互相鼓励。", "咲季视自己为未来的顶级偶像。"], "worldbuilding_facts": ["咲季的目标是成为顶级偶像。", "咲季正在准备一首关于妹妹的歌。", "咲季性格怯懦但渴望被认可。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00015", "scene_id": "scene-00015", "source_file": "CSV/cidol/hski/adv_cidol-hski-3-001_01.csv", "source_kind": "cidol", "chapter": "cidol/hski", "scene": "adv_cidol-hski-3-001_01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "36", "line_count": 36}], "source_refs": ["CSV/cidol/hski/adv_cidol-hski-3-001_01.csv:1-36"], "line_count": 36, "speakers": ["众人", "佑芽", "制作人", "咲季"], "topics": ["relationships", "dialogue_style", "character_arc", "worldbuilding"], "title": "制作人秘密陪伴咲季", "summary": "制作人突然请求与咲季独处共进早餐，并隐瞒真实理由。训练结束后，佑芽发现制作人全程专注注视咲季，怀疑两人存在禁忌之恋，咲季对此感到困惑与在意。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "姐姐"], "worldbuilding_signals": ["训练"], "dialogue_style_signals": ["真是的", "呵呵", "制作人", "啦"], "key_evidence": [{"source_row": "3", "speaker": "制作人", "text_zh": "可以让我和咲季同学一起待一会儿吗？"}, {"source_row": "19", "speaker": "制作人", "text_zh": "有些特殊情况。方才不小心多嘴了……"}, {"source_row": "36", "speaker": "佑芽", "text_zh": "制作人可能对姐姐……做了那种事……"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["制作人请求与咲季独处并共进早餐。", "制作人隐瞒了陪伴咲季的真实理由。", "佑芽怀疑制作人与咲季存在禁忌之恋。"], "relationship_facts": ["咲季与佑芽是姐妹关系。", "制作人是咲季的同事或上级。", "佑芽与制作人存在情感上的竞争或误解。"], "worldbuilding_facts": ["咲季负责研发新的宠物食品。", "咲季与佑芽共同进行训练。", "制作人与咲季之间存在某种特殊且未公开的关联。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00016", "scene_id": "scene-00016", "source_file": "CSV/cidol/hski/adv_cidol-hski-3-001_02.csv", "source_kind": "cidol", "chapter": "cidol/hski", "scene": "adv_cidol-hski-3-001_02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "41", "line_count": 41}], "source_refs": ["CSV/cidol/hski/adv_cidol-hski-3-001_02.csv:1-41"], "line_count": 41, "speakers": ["佑芽", "制作人", "咲季", "旁白"], "topics": ["dialogue_style", "relationships", "character_arc", "worldbuilding"], "title": "咲季的觉悟与求婚", "summary": "咲季因佑芽的玩笑陷入慌乱，制作人表白后，咲季决定以全部实力成为偶像，弥补与佑芽的差距，立志成为佑芽的依靠。她向制作人道歉并请求等待引退后求婚，展现了成熟与深情。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "姐姐"], "worldbuilding_signals": ["偶像", "训练"], "dialogue_style_signals": ["当然", "才不是", "真是的", "嘿嘿", "制作人", "啦"], "key_evidence": [{"source_row": "28", "speaker": "咲季", "text_zh": "我要用我的全部，来当偶像！"}, {"source_row": "38", "speaker": "咲季", "text_zh": "成为那个仰慕着我的孩子可以依靠的好姐姐。"}, {"source_row": "41", "speaker": "咲季", "text_zh": "快向我求婚啦♡"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季决定用全部实力成为偶像，全力弥补才能差距。", "咲季立志成为佑芽可以依靠的好姐姐。", "咲季向制作人道歉，并请求等到引退后再求婚。"], "relationship_facts": ["咲季与佑芽是姐妹关系，咲季视佑芽为需要依靠的妹妹。", "咲季与制作人是恋人关系，咲季深爱制作人。", "佑芽是咲季的妹妹，也是制作人的同事。"], "worldbuilding_facts": ["咲季是注重健康管理的偶像。", "咲季自认才能不如佑芽，但决心通过努力弥补差距。", "咲季有不能告诉任何人的秘密。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00017", "scene_id": "scene-00017", "source_file": "CSV/cidol/hski/adv_cidol-hski-3-001_03.csv", "source_kind": "cidol", "chapter": "cidol/hski", "scene": "adv_cidol-hski-3-001_03", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "36", "line_count": 36}], "source_refs": ["CSV/cidol/hski/adv_cidol-hski-3-001_03.csv:1-36"], "line_count": 36, "speakers": ["制作人", "咲季"], "topics": ["dialogue_style", "relationships", "worldbuilding", "character_arc"], "title": "咲季与制作人的心意", "summary": "制作人向咲季表白心意并递交企划书，咲季虽调侃其丧失制作人资格，却顺势约定引退后求婚。两人确认了超越工作的深厚羁绊，制作人盛赞咲季的多重魅力，咲季则感叹这是禁忌之恋。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["当然", "哼", "嘿嘿", "制作人", "啦"], "key_evidence": [{"source_row": "24", "speaker": "制作人", "text_zh": "企划书。为了让全世界都能知晓咲季同学的魅力。"}, {"source_row": "16", "speaker": "咲季", "text_zh": "等到我将来引退的时候，到那时，再正式地——来向我求婚吧♡"}, {"source_row": "36", "speaker": "咲季", "text_zh": "禁忌之恋。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["制作人向咲季递交了旨在推广其魅力的企划书。", "咲季提议等到自己引退后，再接受制作人的正式求婚。", "制作人认为迷恋偶像虽有风险，却是培育优秀成果的必要条件。"], "relationship_facts": ["咲季与制作人是工作搭档及恋人关系。", "咲季对制作人抱有超越工作的特殊情感。", "两人之间存在关于‘制作人资格’与‘偶像魅力’的互动张力。"], "worldbuilding_facts": ["制作人有‘迷恋偶像即丧失资格’的职场信条。", "咲季拥有从自信到土气等多种被认可的魅力特质。", "咲季与制作人之间的恋情被咲季定义为‘禁忌之恋’。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00018", "scene_id": "scene-00018", "source_file": "CSV/cidol/hski/adv_cidol-hski-3-002_01.csv", "source_kind": "cidol", "chapter": "cidol/hski", "scene": "adv_cidol-hski-3-002_01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "30", "line_count": 30}], "source_refs": ["CSV/cidol/hski/adv_cidol-hski-3-002_01.csv:1-30"], "line_count": 30, "speakers": ["制作人", "咲季"], "topics": ["dialogue_style", "relationships", "worldbuilding", "team_story"], "title": "咲季挑战暑假休养对决", "summary": "制作人与咲季就暑假安排展开对决，决定比拼休养方案。咲季虽习惯忙碌，但意识到暑假需多样化休息。她接受挑战，要求制作人陪同实践，并苦恼于缺乏夏日度假点子，展现其认真与依赖。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "妹妹"], "worldbuilding_signals": ["偶像", "训练", "工作"], "dialogue_style_signals": ["当然", "呵呵", "制作人", "啦"], "key_evidence": [{"source_row": "3", "speaker": "咲季", "text_zh": "好啊！要比什么呢？"}, {"source_row": "11", "speaker": "制作人", "text_zh": "我们要比的是暑假期间的休养方案。"}, {"source_row": "22", "speaker": "咲季", "text_zh": "实践计划的时候，你当然会陪我的吧？"}, {"source_row": "30", "speaker": "咲季", "text_zh": "充满夏日风情的度假方式……完全想不出来啊！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["制作人与咲季决定进行关于暑假休养方案的比拼。", "咲季认为休息日应全力在房间休息，但被制作人指出不够最佳。", "咲季接受挑战，要求制作人在实践计划时陪同度过休息日。", "咲季表示对充满夏日风情的度假方式完全不擅长。"], "relationship_facts": ["咲季与制作人之间存在偶像与制作人的工作关系。", "咲季将制作人视为可以共同度过休息日的亲密伙伴。", "咲季在制作面前展现出依赖与撒娇的一面。"], "worldbuilding_facts": ["偶像通常没有暑假，需要持续进行训练、工作和活动。", "即使不用上课，偶像在暑假期间也需要制定计划以防撑不下去。", "制作人的职责包括安排偶像活动的行程。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00019", "scene_id": "scene-00019", "source_file": "CSV/cidol/hski/adv_cidol-hski-3-002_02.csv", "source_kind": "cidol", "chapter": "cidol/hski", "scene": "adv_cidol-hski-3-002_02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "40", "line_count": 40}], "source_refs": ["CSV/cidol/hski/adv_cidol-hski-3-002_02.csv:1-40"], "line_count": 40, "speakers": ["制作人", "咲季"], "topics": ["dialogue_style", "relationships", "character_arc", "team_story"], "title": "咲季的游乐场对决", "summary": "咲季与制作人前往体育休闲设施，体验各类载具与运动项目。咲季展现充沛精力，欲将制作人拉入载具类项目对决，并计划邀请妹妹参与。尽管制作人提议结束，咲季仍坚持继续游玩，承诺给予制作人完美假日。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "妹妹"], "worldbuilding_signals": ["训练"], "dialogue_style_signals": ["当然", "才不是", "哼", "嘿嘿", "制作人", "啦"], "key_evidence": [{"source_row": "20", "speaker": "咲季", "text_zh": "今天就把载具类项目全部通关吧。"}, {"source_row": "24", "speaker": "制作人", "text_zh": "你打算把妹妹也带来对吧。"}, {"source_row": "32", "speaker": "咲季", "text_zh": "这和训练时的身体运动是截然不同的快乐呢！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季计划将制作人拉入载具类项目的对决。", "咲季打算邀请妹妹一同参与今天的活动。", "咲季认为今天的运动快乐与训练时的身体运动截然不同。"], "relationship_facts": ["咲季与制作人关系亲密，咲季主动邀请制作人参与游戏。", "咲季计划将妹妹也带入当前的活动场景中。"], "worldbuilding_facts": ["存在一个非高级训练设施、随性且可轻松享受运动的体育休闲场所。", "该场所提供多种载具类项目供体验。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00020", "scene_id": "scene-00020", "source_file": "CSV/cidol/hski/adv_cidol-hski-3-002_03.csv", "source_kind": "cidol", "chapter": "cidol/hski", "scene": "adv_cidol-hski-3-002_03", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "29", "line_count": 29}], "source_refs": ["CSV/cidol/hski/adv_cidol-hski-3-002_03.csv:1-29"], "line_count": 29, "speakers": ["制作人", "咲季"], "topics": ["dialogue_style", "relationships", "team_story"], "title": "星空下的夏日约定", "summary": "咲季带制作人来到宿舍附近观星，两人欣赏夏季大三角并目睹流星。咲季许愿对手健康，并承诺实现制作人愿望。双方以平手结束夏日休养计划，约定夏天结束前再比一次。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人", "对手"], "worldbuilding_signals": [], "dialogue_style_signals": ["呵呵", "嘿嘿", "制作人"], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "好了，我们到了。"}, {"source_row": "21", "speaker": "咲季", "text_zh": "希望我的竞争对手们都能健健康康的。"}, {"source_row": "26", "speaker": "咲季", "text_zh": "我会帮你实现的。要多少都行。"}, {"source_row": "29", "speaker": "咲季", "text_zh": "趁着夏天还没结束，我们再比一次哦！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季带制作人来到宿舍附近观星。", "咲季许愿希望竞争对手们都能健健康康。", "咲季承诺会实现制作人的任何愿望。", "双方约定夏天结束前再比一次。"], "relationship_facts": ["咲季与制作人是竞争对手关系。", "咲季对制作人表现出亲近与信任。", "咲季视制作人为能看穿自己计划的对象。"], "worldbuilding_facts": ["当前场景位于宿舍附近，有门禁时间。", "天空中可见夏季大三角（织女星、天津四、牛郎星）。", "咲季正在执行名为『夏日休养计划』的活动。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00021", "scene_id": "scene-00021", "source_file": "CSV/cidol/hski/adv_cidol-hski-3-006_01.csv", "source_kind": "cidol", "chapter": "cidol/hski", "scene": "adv_cidol-hski-3-006_01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "31", "line_count": 31}], "source_refs": ["CSV/cidol/hski/adv_cidol-hski-3-006_01.csv:1-31"], "line_count": 31, "speakers": ["制作人", "咲季"], "topics": ["dialogue_style", "relationships", "character_arc", "team_story"], "title": "咲季初探Animate", "summary": "咲季跟随制作人来到Animate动漫店，对店内丰富的漫画、玩偶服装及墙绘感到惊叹。她敏锐地察觉制作人的约会意图，并大方接受邀请。两人一同探索店铺，咲季享受着二次元周边的乐趣，展现了她对动漫文化的热爱与对制作人关系的微妙互动。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人"], "worldbuilding_signals": ["训练"], "dialogue_style_signals": ["真是的", "制作人", "啦"], "key_evidence": [{"source_row": "3", "speaker": "制作人", "text_zh": "是的。是animate动漫店。"}, {"source_row": "10", "speaker": "咲季", "text_zh": "想和我约会的话，直接说出来不就好了！"}, {"source_row": "22", "speaker": "咲季", "text_zh": "有好多小小的服装呢！"}, {"source_row": "29", "speaker": "咲季", "text_zh": "制作人，楼梯墙上画着好多不同的角色哦！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季跟随制作人来到Animate动漫店。", "咲季察觉制作人的意图并同意约会。", "咲季对店内的漫画和玩偶服装表现出浓厚兴趣。"], "relationship_facts": ["咲季与制作人是同事或上下级关系。", "咲季对制作人抱有亲近感，愿意接受约会。", "制作人对咲季的喜好表示理解与尊重。"], "worldbuilding_facts": ["Animate是一家售卖漫画、玩偶及角色周边的动漫店。", "店内提供可让玩偶穿着不同作品角色服装的服务。", "店铺楼梯墙上绘有众多动漫角色的壁画。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00022", "scene_id": "scene-00022", "source_file": "CSV/cidol/hski/adv_cidol-hski-3-006_02.csv", "source_kind": "cidol", "chapter": "cidol/hski", "scene": "adv_cidol-hski-3-006_02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "32", "line_count": 32}], "source_refs": ["CSV/cidol/hski/adv_cidol-hski-3-006_02.csv:1-32"], "line_count": 32, "speakers": ["制作人", "咲季", "旁白"], "topics": ["dialogue_style", "relationships", "worldbuilding", "team_story"], "title": "咲季挑战一日店长", "summary": "咲季在动漫商店购物后，被制作人邀请担任一日店长。她虽惊讶但决定全力以赴，认为顾客与粉丝无异，需通过了解大家来炒热气氛，决心让店铺比任何人都热闹。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽"], "worldbuilding_signals": ["演唱会", "工作"], "dialogue_style_signals": ["当然", "真是的", "哼", "制作人", "啦"], "key_evidence": [{"source_row": "10", "speaker": "制作人", "text_zh": "计划下次请咲季同学在那家店担任一日店长。"}, {"source_row": "26", "speaker": "咲季", "text_zh": "来店的客人们，和来看演唱会的粉丝们是一样的。"}, {"source_row": "32", "speaker": "咲季", "text_zh": "为了能让店铺比任何人都热闹，我会全力以赴的！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季被制作人邀请担任动漫商店一日店长。", "咲季认为顾客与演唱会粉丝心态相似。", "咲季决心为让店铺热闹而全力以赴。"], "relationship_facts": ["制作人与咲季是同事或上下级关系。", "咲季与佑芽是朋友关系。", "咲季将顾客视为粉丝般对待。"], "worldbuilding_facts": ["动漫商店是咲季第一次光顾的地方。", "咲季曾为佑芽购买过伴手礼。", "咲季计划将店铺气氛炒热。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00023", "scene_id": "scene-00023", "source_file": "CSV/cidol/hski/adv_cidol-hski-3-006_03.csv", "source_kind": "cidol", "chapter": "cidol/hski", "scene": "adv_cidol-hski-3-006_03", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "38", "line_count": 38}], "source_refs": ["CSV/cidol/hski/adv_cidol-hski-3-006_03.csv:1-38"], "line_count": 38, "speakers": ["制作人", "咲季"], "topics": ["dialogue_style", "relationships", "worldbuilding", "character_arc"], "title": "咲季确立偶像决心", "summary": "咲季在观看动画后深受鼓舞，向制作人询问入职原因。制作人指出咲季爱逞强且从不轻言放弃，并揭示其作为未知偶像的潜力。咲季深受触动，决心利用休息日提升人气，让所有客人都成为她的粉丝。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人"], "worldbuilding_signals": ["偶像", "工作"], "dialogue_style_signals": ["当然", "哼", "制作人"], "key_evidence": [{"source_row": "20", "speaker": "咲季", "text_zh": "这份工作……为什么选择了我？"}, {"source_row": "24", "speaker": "咲季", "text_zh": "那要是面对我呢？"}, {"source_row": "31", "speaker": "制作人", "text_zh": "还有很多人不认识名叫花海咲季的偶像。"}, {"source_row": "38", "speaker": "咲季", "text_zh": "全都成为花海咲季的俘虏！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季通过观看动画确认了努力的价值，对接下来的挑战充满期待。", "制作人认为咲季虽缺乏相关知识储备，但绝不会以无知状态发起挑战。", "咲季得知制作人的目的是提升自己在大众中的知名度，并对此表示认同。", "咲季决定在休息日继续工作，目标是让所有来店客人都成为她的粉丝。"], "relationship_facts": ["咲季与制作人之间存在上下级及合作伙伴关系。", "制作人对咲季的能力和性格（爱逞强）有深刻的了解与信任。", "咲季视制作人为值得追随和信赖的领导者。"], "worldbuilding_facts": ["咲季是尚未被大众广泛认知的偶像花海咲季。", "咲季对动画和漫画等二次元文化完全一窍不通。", "咲季所在的店铺（Animate）是顾客购买周边和观看作品的重要场所。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00024", "scene_id": "scene-00024", "source_file": "CSV/cidol/hski/adv_cidol-hski-3-008_01.csv", "source_kind": "cidol", "chapter": "cidol/hski", "scene": "adv_cidol-hski-3-008_01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "43", "line_count": 43}], "source_refs": ["CSV/cidol/hski/adv_cidol-hski-3-008_01.csv:1-43"], "line_count": 43, "speakers": ["制作人", "咲季"], "topics": ["dialogue_style", "relationships", "worldbuilding", "character_arc"], "title": "咲季获得演出服", "summary": "制作人赠予咲季初星学园传统曲目《Campus mode!!》的演出服。咲季对此欣喜若狂，坦言自己考入学园既为成为顶级偶像，更因被偶像们的可爱深深吸引。她决定以世界第一为目标，并请求制作人保密这段可爱的一面。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "妹妹"], "worldbuilding_signals": ["学园", "偶像"], "dialogue_style_signals": ["当然", "呵呵", "嘿嘿", "制作人", "啦"], "key_evidence": [{"source_row": "6", "speaker": "制作人", "text_zh": "初星学园的偶像们在重要时刻演唱的传统曲目。"}, {"source_row": "11", "speaker": "咲季", "text_zh": "我可是怀着憧憬才考入初星学园的呀。"}, {"source_row": "32", "speaker": "咲季", "text_zh": "因为《校园模式!!》里的偶像们都可爱得不得了啊。"}, {"source_row": "42", "speaker": "咲季", "text_zh": "这段故事可不要公开给粉丝们看哦。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["制作人赠予咲季《Campus mode!!》演出服。", "咲季考入初星学园是为了成为顶级偶像。", "咲季因偶像们的可爱而深受吸引。", "咲季请求制作人保密她可爱的反应。"], "relationship_facts": ["制作人是咲季的指导者。", "咲季视制作人为可信赖的对象。", "咲季与粉丝之间存在需要保密的互动。"], "worldbuilding_facts": ["初星学园是业界最大规模的偶像学园。", "《Campus mode!!》是初星学园偶像的传统曲目。", "初星学园拥有100家事务所入驻。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00025", "scene_id": "scene-00025", "source_file": "CSV/cidol/hski/adv_cidol-hski-3-008_02.csv", "source_kind": "cidol", "chapter": "cidol/hski", "scene": "adv_cidol-hski-3-008_02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "48", "line_count": 48}], "source_refs": ["CSV/cidol/hski/adv_cidol-hski-3-008_02.csv:1-48"], "line_count": 48, "speakers": ["制作人", "咲季", "女孩子"], "topics": ["worldbuilding", "dialogue_style", "relationships", "plot"], "title": "咲季的偶像觉悟", "summary": "咲季接受制作人委托，在中学举办迷你演唱会以播撒憧憬种子。她意识到偶像工作的重大使命，决心为观众带来笑容并实现成为偶像的梦想。咲季视观众为妹妹，展现出作为姐姐的觉悟与责任感，完成了从抱怨到坚定的心态转变。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "妹妹", "姐姐"], "worldbuilding_signals": ["学园", "偶像", "试镜", "演唱会", "工作"], "dialogue_style_signals": ["呵呵", "嘿嘿", "制作人", "啦"], "key_evidence": [{"source_row": "16", "speaker": "制作人", "text_zh": "对偶像来说最重要的工作是——播撒『憧憬』的种子。"}, {"source_row": "22", "speaker": "咲季", "text_zh": "为孩子们带来笑容呢。"}, {"source_row": "47", "speaker": "咲季", "text_zh": "作为那些孩子们的姐姐——绝不能展现出丢脸的样子。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季接受委托在中学举办迷你演唱会。", "咲季意识到偶像工作的核心是播撒憧憬的种子。", "咲季将观众视为妹妹并展现出姐姐的觉悟。", "咲季通过演出实现了成为偶像的梦想。"], "relationship_facts": ["咲季与制作人是同事兼上下级关系。", "咲季与观众建立了类似姐妹的情感联系。", "咲季与初星学园前辈存在传承关系。"], "worldbuilding_facts": ["初星学园偶像穿着被称为战斗服的偶像服装。", "偶像工作的核心目标是播撒憧憬的种子。", "偶像演唱会旨在为年轻人聚集的SNS制造话题。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00026", "scene_id": "scene-00026", "source_file": "CSV/cidol/hski/adv_cidol-hski-3-008_03.csv", "source_kind": "cidol", "chapter": "cidol/hski", "scene": "adv_cidol-hski-3-008_03", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "30", "line_count": 30}], "source_refs": ["CSV/cidol/hski/adv_cidol-hski-3-008_03.csv:1-30"], "line_count": 30, "speakers": ["制作人", "咲季"], "topics": ["worldbuilding", "dialogue_style", "plot", "relationships"], "title": "咲季的成长与偶像意义", "summary": "咲季向制作人展示粉丝支持，感慨从入学到加入N.I.A的成长历程。她虽自认技术停滞，但粉丝应援赋予了她力量。咲季重新定义偶像为竞技，认为其意义已变，决心通过Campus mode让所有人喜欢自己，创造美好回忆。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人"], "worldbuilding_signals": ["学园", "偶像", "演唱会"], "dialogue_style_signals": ["呵呵", "制作人", "啦"], "key_evidence": [{"source_row": "14", "speaker": "咲季", "text_zh": "力量不断涌出来。这可不是错觉。"}, {"source_row": "16", "speaker": "咲季", "text_zh": "连技术都停滞不前……简直像在龟速前进。"}, {"source_row": "23", "speaker": "咲季", "text_zh": "偶像就是竞技——我现在依然这么认为。"}, {"source_row": "30", "speaker": "咲季", "text_zh": "用花海咲季的『Campus mode!!』来达成！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季认为粉丝应援的声音越来越多，让她感到力量涌出。", "咲季自认技术停滞不前，但粉丝支持让她感到神奇。", "咲季认为偶像不仅是竞技，其意义已随成长发生巨大变化。", "咲季决心通过Campus mode让所有人都喜欢上自己。"], "relationship_facts": ["咲季与制作人是对话伙伴，制作人鼓励咲季。", "咲季与粉丝有深厚的情感联系，粉丝是她力量的来源。", "咲季与N.I.A成员有共度回忆的经历。"], "worldbuilding_facts": ["咲季加入的团体名为N.I.A。", "咲季拥有娇小的体型，这既是挑战也是优势。", "咲季正在准备名为Campus mode的演出或活动。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00027", "scene_id": "scene-00027", "source_file": "CSV/cidol/hski/adv_cidol-hski-3-011_01.csv", "source_kind": "cidol", "chapter": "cidol/hski", "scene": "adv_cidol-hski-3-011_01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "64", "line_count": 64}], "source_refs": ["CSV/cidol/hski/adv_cidol-hski-3-011_01.csv:1-64"], "line_count": 64, "speakers": ["制作人", "咲季"], "topics": ["dialogue_style", "relationships", "worldbuilding", "team_story"], "title": "咲季与制作人的羁绊", "summary": "咲季感慨与制作人相识已久，回忆初次相遇时制作人坦率地表示要培育她。制作人因咲季屡败屡战的不屈精神而选中她。两人确认彼此是追逐梦想的完美搭档，咲季誓言即使契约结束也不会放手。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人", "伙伴"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["当然", "真是的", "哼", "呵呵", "制作人"], "key_evidence": [{"source_row": "2", "speaker": "咲季", "text_zh": "和你相识的日子，已经相当漫长了呢。"}, {"source_row": "34", "speaker": "制作人", "text_zh": "正因你是被粉碎了无数次真正梦想，却仍能重新站起来追逐梦想的人。"}, {"source_row": "52", "speaker": "咲季", "text_zh": "在发掘我的制作人中你是唯一一个。"}, {"source_row": "64", "speaker": "咲季", "text_zh": "就算契约结束了也绝对不会放你走的！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季与制作人相识时间相当漫长。", "制作人因咲季是屡败屡战的人而选中她。", "咲季认为制作人是唯一看穿她烦恼并愿意培育她的人。", "咲季誓言即使契约结束也不会放走制作人。"], "relationship_facts": ["咲季与制作人是追逐相同梦想的搭档。", "制作人是发掘咲季的唯一制作人。", "咲季视制作人为最棒的搭档。"], "worldbuilding_facts": ["咲季曾无数次放弃梦想又重新站起来。", "制作人的梦想是培育不屈不挠的偶像。", "咲季与制作人之间存在偶像契约。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00028", "scene_id": "scene-00028", "source_file": "CSV/cidol/hski/adv_cidol-hski-3-011_02.csv", "source_kind": "cidol", "chapter": "cidol/hski", "scene": "adv_cidol-hski-3-011_02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "49", "line_count": 49}], "source_refs": ["CSV/cidol/hski/adv_cidol-hski-3-011_02.csv:1-49"], "line_count": 49, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "team_story"], "title": "咲季回忆制作人初遇", "summary": "合约结束后，咲季因冲动说出想永远与制作人在一起的羞耻台词。她冷静下来后，试图回想制作人当初选择她时的回答，发现对方也说过类似羞人的话。咲季意识到制作人是在捉弄她，两人确认了彼此心意，咲季对此感到既生气又痛快。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人"], "worldbuilding_signals": [], "dialogue_style_signals": ["真是的", "呵呵", "嘿嘿", "制作人", "啦"], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "就算合约结束了，我也绝对不会放你走的！"}, {"source_row": "15", "speaker": "制作人", "text_zh": "答案不会改变。咲季同学你——"}, {"source_row": "48", "speaker": "咲季", "text_zh": "你！有时候故意捉弄我取乐对吧～！"}, {"source_row": "49", "speaker": "咲季", "text_zh": "给我记住～～～～～啊！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季在合约结束后冲动表白想永远与制作人在一起。", "咲季回忆起制作人当初选择她时说过类似羞人的话。", "咲季意识到制作人是在故意捉弄她取乐。", "咲季最终确认了制作人的心意并感到痛快。"], "relationship_facts": ["咲季与制作人是最佳搭档。", "咲季与制作人之间存在互相捉弄的亲密关系。", "咲季对制作人怀有超越搭档的深厚感情。"], "worldbuilding_facts": ["咲季与制作人之间存在正式合约关系。", "咲季曾接受过制作人的资料调查。", "咲季与制作人处于演艺或偶像行业背景中。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00029", "scene_id": "scene-00029", "source_file": "CSV/cidol/hski/adv_cidol-hski-3-011_03.csv", "source_kind": "cidol", "chapter": "cidol/hski", "scene": "adv_cidol-hski-3-011_03", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "71", "line_count": 71}], "source_refs": ["CSV/cidol/hski/adv_cidol-hski-3-011_03.csv:1-71"], "line_count": 71, "speakers": ["制作人", "咲季"], "topics": ["dialogue_style", "relationships", "worldbuilding", "team_story"], "title": "咲季与制作人的坦诚对话", "summary": "咲季主动邀请制作人闲聊，提及对方对自己隐瞒与父母见面之事。制作人解释后，咲季察觉其情感流露，指出其过度投入。制作人坦言职业教诲，咲季则回应无论未来如何，制作人永远是她唯一的偶像，两人关系在坦诚中升华。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "妹妹", "父母"], "worldbuilding_signals": ["偶像", "制作人科"], "dialogue_style_signals": ["才不是", "真是的", "呵呵", "嘿嘿", "制作人", "不是吗", "啦"], "key_evidence": [{"source_row": "27", "speaker": "咲季", "text_zh": "你经常私下和我父母见面开汇报会是真的吗？"}, {"source_row": "50", "speaker": "制作人", "text_zh": "不可以对担当偶像投入过多感情。"}, {"source_row": "71", "speaker": "咲季", "text_zh": "你永远都是我的制作人！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季发现制作人私下与其父母见面汇报工作。", "咲季指出制作人对自己投入了过多感情与期待。", "咲季确认无论合约是否结束，制作人都是她唯一的偶像。", "咲季为制作人准备了亲手制作的料理作为谢礼。"], "relationship_facts": ["咲季是制作人的担当偶像。", "咲季与制作人之间存在深厚的情感羁绊。", "咲季视制作人为自己生命中唯一且永恒的偶像。"], "worldbuilding_facts": ["制作人科教导制作人与偶像必须保持对等关系。", "制作人不能对偶像投入过多感情以免察觉。", "制作人对偶像产生沉重执着被视为职业禁忌。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00030", "scene_id": "scene-00030", "source_file": "CSV/cidol/hski/adv_cidol-hski-3-012_01.csv", "source_kind": "cidol", "chapter": "cidol/hski", "scene": "adv_cidol-hski-3-012_01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "53", "line_count": 53}], "source_refs": ["CSV/cidol/hski/adv_cidol-hski-3-012_01.csv:1-53"], "line_count": 53, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "worldbuilding", "character_arc"], "title": "咲季独占制作人之心", "summary": "咲季为制作人特制料理并分享灵感，制作人坦言因咲季对组合活动适应性强而只发掘她一人。咲季感动于被独占，主动请求今后只接受制作人的培育，拒绝加入组合，两人关系更加亲密。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人", "手毬", "朋友", "伙伴"], "worldbuilding_signals": ["偶像", "课程", "训练"], "dialogue_style_signals": ["当然", "真是的", "呵呵", "嘿嘿", "制作人", "啦"], "key_evidence": [{"source_row": "21", "speaker": "咲季", "text_zh": "想让他们……也想让你。都能吃到美味的料理呢……"}, {"source_row": "34", "speaker": "制作人", "text_zh": "咲季同学她，对于组合活动有着极高的适应性。"}, {"source_row": "45", "speaker": "制作人", "text_zh": "却只发掘你一个人的理由。"}, {"source_row": "53", "speaker": "咲季", "text_zh": "从今以后，也只要培育我一个人哦♪"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季因灵感突发而特制了30种变化的料理。", "咲季在模拟训练中展现出极高的组合活动适应性。", "制作人明知咲季适合组合，却只发掘她一人。", "咲季请求今后只接受制作人的单人培育。"], "relationship_facts": ["咲季与制作人关系亲密，咲季希望独占制作人。", "咲季与大受好评的手毬同学关系变好。", "制作人对咲季抱有独占欲，希望她成为 solo 偶像。"], "worldbuilding_facts": ["咲季特制的偶像养成套餐有30种变化。", "咲季能根据用餐对象不同定制调整菜单。", "咲季对组合活动有着极高的适应性。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00031", "scene_id": "scene-00031", "source_file": "CSV/cidol/hski/adv_cidol-hski-3-012_02.csv", "source_kind": "cidol", "chapter": "cidol/hski", "scene": "adv_cidol-hski-3-012_02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "47", "line_count": 47}], "source_refs": ["CSV/cidol/hski/adv_cidol-hski-3-012_02.csv:1-47"], "line_count": 47, "speakers": ["众人", "咲季", "手毬", "琴音"], "topics": ["team_story", "relationships", "dialogue_style", "character_arc"], "title": "咲季邀请众人合练", "summary": "咲季结束自主训练后，感谢手毬与琴音的陪伴。众人因炸猪排一事和解，咲季解释合练是制作人提议，旨在利用彼此实力建立双赢关系。咲季高度认可手毬与琴音的实力，三人约定暂时结成共同战线，在考试前假装友好，随后由琴音带头开始最强偶像的合练。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "琴音", "手毬", "朋友", "对手"], "worldbuilding_signals": ["偶像", "训练"], "dialogue_style_signals": ["才不是", "制作人", "啦"], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "今天就到这里吧！谢谢你们陪我自主训练"}, {"source_row": "27", "speaker": "咲季", "text_zh": "既然存在能建立双赢关系的对象就应该互相利用"}, {"source_row": "32", "speaker": "咲季", "text_zh": "和佑芽一起练习时那种特别的默契感"}, {"source_row": "46", "speaker": "琴音", "text_zh": "目标是最强偶像"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季结束自主训练并感谢手毬与琴音的陪伴。", "咲季解释合练是制作人提议，旨在利用彼此实力建立双赢关系。", "咲季高度认可手毬与琴音的实力，称其为中等部王牌。", "三人约定暂时结成共同战线，在考试前假装友好。"], "relationship_facts": ["咲季与手毬、琴音是互相竞争的对手关系。", "咲季与手毬、琴音约定暂时结成共同战线。", "咲季与琴音之间存在特别的默契感。"], "worldbuilding_facts": ["咲季平时负责做饭和按摩。", "手毬对炸猪排的吃法有非常讲究的要求。", "咲季与佑芽一起练习时曾有过特别的默契感。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00032", "scene_id": "scene-00032", "source_file": "CSV/cidol/hski/adv_cidol-hski-3-012_03.csv", "source_kind": "cidol", "chapter": "cidol/hski", "scene": "adv_cidol-hski-3-012_03", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "35", "line_count": 35}], "source_refs": ["CSV/cidol/hski/adv_cidol-hski-3-012_03.csv:1-35"], "line_count": 35, "speakers": ["制作人", "咲季"], "topics": ["relationships", "dialogue_style", "worldbuilding", "character_arc"], "title": "最强搭档的荣耀宣言", "summary": "训练结束后，咲季与制作人互诉心声。咲季肯定联合训练成果，制作人则炫耀选中咲季的决定。两人确认彼此是无可替代的最强组合，誓言继续证明这份羁绊，将日常危机转化为欢笑，共同迈向世界巅峰。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人", "琴音", "手毬", "对手"], "worldbuilding_signals": ["偶像", "制作人科", "训练"], "dialogue_style_signals": ["呵呵", "制作人"], "key_evidence": [{"source_row": "17", "speaker": "咲季", "text_zh": "作为你的担当偶像我什么都愿意听哦。"}, {"source_row": "24", "speaker": "制作人", "text_zh": "『选中花海咲季的我』才是最强的。"}, {"source_row": "32", "speaker": "咲季", "text_zh": "『被你培育着的我』才是最强的存在。"}, {"source_row": "35", "speaker": "咲季", "text_zh": "你与我的组合才是世界最强的搭档啊！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季与制作人确认联合训练效果显著，双方相性极佳。", "咲季认为被制作人培育的自己才是最强的存在。", "制作人表示选中咲季的决定让他心中涌起无上荣耀。", "咲季与制作人誓言继续证明彼此是世界最强的搭档。"], "relationship_facts": ["咲季是制作人的担当偶像。", "咲季与制作人是互相认可的最强搭档。", "咲季视制作人为能让她挺起胸膛勇往直前的存在。"], "worldbuilding_facts": ["制作人科的教学理念通常不鼓励违背常规的想法。", "偶像培育方案强调发挥组合适配性。", "现实经历比模拟推演更能给出明确答案。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00033", "scene_id": "scene-00033", "source_file": "CSV/cidol/hski/adv_cidol-hski-3-015_01.csv", "source_kind": "cidol", "chapter": "cidol/hski", "scene": "adv_cidol-hski-3-015_01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "37", "line_count": 37}], "source_refs": ["CSV/cidol/hski/adv_cidol-hski-3-015_01.csv:1-37"], "line_count": 37, "speakers": ["制作人", "咲季"], "topics": ["relationships", "dialogue_style", "worldbuilding", "team_story"], "title": "咲季与对手们的演唱会", "summary": "咲季请求制作人辅导下次演唱会事宜。她视手毬和琴音为重要朋友及强劲对手，甚至认为她们与佑芽同样优秀。制作人肯定了她们的天赋与状态恢复，并赞扬咲季的支持。咲季决心展现精彩演出，邀请制作人共同商讨。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "琴音", "手毬", "朋友", "对手", "伙伴"], "worldbuilding_signals": ["偶像", "演唱会"], "dialogue_style_signals": ["当然", "哼", "呵呵", "制作人"], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "制作人！请来辅导我一下吧！"}, {"source_row": "4", "speaker": "咲季", "text_zh": "下次演唱会的合作者是手毬和琴音。"}, {"source_row": "16", "speaker": "制作人", "text_zh": "从藤田同学身上能感受到舞蹈…以及作为偶像与生俱来的天赋。"}, {"source_row": "37", "speaker": "咲季", "text_zh": "嗯！马上开会吧！制作人！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季请求制作人辅导下次演唱会。", "咲季视手毬和琴音为重要朋友及强劲对手。", "制作人肯定咲季对手毬和琴音的支持。"], "relationship_facts": ["咲季与手毬、琴音是朋友兼对手。", "咲季与制作人关系亲密。", "手毬和琴音是咲季特别的存在。"], "worldbuilding_facts": ["手毬拥有舞蹈天赋与偶像天分。", "琴音拥有压倒性的歌唱力与存在感。", "手毬和琴音在春天时状态不佳但已恢复。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00034", "scene_id": "scene-00034", "source_file": "CSV/cidol/hski/adv_cidol-hski-3-015_02.csv", "source_kind": "cidol", "chapter": "cidol/hski", "scene": "adv_cidol-hski-3-015_02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "41", "line_count": 41}], "source_refs": ["CSV/cidol/hski/adv_cidol-hski-3-015_02.csv:1-41"], "line_count": 41, "speakers": ["制作人", "咲季"], "topics": ["relationships", "dialogue_style", "worldbuilding", "team_story"], "title": "咲季接纳软弱自我", "summary": "咲季为战胜对手欲打磨歌曲，却因畏惧展现软弱而犹豫。制作人指出其隐藏的真实魅力，鼓励她接纳不完美的自己。咲季最终决定将这首非专属歌曲据为己有，决心在舞台上展现真实的脆弱与莽撞。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "琴音", "手毬", "妹妹", "姐姐"], "worldbuilding_signals": ["学园", "偶像", "演唱会"], "dialogue_style_signals": ["当然", "真是的", "制作人", "啦"], "key_evidence": [{"source_row": "18", "speaker": "咲季", "text_zh": "只是难看的垂死挣扎，每况愈下"}, {"source_row": "24", "speaker": "制作人", "text_zh": "因恐惧而颤抖的身姿也好"}, {"source_row": "39", "speaker": "咲季", "text_zh": "就让它成为我的曲子吧！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季认为自己的‘不顾一切’是难看的垂死挣扎，没有未来。", "制作人指出咲季隐藏软弱、恐惧的模样同样充满偶像魅力。", "咲季决定接纳‘又逊又难堪’的自己，将歌曲《不顾一切地前进吧！》作为自己的曲子。"], "relationship_facts": ["咲季视手毬和琴音为演唱会上的对手。", "咲季希望成为在妹妹和粉丝面前帅气的姐姐。", "制作人与咲季是指导与被指导的亲密关系，制作人能洞察咲季内心。"], "worldbuilding_facts": ["咲季是初星学园的偶像。", "咲季演唱的歌曲名为《不顾一切地前进吧！》。", "咲季平时以聪明、帅气的形象示人，隐藏了笨拙和恐惧的一面。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00035", "scene_id": "scene-00035", "source_file": "CSV/cidol/hski/adv_cidol-hski-3-015_03.csv", "source_kind": "cidol", "chapter": "cidol/hski", "scene": "adv_cidol-hski-3-015_03", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "41", "line_count": 41}], "source_refs": ["CSV/cidol/hski/adv_cidol-hski-3-015_03.csv:1-41"], "line_count": 41, "speakers": ["咲季", "手毬", "琴音"], "topics": ["relationships", "team_story", "dialogue_style", "worldbuilding"], "title": "咲季与对手的排练", "summary": "咲季在排练中展现惊人投入，手毬与琴音对此表示惊讶并调侃。手毬感谢咲季的营养餐支持，咲季则回应演出是献给粉丝与伙伴的。三人互动充满竞争与温情，咲季以压倒性演出回应挑衅，承诺让大家开心。", "saki_role": "同学/对手：咲季在群像关系中以好胜、直率和带头推进对话的姿态出现。", "relationship_signals": ["琴音", "手毬", "对手"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["当然", "真是的", "哼", "啦"], "key_evidence": [{"source_row": "4", "speaker": "琴音", "text_zh": "体力怪物般的咲季怎么可能累趴啦。"}, {"source_row": "12", "speaker": "手毬", "text_zh": "都是多亏了咲季，还有她每天为我准备的营养餐呢。"}, {"source_row": "39", "speaker": "咲季", "text_zh": "今天这场演出，不仅是献给粉丝，也是献给你们的。"}, {"source_row": "41", "speaker": "咲季", "text_zh": "我会唱歌、跳舞，让大家开心的！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季在排练时唱得超级投入，体力充沛。", "手毬表示咲季每天为她准备营养餐，帮助她提升体力。", "咲季称今天的演出是献给粉丝和手毬、琴音的。", "咲季承诺会不顾一切地唱歌跳舞让大家开心。"], "relationship_facts": ["咲季与手毬、琴音是队友兼竞争对手。", "手毬与琴音互相调侃，关系亲密。", "咲季对对手（手毬、琴音）关怀备至。"], "worldbuilding_facts": ["咲季因营养餐而体力超群，被称为体力怪物。", "排练不仅是表演，也是献给粉丝的演出。", "咲季擅长用压倒性演出回应挑衅。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00036", "scene_id": "scene-00036", "source_file": "CSV/cidol/hski/adv_cidol-hski-3-017_01.csv", "source_kind": "cidol", "chapter": "cidol/hski", "scene": "adv_cidol-hski-3-017_01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "27", "line_count": 27}], "source_refs": ["CSV/cidol/hski/adv_cidol-hski-3-017_01.csv:1-27"], "line_count": 27, "speakers": ["制作人", "咲季", "旁白"], "topics": ["dialogue_style", "relationships", "team_story"], "title": "咲季夺冠后的新曲抉择", "summary": "花海咲季在『NEXT IDOL AUDITION』夺冠次日，提议立即创作新曲。制作人虽已下单，咲季却坚持夏季『H.I.F』正赛不使用新曲。她认为现有曲目与自身有深厚情感，且熟练度差距无法抹平，主张以手牌挑战。咲季强调全力以赴的意义在于注视过去、现在与未来，拒绝因速度而轻视现有积累，展现了其独特的进取与稳重并存的态度。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人"], "worldbuilding_signals": [], "dialogue_style_signals": ["当然", "呵呵", "制作人"], "key_evidence": [{"source_row": "1", "speaker": "旁白", "text_zh": "花海咲季在『NEXT IDOL AUDITION』中夺冠的第二天。"}, {"source_row": "16", "speaker": "咲季", "text_zh": "虽然我的乐曲掌握速度，比任何人都快。"}, {"source_row": "18", "speaker": "咲季", "text_zh": "对一路陪我走来的这些乐曲也有感情。"}, {"source_row": "25", "speaker": "咲季", "text_zh": "这就是全力以赴的意义。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["花海咲季在『NEXT IDOL AUDITION』中夺冠。", "咲季提议在夺冠后立即创作新曲。", "咲季决定夏季『H.I.F』正赛不使用新曲。", "咲季认为现有曲目与自身有深厚情感。"], "relationship_facts": ["咲季与制作人关系融洽，互相理解。", "制作人是咲季的专属制作人。", "咲季视制作人为能理解其作风的伙伴。"], "worldbuilding_facts": ["夏季举办『H.I.F』正赛。", "咲季拥有极快的乐曲掌握速度。", "新曲需一定熟练度才能在正赛使用。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00037", "scene_id": "scene-00037", "source_file": "CSV/cidol/hski/adv_cidol-hski-3-017_02.csv", "source_kind": "cidol", "chapter": "cidol/hski", "scene": "adv_cidol-hski-3-017_02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "36", "line_count": 36}], "source_refs": ["CSV/cidol/hski/adv_cidol-hski-3-017_02.csv:1-36"], "line_count": 36, "speakers": ["制作人", "咲季", "旁白"], "topics": ["dialogue_style", "relationships", "team_story", "plot"], "title": "咲季提议重写新曲", "summary": "夏日H.I.F后，咲季催促制作人重写新曲。制作人坦言因方案变更且被咲季触动而心潮澎湃。咲季提议以现有八成完成的歌词为基础，旨在超越初遇时的自己，展现未来的花海咲季。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人"], "worldbuilding_signals": ["演唱会"], "dialogue_style_signals": ["当然", "呵呵", "制作人", "啦"], "key_evidence": [{"source_row": "3", "speaker": "咲季", "text_zh": "现在正是需要之前提过的『花海咲季的新曲』的时候了。"}, {"source_row": "14", "speaker": "制作人", "text_zh": "经历了『H.I.F』之后，重新……在与您共处的当下。我感到非常……心潮澎湃。"}, {"source_row": "25", "speaker": "制作人", "text_zh": "包括歌词在内，大约完成了八成。"}, {"source_row": "36", "speaker": "咲季", "text_zh": "我要超越她，继续前进！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["夏日H.I.F活动后咲季催促制作人开始新曲制作。", "制作人因方案变更及与咲季共处的感动决定重写。", "原计划新曲歌词部分已完成约八成。", "咲季提议基于现有基础制作，旨在超越过去的自己。"], "relationship_facts": ["咲季与制作人共同商讨新曲创作。", "咲季视制作人为能见证并推动其成长的伙伴。", "制作人因咲季的存在而感到心潮澎湃。"], "worldbuilding_facts": ["花海咲季拥有名为『花海咲季』的特定形象或阶段。", "咲季在H.I.F活动后计划推出个人新曲。", "咲季的目标是超越初遇时梦想中的未来自我。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00038", "scene_id": "scene-00038", "source_file": "CSV/cidol/hski/adv_cidol-hski-3-017_03.csv", "source_kind": "cidol", "chapter": "cidol/hski", "scene": "adv_cidol-hski-3-017_03", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "44", "line_count": 44}], "source_refs": ["CSV/cidol/hski/adv_cidol-hski-3-017_03.csv:1-44"], "line_count": 44, "speakers": ["咲季", "星南", "燐羽"], "topics": ["dialogue_style", "relationships", "worldbuilding"], "title": "咲季夺回歌曲主权", "summary": "咲季向星南与燐羽请教新歌方向，确认将原本属于他人的未竟之作彻底掌握。她决心以实力让歌曲成为自己的东西，向制作人及粉丝宣告主权，并请求将新曲改得更适合自己，展现偶像成长的坚定意志。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "星南", "姐姐"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["呵呵", "制作人"], "key_evidence": [{"source_row": "30", "speaker": "咲季", "text_zh": "我要夺走它，让它成为我的东西。"}, {"source_row": "36", "speaker": "咲季", "text_zh": "给我把它改得更更更更适合我！"}, {"source_row": "22", "speaker": "燐羽", "text_zh": "用实力差距彻底击溃她们。"}, {"source_row": "44", "speaker": "咲季", "text_zh": "所有人统统都是，我的东西哦！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季决定夺走原本属于‘那家伙’的未竟歌曲，将其变为自己的作品。", "咲季请求星南和燐羽协助，将新曲改得更加适合自己演唱。", "燐羽提出通过实力差距独占歌曲，让其他偶像无法演唱的建议。", "咲季明确表示要将制作人、粉丝及同伴都视为自己的所有物。"], "relationship_facts": ["咲季与星南、燐羽是同伴关系，正在讨论歌曲改编事宜。", "星南认为咲季已发生巨大改变，建议配合其变化改编乐曲。", "燐羽与星南观点不同，主张用实力独占歌曲而非量身定做。"], "worldbuilding_facts": ["歌曲创作存在‘量身定做’与‘强行独占’两种不同的偶像发展路径。", "偶像需要通过实力差距来确立对歌曲的绝对所有权。", "未完成的曲子原本属于特定对象（那家伙），需被夺回。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00039", "scene_id": "scene-00039", "source_file": "CSV/cidol/hume/adv_cidol-hume-3-005_01.csv", "source_kind": "cidol", "chapter": "cidol/hume", "scene": "adv_cidol-hume-3-005_01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "50", "line_count": 50}], "source_refs": ["CSV/cidol/hume/adv_cidol-hume-3-005_01.csv:1-50"], "line_count": 50, "speakers": ["众人", "佑芽", "千奈", "广"], "topics": ["team_story", "relationships", "dialogue_style", "worldbuilding"], "title": "圣诞派对筹备与邀请", "summary": "佑芽、千奈与广讨论圣诞节派对，决定避开工作高峰并邀请平日关照众人的人参加。众人考虑邀请制作人、学生会成员及祖父，最终佑芽提出合适人选。咲季虽被提及为忙碌的姐姐，但未直接出场。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "广", "姐姐"], "worldbuilding_signals": ["学园", "偶像", "工作"], "dialogue_style_signals": ["当然", "才不是", "呵呵", "嘿嘿", "制作人", "啦"], "key_evidence": [{"source_row": "43", "speaker": "千奈", "text_zh": "秦谷同学和月村同学、咲季姐姐大人……"}, {"source_row": "44", "speaker": "千奈", "text_zh": "……看起来都很忙呢。"}, {"source_row": "46", "speaker": "千奈", "text_zh": "我家祖父大人可能会闹别扭呢。"}, {"source_row": "50", "speaker": "佑芽", "text_zh": "我——想到合适人选啦！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["决定举办圣诞派对，时间需与圣诞节当天错开。", "计划邀请平日关照众人的制作人及学生会成员参加。", "考虑到学园长祖父可能闹别扭，暂时不邀请。", "广希望借此机会与制作人签约。"], "relationship_facts": ["佑芽与制作人关系亲密，制作人常调整其行程。", "千奈与广是偶像搭档，共同策划派对。", "咲季是千奈的姐姐，属于学生会成员。"], "worldbuilding_facts": ["主角团是偶像，圣诞节期间工作繁忙。", "学园长是老爷爷，其祖父可能因派对闹别扭。", "制作人对佑芽有特殊的照顾和行程调整能力。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00040", "scene_id": "scene-00040", "source_file": "CSV/cidol/hume/adv_cidol-hume-3-006_01.csv", "source_kind": "cidol", "chapter": "cidol/hume", "scene": "adv_cidol-hume-3-006_01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "35", "line_count": 35}], "source_refs": ["CSV/cidol/hume/adv_cidol-hume-3-006_01.csv:1-35"], "line_count": 35, "speakers": ["佑芽", "制作人"], "topics": ["relationships", "dialogue_style", "worldbuilding", "character_arc"], "title": "佑芽获授必杀技", "summary": "佑芽因输给咲季而自责，制作人鼓励她并传授应对宿敌 N.I.A 的策略。制作人指出佑芽已具备与咲季势均力敌的实力，授予其学园必杀技《Campus mode!!》作为决战曲目，佑芽深受鼓舞决心努力掌握。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "姐姐", "对手"], "worldbuilding_signals": ["学园", "偶像"], "dialogue_style_signals": ["制作人", "啦"], "key_evidence": [{"source_row": "8", "speaker": "佑芽", "text_zh": "明明是和姐姐打成平手……"}, {"source_row": "25", "speaker": "制作人", "text_zh": "获得了与咲季同学势均力敌的实力。"}, {"source_row": "21", "speaker": "制作人", "text_zh": "『Campus mode!!』是初星学园偶像的必杀技。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["佑芽因输给咲季导致其评价降低而感到不甘心。", "制作人确认佑芽已获得与咲季势均力敌的实力。", "制作人将《Campus mode!!》定为佑芽对抗宿敌 N.I.A 的策略。"], "relationship_facts": ["佑芽视咲季为姐姐及宿命对手。", "制作人是佑芽的导师与鼓励者。", "咲季是初星学园偶像的顶尖存在。"], "worldbuilding_facts": ["《Campus mode!!》是初星学园偶像的必杀技。", "该曲目唯有被选中之人才能在舞台演唱。", "获得此称号需通过在定期公演中获胜。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00041", "scene_id": "scene-00041", "source_file": "CSV/cidol/hume/adv_cidol-hume-3-006_02.csv", "source_kind": "cidol", "chapter": "cidol/hume", "scene": "adv_cidol-hume-3-006_02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "70", "line_count": 70}], "source_refs": ["CSV/cidol/hume/adv_cidol-hume-3-006_02.csv:1-70"], "line_count": 70, "speakers": ["众人", "佑芽", "制作人", "千奈", "广"], "topics": ["relationships", "dialogue_style", "team_story", "worldbuilding"], "title": "花海咲季之复仇计划", "summary": "制作人与佑芽策划针对咲季的“复仇”计划，旨在激发咲季无法用数值衡量的偶像之力。广与千奈加入队伍，利用自身神秘力量协助。众人约定通过选拔赛提升人气，最终在 N.I.A 演唱《Campus mode!!》。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "广", "星南", "姐姐"], "worldbuilding_signals": ["学园", "偶像"], "dialogue_style_signals": ["当然", "哼", "呵呵", "嘿嘿", "制作人", "啦"], "key_evidence": [{"source_row": "22", "speaker": "制作人", "text_zh": "咲季同学在最后关头展现的……无法用数值衡量的……偶像之力。"}, {"source_row": "44", "speaker": "广", "text_zh": "那种两者皆非的力量，据说我和千奈都拥有。"}, {"source_row": "60", "speaker": "千奈", "text_zh": "我们也能在『N.I.A』上演唱『Campus mode!!』了呀～！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["制作人与佑芽决定挑战咲季无法用数值衡量的偶像之力。", "广与千奈拥有咲季类似的无法用数值衡量的神秘力量。", "三人组约定通过选拔赛提升人气，并在 N.I.A 演唱《Campus mode!!》。"], "relationship_facts": ["制作人与佑芽是搭档，共同策划针对咲季的特别计划。", "广与千奈是咲季的队友，拥有类似咲季的神秘力量。", "星南是千奈的姐姐，负责向学园申请演出许可。"], "worldbuilding_facts": ["咲季拥有无法用常规数值衡量的“偶像之力”。", "广与千奈也拥有咲季类似的无法用数值衡量的神秘力量。", "N.I.A 是重要的偶像活动舞台，演唱《Campus mode!!》需通过正式选拔赛。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00042", "scene_id": "scene-00042", "source_file": "CSV/cidol/hume/adv_cidol-hume-3-006_03.csv", "source_kind": "cidol", "chapter": "cidol/hume", "scene": "adv_cidol-hume-3-006_03", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "76", "line_count": 76}], "source_refs": ["CSV/cidol/hume/adv_cidol-hume-3-006_03.csv:1-76"], "line_count": 76, "speakers": ["佑芽", "制作人", "千奈", "广"], "topics": ["relationships", "dialogue_style", "worldbuilding", "team_story"], "title": "咲季在幕后被提及", "summary": "佑芽在制作人面前倾诉紧张，意识到粉丝不仅是观众更是自身的一部分。她反思自己过去只模仿姐姐，如今决心展现全部实力。制作人鼓励她向粉丝传达心意，佑芽重拾信心，准备以全新的姿态登上舞台。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "广", "姐姐"], "worldbuilding_signals": ["偶像", "试镜", "演唱会", "工作"], "dialogue_style_signals": ["制作人", "啦"], "key_evidence": [{"source_row": "15", "speaker": "佑芽", "text_zh": "那些期待着花海咲季演唱会的人们也——"}, {"source_row": "40", "speaker": "佑芽", "text_zh": "我一直以来，都只想着要胜过姐姐……"}, {"source_row": "64", "speaker": "制作人", "text_zh": "『粉丝是自身的一部分』——这不是一句很好的话吗？"}, {"source_row": "76", "speaker": "佑芽", "text_zh": "『Campus mode!!』我出发了！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["佑芽意识到粉丝是偶像力量源泉的一部分。", "佑芽承认自己过去只想着胜过姐姐，缺乏对粉丝的真诚。", "制作人指出佑芽受千奈和广影响，对粉丝的爱意不输他人。", "佑芽决定在演唱会上向所有粉丝传达心意。"], "relationship_facts": ["佑芽与制作人：指导与被指导，制作人鼓励佑芽。", "佑芽与千奈、广：竞争对手兼榜样，佑芽视她们为学习对象。", "佑芽与粉丝：从利用关系转变为视粉丝为自身一部分的深厚羁绊。"], "worldbuilding_facts": ["FINALE 是偶像试镜的重要舞台。", "偶像的力量源泉包括粉丝的支持与反馈。", "Campus mode 是花海佑芽的专属表演模式。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00043", "scene_id": "scene-00043", "source_file": "CSV/cidol/hume/adv_cidol-hume-3-009_01.csv", "source_kind": "cidol", "chapter": "cidol/hume", "scene": "adv_cidol-hume-3-009_01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "63", "line_count": 63}], "source_refs": ["CSV/cidol/hume/adv_cidol-hume-3-009_01.csv:1-63"], "line_count": 63, "speakers": ["佑芽", "制作人", "咲季"], "topics": ["relationships", "dialogue_style", "worldbuilding", "team_story"], "title": "咲季助佑芽挑战宿敌", "summary": "制作人欲为佑芽创作挑战咲季的新曲，咲季虽被佑芽视为追赶背影的对象，却指出其缺乏偶像敬意。咲季最终理解并协助制作人，共同打磨这首展现佑芽青涩力量的绝妙乐曲，助其成长。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "姐姐", "朋友"], "worldbuilding_signals": ["学园", "偶像"], "dialogue_style_signals": ["当然", "制作人"], "key_evidence": [{"source_row": "5", "speaker": "制作人", "text_zh": "『为了战胜咲季同学的曲子』"}, {"source_row": "31", "speaker": "咲季", "text_zh": "因为那孩子啊，眼里只看得见我的背影。"}, {"source_row": "45", "speaker": "咲季", "text_zh": "符合现阶段花海佑芽风格的乐曲，想必——"}, {"source_row": "63", "speaker": "咲季", "text_zh": "要创作出能成为顶尖偶像·花海佑芽代名词的——绝妙乐曲！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["制作人计划为佑芽创作一首名为『向花海咲季挑战的曲子』的新歌。", "咲季指出佑芽目前缺乏对偶像应有的敬意，视野狭隘。", "咲季决定协助制作人，共同创作这首展现佑芽不完美力量的乐曲。", "该乐曲旨在成为未来顶尖偶像花海佑芽的代名词。"], "relationship_facts": ["咲季是佑芽的姐姐及偶像前辈。", "咲季是佑芽在偶像道路上的宿敌。", "制作人是负责培养偶像的前辈。"], "worldbuilding_facts": ["偶像的成长需要时间，不完美是力量的源泉。", "对偶像的敬意是成为顶尖偶像的重要素质。", "乐曲对偶像而言如同利剑，能锻炼其才能。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00044", "scene_id": "scene-00044", "source_file": "CSV/cidol/hume/adv_cidol-hume-3-009_02.csv", "source_kind": "cidol", "chapter": "cidol/hume", "scene": "adv_cidol-hume-3-009_02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "58", "line_count": 58}], "source_refs": ["CSV/cidol/hume/adv_cidol-hume-3-009_02.csv:1-58"], "line_count": 58, "speakers": ["众人", "佑芽", "千奈", "咲季", "广"], "topics": ["relationships", "team_story", "dialogue_style", "worldbuilding"], "title": "咲季与佑芽的恋爱误会", "summary": "咲季提议与佑芽假期同行，佑芽误以为两人正在交往而惊慌失措。广出面澄清咲季不会恋爱，并建议佑芽进行自我分析以理清内心动摇的原因，最终佑芽意识到自己受恋爱漫画影响过深。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "广", "姐姐"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["才不是", "哼", "呵呵", "嘿嘿", "制作人", "啦"], "key_evidence": [{"source_row": "4", "speaker": "咲季", "text_zh": "下次，什么时候能见面呢？我们把假期调整到一起吧。"}, {"source_row": "14", "speaker": "佑芽", "text_zh": "制作人同学和姐姐她……可能正在交往！！"}, {"source_row": "23", "speaker": "广", "text_zh": "咲季不会做那种事。也不会成为佑芽的制作人。"}, {"source_row": "58", "speaker": "佑芽", "text_zh": "……果然我……可能是看太多了……恋爱漫画。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季提议与佑芽将假期调整到一起见面。", "佑芽误以为咲季与制作人（广）正在交往。", "广指出咲季不会恋爱，也不会成为佑芽的制作人。", "佑芽最终承认自己因看太多恋爱漫画而动摇。"], "relationship_facts": ["咲季是佑芽的姐姐。", "广是佑芽的制作人。", "千奈是咲季和广的朋友。"], "worldbuilding_facts": ["广认为偶像不需要恋爱，应专心投入活动。", "广自认为成熟女性，与恋慕之心无缘。", "广认为偶像应让所有人陷入恋慕，自己陷入恋慕则算输。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00045", "scene_id": "scene-00045", "source_file": "CSV/cidol/hume/adv_cidol-hume-3-009_03.csv", "source_kind": "cidol", "chapter": "cidol/hume", "scene": "adv_cidol-hume-3-009_03", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "53", "line_count": 53}], "source_refs": ["CSV/cidol/hume/adv_cidol-hume-3-009_03.csv:1-53"], "line_count": 53, "speakers": ["佑芽", "制作人"], "topics": ["relationships", "dialogue_style", "worldbuilding"], "title": "佑芽挑战咲季的新曲", "summary": "佑芽因误会姐姐与制作人交往而吃醋，后得知姐姐协助制作新曲。制作人解释此曲是佑芽向咲季发起的挑战，蕴含咲季心愿。佑芽感动于两人并肩作战的心情，决心全力以赴寻找偶像的真谛。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "姐姐"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["呵呵", "制作人", "啦"], "key_evidence": [{"source_row": "10", "speaker": "佑芽", "text_zh": "看到姐姐和制作人同学关系很好地聊天"}, {"source_row": "27", "speaker": "制作人", "text_zh": "是在请她协助佑芽同学制作新曲"}, {"source_row": "38", "speaker": "制作人", "text_zh": "这首曲子，是现在的花海佑芽向花海咲季发起挑战的曲子"}, {"source_row": "49", "speaker": "佑芽", "text_zh": "仿佛成为了无敌的偶像……就是这样的心情"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["佑芽因看到姐姐与制作人聊天而产生误会，后证实是协助制作新曲。", "制作人透露新曲是佑芽向咲季发起的挑战，符合佑芽当前风格。", "佑芽感动于曲中蕴含的咲季心愿，视其为与姐姐并肩作战。", "制作人引用咲季的话，希望佑芽在成为真正偶像时唱响此曲。"], "relationship_facts": ["佑芽与咲季是姐妹关系。", "制作人与咲季是合作关系，共同协助佑芽。", "佑芽与制作人之间存在着互相调侃与信任的互动。"], "worldbuilding_facts": ["花海佑芽是正在追求成为真正偶像的歌手。", "花海咲季是佑芽的姐姐，也是制作人。", "制作新曲是偶像成长与自我挑战的重要环节。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00046", "scene_id": "scene-00046", "source_file": "CSV/cidol/hume/adv_cidol-hume-3-016_03.csv", "source_kind": "cidol", "chapter": "cidol/hume", "scene": "adv_cidol-hume-3-016_03", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "42", "line_count": 42}], "source_refs": ["CSV/cidol/hume/adv_cidol-hume-3-016_03.csv:1-42"], "line_count": 42, "speakers": ["众人", "佑芽", "星南", "美铃"], "topics": ["relationships", "team_story", "dialogue_style"], "title": "咲季缺席的舞蹈讨论", "summary": "众人休息时讨论佑芽快速掌握『ENDLESS DANCE』的进步，星南与美铃表示愿意指导。星南提及若咲季在场可能会因佑芽对两人的喜爱而吃醋，暗示咲季未在场。美铃随后透露佑芽是模仿了包括咲季在内的同伴才学会舞蹈，并提及咲季曾受畏惧但现已改变。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "星南", "美铃", "朋友"], "worldbuilding_signals": [], "dialogue_style_signals": ["当然", "呵呵", "嘿嘿"], "key_evidence": [{"source_row": "15", "speaker": "星南", "text_zh": "要是让咲季知道了，她可能会吃醋呢。"}, {"source_row": "27", "speaker": "美铃", "text_zh": "模仿了谁和谁，才习得了『ENDLESS DANCE』。"}, {"source_row": "32", "speaker": "美铃", "text_zh": "她，曾经被大家所畏惧。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["星南提到若咲季在场，她可能会因为佑芽对星南和美铃的喜爱而吃醋。", "美铃指出佑芽是通过模仿包括咲季在内的同伴才学会『ENDLESS DANCE』。", "美铃透露咲季曾经被大家畏惧，但现在已经能理解大家的心情了。"], "relationship_facts": ["星南和美铃是会长，佑芽是他们的学妹。", "星南和美铃是『一等星』的成员，佑芽正在挑战她们的地位。", "咲季是星南和美铃的同伴，也是佑芽模仿的对象之一。"], "worldbuilding_facts": ["『ENDLESS DANCE』是一个需要记忆和练习的舞蹈。", "星南和美铃是『一等星』的成员，地位受到佑芽的挑战。", "咲季曾经被大家畏惧，但现在已经能理解大家的心情了。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00047", "scene_id": "scene-00047", "source_file": "CSV/cidol/jsna/adv_cidol-jsna-3-006_02.csv", "source_kind": "cidol", "chapter": "cidol/jsna", "scene": "adv_cidol-jsna-3-006_02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "37", "line_count": 37}], "source_refs": ["CSV/cidol/jsna/adv_cidol-jsna-3-006_02.csv:1-37"], "line_count": 37, "speakers": ["咲季", "星南", "燕", "脳内のことね", "脳内の千奈", "莉波", "麻央"], "topics": ["team_story", "dialogue_style", "worldbuilding", "relationships"], "title": "咲季宣言偶像无极限", "summary": "星南陷入对传达对象与歌曲的迷茫，被脑内人格调侃。咲季突然现身，以『一等星』身份宣告偶像没有极限，鼓励星南向初星学园全体同学传达心意。麻央与莉波支持星南随心所欲表达，众人决定共同期待十王星南的新曲。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["麻央", "莉波", "星南", "姐姐", "对手"], "worldbuilding_signals": ["学园", "偶像"], "dialogue_style_signals": ["当然", "哼", "呵呵", "啦"], "key_evidence": [{"source_row": "8", "speaker": "咲季", "text_zh": "『一等星』！就让我来告诉你吧！"}, {"source_row": "9", "speaker": "咲季", "text_zh": "偶像根本不存在什么极限这件事！"}, {"source_row": "36", "speaker": "星南", "text_zh": "就是你们所有人啊！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季以『一等星』身份登场，宣称偶像不存在极限。", "星南决定将心意传达给初星学园全体同学。", "麻央与莉波支持星南随心所欲地表达自我。"], "relationship_facts": ["咲季与星南为竞争对手或同辈关系。", "麻央与莉波是星南的同伴，支持其决定。", "脑内的千奈与ことね是星南的脑内人格。"], "worldbuilding_facts": ["星南拥有脑内人格（千奈、ことね）。", "星南所属团体名为『十王星南』。", "星南就读于初星学园。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00048", "scene_id": "scene-00048", "source_file": "CSV/cidol/jsna/adv_cidol-jsna-3-011_01.csv", "source_kind": "cidol", "chapter": "cidol/jsna", "scene": "adv_cidol-jsna-3-011_01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "45", "line_count": 45}], "source_refs": ["CSV/cidol/jsna/adv_cidol-jsna-3-011_01.csv:1-45"], "line_count": 45, "speakers": ["制作人", "星南"], "topics": ["dialogue_style", "relationships", "worldbuilding", "team_story"], "title": "最强组合的模拟讨论", "summary": "制作人提议组建初星学园最强偶像组合，星南提议藤田琴音与十王星南，但制作人指出星南明年无法参加校内选拔。两人随后讨论其他组合方案，如花海咲季姐妹组，并约定明日继续探讨培养计划。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "琴音", "星南"], "worldbuilding_signals": ["学园", "偶像"], "dialogue_style_signals": ["哼", "呵呵", "制作人"], "key_evidence": [{"source_row": "27", "speaker": "星南", "text_zh": "正是初星学园最强的偶像组合呢！"}, {"source_row": "31", "speaker": "制作人", "text_zh": "从明年起无法参加校内选拔赛。"}, {"source_row": "17", "speaker": "制作人", "text_zh": "花海咲季同学和花海佑芽同学。"}, {"source_row": "45", "speaker": "星南", "text_zh": "一定要组建一支不会输给我和琴音的双人组合"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["星南提议由自己与藤田琴音组成最强组合。", "制作人指出星南明年无法参加校内选拔赛。", "两人约定明日继续讨论组合培养方案。", "制作人提议花海咲季姐妹作为双人组合人选。"], "relationship_facts": ["制作人与星南是前辈与学妹关系。", "星南与藤田琴音是拟组建组合的搭档。", "花海咲季与花海佑芽是姐妹关系。"], "worldbuilding_facts": ["初星学园存在校内偶像选拔赛。", "十王星南因故明年无法参加校内选拔。", "花海咲季与花海佑芽是姐妹组合。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00049", "scene_id": "scene-00049", "source_file": "CSV/cidol/jsna/adv_cidol-jsna-3-011_02.csv", "source_kind": "cidol", "chapter": "cidol/jsna", "scene": "adv_cidol-jsna-3-011_02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "49", "line_count": 49}], "source_refs": ["CSV/cidol/jsna/adv_cidol-jsna-3-011_02.csv:1-49"], "line_count": 49, "speakers": ["制作人", "星南", "选项"], "topics": ["dialogue_style", "relationships", "worldbuilding", "team_story"], "title": "制作人发掘咲季", "summary": "制作人向星南展示最强组合方案，包含咲季、手毬与琴音。咲季被描述为能激发他人潜力的炽热偶像，与星南相似却不同。制作人强调发掘咲季是为了挖掘星南自身，令星南深受触动并决定继续讨论。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人", "琴音", "手毬", "星南", "对手"], "worldbuilding_signals": ["学园", "偶像", "训练"], "dialogue_style_signals": ["当然", "哼", "呵呵", "制作人", "啦"], "key_evidence": [{"source_row": "17", "speaker": "制作人", "text_zh": "她是无论如何都想塞进任何组合的偶像。"}, {"source_row": "21", "speaker": "制作人", "text_zh": "在初星学园里，用花海咲季来对撞难道会有燃烧不起来的偶像吗？"}, {"source_row": "26", "speaker": "星南", "text_zh": "镜中映出的另一个我正是那个不顾一切的、青涩炽热的我。"}, {"source_row": "44", "speaker": "制作人", "text_zh": "本大爷要发掘的不是她们，而是十王星南。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["制作人认为花海咲季是无论如何都想塞进任何组合的偶像。", "咲季能激发任何偶像的燃烧潜力，不存在无法与她共事的偶像。", "咲季与星南相似，是星南不顾一切的青涩炽热自我的镜像。", "制作人选择咲季组合方案是为了发掘星南本人。"], "relationship_facts": ["咲季与星南是相似却不同的对手关系。", "咲季与手毬、琴音组成制作人眼中的最强组合。", "制作人与星南是前辈与后辈的教导关系。"], "worldbuilding_facts": ["初星学园聚集了怀揣成为偶像决心的成员。", "咲季具有不顾一切的青涩炽热特质。", "星南是十王星南，咲季是与其相似却不同的存在。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00050", "scene_id": "scene-00050", "source_file": "CSV/cidol/jsna/adv_cidol-jsna-3-016_01.csv", "source_kind": "cidol", "chapter": "cidol/jsna", "scene": "adv_cidol-jsna-3-016_01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "45", "line_count": 45}], "source_refs": ["CSV/cidol/jsna/adv_cidol-jsna-3-016_01.csv:1-45"], "line_count": 45, "speakers": ["制作人", "星南"], "topics": ["relationships", "dialogue_style", "worldbuilding", "plot"], "title": "咲季提及佑芽成长", "summary": "星南向制作人提议让佑芽、美铃同台，并自豪地展示其培养成果。她透露佑芽虽记性差、曾无偶像敬意，但星南发掘其潜力并决心将其培养成顶级偶像。目前佑芽已成长为业界怪物，星南对其充满期待。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "星南", "美铃", "妹妹", "对手"], "worldbuilding_signals": ["偶像", "演唱会", "工作"], "dialogue_style_signals": ["哼", "呵呵", "制作人", "啦"], "key_evidence": [{"source_row": "14", "speaker": "制作人", "text_zh": "花海佑芽。入学考试获得首席的\n花海咲季同学的妹妹对吧。"}, {"source_row": "16", "speaker": "星南", "text_zh": "嗯，那个孩子啊……非常……\n记性很差哦。"}, {"source_row": "33", "speaker": "星南", "text_zh": "所以，我才发掘了她。\n说要引领她走向顶点——这样。"}, {"source_row": "41", "speaker": "制作人", "text_zh": "如今初星的怪物・花海佑芽的传闻，\n已经响彻整个偶像业界。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["星南计划让佑芽和美铃与自己在下届演唱会同台。", "星南透露花海佑芽记性很差，连歌曲都难以学会。", "星南当初发掘佑芽时并未看到其才能，仅凭直觉想将其培养至顶点。", "花海佑芽现已成为初星怪物，歌声能照亮世界。"], "relationship_facts": ["星南是花海佑芽的发掘者与制作人。", "花海咲季是花海佑芽的姐姐。", "星南与制作人关系亲密，常互相调侃。"], "worldbuilding_facts": ["花海佑芽是初星事务所的顶级偶像，被称为怪物。", "花海咲季是入学考试获得首席的优等生。", "星南以培养实力超越自己的偶像为荣。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00051", "scene_id": "scene-00051", "source_file": "CSV/cidol/kllj/adv_cidol-kllj-3-008_01.csv", "source_kind": "cidol", "chapter": "cidol/kllj", "scene": "adv_cidol-kllj-3-008_01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "37", "line_count": 37}], "source_refs": ["CSV/cidol/kllj/adv_cidol-kllj-3-008_01.csv:1-37"], "line_count": 37, "speakers": ["テレビ", "制作人", "莉莉娅"], "topics": ["relationships", "dialogue_style", "character_arc", "plot"], "title": "咲季登场引发咲季反思", "summary": "制作人安慰失误的莉莉娅，此时电视宣布花海咲季登场。莉莉娅因咲季表现优异而深感自卑与不甘，制作人指出这是成长的证明，并建议莉莉娅主动与咲季交流，以从竞争对手身上获得启发。", "saki_role": "同学/对手：咲季在群像关系中以好胜、直率和带头推进对话的姿态出现。", "relationship_signals": ["制作人", "莉莉娅", "对手"], "worldbuilding_signals": ["学园", "演唱会"], "dialogue_style_signals": ["制作人"], "key_evidence": [{"source_row": "13", "speaker": "テレビ", "text_zh": "接下来登场的是来自初星学园的花海咲季同学！"}, {"source_row": "15", "speaker": "莉莉娅", "text_zh": "（好厉害啊……小咲季）"}, {"source_row": "21", "speaker": "制作人", "text_zh": "看到同班同学的飞跃进步而感到不甘心，这正是成长的证明。"}, {"source_row": "37", "speaker": "制作人", "text_zh": "我觉得和开始能看到背影的竞争对手交流，也能获得些什么哦。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["莉莉娅在演唱会中表现失误，感到自责。", "花海咲季作为初星学园的新星登场，表现优异。", "莉莉娅因咲季的进步而感到不甘心。", "制作人建议莉莉娅与咲季交流以获取成长。"], "relationship_facts": ["制作人与莉莉娅是前辈后辈关系。", "莉莉娅与花海咲季是同班同学。", "花海咲季是莉莉娅的竞争对手。"], "worldbuilding_facts": ["花海咲季来自初星学园。", "花海咲季被视为期待的新星。", "莉莉娅与咲季同属一个班级。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00052", "scene_id": "scene-00052", "source_file": "CSV/cidol/kllj/adv_cidol-kllj-3-008_02.csv", "source_kind": "cidol", "chapter": "cidol/kllj", "scene": "adv_cidol-kllj-3-008_02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "55", "line_count": 55}], "source_refs": ["CSV/cidol/kllj/adv_cidol-kllj-3-008_02.csv:1-55"], "line_count": 55, "speakers": ["制作人", "咲季", "莉莉娅"], "topics": ["worldbuilding", "plot", "character_arc", "dialogue_style"], "title": "咲季鼓励莉莉娅", "summary": "演唱会失误的莉莉娅向咲季寻求建议，咲季肯定其坚强意志并表达欣赏，鼓励她保持自我。咲季澄清并非喜欢莉莉娅本人，而是将其视为竞争对手，并激励她建立自信，最终莉莉娅重拾信心，立志成为顶级偶像。", "saki_role": "同学/对手：咲季在群像关系中以好胜、直率和带头推进对话的姿态出现。", "relationship_signals": ["制作人", "莉莉娅", "对手"], "worldbuilding_signals": ["偶像", "训练", "演唱会"], "dialogue_style_signals": ["制作人", "啦"], "key_evidence": [{"source_row": "21", "speaker": "咲季", "text_zh": "这孩子，是不会折断的呢。"}, {"source_row": "37", "speaker": "咲季", "text_zh": "我可是把你当作竞争对手来看待的哦。"}, {"source_row": "43", "speaker": "咲季", "text_zh": "哪怕最初只是虚张声势，也一定能成为推动你前进的力量。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季在演唱会结束后与沮丧的莉莉娅交谈。", "咲季指出莉莉娅拥有不轻易折断的坚强意志。", "咲季明确表示将莉莉娅视为竞争对手而非单纯的朋友。", "咲季鼓励莉莉娅通过说出缺乏自信来推动自己前进。"], "relationship_facts": ["咲季与莉莉娅是同班同学。", "咲季一直尊敬莉莉娅。", "咲季将莉莉娅视为偶像领域的竞争对手。"], "worldbuilding_facts": ["坚定的意志是偶像最重要的才能。", "咲季的目标是成为未来的顶级偶像。", "莉莉娅的目标是成为未来的顶级偶像。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00053", "scene_id": "scene-00053", "source_file": "CSV/cidol/kllj/adv_cidol-kllj-3-012_02.csv", "source_kind": "cidol", "chapter": "cidol/kllj", "scene": "adv_cidol-kllj-3-012_02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "61", "line_count": 61}], "source_refs": ["CSV/cidol/kllj/adv_cidol-kllj-3-012_02.csv:1-61"], "line_count": 61, "speakers": ["制作人", "咲季", "四音", "形象训练师", "旁白", "舞蹈训练师", "莉莉娅"], "topics": ["dialogue_style", "relationships", "character_arc", "worldbuilding"], "title": "咲季指导莉莉娅实战", "summary": "模拟战胜利后，咲季指导莉莉娅纠正射击姿势与心态。面对实战恐惧，咲季鼓励莉莉娅守护他人。制作人决定让莉莉娅驾驶新型机器人『银辉』出击，咲季与四音一同支援，共同应对敌军王牌十王星南。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["制作人", "手毬", "星南", "莉莉娅"], "worldbuilding_signals": ["训练"], "dialogue_style_signals": ["当然", "哼", "呵呵", "制作人"], "key_evidence": [{"source_row": "21", "speaker": "咲季", "text_zh": "就让我来教你射击的方法吧！"}, {"source_row": "53", "speaker": "制作人", "text_zh": "就交给葛城同学了。"}, {"source_row": "55", "speaker": "咲季", "text_zh": "这不是很好嘛，莉莉娅！"}, {"source_row": "42", "speaker": "咲季", "text_zh": "你有想要守护的人吧？"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季指导莉莉娅调整持枪姿势并纠正射击时的闭眼习惯。", "制作人决定让莉莉娅驾驶尚未分配驾驶员的新型机器人『银辉』。", "咲季鼓励莉莉娅拥有守护他人的战斗理由以克服恐惧。", "咲季与四音作为候补生一同获得出击许可支援莉莉娅。"], "relationship_facts": ["咲季是莉莉娅的射击指导者与精神支柱。", "四音与咲季同为驾驶员候补生，但态度傲慢。", "制作人是训练负责人，负责分配任务与评估战力。"], "worldbuilding_facts": ["葛城莉莉娅是初次机器人战斗胜利后的驾驶员候补生。", "咲季是驾驶员候补生首席，拥有敏锐的洞察力。", "敌方王牌驾驶员十王星南驾驶精锐机器人，战力悬殊。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00054", "scene_id": "scene-00054", "source_file": "CSV/cidol/kllj/adv_cidol-kllj-3-012_03.csv", "source_kind": "cidol", "chapter": "cidol/kllj", "scene": "adv_cidol-kllj-3-012_03", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "52", "line_count": 52}], "source_refs": ["CSV/cidol/kllj/adv_cidol-kllj-3-012_03.csv:1-52"], "line_count": 52, "speakers": ["制作人", "咲季", "四音", "星南", "燕", "莉莉娅"], "topics": ["dialogue_style", "relationships", "team_story", "worldbuilding"], "title": "咲季守护大家之战", "summary": "咲季指挥机体对抗星南，在制作人保护莉莉娅后，咲季引导莉莉娅觉醒意志之力击败敌人。战后制作人向咲季表白，咲季因偶像身份拒绝并匆匆离开，展现其责任感与青涩。", "saki_role": "同学/对手：咲季在群像关系中以好胜、直率和带头推进对话的姿态出现。", "relationship_signals": ["制作人", "星南", "莉莉娅", "对手"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["哼", "呵呵", "制作人", "啦"], "key_evidence": [{"source_row": "4", "speaker": "咲季", "text_zh": "敌方王牌！"}, {"source_row": "28", "speaker": "莉莉娅", "text_zh": "就由我来守护大家！"}, {"source_row": "45", "speaker": "莉莉娅", "text_zh": "因为我是偶像，现在还不行"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季指挥机体对抗星南，并成功引导莉莉娅觉醒意志之力获胜。", "制作人向咲季表白心意，咲季因偶像身份拒绝并离开。", "咲季在战斗中保护莉莉娅，并在战后引导其情绪。"], "relationship_facts": ["咲季与莉莉娅是战友关系，咲季负责指挥与保护。", "咲季与制作人是暧昧关系，制作人向咲季表白。", "咲季与星南是敌对关系，星南驾驶新型机挑战咲季。"], "worldbuilding_facts": ["咲季拥有指挥机体战斗的能力，被称为驾驶员。", "莉莉娅作为偶像，因身份限制无法接受制作人的表白。", "战斗中存在意志之力，能激发机体发光并增强战斗力。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00055", "scene_id": "scene-00055", "source_file": "CSV/cidol/shro/adv_cidol-shro-3-007_02.csv", "source_kind": "cidol", "chapter": "cidol/shro", "scene": "adv_cidol-shro-3-007_02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "53", "line_count": 53}], "source_refs": ["CSV/cidol/shro/adv_cidol-shro-3-007_02.csv:1-53"], "line_count": 53, "speakers": ["制作人", "广"], "topics": ["team_story", "dialogue_style", "relationships", "worldbuilding"], "title": "广的美食综艺首秀", "summary": "广为《Campus mode!!》首次工作参加美食探店综艺，挑战变态辣成功吸睛。虽身体不适，但节目效果火爆，广确认适合综艺，制作人肯定其表现，双方关系融洽。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "广"], "worldbuilding_signals": ["学园", "训练", "工作"], "dialogue_style_signals": ["当然", "哼", "呵呵", "制作人", "啦"], "key_evidence": [{"source_row": "25", "speaker": "广", "text_zh": "我要作为嘉宾出演的是……美食探店节目。"}, {"source_row": "37", "speaker": "广", "text_zh": "辣到差点以为要死了。"}, {"source_row": "48", "speaker": "制作人", "text_zh": "现在……非常火爆呢。"}, {"source_row": "53", "speaker": "广", "text_zh": "还想……再参加一次。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["广作为嘉宾出演美食探店综艺节目。", "广在节目中挑战了变态辣食物。", "节目播出后反响非常火爆。", "广认为综艺节目很开心并想再次参加。"], "relationship_facts": ["制作人与广是搭档关系。", "制作人对广的工作给予支持和指导。", "广对制作人充满信任。"], "worldbuilding_facts": ["广所属组合为『Campus mode!!』。", "广所属组合名为『N.I.A』。", "广的身体健康状况（体检结果）已大幅改善。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00056", "scene_id": "scene-00056", "source_file": "CSV/cidol/ttmr/adv_cidol-ttmr-3-011_01.csv", "source_kind": "cidol", "chapter": "cidol/ttmr", "scene": "adv_cidol-ttmr-3-011_01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "43", "line_count": 43}], "source_refs": ["CSV/cidol/ttmr/adv_cidol-ttmr-3-011_01.csv:1-43"], "line_count": 43, "speakers": ["制作人", "手毬"], "topics": ["relationships", "team_story", "dialogue_style", "worldbuilding"], "title": "咲季入梦组合初现", "summary": "手毬向制作人倾诉关于咲季、琴音与制作人三人的偶像组合梦境。制作人震惊于该组合能助咲季正常发挥，视其为奇迹。手毬虽知梦境与现实有别，但提及咲季时仍感复杂，最终在制作人面前放松警惕。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人", "琴音", "手毬"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["当然", "哼", "制作人"], "key_evidence": [{"source_row": "14", "speaker": "手毬", "text_zh": "是和咲季、琴音三个人……"}, {"source_row": "35", "speaker": "制作人", "text_zh": "能让月村同学正常发挥的组合……"}, {"source_row": "38", "speaker": "制作人", "text_zh": "对月村同学来说，组合这件事……"}, {"source_row": "41", "speaker": "手毬", "text_zh": "因为有制作人在。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["手毬梦见自己与咲季、琴音组成偶像组合。", "制作人认为该组合能让咲季正常发挥，是奇迹搭配。", "手毬在梦中与咲季相处融洽，但现实中感到怪异。", "手毬因制作人在场而感到安心，对咲季话题不再敏感。"], "relationship_facts": ["手毬与制作人关系亲密，手毬依赖制作人。", "咲季与琴音是手毬梦中的组合队友。", "制作人对咲季抱有极高的期待与关注。"], "worldbuilding_facts": ["咲季存在偶像组合活动的可能性。", "咲季对组合话题较为敏感。", "月村（咲季）与制作人的互动影响咲季状态。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00057", "scene_id": "scene-00057", "source_file": "CSV/cidol/ttmr/adv_cidol-ttmr-3-015_01.csv", "source_kind": "cidol", "chapter": "cidol/ttmr", "scene": "adv_cidol-ttmr-3-015_01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "42", "line_count": 42}], "source_refs": ["CSV/cidol/ttmr/adv_cidol-ttmr-3-015_01.csv:1-42"], "line_count": 42, "speakers": ["制作人", "手毬"], "topics": ["relationships", "team_story", "dialogue_style", "worldbuilding"], "title": "咲季与琴音同台演出", "summary": "制作人纠正手毬沟通方式，确认咲季与琴音状态良好。手毬担忧两人同台影响自信，制作人澄清自己期待演出，并提议召开筹备会议，三人将共同呈现精彩表演。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人", "琴音", "手毬"], "worldbuilding_signals": ["偶像", "演唱会"], "dialogue_style_signals": ["当然", "哼", "制作人", "啦"], "key_evidence": [{"source_row": "16", "speaker": "手毬", "text_zh": "是关于下次演唱会的事……"}, {"source_row": "16", "speaker": "手毬", "text_zh": "我听说要和咲季跟琴音两人共同演出。"}, {"source_row": "25", "speaker": "手毬", "text_zh": "咲季和琴音最近状态似乎很不错呢。"}, {"source_row": "40", "speaker": "制作人", "text_zh": "花海咲季同学和藤田琴音同学。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["咲季与琴音将共同出演下次演唱会。", "咲季和琴音近期状态不错，步入正轨。", "制作人期待与咲季、琴音同台演出。", "手毬担心咲季和琴音失去自信。"], "relationship_facts": ["手毬是制作人的同事/朋友。", "咲季和琴音是偶像搭档。", "制作人与咲季、琴音是上下级关系。"], "worldbuilding_facts": ["咲季和琴音是偶像团体成员。", "手毬是月村同学。", "即将举行下次演唱会。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00058", "scene_id": "scene-00058", "source_file": "CSV/cidol/ttmr/adv_cidol-ttmr-3-015_02.csv", "source_kind": "cidol", "chapter": "cidol/ttmr", "scene": "adv_cidol-ttmr-3-015_02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "36", "line_count": 36}], "source_refs": ["CSV/cidol/ttmr/adv_cidol-ttmr-3-015_02.csv:1-36"], "line_count": 36, "speakers": ["制作人", "手毬"], "topics": ["relationships", "team_story", "dialogue_style", "worldbuilding"], "title": "咲季与琴音的羁绊", "summary": "制作人询问手毬关于咲季与琴音的关系。手毬承认咲季是禁欲系偶像，拥有持续努力的知识和经验，且乐于助人。两人虽为竞争对手，但琴音能调解冲突，手毬认为咲季在人类层面难以战胜，对月村同学有积极影响。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人", "琴音", "手毬", "朋友", "对手"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["当然", "才不是", "哼", "制作人", "啦"], "key_evidence": [{"source_row": "23", "speaker": "手毬", "text_zh": "咲季和我不同……是真正的，『禁欲系偶像』。"}, {"source_row": "25", "speaker": "手毬", "text_zh": "拥有着持续过好对自己而言最佳日常的知识和经验。"}, {"source_row": "26", "speaker": "手毬", "text_zh": "但只要有人请教，就会欣然分享诀窍的老好人。"}, {"source_row": "30", "speaker": "手毬", "text_zh": "总是琴音来居中调解。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["咲季是真正的禁欲系偶像，能持续付出最大努力。", "咲季拥有过好最佳日常的知识经验，并乐于分享诀窍。", "咲季在目标受阻时会固执，但激烈碰撞后能互相理解。", "琴音在咲季与手毬冲突时负责居中调解。"], "relationship_facts": ["咲季与琴音是亲密友人及竞争对手。", "咲季与手毬是竞争对手关系，但手毬认可咲季。", "咲季与月村同学（制作人）存在积极影响关系。"], "worldbuilding_facts": ["咲季被定义为禁欲系偶像。", "手毬、咲季、琴音均为顶尖偶像目标。", "手毬与咲季、琴音之间存在复杂的竞争与互助关系。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00059", "scene_id": "scene-00059", "source_file": "CSV/cidol/ttmr/adv_cidol-ttmr-3-015_03.csv", "source_kind": "cidol", "chapter": "cidol/ttmr", "scene": "adv_cidol-ttmr-3-015_03", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "49", "line_count": 49}], "source_refs": ["CSV/cidol/ttmr/adv_cidol-ttmr-3-015_03.csv:1-49"], "line_count": 49, "speakers": ["制作人", "手毬"], "topics": ["relationships", "team_story", "dialogue_style", "worldbuilding"], "title": "咲季与手毬的相似性", "summary": "手毬与制作人讨论共演歌曲，提及咲季与琴音同样是不服输的性格。手毬认为三人因性格相似而合拍，并强调咲季是属于自己的偶像，决心在演唱会上击败对手。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人", "琴音", "手毬", "朋友", "对手"], "worldbuilding_signals": ["偶像", "演唱会"], "dialogue_style_signals": ["当然", "真是的", "制作人"], "key_evidence": [{"source_row": "15", "speaker": "手毬", "text_zh": "无论是咲季还是琴音，都是不肯服输的人。"}, {"source_row": "38", "speaker": "手毬", "text_zh": "倘若由你来培育咲季和琴音的话。"}, {"source_row": "40", "speaker": "手毬", "text_zh": "因为她是属于我的。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["咲季与琴音是不肯服输的人", "咲季与手毬性格相似", "咲季属于手毬"], "relationship_facts": ["手毬与咲季是好朋友", "手毬与制作人关系亲密", "咲季、琴音、手毬是性格相似的三人组"], "worldbuilding_facts": ["共演意味着共同演出而非对决", "偶像通常具有好胜心", "视野狭隘也是偶像特质之一"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00060", "scene_id": "scene-00060", "source_file": "CSV/csprt/csprt-1-0000/adv_csprt-1-0000_01.csv", "source_kind": "csprt", "chapter": "csprt/csprt-1-0000", "scene": "adv_csprt-1-0000_01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "16", "line_count": 16}], "source_refs": ["CSV/csprt/csprt-1-0000/adv_csprt-1-0000_01.csv:1-16"], "line_count": 16, "speakers": ["千奈", "咲季"], "topics": ["character_arc", "worldbuilding", "dialogue_style", "relationships"], "title": "咲季指导千奈特训", "summary": "千奈因训练过度感到疲惫，咲季认为其基础尚浅，决定立即进行针对性指导。咲季以佑芽为例鼓励千奈，并承诺为其量身定制方案，尽管千奈表示已达极限，咲季仍坚持开始训练。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽"], "worldbuilding_signals": ["训练"], "dialogue_style_signals": ["当然", "啦"], "key_evidence": [{"source_row": "3", "speaker": "千奈", "text_zh": "刚才的训练，对我来说太艰苦了。"}, {"source_row": "5", "speaker": "咲季", "text_zh": "说明还需要更多基础训练呢。"}, {"source_row": "11", "speaker": "咲季", "text_zh": "佑芽的话这种程度是家常便饭哦。"}, {"source_row": "14", "speaker": "咲季", "text_zh": "我会为千奈量身定制最适合的训练方案"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["千奈因刚才的训练感到十分疲惫，认为已到达极限。", "咲季认为千奈的基础训练还不够，需要更多练习。", "咲季决定为千奈量身定制最适合的训练方案。", "咲季提到佑芽能轻松应对这种程度的训练。"], "relationship_facts": ["千奈与咲季是同学关系。", "咲季是千奈的训练指导者。", "佑芽是咲季提到的另一位训练对象。"], "worldbuilding_facts": ["训练对千奈来说非常艰苦。", "咲季擅长制定训练方案。", "训练时间有限，需要抓紧进行。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00061", "scene_id": "scene-00061", "source_file": "CSV/csprt/csprt-1-0000/adv_csprt-1-0000_02.csv", "source_kind": "csprt", "chapter": "csprt/csprt-1-0000", "scene": "adv_csprt-1-0000_02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-1-0000/adv_csprt-1-0000_02.csv:1-20"], "line_count": 20, "speakers": ["咲季", "广"], "topics": ["team_story", "dialogue_style", "relationships", "character_arc"], "title": "咲季与广的复习对决", "summary": "咲季确认复习范围后，广因训练而发呆。咲季揭露自己曾是考试第二名，并纠正广对自己是佑芽妹妹的误解。咲季决心要赢过广，广则自信无需复习也能解题，随后突然晕倒，令咲季惊慌。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "广", "妹妹", "姐姐"], "worldbuilding_signals": ["训练"], "dialogue_style_signals": ["才不是", "啦"], "key_evidence": [{"source_row": "8", "speaker": "咲季", "text_zh": "上次考试输给你的第二名花海咲季就是我！"}, {"source_row": "9", "speaker": "广", "text_zh": "佑芽的、妹妹？"}, {"source_row": "10", "speaker": "咲季", "text_zh": "才不是呢！我才是姐姐啦！"}, {"source_row": "13", "speaker": "广", "text_zh": "刚才一直在训练。"}, {"source_row": "14", "speaker": "广", "text_zh": "而且，不复习也能解开考题哦。"}, {"source_row": "20", "speaker": "咲季", "text_zh": "等、等等！别在这种地方晕倒啊——！！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季是上次考试的第二名。", "广在考试前一直在进行训练。", "广声称不复习也能解开考题。", "广在对话过程中突然晕倒。"], "relationship_facts": ["咲季是佑芽的姐姐。", "咲季与广是竞争对手。", "咲季与广正在一起复习。"], "worldbuilding_facts": ["咲季曾参加过考试并获得第二名。", "广拥有不复习也能解题的能力。", "咲季和广似乎身处学校或训练场所。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00062", "scene_id": "scene-00062", "source_file": "CSV/csprt/csprt-1-0001/adv_csprt-1-0001_02.csv", "source_kind": "csprt", "chapter": "csprt/csprt-1-0001", "scene": "adv_csprt-1-0001_02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-1-0001/adv_csprt-1-0001_02.csv:1-20"], "line_count": 20, "speakers": ["咲季", "声乐训练师", "手毬"], "topics": ["character_arc", "relationships", "team_story", "worldbuilding"], "title": "咲季争抢声乐练习机会", "summary": "声乐课上，手毬与咲季争相参与发声练习。咲季作为高等部新生，因不甘落后而主动请缨，与手毬发生争执。声乐训练师调解后安排咲季练习，咲季展现出积极好胜的性格，手毬则视其为怪人。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["手毬"], "worldbuilding_signals": ["课程", "训练"], "dialogue_style_signals": ["才不是", "啦"], "key_evidence": [{"source_row": "5", "speaker": "咲季", "text_zh": "是，我来！"}, {"source_row": "13", "speaker": "咲季", "text_zh": "让我来！"}, {"source_row": "15", "speaker": "咲季", "text_zh": "不第一个来我就不甘心。"}, {"source_row": "20", "speaker": "手毬", "text_zh": "真是个怪人"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季是高等部的新生。", "咲季与手毬在练习机会上发生争执。", "咲季性格好胜，不愿落后于人。", "声乐训练师负责指导并调解两人。"], "relationship_facts": ["咲季与手毬是同学关系。", "声乐训练师是咲季和手毬的指导者。", "咲季与手毬存在竞争关系。"], "worldbuilding_facts": ["场景发生在声乐训练课程中。", "课程包含发声练习和课题曲练习。", "咲季属于高等部。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00063", "scene_id": "scene-00063", "source_file": "CSV/csprt/csprt-1-0002/adv_csprt-1-0002_01.csv", "source_kind": "csprt", "chapter": "csprt/csprt-1-0002", "scene": "adv_csprt-1-0002_01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-1-0002/adv_csprt-1-0002_01.csv:1-20"], "line_count": 20, "speakers": ["咲季", "琴音", "舞蹈训练师"], "topics": ["relationships", "team_story", "dialogue_style", "worldbuilding"], "title": "咲季为琴音制作SSD", "summary": "舞蹈训练后，咲季发现琴音仍想继续打工。面对琴音的沮丧，咲季提议制作专属SSD帮助塑形。琴音虽吐槽但感动于咲季的关心，重拾干劲决定再次训练，咲季对此表示欣慰。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["琴音"], "worldbuilding_signals": ["偶像", "训练"], "dialogue_style_signals": ["真是的", "啦"], "key_evidence": [{"source_row": "5", "speaker": "咲季", "text_zh": "琴音。你不是说要辞掉打工的吗？"}, {"source_row": "12", "speaker": "咲季", "text_zh": "给你制作专属SSD！对塑造体型很有效哦！"}, {"source_row": "15", "speaker": "琴音", "text_zh": "多亏了咲季，现在超级有干劲！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季发现琴音仍在犹豫是否辞掉打工。", "咲季提议制作专属SSD帮助琴音塑形。", "琴音因咲季的关心重拾干劲决定继续训练。"], "relationship_facts": ["咲季与琴音是亲密的朋友或偶像同伴。", "咲季关心琴音的身体状况与心情。", "咲季与舞蹈训练师共同关注琴音的训练。"], "worldbuilding_facts": ["SSD是一种能塑造体型的道具。", "偶像需要持续锻炼体力。", "打工是偶像日常活动的一部分。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00064", "scene_id": "scene-00064", "source_file": "CSV/csprt/csprt-1-0003/adv_csprt-1-0003_02.csv", "source_kind": "csprt", "chapter": "csprt/csprt-1-0003", "scene": "adv_csprt-1-0003_02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-1-0003/adv_csprt-1-0003_02.csv:1-20"], "line_count": 20, "speakers": ["琴音", "麻央"], "topics": ["team_story", "relationships", "dialogue_style"], "title": "咲季与琴音的夜游风波", "summary": "琴音结束工作后偶遇夜游的麻央学姐，随即展开跟踪调查。麻央解释自己是从道场归来且已获许可，并反问琴音是否申请门禁。琴音承认曾向咲季报备，但被麻央批评。咲季虽未现身，却是琴音行动的关键关联人。", "saki_role": "被提及对象：咲季未必直接发言，但场景信息与她的关系或评价有关。", "relationship_signals": ["琴音", "麻央"], "worldbuilding_signals": [], "dialogue_style_signals": ["当然", "哼", "啦"], "key_evidence": [{"source_row": "18", "speaker": "琴音", "text_zh": "好像和咲季说过了～"}, {"source_row": "15", "speaker": "麻央", "text_zh": "是从道场回来。"}, {"source_row": "16", "speaker": "麻央", "text_zh": "我都好好申请了门禁许可的"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["琴音结束工作后在深夜遇到麻央。", "琴音怀疑麻央夜游并决定跟踪确认。", "麻央解释自己是从道场回来且已获许可。", "琴音承认自己曾向咲季说明情况。"], "relationship_facts": ["琴音与麻央是学姐学妹关系。", "琴音与咲季存在报备门禁的互动关系。", "麻央对琴音有管教和说教的倾向。"], "worldbuilding_facts": ["学园设有门禁制度。", "离开学园需申请门禁许可。", "道场是学园内的特定场所。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00065", "scene_id": "scene-00065", "source_file": "CSV/csprt/csprt-1-0004/adv_csprt-1-0004_02.csv", "source_kind": "csprt", "chapter": "csprt/csprt-1-0004", "scene": "adv_csprt-1-0004_02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "19", "line_count": 19}], "source_refs": ["CSV/csprt/csprt-1-0004/adv_csprt-1-0004_02.csv:1-19"], "line_count": 19, "speakers": ["佑芽", "莉波"], "topics": ["team_story", "relationships", "dialogue_style", "character_arc"], "title": "莉波提及咲季照顾妹妹", "summary": "佑芽惊讶于莉波因妹妹发烧而决定不回家。莉波解释妹妹发烧是因为露肚子睡觉，并调侃妹妹想借机逃课。莉波表示比起自己，咲季在照顾妹妹方面更像真正的姐姐，并开玩笑说等佑芽发烧时也要去探病。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "莉波", "妹妹", "姐姐"], "worldbuilding_signals": [], "dialogue_style_signals": ["呵呵", "啦"], "key_evidence": [{"source_row": "18", "speaker": "莉波", "text_zh": "我觉得比不上咲季同学啦。"}, {"source_row": "19", "speaker": "莉波", "text_zh": "那等佑芽发烧的时候，我也去探病好了。"}, {"source_row": "14", "speaker": "莉波", "text_zh": "明明发着烧还闹着要出去玩。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["莉波因妹妹发烧决定不回家。", "妹妹发烧是因为露着肚子睡觉。", "妹妹发烧仍想出去玩，被莉波认为是想逃课。", "莉波认为咲季比她更像真正的姐姐。"], "relationship_facts": ["莉波是佑芽的学姐。", "莉波是妹妹的姐姐。", "咲季是莉波的同学。"], "worldbuilding_facts": ["角色之间存在家庭关系（姐姐与妹妹）。", "角色之间存在学校关系（同学、学姐）。", "角色之间存在生病与照顾的互动情境。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00066", "scene_id": "scene-00066", "source_file": "CSV/csprt/csprt-1-0012/adv_csprt-1-0012_01.csv", "source_kind": "csprt", "chapter": "csprt/csprt-1-0012", "scene": "adv_csprt-1-0012_01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-1-0012/adv_csprt-1-0012_01.csv:1-20"], "line_count": 20, "speakers": ["咲季", "燕"], "topics": ["dialogue_style", "worldbuilding", "character_arc"], "title": "咲季请教训练要领", "summary": "一年级生花海咲季向雨夜燕请教偶像训练动作。燕指出咲季转身时膝盖内倾过多，并亲自示范。咲季领悟后致谢，燕赞赏其天赋与礼仪，考虑推荐至学生会。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": [], "worldbuilding_signals": ["偶像", "训练"], "dialogue_style_signals": ["当然", "哼"], "key_evidence": [{"source_row": "5", "speaker": "燕", "text_zh": "特别是入学考试第一名的花海。"}, {"source_row": "10", "speaker": "咲季", "text_zh": "总是在转身时失去平衡……"}, {"source_row": "11", "speaker": "燕", "text_zh": "膝盖向内倾斜得太多了。"}, {"source_row": "19", "speaker": "燕", "text_zh": "这实力完全不像毫无经验的一年级生。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["花海咲季是入学考试第一名的一年级生。", "咲季在练习转身动作时总是失去平衡。", "燕指出咲季膝盖向内倾斜过多。", "燕赞赏咲季实力不俗且懂得礼仪。"], "relationship_facts": ["花海咲季称呼雨夜为雨夜学姐。", "燕是花海咲季的学姐。", "燕是学生会成员。"], "worldbuilding_facts": ["体力是偶像的基础。", "学校有内部升学组和考试入学组。", "一年级生有面向新生的训练活动。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00067", "scene_id": "scene-00067", "source_file": "CSV/csprt/csprt-2-0000/adv_csprt-2-0000_01.csv", "source_kind": "csprt", "chapter": "csprt/csprt-2-0000", "scene": "adv_csprt-2-0000_01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "17", "line_count": 17}], "source_refs": ["CSV/csprt/csprt-2-0000/adv_csprt-2-0000_01.csv:1-17"], "line_count": 17, "speakers": ["佑芽", "咲季"], "topics": ["relationships", "dialogue_style"], "title": "佑芽撒娇扑抱咲季", "summary": "佑芽突然扑向咲季表达爱意，咲季虽抱怨危险但并未推开。佑芽坚持只对姐姐撒娇，咲季无奈接受并警告不可对他人如此。最终咲季感叹有个爱撒娇的妹妹让人头疼，展现了姐妹间亲密又略带打闹的温馨日常。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "妹妹", "姐姐"], "worldbuilding_signals": [], "dialogue_style_signals": ["真是的", "啦"], "key_evidence": [{"source_row": "1", "speaker": "佑芽", "text_zh": "姐姐～～～～～～～～！"}, {"source_row": "4", "speaker": "咲季", "text_zh": "不是总跟你说不要突然扑过来吗"}, {"source_row": "7", "speaker": "咲季", "text_zh": "对其他孩子这样做哦。太危险了。"}, {"source_row": "17", "speaker": "咲季", "text_zh": "有个这么爱撒娇的妹妹真让人头疼呢。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["佑芽突然扑向咲季表达爱意。", "咲季警告突然扑抱会受伤。", "咲季表示不能对其他孩子这样做。", "咲季感叹有个爱撒娇的妹妹让人头疼。"], "relationship_facts": ["咲季是佑芽的姐姐。", "佑芽是咲季的妹妹。", "姐妹关系亲密且充满打闹。"], "worldbuilding_facts": ["咲季是姐姐，佑芽是妹妹。", "突然扑抱存在受伤风险。", "咲季对妹妹的撒娇感到无奈。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00068", "scene_id": "scene-00068", "source_file": "CSV/csprt/csprt-2-0000/adv_csprt-2-0000_02.csv", "source_kind": "csprt", "chapter": "csprt/csprt-2-0000", "scene": "adv_csprt-2-0000_02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "12", "line_count": 12}], "source_refs": ["CSV/csprt/csprt-2-0000/adv_csprt-2-0000_02.csv:1-12"], "line_count": 12, "speakers": ["佑芽", "咲季"], "topics": ["relationships", "dialogue_style", "team_story", "worldbuilding"], "title": "佑芽与咲季共进午餐", "summary": "佑芽邀请姐姐咲季一起外出吃便当，而非与同班同学。咲季询问训练情况，对佑芽的进步表示欣慰并承诺其将成为仅次于自己的偶像。两人互诉喜爱，咲季在互动中展现宠溺与亲昵。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "姐姐"], "worldbuilding_signals": ["偶像", "训练"], "dialogue_style_signals": ["当然", "真是的", "啦"], "key_evidence": [{"source_row": "2", "speaker": "咲季", "text_zh": "哎呀，不和同班同学一起吃吗？"}, {"source_row": "5", "speaker": "咲季", "text_zh": "——最近训练怎么样？"}, {"source_row": "9", "speaker": "咲季", "text_zh": "你一定会成为最棒的偶像的。"}, {"source_row": "10", "speaker": "咲季", "text_zh": "当然是仅次于我啦。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["佑芽邀请咲季一起外出吃便当。", "咲季询问佑芽最近的训练情况。", "咲季承诺佑芽会成为仅次于自己的偶像。", "咲季对佑芽摸头的行为表示制止。"], "relationship_facts": ["咲季是佑芽的姐姐。", "咲季是佑芽的偶像榜样。", "两人关系亲密且互相喜爱。"], "worldbuilding_facts": ["咲季是佑芽的偶像。", "佑芽正在接受偶像相关的训练。", "咲季是佑芽的同班同学（或至少是佑芽想一起吃饭的对象，但咲季提到同班同学暗示自己可能不同班或特意避开）。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00069", "scene_id": "scene-00069", "source_file": "CSV/csprt/csprt-2-0006/adv_csprt-2-0006_01.csv", "source_kind": "csprt", "chapter": "csprt/csprt-2-0006", "scene": "adv_csprt-2-0006_01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "15", "line_count": 15}], "source_refs": ["CSV/csprt/csprt-2-0006/adv_csprt-2-0006_01.csv:1-15"], "line_count": 15, "speakers": ["咲季", "清夏"], "topics": ["team_story", "dialogue_style", "worldbuilding", "character_arc"], "title": "咲季夸清夏身材", "summary": "咲季称赞清夏身体状态极佳，称其肉体无可挑剔。清夏误以为咲季是健身达人并请求建议，咲季随即讲解股四头肌训练与饮食。清夏表示无意练肌肉，咲季感叹清夏肌肉很棒并誓言下次不再让她逃避。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["清夏"], "worldbuilding_signals": ["偶像", "训练"], "dialogue_style_signals": ["当然", "啦"], "key_evidence": [{"source_row": "5", "speaker": "咲季", "text_zh": "作为偶像来说，这简直是无可挑剔的肉体呢。"}, {"source_row": "8", "speaker": "咲季", "text_zh": "要让股四头肌达到更理想的状态，知道需要什么吗？"}, {"source_row": "11", "speaker": "清夏", "text_zh": "咲季同学，我又没打算练出肌肉什么的。"}, {"source_row": "14", "speaker": "咲季", "text_zh": "明明有那么棒的肌肉……"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季认为清夏的身体状态无可挑剔。", "咲季向清夏提供股四头肌训练建议。", "清夏明确表示不想练出肌肉。", "咲季感叹清夏拥有很棒的身材。"], "relationship_facts": ["咲季与清夏是同学关系。", "咲季对清夏的身材持有欣赏态度。", "咲季对清夏表现出一定的执着。"], "worldbuilding_facts": ["清夏作为偶像拥有无可挑剔的肉体。", "咲季了解股四头肌的训练与饮食知识。", "清夏目前并未进行肌肉训练。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00070", "scene_id": "scene-00070", "source_file": "CSV/csprt/csprt-2-0006/adv_csprt-2-0006_02.csv", "source_kind": "csprt", "chapter": "csprt/csprt-2-0006", "scene": "adv_csprt-2-0006_02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "19", "line_count": 19}], "source_refs": ["CSV/csprt/csprt-2-0006/adv_csprt-2-0006_02.csv:1-19"], "line_count": 19, "speakers": ["咲季", "清夏"], "topics": ["team_story", "relationships", "character_arc", "dialogue_style"], "title": "咲季为妹妹设计饮品", "summary": "咲季向清夏展示为妹妹特制的饮品，强调其非危险性。她提及妹妹虽起初笨拙但毅力惊人，且常与她对抗。咲季自豪地表示妹妹称赞她的菜单美味，并享受被妹妹称呼姐姐的时光，清夏在一旁默默观察并猜测饮品中可能藏着让咲季兴奋的‘妹妹开关’。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["清夏", "妹妹", "姐姐"], "worldbuilding_signals": [], "dialogue_style_signals": ["啦"], "key_evidence": [{"source_row": "5", "speaker": "咲季", "text_zh": "才不危险呢！这是为了我和妹妹特意设计的。"}, {"source_row": "8", "speaker": "咲季", "text_zh": "那孩子虽然一开始完全不行，但特别有毅力在努力哦。"}, {"source_row": "10", "speaker": "咲季", "text_zh": "而且总是对我燃起对抗心，可爱得不得了……"}, {"source_row": "18", "speaker": "咲季", "text_zh": "还有啊，我做的菜单她每次都说很好吃……"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季为妹妹特意设计了那款饮品。", "妹妹起初完全不行，但非常有毅力在努力。", "妹妹总是对咲季燃起对抗心。", "妹妹每次都说咲季做的菜单很好吃。"], "relationship_facts": ["咲季是妹妹的姐姐。", "咲季与妹妹在隔壁班。", "清夏是咲季的同学。"], "worldbuilding_facts": ["咲季制作的饮品看起来超危险。", "咲季妹妹在隔壁班。", "咲季妹妹总是叫咲季姐姐。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00071", "scene_id": "scene-00071", "source_file": "CSV/csprt/csprt-2-0016/adv_csprt-2-0016_01.csv", "source_kind": "csprt", "chapter": "csprt/csprt-2-0016", "scene": "adv_csprt-2-0016_01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "18", "line_count": 18}], "source_refs": ["CSV/csprt/csprt-2-0016/adv_csprt-2-0016_01.csv:1-18"], "line_count": 18, "speakers": ["咲季", "琴音"], "topics": ["relationships", "team_story", "dialogue_style", "character_arc"], "title": "咲季晨练遇冷遇新品", "summary": "咲季晨练后状态良好，琴音出现并调侃其怪声。为回请咲季调配的怪饮，琴音提供打工处新品，咲季却觉得难喝。咲季感叹琴音对自己印象不佳，两人互动展现日常羁绊。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["琴音"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["哼", "啦"], "key_evidence": [{"source_row": "3", "speaker": "咲季", "text_zh": "为了下一场演出，下午要更加努力才行"}, {"source_row": "11", "speaker": "琴音", "text_zh": "因为小咲季总是给我调配奇怪的特别饮品"}, {"source_row": "14", "speaker": "琴音", "text_zh": "这是打工地方拿的，不用在意～据说是新品哦"}, {"source_row": "18", "speaker": "咲季", "text_zh": "我总算明白琴音同学是怎么看待我的了"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季晨练后状态良好，准备下午努力。", "琴音提供打工处新品饮料给咲季。", "咲季认为新品超级难喝。", "咲季感叹琴音对自己印象不佳。"], "relationship_facts": ["咲季与琴音是偶像同伴。", "咲季常给琴音调配特别饮品。", "琴音偶尔会回请咲季饮品。"], "worldbuilding_facts": ["咲季在打工地方工作。", "打工地方有新品饮料。", "咲季擅长调配特别饮品。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00072", "scene_id": "scene-00072", "source_file": "CSV/csprt/csprt-2-0016/adv_csprt-2-0016_02.csv", "source_kind": "csprt", "chapter": "csprt/csprt-2-0016", "scene": "adv_csprt-2-0016_02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-2-0016/adv_csprt-2-0016_02.csv:1-20"], "line_count": 20, "speakers": ["咲季", "琴音"], "topics": ["relationships", "team_story", "character_arc", "worldbuilding"], "title": "咲季与琴音的声乐特训", "summary": "训练结束后，咲季肯定琴音的进步并自信表示将超越对方。随后咲季提议进行歌唱训练，尽管琴音认为舞蹈训练已结束，但咲季坚持声乐与舞蹈分开，并邀请琴音一同前往卡拉OK，最终琴音无奈答应陪练到底。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["琴音"], "worldbuilding_signals": ["训练"], "dialogue_style_signals": ["当然", "哼", "啦"], "key_evidence": [{"source_row": "5", "speaker": "咲季", "text_zh": "舞蹈方面暂时还是琴音更厉害，但我马上就会超越你的。"}, {"source_row": "11", "speaker": "咲季", "text_zh": "好，接下来是歌唱训练。"}, {"source_row": "15", "speaker": "咲季", "text_zh": "声乐训练和舞蹈训练是分开的吧。"}, {"source_row": "17", "speaker": "咲季", "text_zh": "琴音也一起来。果汁什么的还是请得起的。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季认为舞蹈训练结束后，声乐训练仍需继续。", "咲季自信地表示舞蹈方面即将超越琴音。", "咲季邀请琴音一同前往卡拉OK进行歌唱训练。"], "relationship_facts": ["咲季与琴音是共同进行舞蹈和声乐训练的同伴。", "咲季对琴音的进步表示认可并带有竞争意识。", "琴音视咲季为体力与能力都很强的伙伴。"], "worldbuilding_facts": ["偶像训练包含舞蹈和声乐两个独立部分。", "训练室被占用时，团队会选择去卡拉OK进行声乐训练。", "咲季在训练结束后会请喝果汁作为奖励。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00073", "scene_id": "scene-00073", "source_file": "CSV/csprt/csprt-2-0018/adv_csprt-2-0018_01.csv", "source_kind": "csprt", "chapter": "csprt/csprt-2-0018", "scene": "adv_csprt-2-0018_01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "19", "line_count": 19}], "source_refs": ["CSV/csprt/csprt-2-0018/adv_csprt-2-0018_01.csv:1-19"], "line_count": 19, "speakers": ["咲季", "手毬"], "topics": ["relationships", "team_story", "dialogue_style", "character_arc"], "title": "咲季挑战手毬柔韧性", "summary": "咲季与手毬进行柔韧性比拼，咲季通过言语刺激手毬，手毬虽感不适但坚持到底。咲季认可手毬的毅力，并自信地表示下次将轮到她展示更高超的柔韧性，手毬对此感到既恶心又不服气。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["琴音", "手毬"], "worldbuilding_signals": [], "dialogue_style_signals": ["哼"], "key_evidence": [{"source_row": "6", "speaker": "咲季", "text_zh": "顺便说，琴音刚才就在这里放弃了哦。"}, {"source_row": "12", "speaker": "咲季", "text_zh": "不要太勉强自己哦。"}, {"source_row": "16", "speaker": "咲季", "text_zh": "这可是本小姐在认可你哦。"}, {"source_row": "19", "speaker": "手毬", "text_zh": "软体动物……？"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季与手毬正在进行柔韧性方面的比拼。", "咲季指出琴音刚才已放弃，以此激励手毬。", "手毬在感到恶心和不适的情况下仍坚持完成挑战。", "咲季自信地表示在柔韧性方面很有自信。"], "relationship_facts": ["咲季与手毬是竞争对手关系。", "咲季对琴音有评价和提及。", "咲季以居高临下的态度认可手毬。"], "worldbuilding_facts": ["咲季在柔韧性方面拥有自信。", "手毬被咲季形容为软体动物。", "咲季拥有比手毬更高的柔韧性。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00074", "scene_id": "scene-00074", "source_file": "CSV/csprt/csprt-2-0018/adv_csprt-2-0018_02.csv", "source_kind": "csprt", "chapter": "csprt/csprt-2-0018", "scene": "adv_csprt-2-0018_02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-2-0018/adv_csprt-2-0018_02.csv:1-20"], "line_count": 20, "speakers": ["咲季", "手毬"], "topics": ["team_story", "relationships", "dialogue_style"], "title": "咲季训练手毬扭伤", "summary": "咲季与手毬进行体能训练，咲季节奏极快，手毬勉强跟上后体力透支导致扭伤。咲季立即停止训练并为主角包扎，自责让手毬勉强。咲季鼓励手毬提升实力，手毬虽不服气但承认差距，期待下次能跟上咲季的步伐。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["手毬"], "worldbuilding_signals": [], "dialogue_style_signals": ["当然"], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "好，一、二、收工！"}, {"source_row": "5", "speaker": "手毬", "text_zh": "这个体力怪物……！"}, {"source_row": "11", "speaker": "手毬", "text_zh": "只是稍微扭了一下。"}, {"source_row": "20", "speaker": "咲季", "text_zh": "呵，我很期待哦，手毬。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季与手毬正在进行高强度的体能训练。", "手毬因跟不上咲季的节奏导致身体扭伤。", "咲季主动为手毬包扎伤口并道歉。", "咲季鼓励手毬下次要提升实力跟上自己。"], "relationship_facts": ["咲季是手毬的训练搭档。", "咲季对训练对手表现出关心与责任感。", "手毬对咲季的实力感到惊讶并略带不服。"], "worldbuilding_facts": ["咲季拥有远超常人的体能和节奏掌控力。", "训练环境允许进行高强度的体力对抗。", "角色间存在互相激励提升实力的竞争关系。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00075", "scene_id": "scene-00075", "source_file": "CSV/csprt/csprt-2-0019/adv_csprt-2-0019_02.csv", "source_kind": "csprt", "chapter": "csprt/csprt-2-0019", "scene": "adv_csprt-2-0019_02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-2-0019/adv_csprt-2-0019_02.csv:1-20"], "line_count": 20, "speakers": ["佑芽", "千奈"], "topics": ["relationships", "team_story", "character_arc", "dialogue_style"], "title": "咲季写真引发模仿热潮", "summary": "佑芽与千奈讨论登台姿势，千奈借来前辈宣传照。虽星南与麻央照片气场强大，但两人自认难以模仿。随后发现咲季的写真，佑芽深受鼓舞试图模仿，却因姿势难度过大而失败，最终决定不再参考他人。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "麻央", "星南", "姐姐"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["哼"], "key_evidence": [{"source_row": "16", "speaker": "千奈", "text_zh": "咲季同学的写真里，洋溢着自信的感觉呢。"}, {"source_row": "17", "speaker": "佑芽", "text_zh": "哼，佑芽，快点——追上我的脚步吧！"}, {"source_row": "19", "speaker": "佑芽", "text_zh": "那个…我试着模仿了姐姐的姿势…可是——"}, {"source_row": "20", "speaker": "千奈", "text_zh": "看来还是不要参考别人的姿势比较好吧。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["佑芽和千奈正在讨论登台前的姿势练习。", "千奈借来了星南会长和麻央前辈的宣传照作为参考。", "佑芽看到咲季的写真后试图模仿其自信的姿势，但未能成功。", "两人最终决定不模仿星南会长或麻央前辈的特定姿势。"], "relationship_facts": ["佑芽和千奈是共同练习登台姿势的同伴。", "星南会长是前辈，其照片被视作顶级偶像的典范。", "麻央前辈是另一位前辈，其照片展现出王子般的气质。"], "worldbuilding_facts": ["咲季是一位拥有自信气质的偶像，其写真被用作参考。", "星南会长拥有强大的气场，是顶级偶像的代表。", "麻央前辈的形象如同真正的王子殿下，气质独特。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00076", "scene_id": "scene-00076", "source_file": "CSV/csprt/csprt-2-0028/adv_csprt-2-0028_02.csv", "source_kind": "csprt", "chapter": "csprt/csprt-2-0028", "scene": "adv_csprt-2-0028_02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-2-0028/adv_csprt-2-0028_02.csv:1-20"], "line_count": 20, "speakers": ["佑芽", "琴音"], "topics": ["relationships", "team_story", "dialogue_style", "worldbuilding"], "title": "咲季的便当与家庭温暖", "summary": "佑芽与琴音闲聊咲季为她们做便当的往事。佑芽回忆咲季从小教导她制作点心，虽初期失败但坚持练习，因父母忙碌常照顾她。琴音也提及咲季让班级充满活力，两人均视咲季为重要的姐姐角色，充满怀念与喜爱。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "琴音", "妹妹", "姐姐", "朋友", "父母"], "worldbuilding_signals": ["工作"], "dialogue_style_signals": ["嘿嘿", "啦"], "key_evidence": [{"source_row": "2", "speaker": "佑芽", "text_zh": "姐姐教过我做便当！"}, {"source_row": "8", "speaker": "佑芽", "text_zh": "我们家父母工作忙"}, {"source_row": "18", "speaker": "琴音", "text_zh": "多亏了咲季同学"}, {"source_row": "20", "speaker": "佑芽", "text_zh": "正是姐姐的优点嘛！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["咲季曾为琴音和佑芽制作便当。", "咲季从小教导佑芽制作点心。", "咲季的父母工作忙碌，常不在家。", "咲季的存在让班级氛围变得热闹。"], "relationship_facts": ["佑芽视咲季为姐姐。", "琴音视咲季为姐姐。", "佑芽与琴音是同学关系。"], "worldbuilding_facts": ["咲季的父母工作繁忙。", "咲季擅长制作便当和点心。", "咲季性格活泼，能带动周围人。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00077", "scene_id": "scene-00077", "source_file": "CSV/csprt/csprt-2-0030/adv_csprt-2-0030_01.csv", "source_kind": "csprt", "chapter": "csprt/csprt-2-0030", "scene": "adv_csprt-2-0030_01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "19", "line_count": 19}], "source_refs": ["CSV/csprt/csprt-2-0030/adv_csprt-2-0030_01.csv:1-19"], "line_count": 19, "speakers": ["咲季", "广"], "topics": ["team_story", "dialogue_style"], "title": "咲季晨练后特制饮品", "summary": "咲季晨练结束后，发现气喘吁吁的广。她拿出特制的SSD饮品招待，广品尝后赞不绝口并询问配方。咲季爽快答应，并告知从明天起会为广制作专属份，冰箱里可随意取用。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["广"], "worldbuilding_signals": [], "dialogue_style_signals": ["当然", "呵呵", "嘿嘿"], "key_evidence": [{"source_row": "2", "speaker": "咲季", "text_zh": "呼！晨练结束！"}, {"source_row": "9", "speaker": "咲季", "text_zh": "诶？啊……是我特制的SSD哦！"}, {"source_row": "18", "speaker": "咲季", "text_zh": "从明天开始，我也会做你那份的。"}, {"source_row": "19", "speaker": "咲季", "text_zh": "那边的冰箱里，可以随便拿哦！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季晨练结束后发现广身体不适。", "咲季拿出特制饮品SSD招待广。", "咲季承诺从明天开始为广制作专属饮品。", "广的专属饮品存放在咲季那边的冰箱里。"], "relationship_facts": ["咲季与广是晨练伙伴。", "咲季关心广的身体状况。", "咲季愿意为广提供专属照顾。"], "worldbuilding_facts": ["咲季有晨练的习惯。", "咲季制作特制饮品SSD。", "咲季家中冰箱存放有广可随意取用的饮品。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00078", "scene_id": "scene-00078", "source_file": "CSV/csprt/csprt-2-0030/adv_csprt-2-0030_02.csv", "source_kind": "csprt", "chapter": "csprt/csprt-2-0030", "scene": "adv_csprt-2-0030_02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "19", "line_count": 19}], "source_refs": ["CSV/csprt/csprt-2-0030/adv_csprt-2-0030_02.csv:1-19"], "line_count": 19, "speakers": ["咲季", "广"], "topics": ["team_story", "dialogue_style", "worldbuilding", "relationships"], "title": "咲季与广的入学竞争", "summary": "咲季与广在初星学园相遇，广透露自己笔试满分，咲季则自称综合排名第一。广推测咲季是第二名，咲季愤怒反驳并指责广是性格恶劣的不服输者，试图在败者身上寻找优越感，两人就此展开关于性格与排名的争论。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "广"], "worldbuilding_signals": ["学园", "偶像"], "dialogue_style_signals": ["真是的", "哼", "呵呵", "嘿嘿"], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "诶～！原来你也是从高中开始进入初星学园的啊。"}, {"source_row": "4", "speaker": "咲季", "text_zh": "顺便说一下，我可是入学考试的第一名哦。"}, {"source_row": "7", "speaker": "广", "text_zh": "顺便说一下，我的笔试可是满分。"}, {"source_row": "16", "speaker": "咲季", "text_zh": "绝对是的！只有性格恶劣的不服输鬼才会在败者身上找优越感！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["广在入学考试中笔试获得满分。", "咲季声称自己在入学考试中的综合排名高于广。", "咲季认为广是在败者身上寻找优越感的不服输性格。", "广和咲季都是从高中开始进入初星学园的。"], "relationship_facts": ["咲季和广是初星学园的同班同学。", "咲季和广在入学考试中进行了排名竞争。", "咲季对广的不服输性格感到不满和愤怒。"], "worldbuilding_facts": ["初星学园是咲季和广就读的高中。", "初星学园入学考试包含笔试和综合排名。", "佑芽是咲季认识的人，常拿咲季入学第一的事炫耀。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00079", "scene_id": "scene-00079", "source_file": "CSV/csprt/csprt-2-0031/adv_csprt-2-0031_01.csv", "source_kind": "csprt", "chapter": "csprt/csprt-2-0031", "scene": "adv_csprt-2-0031_01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-2-0031/adv_csprt-2-0031_01.csv:1-20"], "line_count": 20, "speakers": ["佑芽", "莉波"], "topics": ["relationships", "team_story", "worldbuilding", "character_arc"], "title": "咲季的秘制SSD配方", "summary": "佑芽与莉波讨论咲季特制的偶像训练用SSD。佑芽透露配方单被自己发现，莉波震惊于其中包含生鸡蛋、小鱼干、纳豆等奇特食材，感叹这是咲季为打造偶像体质而精心调配的秘方。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "莉波", "姐姐"], "worldbuilding_signals": ["偶像", "训练"], "dialogue_style_signals": ["呵呵"], "key_evidence": [{"source_row": "6", "speaker": "佑芽", "text_zh": "是的。是姐姐专门为我制作的"}, {"source_row": "12", "speaker": "佑芽", "text_zh": "但唯独这个秘制配方，她坚决不肯告诉我。"}, {"source_row": "15", "speaker": "佑芽", "text_zh": "姐姐忘在厨房的SSD配方单。"}, {"source_row": "19", "speaker": "莉波", "text_zh": "生、生鸡蛋配小鱼干和鱼干……还有梅干、肝脏、纳豆～～～？"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["咲季为佑芽制作了特制的SSD饮品。", "该饮品配方是咲季的独家秘方，佑芽曾询问但未被告知。", "佑芽偶然发现了咲季遗落在厨房的配方单。", "配方中包含生鸡蛋、小鱼干、梅干、肝脏和纳豆等食材。"], "relationship_facts": ["佑芽称呼咲季为姐姐。", "莉波是佑芽的前辈。", "咲季是佑芽的姐姐，也是莉波认识的人。"], "worldbuilding_facts": ["SSD是一种用于打造偶像体质的特制饮品。", "成为偶像需要摄入特定的营养素。", "咲季制作的SSD配方非常独特且保密。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00080", "scene_id": "scene-00080", "source_file": "CSV/csprt/csprt-2-0031/adv_csprt-2-0031_02.csv", "source_kind": "csprt", "chapter": "csprt/csprt-2-0031", "scene": "adv_csprt-2-0031_02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-2-0031/adv_csprt-2-0031_02.csv:1-20"], "line_count": 20, "speakers": ["佑芽", "咲季", "莉波"], "topics": ["relationships", "team_story", "dialogue_style"], "title": "咲季制作SSD饮品", "summary": "佑芽偷看姐姐咲季制作SSD饮品，莉波加入观察。咲季完成搅拌后，将饮品留给疲惫的手毬。佑芽在搅拌机下发现纸条，得知调味是名字以“あ”开头的东西，莉波猜测是“爱”。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "手毬", "莉波", "姐姐"], "worldbuilding_signals": [], "dialogue_style_signals": ["哼", "啦"], "key_evidence": [{"source_row": "8", "speaker": "咲季", "text_zh": "最后把这些放进搅拌机就完成啦。"}, {"source_row": "9", "speaker": "咲季", "text_zh": "在给佑芽喝之前，先拿去给看起来很疲惫的手毬尝尝吧。"}, {"source_row": "17", "speaker": "佑芽", "text_zh": "但特别给你个提示：秘制调味是名字以あ开头的东西哦♪"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季正在制作SSD饮品。", "咲季将做好的饮品留给手毬。", "佑芽在搅拌机下发现提示纸条。", "纸条提示调味是名字以“あ”开头的东西。"], "relationship_facts": ["咲季是佑芽的姐姐。", "莉波是佑芽的前辈。", "手毬是咲季照顾的对象。"], "worldbuilding_facts": ["SSD饮品需要放入搅拌机制作。", "饮品材料包含番茄、胡萝卜、菠菜、苹果等蔬果。", "纸条上的提示暗示了饮品调味的特殊性质。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00081", "scene_id": "scene-00081", "source_file": "CSV/csprt/csprt-2-0034/adv_csprt-2-0034_01.csv", "source_kind": "csprt", "chapter": "csprt/csprt-2-0034", "scene": "adv_csprt-2-0034_01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-2-0034/adv_csprt-2-0034_01.csv:1-20"], "line_count": 20, "speakers": ["佑芽", "咲季"], "topics": ["relationships", "dialogue_style"], "title": "咲季的定妆pose特训", "summary": "咲季向佑芽展示为追求完美定妆pose而进行的特训，强调即使疲惫也要保持指尖静止。她以蜻蜓停在指尖为例，解释这是达到无我境界的奥义。随后发现佑芽头发上也停着蜻蜓，咲季惊讶地认为佑芽已无意识掌握此境界。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "姐姐"], "worldbuilding_signals": [], "dialogue_style_signals": ["哼"], "key_evidence": [{"source_row": "2", "speaker": "咲季", "text_zh": "哼，在练习定妆pose的特训哦！"}, {"source_row": "6", "speaker": "咲季", "text_zh": "即使高强度舞蹈后疲惫不堪，指尖也要保持笔直纹丝不动。"}, {"source_row": "13", "speaker": "咲季", "text_zh": "这才算是达到了无我境界的定妆pose奥义。"}, {"source_row": "16", "speaker": "咲季", "text_zh": "（啊、佑芽头发上，有蜻蜓！？）"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季正在进行定妆pose的特训。", "咲季认为完美的pose需要指尖纹丝不动。", "蜻蜓停在咲季指尖是因为她达到了无我境界。", "佑芽头发上也停着一只蜻蜓。"], "relationship_facts": ["咲季是佑芽的姐姐。", "咲季指导佑芽进行特训。", "咲季对佑芽的天赋感到惊讶和认可。"], "worldbuilding_facts": ["定妆pose是表演中至关重要的一环。", "保持指尖静止可吸引昆虫停留。", "达到无我境界是定妆pose的奥义。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00082", "scene_id": "scene-00082", "source_file": "CSV/csprt/csprt-2-0034/adv_csprt-2-0034_02.csv", "source_kind": "csprt", "chapter": "csprt/csprt-2-0034", "scene": "adv_csprt-2-0034_02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-2-0034/adv_csprt-2-0034_02.csv:1-20"], "line_count": 20, "speakers": ["佑芽", "咲季"], "topics": ["relationships", "dialogue_style"], "title": "秋日便当与捉蜻蜓", "summary": "佑芽感叹秋天到来，咲季承诺在便当中加入当季食材并特制红薯杂粮饭。两人回忆童年捉蜻蜓、吃野果的往事，咲季提及自己曾闹肚子。咲季提议进行捉蜻蜓比赛，佑芽自信表示这次绝不输给她。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "妹妹", "姐姐"], "worldbuilding_signals": [], "dialogue_style_signals": ["当然", "呵呵", "嘿嘿", "啦"], "key_evidence": [{"source_row": "3", "speaker": "咲季", "text_zh": "会给佑芽的便当里好好放进当季食材的。"}, {"source_row": "13", "speaker": "咲季", "text_zh": "两个人玩得浑身是泥，经常一起挨骂呢。"}, {"source_row": "15", "speaker": "咲季", "text_zh": "我当时就闹肚子了，佑芽却完全没事呢～"}, {"source_row": "18", "speaker": "咲季", "text_zh": "要不要久违地比试一下？捉蜻蜓比赛。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季承诺在佑芽的便当中加入红薯、南瓜等当季食材。", "咲季提议与佑芽进行久违的捉蜻蜓比赛。", "咲季回忆童年时吃野果闹肚子，而佑芽没事。"], "relationship_facts": ["咲季是佑芽的姐姐。", "咲季与佑芽是青梅竹马，曾一起在稻田捉蜻蜓。", "佑芽非常依赖并喜爱咲季。"], "worldbuilding_facts": ["当前季节为秋天，枫叶变红。", "当地水边和树丛附近有很多蜻蜓繁殖。", "佑芽的奶奶家附近有稻田。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00083", "scene_id": "scene-00083", "source_file": "CSV/csprt/csprt-2-0039/adv_csprt-2-0039_01.csv", "source_kind": "csprt", "chapter": "csprt/csprt-2-0039", "scene": "adv_csprt-2-0039_01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-2-0039/adv_csprt-2-0039_01.csv:1-20"], "line_count": 20, "speakers": ["咲季", "形象训练师"], "topics": ["worldbuilding", "character_arc", "plot", "relationships"], "title": "咲季初次体验瑜伽", "summary": "形象训练师指导咲季进行瑜伽训练，旨在帮助其身心放松以达成完美表演。咲季作为优等生迅速掌握技巧，并计划将瑜伽分享给妹妹。训练师称赞咲季适合当教练，咲季则立志将这份赞美转化为成为顶级偶像的动力。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["妹妹"], "worldbuilding_signals": ["学园", "偶像", "训练"], "dialogue_style_signals": [], "key_evidence": [{"source_row": "2", "speaker": "咲季", "text_zh": "我还是第一次体验瑜伽。"}, {"source_row": "13", "speaker": "咲季", "text_zh": "我觉得对调整心理状态非常有效。"}, {"source_row": "17", "speaker": "咲季", "text_zh": "我打算马上也教给妹妹。"}, {"source_row": "20", "speaker": "咲季", "text_zh": "我会用来成为顶级偶像的！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季是初次体验瑜伽的优等生。", "瑜伽对调整咲季的心理状态非常有效。", "咲季打算将瑜伽技巧教给妹妹。", "形象训练师认为咲季适合担任教练。"], "relationship_facts": ["咲季与形象训练师是指导与被指导关系。", "咲季与妹妹是姐妹关系。", "咲季是初星学园的学生。"], "worldbuilding_facts": ["初星学园的学生需要掌握多种技能。", "完美的精神状态能带来完美的表演。", "正式演出前和休息日都需要调整心理状态。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00084", "scene_id": "scene-00084", "source_file": "CSV/csprt/csprt-2-0039/adv_csprt-2-0039_02.csv", "source_kind": "csprt", "chapter": "csprt/csprt-2-0039", "scene": "adv_csprt-2-0039_02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-2-0039/adv_csprt-2-0039_02.csv:1-20"], "line_count": 20, "speakers": ["咲季", "形象训练师"], "topics": ["worldbuilding", "character_arc", "dialogue_style", "plot"], "title": "咲季接受表现力特训", "summary": "为筹备演唱会，形象训练师决定对咲季进行全方位的表现力打磨。咲季虽已很可爱，但训练师指出提升表现力能让她更萌，甚至让粉丝窒息。咲季对此充满期待，决心接受严格训练以变得更可爱，并请求传授秘诀。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": [], "worldbuilding_signals": ["偶像", "训练", "演唱会"], "dialogue_style_signals": ["当然", "嘿嘿"], "key_evidence": [{"source_row": "1", "speaker": "形象训练师", "text_zh": "为了接下来的演唱会必须把小咲季的表现能力打磨到完美呢"}, {"source_row": "14", "speaker": "形象训练师", "text_zh": "小咲季虽然经常专注于舞蹈和歌唱能力"}, {"source_row": "17", "speaker": "咲季", "text_zh": "训练师！我想变得更加可爱！"}, {"source_row": "19", "speaker": "形象训练师", "text_zh": "当然可以！会很严格的，做好觉悟了吗？"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季即将参加接下来的演唱会。", "形象训练师计划对咲季进行化妆、服装及应援等全方位表现力训练。", "咲季表示想变得更可爱，并请求训练师传授表现力训练的秘诀。", "训练师警告咲季接下来的训练会很严格，咲季表示正合心意。"], "relationship_facts": ["咲季是形象训练师的学员。", "形象训练师负责打磨咲季的表现能力。", "咲季与训练师之间保持着积极互动的师徒关系。"], "worldbuilding_facts": ["咲季目前专注于舞蹈和歌唱能力。", "作为偶像，表现力打磨是变得完美的重要环节。", "粉丝对偶像的萌度反应强烈，甚至可能‘被萌到窒息’。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00085", "scene_id": "scene-00085", "source_file": "CSV/csprt/csprt-2-0041/adv_csprt-2-0041_01.csv", "source_kind": "csprt", "chapter": "csprt/csprt-2-0041", "scene": "adv_csprt-2-0041_01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-2-0041/adv_csprt-2-0041_01.csv:1-20"], "line_count": 20, "speakers": ["咲季", "莉波"], "topics": ["team_story", "relationships", "dialogue_style", "character_arc"], "title": "咲季挑战情人节巧克力", "summary": "咲季因佑芽依赖他人增多而不甘，决心在二月情人节制作最棒巧克力展示实力。莉波提议合作，咲季被称赞为值得骄傲的姐姐后欣然应允。两人开始制作，咲季将巧克力做成彩虹色，令莉波惊讶。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "莉波", "姐姐", "朋友"], "worldbuilding_signals": ["学园"], "dialogue_style_signals": ["哼", "呵呵"], "key_evidence": [{"source_row": "2", "speaker": "咲季", "text_zh": "佑芽自从进入这所学园后，依赖我以外的人的情况变多了。"}, {"source_row": "11", "speaker": "咲季", "text_zh": "是的！想试着做些样品送给佑芽。"}, {"source_row": "14", "speaker": "莉波", "text_zh": "说是值得骄傲的姐姐呢。"}, {"source_row": "20", "speaker": "莉波", "text_zh": "巧克力变成彩虹色了——"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["情人节将至，咲季计划制作巧克力样品送给佑芽。", "莉波邀请咲季共同制作巧克力，并提及材料充足。", "咲季被莉波转述为佑芽口中‘值得骄傲的姐姐’。", "咲季将巧克力制作成了彩虹色，令莉波感到意外。"], "relationship_facts": ["咲季是佑芽的姐姐，且佑芽依赖咲季。", "莉波是咲季的学姐（姫崎学姐）。", "咲季与莉波关系友好，莉波会主动邀请咲季合作。"], "worldbuilding_facts": ["故事发生在学园环境中，包含班级和学生会。", "当前时间为二月，正值情人节前夕。", "咲季擅长料理，这一能力被莉波和佑芽知晓。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00086", "scene_id": "scene-00086", "source_file": "CSV/csprt/csprt-2-0041/adv_csprt-2-0041_02.csv", "source_kind": "csprt", "chapter": "csprt/csprt-2-0041", "scene": "adv_csprt-2-0041_02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-2-0041/adv_csprt-2-0041_02.csv:1-20"], "line_count": 20, "speakers": ["咲季", "莉波"], "topics": ["relationships", "team_story", "dialogue_style"], "title": "咲季为佑芽做巧克力", "summary": "咲季向莉波解释为即将独立的佑芽准备巧克力的用心，会根据考试或运动需求调整可可含量与成分。莉波感叹咲季对妹妹的爱，并提及佑芽在学生会常聊咲季，两人关系亲密。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "莉波", "妹妹", "姐姐"], "worldbuilding_signals": [], "dialogue_style_signals": ["当然", "呵呵", "嘿嘿", "啦"], "key_evidence": [{"source_row": "2", "speaker": "咲季", "text_zh": "是的。所以我想为佑芽准备最棒的巧克力。"}, {"source_row": "6", "speaker": "咲季", "text_zh": "考试期间为了激活大脑，会做可可含量高的。"}, {"source_row": "13", "speaker": "莉波", "text_zh": "什么这个和姐姐一起做过，那个是姐姐擅长的之类的。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季为佑芽准备巧克力以庆祝其独立。", "巧克力配方会根据佑芽的身体状况调整。", "佑芽在学生会经常谈论咲季。"], "relationship_facts": ["咲季是佑芽的姐姐。", "咲季与莉波是同学。", "佑芽非常崇拜咲季。"], "worldbuilding_facts": ["考试期间需要高可可含量巧克力提神。", "巧克力制作需考虑减重需求。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00087", "scene_id": "scene-00087", "source_file": "CSV/csprt/csprt-2-0043/adv_csprt-2-0043_02.csv", "source_kind": "csprt", "chapter": "csprt/csprt-2-0043", "scene": "adv_csprt-2-0043_02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-2-0043/adv_csprt-2-0043_02.csv:1-20"], "line_count": 20, "speakers": ["佑芽", "莉莉娅"], "topics": ["relationships", "dialogue_style", "character_arc"], "title": "佑芽与莉莉娅滑雪", "summary": "佑芽邀请莉莉娅滑雪并发起比赛。莉莉娅自信满满，但佑芽展示高超技巧后坦言输给姐姐咲季。莉莉娅得知咲季滑雪更快，感到受挫，随后佑芽不慎滑倒面临危险。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "莉莉娅", "姐姐"], "worldbuilding_signals": [], "dialogue_style_signals": ["当然", "啦"], "key_evidence": [{"source_row": "13", "speaker": "佑芽", "text_zh": "嘛，因为经常和姐姐比赛嘛！"}, {"source_row": "14", "speaker": "佑芽", "text_zh": "但是，滑雪最后还是没能赢过姐姐！"}, {"source_row": "15", "speaker": "莉莉娅", "text_zh": "咲、咲季同学滑得更快呢……。"}, {"source_row": "20", "speaker": "佑芽", "text_zh": "这样下去会变成雪人的啦！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["佑芽和莉莉娅决定进行滑雪比赛。", "佑芽表示滑雪技术经常输给姐姐咲季。", "莉莉娅得知咲季滑雪速度比她更快。", "佑芽在对话中不慎滑倒面临危险。"], "relationship_facts": ["佑芽是咲季的妹妹。", "佑芽和莉莉娅是同学。", "咲季是佑芽的姐姐。"], "worldbuilding_facts": ["故事背景包含滑雪运动。", "咲季是雪国出生或具有相关背景。", "冬季运动是角色间比较的领域。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00088", "scene_id": "scene-00088", "source_file": "CSV/csprt/csprt-2-0047/adv_csprt-2-0047_01.csv", "source_kind": "csprt", "chapter": "csprt/csprt-2-0047", "scene": "adv_csprt-2-0047_01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-2-0047/adv_csprt-2-0047_01.csv:1-20"], "line_count": 20, "speakers": ["咲季", "莉莉娅"], "topics": ["character_arc", "worldbuilding", "dialogue_style"], "title": "咲季与莉莉娅跳绳对决", "summary": "咲季邀请莉莉娅进行跳绳比赛，旨在通过双摇等动作高效锻炼全身。比赛中莉莉娅虽因体力下降感到沉重，但在咲季鼓励下坚持。咲季展示高超技巧，两人约定再次进行双摇比赛，展现了积极的训练氛围。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["莉莉娅"], "worldbuilding_signals": ["训练"], "dialogue_style_signals": ["呵呵"], "key_evidence": [{"source_row": "3", "speaker": "咲季", "text_zh": "今天的比赛项目是这个！"}, {"source_row": "5", "speaker": "咲季", "text_zh": "跳绳啊，可是能高效锻炼全身的绝佳训练方式呢！"}, {"source_row": "10", "speaker": "莉莉娅", "text_zh": "哇，双摇……！三、三摇！好厉害……！"}, {"source_row": "20", "speaker": "咲季", "text_zh": "尽管放马过来多少次都行！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季邀请莉莉娅进行跳绳比赛。", "比赛项目包含双摇跳绳。", "莉莉娅在体力下降后仍请求再比一次。", "咲季认为跳绳是全身肌肉发力的绝佳训练。"], "relationship_facts": ["咲季与莉莉娅是竞争对手兼朋友。", "咲季在指导并鼓励莉莉娅。", "两人约定进行双摇比赛。"], "worldbuilding_facts": ["跳绳被描述为能高效锻炼全身的训练方式。", "双摇跳绳是比赛中的高难度动作。", "身体沉重是肌肉发力的正常反应。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00089", "scene_id": "scene-00089", "source_file": "CSV/csprt/csprt-2-0047/adv_csprt-2-0047_02.csv", "source_kind": "csprt", "chapter": "csprt/csprt-2-0047", "scene": "adv_csprt-2-0047_02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-2-0047/adv_csprt-2-0047_02.csv:1-20"], "line_count": 20, "speakers": ["佑芽", "咲季", "莉莉娅"], "topics": ["relationships", "dialogue_style", "team_story", "character_arc"], "title": "咲季指导莉莉娅跳舞", "summary": "咲季指导莉莉娅练习舞蹈，强调聆听音乐与节奏的重要性。莉莉娅在咲季的鼓励下成功完成训练，两人关系融洽。随后佑芽出现，咲季表明莉莉娅是自己的朋友，而佑芽则是自己的妹妹，拒绝了佑芽想与莉莉娅对决的请求。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "莉莉娅", "妹妹", "姐姐", "朋友"], "worldbuilding_signals": ["训练"], "dialogue_style_signals": ["当然", "嘿嘿", "啦"], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "莉莉娅！今天要用舞蹈一决胜负哦！"}, {"source_row": "16", "speaker": "咲季", "text_zh": "我和莉莉娅是朋友嘛！"}, {"source_row": "18", "speaker": "咲季", "text_zh": "你可是我的妹妹呀。"}, {"source_row": "19", "speaker": "佑芽", "text_zh": "莉莉娅同学，和我一决胜负！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季指导莉莉娅练习舞蹈并纠正其节奏问题。", "莉莉娅在咲季的鼓励下成功完成了舞蹈训练。", "咲季明确表示莉莉娅是自己的朋友。", "咲季指出佑芽是自己的妹妹，而非朋友。"], "relationship_facts": ["咲季与莉莉娅是朋友。", "咲季与佑芽是姐妹关系。", "佑芽想与莉莉娅成为朋友但被咲季拒绝。"], "worldbuilding_facts": ["角色之间存在舞蹈一决胜负的互动模式。", "咲季作为姐姐对妹妹佑芽有明确的身份认知。", "舞蹈训练是角色间互动的重要场景。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00090", "scene_id": "scene-00090", "source_file": "CSV/csprt/csprt-2-0050/adv_csprt-2-0050_01.csv", "source_kind": "csprt", "chapter": "csprt/csprt-2-0050", "scene": "adv_csprt-2-0050_01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-2-0050/adv_csprt-2-0050_01.csv:1-20"], "line_count": 20, "speakers": ["手毬", "琴音"], "topics": ["team_story", "relationships", "dialogue_style", "character_arc"], "title": "咲季被提及的自律日常", "summary": "手毬与琴音讨论购物量及饮食自律。琴音提及咲季能随时帮忙处理饮食数据，手毬对此表示认可。两人最终决定由琴音吃掉手毬无法下口的炸鸡块，展现了手毬对咲季能力的信任及日常互动。", "saki_role": "被提及对象：咲季未必直接发言，但场景信息与她的关系或评价有关。", "relationship_signals": ["琴音", "手毬", "清夏"], "worldbuilding_signals": [], "dialogue_style_signals": ["当然", "啦"], "key_evidence": [{"source_row": "11", "speaker": "琴音", "text_zh": "这种事拜托咲季的话，她随时都能帮你做吧～"}, {"source_row": "12", "speaker": "手毬", "text_zh": "……那样……也行吗。"}, {"source_row": "19", "speaker": "琴音", "text_zh": "手毬同学这种自律的地方，我觉得很棒。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["手毬使用清夏推荐的APP记录步数和卡路里。", "琴音开玩笑说咲季随时能帮手毬处理饮食数据。", "手毬因炸鸡块热量超标请求琴音帮忙吃掉。", "琴音称赞手毬的自律精神很棒。"], "relationship_facts": ["手毬与琴音是关系亲密的同学。", "咲季是手毬信任并愿意求助的对象。", "琴音与咲季之间存在某种互动或委托关系。"], "worldbuilding_facts": ["存在一款名为清夏推荐的饮食运动APP。", "APP会根据饮食和运动量给出评价及分数。", "炸鸡块被手毬视为高热量食物。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00091", "scene_id": "scene-00091", "source_file": "CSV/csprt/csprt-2-0050/adv_csprt-2-0050_02.csv", "source_kind": "csprt", "chapter": "csprt/csprt-2-0050", "scene": "adv_csprt-2-0050_02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-2-0050/adv_csprt-2-0050_02.csv:1-20"], "line_count": 20, "speakers": ["众人", "手毬", "琴音"], "topics": ["team_story", "relationships", "character_arc", "dialogue_style"], "title": "咲季缺席的购物之旅", "summary": "琴音与手毬因咲季被训练师叫走而独自承担宿舍用品采购任务。两人先比价购买必需品，随后又兴致勃勃地挑选衣物。咲季虽未现身，但作为被提及的缺席者，其原本的任务背景构成了本次购物的起因。", "saki_role": "被提及对象：咲季未必直接发言，但场景信息与她的关系或评价有关。", "relationship_signals": ["琴音", "手毬", "麻央"], "worldbuilding_signals": ["训练"], "dialogue_style_signals": ["啦"], "key_evidence": [{"source_row": "3", "speaker": "琴音", "text_zh": "结果咲季突然被训练师叫去帮忙，来不了了……"}, {"source_row": "5", "speaker": "琴音", "text_zh": "洗衣液、柔顺剂……打扫房间用的拖把，还有在房间里吃的零食。"}, {"source_row": "14", "speaker": "琴音", "text_zh": "手毬手上拿的这条就很好啊。黑色真的很适合你。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["咲季因被训练师叫去帮忙而无法参与购物。", "琴音与手毬决定先购买洗衣液、拖把等必需品。", "两人随后又去挑选适合手毬的黑色裙子。"], "relationship_facts": ["琴音与手毬是关系亲密的同伴。", "咲季是琴音的学姐（或同辈，文中称麻央学姐，咲季接任务）。", "训练师是咲季的上司或指导者。"], "worldbuilding_facts": ["宿舍用品（如洗衣液、拖把）快用完了。", "角色们有闲暇时间进行购物和比价。", "宿舍内允许存放零食。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00092", "scene_id": "scene-00092", "source_file": "CSV/csprt/csprt-2-0063/adv_csprt-2-0063_01.csv", "source_kind": "csprt", "chapter": "csprt/csprt-2-0063", "scene": "adv_csprt-2-0063_01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-2-0063/adv_csprt-2-0063_01.csv:1-20"], "line_count": 20, "speakers": ["佑芽", "手毬"], "topics": ["relationships", "team_story", "character_arc", "dialogue_style"], "title": "手毬压腿与涌泉穴", "summary": "佑芽邀请手毬协助柔韧训练，手毬虽担心但同意并主动为佑芽压腿。佑芽发现手毬体寒，便用按摩涌泉穴的方式为其取暖，手毬感到脚底变暖和，对佑芽的按摩手法表示惊讶。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "手毬", "姐姐"], "worldbuilding_signals": ["训练"], "dialogue_style_signals": ["啦"], "key_evidence": [{"source_row": "9", "speaker": "手毬", "text_zh": "虽然咲季也很柔软，但佑芽也很厉害呢"}, {"source_row": "14", "speaker": "佑芽", "text_zh": "是脚底的涌泉穴——这附近！"}, {"source_row": "20", "speaker": "手毬", "text_zh": "脚底开始暖和起来了！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["手毬主动提出帮佑芽压腿以缓解其体寒。", "佑芽通过按摩手毬脚底涌泉穴使其感到温暖。", "手毬惊讶于涌泉穴按摩的实际效果。"], "relationship_facts": ["佑芽与手毬是主训伙伴。", "手毬与咲季同为柔道部成员。", "佑芽有给姐姐按摩的经验。"], "worldbuilding_facts": ["柔道训练包含压腿等柔韧训练。", "涌泉穴位于脚底，按摩可缓解体寒。", "咲季的身体素质（柔软度）与佑芽相当。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00093", "scene_id": "scene-00093", "source_file": "CSV/csprt/csprt-2-0068/adv_csprt-2-0068_01.csv", "source_kind": "csprt", "chapter": "csprt/csprt-2-0068", "scene": "adv_csprt-2-0068_01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-2-0068/adv_csprt-2-0068_01.csv:1-20"], "line_count": 20, "speakers": ["佑芽", "千奈", "咲季", "广"], "topics": ["team_story", "relationships", "dialogue_style"], "title": "好友间的打情骂俏挑战", "summary": "咲季与佑芽因进食互动而争吵，广与千奈旁观并羡慕。广提议两人模仿咲季与佑芽进行假装吵架以增进友谊，千奈欣然接受，决定挑战挚友间的打情骂俏。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "广", "姐姐", "朋友"], "worldbuilding_signals": [], "dialogue_style_signals": ["呵呵"], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "呜～好吃～～～！给我适可而止～～啊！"}, {"source_row": "4", "speaker": "广", "text_zh": "啊，佑芽和咲季又吵架了。"}, {"source_row": "10", "speaker": "广", "text_zh": "我们两个来吵架试试吧。"}, {"source_row": "17", "speaker": "广", "text_zh": "虽然我和千奈，不是姐妹。是朋友。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季与佑芽正在因食物互动而争吵。", "广提议千奈与自己进行假装吵架。", "广与千奈并非姐妹，而是朋友。", "两人决定通过假装吵架来增进友谊。"], "relationship_facts": ["咲季与佑芽是姐妹关系。", "广与千奈是朋友关系。", "广与千奈希望关系变得更加要好。"], "worldbuilding_facts": ["吵架有时能增进感情。", "假装吵架是一种增进友谊的方式。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00094", "scene_id": "scene-00094", "source_file": "CSV/csprt/csprt-2-0072/adv_csprt-2-0072_01.csv", "source_kind": "csprt", "chapter": "csprt/csprt-2-0072", "scene": "adv_csprt-2-0072_01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-2-0072/adv_csprt-2-0072_01.csv:1-20"], "line_count": 20, "speakers": ["咲季", "麻央"], "topics": ["team_story", "character_arc", "dialogue_style", "plot"], "title": "咲季探讨落败演技", "summary": "咲季与麻央进行台词与武打排练。麻央建议咲季学习专门演被砍角色的技巧，以衬托主角。咲季坦言自己难以接受落败，但麻央解释只要观众开心，衬托主角即是胜利，咲季最终认同。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["麻央", "妹妹"], "worldbuilding_signals": [], "dialogue_style_signals": ["呵呵", "嘿嘿"], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "妹妹的仇————！"}, {"source_row": "12", "speaker": "麻央", "text_zh": "对，就是专门演被砍角色的专业人士。"}, {"source_row": "16", "speaker": "咲季", "text_zh": "我啊，就算是在演戏，如果输了也会觉得“好不甘心～～～”呢。"}, {"source_row": "19", "speaker": "麻央", "text_zh": "那对演员来说，就是一大胜利哦。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季正在与麻央进行台词和武打动作的排练。", "麻央建议咲季学习专门饰演被斩杀角色的技巧。", "咲季表示自己在演戏中很难接受输掉或落败的设定。", "麻央认为衬托主角让观众开心对演员而言就是胜利。"], "relationship_facts": ["咲季与麻央是共同进行表演的同伴。", "麻央是咲季的指导者或前辈。", "咲季视麻央为值得请教演技的对象。"], "worldbuilding_facts": ["存在专门饰演被斩杀角色的专业人士。", "在表演中，配角落败是为了衬托主角。", "演员可以通过技巧让落败场面看起来合理且精彩。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00095", "scene_id": "scene-00095", "source_file": "CSV/csprt/csprt-2-0072/adv_csprt-2-0072_02.csv", "source_kind": "csprt", "chapter": "csprt/csprt-2-0072", "scene": "adv_csprt-2-0072_02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-2-0072/adv_csprt-2-0072_02.csv:1-20"], "line_count": 20, "speakers": ["咲季", "麻央"], "topics": ["team_story", "worldbuilding", "dialogue_style"], "title": "咲季的舞台华彩", "summary": "咲季拒绝退却，展现压倒性舞台魅力。麻央肯定其演员才能，建议她不必刻意贴近角色，而是保持自我本色演出，认为这种特质适合她成为职业偶像或演员。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["麻央"], "worldbuilding_signals": ["偶像", "工作"], "dialogue_style_signals": ["当然", "嘿嘿"], "key_evidence": [{"source_row": "3", "speaker": "咲季", "text_zh": "不，我不会退却。我不能抛下子民们。"}, {"source_row": "18", "speaker": "麻央", "text_zh": "仅仅站在舞台上，就拥有压倒性的华彩。"}, {"source_row": "15", "speaker": "麻央", "text_zh": "不如让角色来贴近咲季，或许更能展现魅力。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季在舞台上展现出压倒性的华彩与存在感。", "麻央认为咲季适合让角色贴近自己而非刻意模仿。", "咲季对演戏感到开心，并希望向麻央学习。"], "relationship_facts": ["麻央是咲季的前辈，指导其演艺方向。", "咲季视麻央为值得尊敬的导师。", "两人关系融洽，麻央对咲季充满欣赏。"], "worldbuilding_facts": ["咲季是职业偶像，未来可能涉及演戏工作。", "舞台表演中，个人特质比刻意模仿角色更重要。", "咲季拥有自带华彩、适合舞台的特殊才能。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00096", "scene_id": "scene-00096", "source_file": "CSV/csprt/csprt-2-0074/adv_csprt-2-0074_02.csv", "source_kind": "csprt", "chapter": "csprt/csprt-2-0074", "scene": "adv_csprt-2-0074_02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-2-0074/adv_csprt-2-0074_02.csv:1-20"], "line_count": 20, "speakers": ["千奈", "美铃", "香名江"], "topics": ["dialogue_style"], "title": "美铃赠送柠檬蛋糕", "summary": "美铃向千奈和香名江赠送了由咲季老家柠檬制作的蛋糕。千奈品尝后大加赞赏，认为酸甜适中且香气清新。美铃分享了制作过程，并邀请香名江品尝。众人对这份伴手礼表示满意，气氛融洽。", "saki_role": "被提及对象：咲季未必直接发言，但场景信息与她的关系或评价有关。", "relationship_signals": ["美铃"], "worldbuilding_signals": [], "dialogue_style_signals": ["呵呵"], "key_evidence": [{"source_row": "5", "speaker": "美铃", "text_zh": "咲季同学分给了我一些她老家产的柠檬。"}, {"source_row": "12", "speaker": "千奈", "text_zh": "清新的柠檬香气和蜂蜜的甜味真是太美味了～♡"}, {"source_row": "17", "speaker": "香名江", "text_zh": "非常好吃。完全想不到是酸味很强的柠檬……！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["美铃带来了咲季老家产的柠檬制作的蛋糕。", "千奈和香名江都品尝了蛋糕并称赞美味。", "美铃表示下次会将食谱分享给香名江。"], "relationship_facts": ["美铃与千奈、香名江关系友好，互相赠送礼物。", "咲季与美铃关系亲密，咲季曾将特产分享给美铃。", "千奈与香名江是共同接受礼物的同伴。"], "worldbuilding_facts": ["咲季的老家产柠檬，酸味较重。", "美铃擅长处理食材，通过揉搓和蜂蜜浸泡改良柠檬口感。", "秦谷同学（美铃）与花海农场有合作或关联。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00097", "scene_id": "scene-00097", "source_file": "CSV/csprt/csprt-3-0000/adv_csprt-3-0000_01.csv", "source_kind": "csprt", "chapter": "csprt/csprt-3-0000", "scene": "adv_csprt-3-0000_01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-3-0000/adv_csprt-3-0000_01.csv:1-20"], "line_count": 20, "speakers": ["咲季", "手毬", "琴音"], "topics": ["relationships", "team_story", "dialogue_style"], "title": "咲季与琴音的便当时光", "summary": "咲季为琴音亲手制作便当，琴音大加赞赏并询问是否可每日享用。咲季欣然答应，强调两人是无需金钱往来的朋友，并自豪地展示特制菜单。手毬在一旁冷嘲热讽，认为咲季是在做作表演，试图向妹妹证明自己有朋友，但咲季对此感到开心并极力反驳。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["琴音", "手毬", "妹妹", "朋友"], "worldbuilding_signals": [], "dialogue_style_signals": ["当然", "呵呵", "啦"], "key_evidence": [{"source_row": "10", "speaker": "咲季", "text_zh": "以后每天都可以给你做哦。"}, {"source_row": "13", "speaker": "咲季", "text_zh": "当然可以！我们可是——『朋友』啊！"}, {"source_row": "15", "speaker": "手毬", "text_zh": "这是什么……做作的表演。"}, {"source_row": "16", "speaker": "琴音", "text_zh": "该不会是想向妹妹证明自己也有朋友吧？"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季为琴音制作了便当。", "咲季表示愿意每天为琴音制作特制便当。", "咲季强调朋友之间不需要金钱交易。", "手毬认为咲季的行为是向琴音证明自己有朋友。"], "relationship_facts": ["咲季与琴音是朋友。", "手毬是琴音的妹妹。", "咲季与手毬关系紧张，手毬对咲季持怀疑态度。"], "worldbuilding_facts": ["咲季擅长烹饪，能制作营养丰富的料理。", "咲季将琴音视为重要的朋友。", "手毬对咲季与琴音的友谊持不信任态度。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00098", "scene_id": "scene-00098", "source_file": "CSV/csprt/csprt-3-0000/adv_csprt-3-0000_02.csv", "source_kind": "csprt", "chapter": "csprt/csprt-3-0000", "scene": "adv_csprt-3-0000_02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-3-0000/adv_csprt-3-0000_02.csv:1-20"], "line_count": 20, "speakers": ["咲季", "手毬", "琴音"], "topics": ["relationships", "team_story", "dialogue_style"], "title": "咲季争取朋友身份", "summary": "咲季邀请手毬和琴音去屋顶吃午饭被拒，便提议为她们做便当。手毬直言咲季朋友太少，琴音补充只是同班同学。咲季对此感到震惊并极力反驳，强调自己认定她们是朋友，最终手毬和琴音态度软化，咲季对此感到开心。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["琴音", "手毬", "妹妹", "朋友"], "worldbuilding_signals": [], "dialogue_style_signals": ["才不是"], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "手毬！琴音！午饭一起到屋顶上吃吧！"}, {"source_row": "10", "speaker": "手毬", "text_zh": "这是事实吧。"}, {"source_row": "13", "speaker": "琴音", "text_zh": "只是同班同学而已。"}, {"source_row": "15", "speaker": "咲季", "text_zh": "不管别人怎么说，手毬和琴音就是我的朋友！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季邀请手毬和琴音去屋顶吃午饭被拒绝。", "手毬指出咲季的朋友数量很少。", "琴音认为咲季与她们仅是同班同学关系。", "咲季坚持认定手毬和琴音是自己的朋友。"], "relationship_facts": ["咲季与手毬、琴音是同学关系。", "咲季单方面认定手毬和琴音为朋友。", "手毬和琴音对咲季的朋友定义持保留态度。"], "worldbuilding_facts": ["学校设有食堂供学生就餐。", "学生可以带便当或去食堂吃饭。", "学校建筑包含可供使用的屋顶区域。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00099", "scene_id": "scene-00099", "source_file": "CSV/csprt/csprt-3-0000/adv_csprt-3-0000_03.csv", "source_kind": "csprt", "chapter": "csprt/csprt-3-0000", "scene": "adv_csprt-3-0000_03", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-3-0000/adv_csprt-3-0000_03.csv:1-20"], "line_count": 20, "speakers": ["众人", "咲季", "手毬", "清夏", "琴音"], "topics": ["team_story", "relationships", "dialogue_style"], "title": "咲季拒绝组合活动", "summary": "众人闲聊组合活动，咲季明确表示只考虑个人活动，拒绝与妹妹组队以免无法一决胜负。手毬也坚决拒绝重组组合。清夏提议三人组队被众人强烈反对，咲季感叹手毬拒绝意志更强烈，气氛尴尬。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["琴音", "手毬", "清夏", "妹妹"], "worldbuilding_signals": [], "dialogue_style_signals": ["哼", "啦"], "key_evidence": [{"source_row": "4", "speaker": "咲季", "text_zh": "什么都不打算。我只考虑个人活动。"}, {"source_row": "6", "speaker": "咲季", "text_zh": "要是和她组队的话，不就没办法和她一决胜负了吗？"}, {"source_row": "9", "speaker": "手毬", "text_zh": "不可能。绝对不可能。"}, {"source_row": "20", "speaker": "众人", "text_zh": "绝对不要！！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季明确表示只考虑个人活动，不参与组合。", "咲季拒绝与妹妹组队，理由是希望保持一决胜负的机会。", "手毬坚决拒绝重组组合，咲季认为其拒绝意志比手毬更强烈。", "清夏提议三人组队，遭到在场众人的强烈反对。"], "relationship_facts": ["咲季与妹妹是潜在的竞争对手，咲季希望保持这种竞争关系。", "手毬与咲季曾是组合成员，但手毬拒绝重组。", "清夏、手毬、咲季三人关系良好，但清夏的组队提议被众人（包括咲季和手毬）拒绝。"], "worldbuilding_facts": ["咲季和妹妹之间存在某种竞争关系，她们可能曾是或将是组合成员。", "手毬曾经组过组合，但明确表示不再重组。", "十王会长曾邀请咲季参与某种活动（可能是组合活动）。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00100", "scene_id": "scene-00100", "source_file": "CSV/csprt/csprt-3-0002/adv_csprt-3-0002_01.csv", "source_kind": "csprt", "chapter": "csprt/csprt-3-0002", "scene": "adv_csprt-3-0002_01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-3-0002/adv_csprt-3-0002_01.csv:1-20"], "line_count": 20, "speakers": ["咲季", "手毬", "琴音"], "topics": ["relationships", "team_story", "dialogue_style", "character_arc"], "title": "咲季便当里的蛇", "summary": "手毬因咲季做的减肥便当混入蛇肉而暴怒，咲季解释食材安全且营养。手毬坚持不可原谅，咲季建议忽略味道只看营养。琴音在一旁调侃，庆幸自己未加入该组合，众人就此事展开讨论。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["琴音", "手毬"], "worldbuilding_signals": [], "dialogue_style_signals": ["当然", "哼", "啦"], "key_evidence": [{"source_row": "7", "speaker": "手毬", "text_zh": "最近我让咲季帮我做减肥专用的便当。"}, {"source_row": "9", "speaker": "手毬", "text_zh": "发现便当食材里混进了我最讨厌的东西。"}, {"source_row": "11", "speaker": "手毬", "text_zh": "蛇。"}, {"source_row": "13", "speaker": "咲季", "text_zh": "没错，味道和营养都是一流的。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季为手毬制作了减肥专用便当。", "便当食材中混入了手毬最讨厌的蛇。", "咲季确认蛇肉安全可食用且营养一流。", "手毬因不知情仍食用了含蛇的便当。"], "relationship_facts": ["咲季与手毬是便当制作与食用的关系。", "手毬与琴音是互相吐槽的同伴关系。", "咲季与琴音是互相调侃的同伴关系。"], "worldbuilding_facts": ["存在减肥专用便当这一食物概念。", "蛇肉被设定为味道和营养一流。", "蛇肉被设定为安全可食用。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00101", "scene_id": "scene-00101", "source_file": "CSV/csprt/csprt-3-0002/adv_csprt-3-0002_02.csv", "source_kind": "csprt", "chapter": "csprt/csprt-3-0002", "scene": "adv_csprt-3-0002_02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-3-0002/adv_csprt-3-0002_02.csv:1-20"], "line_count": 20, "speakers": ["咲季", "手毬", "琴音"], "topics": ["team_story", "relationships", "dialogue_style"], "title": "咲季与琴音的争执", "summary": "咲季与琴音因手毬的教育方针发生争执，咲季认为应保持本色，琴音则主张改掉口是心非的毛病。手毬试图调解却遭琴音调侃，咲季虽被手毬指责摆出妈妈桑架势，但随后认可了琴音的部分观点，三人关系在调侃与争论中展现。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["琴音", "手毬"], "worldbuilding_signals": [], "dialogue_style_signals": ["才不是", "真是的", "啦"], "key_evidence": [{"source_row": "16", "speaker": "咲季", "text_zh": "我们是在争论关于手毬的教育方针啦。"}, {"source_row": "18", "speaker": "咲季", "text_zh": "我认为保持本色才是手毬的风格。"}, {"source_row": "20", "speaker": "手毬", "text_zh": "别摆出妈妈桑的架势啦！？"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季与琴音因手毬的教育方针发生争执。", "咲季认为手毬应保持本色，琴音主张其改掉口是心非的毛病。", "手毬试图调解咲季与琴音的争吵，但被琴音调侃。", "咲季最终认可了琴音意见中的几分道理。"], "relationship_facts": ["咲季与琴音是经常争论的同伴。", "手毬是咲季和琴音的调解者。", "咲季与手毬之间存在类似母女般的互动模式。"], "worldbuilding_facts": ["咲季、琴音和手毬属于同一个教室。", "咲季被手毬称为摆出妈妈桑架势的人。", "手毬有口是心非的性格特点。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00102", "scene_id": "scene-00102", "source_file": "CSV/csprt/csprt-3-0002/adv_csprt-3-0002_03.csv", "source_kind": "csprt", "chapter": "csprt/csprt-3-0002", "scene": "adv_csprt-3-0002_03", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-3-0002/adv_csprt-3-0002_03.csv:1-20"], "line_count": 20, "speakers": ["咲季", "手毬", "琴音"], "topics": ["relationships", "team_story", "dialogue_style", "worldbuilding"], "title": "手毬探望受伤琴音", "summary": "琴音因训练受伤被手毬劝退打工，手毬虽嘴硬实则特意前往打工处探望。咲季察觉琴音与手毬的争执，得知手毬特意来看望后感到惊讶。手毬否认关心，琴音则认定两人互相关爱，气氛温馨。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["琴音", "手毬"], "worldbuilding_signals": ["训练", "工作"], "dialogue_style_signals": ["当然", "才不是", "啦"], "key_evidence": [{"source_row": "17", "speaker": "琴音", "text_zh": "对力争上游以外都没兴趣的手毬哦"}, {"source_row": "18", "speaker": "琴音", "text_zh": "原来是担心我勉强自己工作呢"}, {"source_row": "19", "speaker": "手毬", "text_zh": "才不是！只是刚好路过那边而已"}, {"source_row": "20", "speaker": "琴音", "text_zh": "我果然是被爱着的～♡"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["琴音因训练受伤，手毬劝其放弃打工。", "手毬特意前往琴音打工处探望。", "咲季发现手毬与琴音再次争吵。", "琴音认为手毬是担心她勉强自己。"], "relationship_facts": ["手毬与琴音是互相关心的同伴。", "咲季是手毬与琴音的旁观者。", "手毬对努力的人持严格要求态度。"], "worldbuilding_facts": ["角色们有各自的打工地点。", "训练受伤是常见事件。", "角色间存在互相隐瞒关心的互动模式。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00103", "scene_id": "scene-00103", "source_file": "CSV/csprt/csprt-3-0003/adv_csprt-3-0003_01.csv", "source_kind": "csprt", "chapter": "csprt/csprt-3-0003", "scene": "adv_csprt-3-0003_01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-3-0003/adv_csprt-3-0003_01.csv:1-20"], "line_count": 20, "speakers": ["佑芽", "咲季"], "topics": ["relationships", "dialogue_style", "worldbuilding", "plot"], "title": "咲季要求佑芽学化妆", "summary": "佑芽清晨造访咲季房间，误以为姐姐会陪她玩耍，结果被咲季直接要求开始学习化妆。咲季指出佑芽曾接受过特训，要求她展示进步，并警告若技术蹩脚将面临地狱式再特训，展现了姐姐严厉又宠溺的态度。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "妹妹", "姐姐"], "worldbuilding_signals": ["偶像", "演唱会"], "dialogue_style_signals": ["当然", "真是的", "呵呵", "啦"], "key_evidence": [{"source_row": "2", "speaker": "咲季", "text_zh": "欢迎啊，佑芽。那么事不宜迟——"}, {"source_row": "12", "speaker": "咲季", "text_zh": "是化妆啦！必须学的对吧？对偶像来说。"}, {"source_row": "16", "speaker": "佑芽", "text_zh": "然后……不是给我做过化妆特训嘛。"}, {"source_row": "20", "speaker": "咲季", "text_zh": "当然要做好地狱式再特训的觉悟哦♪"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["佑芽误以为咲季会陪她玩耍，实则咲季要求她学习化妆。", "咲季指出佑芽曾在咲季房间接受过化妆特训。", "咲季警告佑芽若化妆技术蹩脚，将面临地狱式再特训。"], "relationship_facts": ["咲季是佑芽的姐姐。", "咲季是佑芽的偶像前辈/指导者。", "佑芽是咲季的妹妹/后辈。"], "worldbuilding_facts": ["咲季是偶像，需要化妆技能。", "佑芽决定成为偶像并入学。", "咲季对佑芽的偶像训练要求严格。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00104", "scene_id": "scene-00104", "source_file": "CSV/csprt/csprt-3-0003/adv_csprt-3-0003_02.csv", "source_kind": "csprt", "chapter": "csprt/csprt-3-0003", "scene": "adv_csprt-3-0003_02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-3-0003/adv_csprt-3-0003_02.csv:1-20"], "line_count": 20, "speakers": ["佑芽", "咲季"], "topics": ["relationships", "dialogue_style", "worldbuilding", "character_arc"], "title": "咲季首次外出逛街", "summary": "咲季与佑芽首次一同走出学园逛街。咲季表示入学以来首次出门，目的是了解街区设施，且对训练设备满意。面对佑芽催促，咲季命令其挑选女装，展现傲娇一面。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "姐姐", "朋友"], "worldbuilding_signals": ["学园", "训练"], "dialogue_style_signals": ["哼", "嘿嘿", "啦"], "key_evidence": [{"source_row": "2", "speaker": "咲季", "text_zh": "入学以来这还是第一次吧？"}, {"source_row": "11", "speaker": "咲季", "text_zh": "这可是我选择入学的理由之一哦。"}, {"source_row": "20", "speaker": "咲季", "text_zh": "给我选出适合姐姐的可爱衣服来！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季入学以来第一次走出学园。", "咲季认为学园训练设备应有尽有。", "咲季命令佑芽挑选适合她的可爱衣服。"], "relationship_facts": ["佑芽是咲季的妹妹。", "佑芽担任咲季的逛街向导。", "咲季对佑芽有命令口吻。"], "worldbuilding_facts": ["咲季入学理由之一是学园训练设备齐全。", "咲季平时很少走出学园。", "学园内拥有与家里相同的训练器材。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00105", "scene_id": "scene-00105", "source_file": "CSV/csprt/csprt-3-0003/adv_csprt-3-0003_03.csv", "source_kind": "csprt", "chapter": "csprt/csprt-3-0003", "scene": "adv_csprt-3-0003_03", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-3-0003/adv_csprt-3-0003_03.csv:1-20"], "line_count": 20, "speakers": ["佑芽", "千奈", "咲季"], "topics": ["relationships", "dialogue_style", "character_arc", "team_story"], "title": "咲季躲避球大胜", "summary": "佑芽在躲避球赛中惨败，咲季得意地宣称自己球技无敌。千奈称赞咲季厉害，并视其为从杀人射球威胁中解救自己的救命恩人。咲季享受夸奖，并邀请佑芽下次再战，对“姐姐”的称呼感到开心。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "姐姐", "朋友"], "worldbuilding_signals": [], "dialogue_style_signals": ["呵呵", "嘿嘿"], "key_evidence": [{"source_row": "2", "speaker": "咲季", "text_zh": "躲避球比赛也是我的胜利哦！"}, {"source_row": "13", "speaker": "千奈", "text_zh": "是将我从杀人射球的威胁中解救出来的英雄啊！"}, {"source_row": "17", "speaker": "咲季", "text_zh": "这称呼真好听♪"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季在躲避球比赛中击败了佑芽。", "千奈称咲季为从杀人射球威胁中解救她的英雄。", "咲季对千奈称呼她为“姐姐”感到开心。"], "relationship_facts": ["咲季是千奈的姐姐。", "咲季是佑芽的对手。", "千奈视咲季为救命恩人。"], "worldbuilding_facts": ["咲季擅长躲避球等球类运动。", "存在“杀人射球”的威胁情境。", "咲季喜欢被夸奖。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00106", "scene_id": "scene-00106", "source_file": "CSV/csprt/csprt-3-0004/adv_csprt-3-0004_01.csv", "source_kind": "csprt", "chapter": "csprt/csprt-3-0004", "scene": "adv_csprt-3-0004_01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-3-0004/adv_csprt-3-0004_01.csv:1-20"], "line_count": 20, "speakers": ["佑芽", "咲季"], "topics": ["relationships", "dialogue_style", "worldbuilding", "team_story"], "title": "操场上的梦境对决", "summary": "休息日的操场上，咲季唤醒呆滞的佑芽，提及两人八岁时在此赛跑惨败的往事。咲季以姐姐身份调侃佑芽记忆力差，并提议在梦境中无限次陪佑芽进行对决，佑芽欣然接受，决定先在梦中雪耻再在现实中获胜。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "姐姐"], "worldbuilding_signals": ["学园", "偶像"], "dialogue_style_signals": ["当然", "呵呵", "啦"], "key_evidence": [{"source_row": "1", "speaker": "佑芽", "text_zh": "今天～是偶像的休息日！"}, {"source_row": "7", "speaker": "咲季", "text_zh": "知道这里是哪里吗？当年8岁的我们直接对决过的——"}, {"source_row": "11", "speaker": "咲季", "text_zh": "如果忘记了就给我想起来——那天赛跑的事！"}, {"source_row": "17", "speaker": "咲季", "text_zh": "梦境里的话，陪你多少次都行。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["今天是偶像的休息日，两人穿着偶像服装在操场。", "咲季指出这里是当年两人八岁时直接对决过的运动会操场。", "咲季提议在梦境中陪佑芽进行无数次对决，并自信会赢。", "佑芽决定先在梦中报仇雪恨，再在现实中获胜。"], "relationship_facts": ["咲季是佑芽的姐姐。", "咲季与佑芽曾是八岁时的直接对手。", "咲季在赛跑中曾惨败给佑芽（或佑芽认为咲季惨败，此处依咲季台词“在直接对决中惨败的”指代佑芽的悔恨，故事实为佑芽曾战胜咲季）。"], "worldbuilding_facts": ["两人就读于初星学园。", "初星学园曾举办运动会，并在操场举行赛跑。", "咲季拥有进入梦境陪佑芽对决的能力。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00107", "scene_id": "scene-00107", "source_file": "CSV/csprt/csprt-3-0004/adv_csprt-3-0004_02.csv", "source_kind": "csprt", "chapter": "csprt/csprt-3-0004", "scene": "adv_csprt-3-0004_02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-3-0004/adv_csprt-3-0004_02.csv:1-20"], "line_count": 20, "speakers": ["佑芽", "咲季"], "topics": ["relationships", "dialogue_style", "team_story"], "title": "咲季午休梦战体能乐园", "summary": "咲季在休息日午休时梦见与佑芽在电视上共演巨型体能乐园。梦中两人进行体力竞技，咲季虽因体力不支惊呼，但最终获胜。醒来后咲季感叹休息日也累坏了，提议将直播设定为共演NG。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "姐姐"], "worldbuilding_signals": [], "dialogue_style_signals": ["才不是", "啦"], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "好——今天可是完全的休养日哦！"}, {"source_row": "8", "speaker": "佑芽", "text_zh": "情况就是——我和姐姐正在电视上首次共演呢♪"}, {"source_row": "10", "speaker": "咲季", "text_zh": "一决胜负！？我和你！？"}, {"source_row": "17", "speaker": "咲季", "text_zh": "……原来是梦啊。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季在休息日的午间进行午休。", "咲季梦见自己与佑芽在电视上首次共演。", "梦中两人进行巨型体能乐园的竞技。", "咲季在梦中获胜并醒来感叹疲惫。"], "relationship_facts": ["咲季与佑芽是姐妹关系。", "佑芽是咲季的妹妹。", "两人正在电视上进行首次共演。"], "worldbuilding_facts": ["当前是咲季的完全休养日。", "咲季与佑芽正在电视直播中。", "节目包含巨型体能乐园竞技项目。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00108", "scene_id": "scene-00108", "source_file": "CSV/csprt/csprt-3-0004/adv_csprt-3-0004_03.csv", "source_kind": "csprt", "chapter": "csprt/csprt-3-0004", "scene": "adv_csprt-3-0004_03", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-3-0004/adv_csprt-3-0004_03.csv:1-20"], "line_count": 20, "speakers": ["佑芽", "咲季"], "topics": ["relationships", "dialogue_style", "team_story", "character_arc"], "title": "咲季与佑芽的按摩练习", "summary": "咲季找到休息日仍想训练的佑芽，确认其意图后允许其拉伸。佑芽为感谢姐姐，主动提出并进行了按摩。咲季肯定佑芽手法进步，指出僵硬时会有痛感，并提议继续练习以调整手法，佑芽欣然接受。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "妹妹", "姐姐", "朋友"], "worldbuilding_signals": ["训练"], "dialogue_style_signals": ["当然", "真是的", "哼", "啦"], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "佑芽！找到你啦！"}, {"source_row": "7", "speaker": "佑芽", "text_zh": "只是想稍微…做一点点训练啦～"}, {"source_row": "16", "speaker": "咲季", "text_zh": "你的手法也进步了呢。"}, {"source_row": "19", "speaker": "咲季", "text_zh": "我们继续练习吧。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季在休息日找到了正在训练的佑芽。", "佑芽因体力过剩而想进行训练。", "佑芽为咲季进行了按摩，手法得到认可。", "咲季提议继续练习按摩以调整手法。"], "relationship_facts": ["咲季是佑芽的姐姐。", "咲季视佑芽为妹妹。", "咲季是佑芽的师傅。"], "worldbuilding_facts": ["佑芽拥有过剩的体力。", "佑芽的按摩手法正在进步。", "身体僵硬时接受按摩会感到疼痛。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00109", "scene_id": "scene-00109", "source_file": "CSV/csprt/csprt-3-0012/adv_csprt-3-0012_02.csv", "source_kind": "csprt", "chapter": "csprt/csprt-3-0012", "scene": "adv_csprt-3-0012_02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-3-0012/adv_csprt-3-0012_02.csv:1-20"], "line_count": 20, "speakers": ["咲季", "手毬", "美铃"], "topics": ["relationships", "team_story", "dialogue_style"], "title": "咲季点破手毬心事", "summary": "美铃在休息时偷懒，手毬因憋尿心不在焉。咲季敏锐察觉手毬异样，直言憋尿不适，点破其并非去厕所。手毬羞恼反驳，咲季则平静指出事实，展现了她对同伴细微情绪的精准把握与关怀。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["手毬", "美铃"], "worldbuilding_signals": [], "dialogue_style_signals": ["才不是", "呵呵"], "key_evidence": [{"source_row": "5", "speaker": "咲季", "text_zh": "手毬，你好像心不在焉呢？"}, {"source_row": "8", "speaker": "咲季", "text_zh": "但是憋着不去厕所……还是适可而止比较好哦。"}, {"source_row": "12", "speaker": "咲季", "text_zh": "……果然不是去厕所啊。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季指出手毬心不在焉是因为憋着不去厕所。", "手毬否认咲季的推测，表示只是被美铃打乱节奏。", "咲季确认手毬确实不是去厕所，而是有其他心事。"], "relationship_facts": ["咲季与手毬关系亲密，能直接指出对方生理需求。", "咲季与美铃关系良好，能轻松调侃其偷懒行为。", "手毬与美铃存在竞争或摩擦，手毬认为美铃的练习无关自己。"], "worldbuilding_facts": ["角色们正在进行发声练习。", "角色们处于户外，天气晴朗温暖。", "咲季作为教练或指导者，关注队员状态。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00110", "scene_id": "scene-00110", "source_file": "CSV/csprt/csprt-3-0018/adv_csprt-3-0018_01.csv", "source_kind": "csprt", "chapter": "csprt/csprt-3-0018", "scene": "adv_csprt-3-0018_01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-3-0018/adv_csprt-3-0018_01.csv:1-20"], "line_count": 20, "speakers": ["咲季", "手毬", "清夏", "琴音", "莉莉娅"], "topics": ["team_story", "relationships", "dialogue_style"], "title": "咲季应战派对游戏", "summary": "琴音宣布第二届教室派对，咲季起初因突发感到不满并拒绝参加。但在清夏提及与莉莉娅再战的机会后，咲季态度转变，决定只玩15分钟并主动挑战莉莉娅。手毬虽不情愿仍陪玩，众人准备开始游戏。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["琴音", "手毬", "清夏", "莉莉娅"], "worldbuilding_signals": [], "dialogue_style_signals": ["啦"], "key_evidence": [{"source_row": "6", "speaker": "咲季", "text_zh": "即便如此也太突然了。我们也有自己的安排啊。"}, {"source_row": "7", "speaker": "咲季", "text_zh": "不好意思，这次我就pass了。"}, {"source_row": "8", "speaker": "清夏", "text_zh": "明明是和莉莉娅再战的机会哦～？"}, {"source_row": "10", "speaker": "咲季", "text_zh": "葛城莉莉娅！今天一定要和你一决胜负！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["琴音宣布第二届教室派对正式召开。", "咲季最初因派对突然且打乱原有安排而拒绝参加。", "在清夏提醒与莉莉娅再战的机会后，咲季决定参与并挑战莉莉娅。", "手毬表示虽然风格不符，但仍会陪大家玩一会。"], "relationship_facts": ["咲季与莉莉娅之间存在竞技关系，咲季渴望再次与莉莉娅一决胜负。", "清夏是派对的组织者之一，负责活跃气氛并提议大家一起玩。", "手毬与咲季、清夏等人关系融洽，愿意配合大家玩游戏。"], "worldbuilding_facts": ["一年一班定期或不定期举办教室派对以增强班级感情。", "上一次派对结束后仅过了一周左右，咲季认为间隔太短。", "咲季与莉莉娅之前有过游戏对决，咲季上次因状态不好而落败。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00111", "scene_id": "scene-00111", "source_file": "CSV/csprt/csprt-3-0018/adv_csprt-3-0018_03.csv", "source_kind": "csprt", "chapter": "csprt/csprt-3-0018", "scene": "adv_csprt-3-0018_03", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-3-0018/adv_csprt-3-0018_03.csv:1-20"], "line_count": 20, "speakers": ["咲季", "手毬", "清夏", "琴音", "莉莉娅"], "topics": ["team_story", "relationships", "dialogue_style"], "title": "咲季休养日与手毬", "summary": "咲季因休养日而精神恍惚，手毬前来问候并阅读美食杂志。清夏与莉莉娅调侃两人，琴音则分享早餐经历并安慰手毬。咲季最终决定为手毬准备食物，展现了同伴间的日常互动与关怀。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["琴音", "手毬", "清夏", "莉莉娅"], "worldbuilding_signals": [], "dialogue_style_signals": ["真是的", "哼", "嘿嘿", "啦"], "key_evidence": [{"source_row": "4", "speaker": "咲季", "text_zh": "今天啊～……是完全休养日哦。"}, {"source_row": "8", "speaker": "手毬", "text_zh": "在看美食杂志。这期有附近餐饮店的专题报道。"}, {"source_row": "10", "speaker": "手毬", "text_zh": "不去。就看看而已。正在减肥呢。"}, {"source_row": "20", "speaker": "咲季", "text_zh": "好啦好啦。给你做点吃的，等着啊。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季今天是全力放空休息的休养日。", "手毬正在阅读关于附近餐饮店的美食杂志。", "手毬表示自己在减肥，因此只看不吃。", "咲季决定为手毬制作食物。"], "relationship_facts": ["咲季与手毬是关系亲密的同伴。", "清夏与莉莉娅是咲季和手毬的朋友。", "琴音是咲季和手毬的朋友。"], "worldbuilding_facts": ["咲季目前处于需要休养的状态。", "手毬有减肥的设定。", "场景发生在可以一起享用早餐的室内环境。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00112", "scene_id": "scene-00112", "source_file": "CSV/csprt/csprt-3-0022/adv_csprt-3-0022_02.csv", "source_kind": "csprt", "chapter": "csprt/csprt-3-0022", "scene": "adv_csprt-3-0022_02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-3-0022/adv_csprt-3-0022_02.csv:1-20"], "line_count": 20, "speakers": ["琴音", "麻央"], "topics": ["team_story", "relationships", "worldbuilding"], "title": "雨中的王子与学妹", "summary": "突降暴雨，琴音淋湿后向学姐麻央求助。麻央为保护学妹，毅然将伞让给琴音，自己冒雨回宿舍。琴音感叹麻央是初星学园的小王子，展现了学姐温柔守护的一面。", "saki_role": "被提及对象：咲季未必直接发言，但场景信息与她的关系或评价有关。", "relationship_signals": ["琴音", "麻央"], "worldbuilding_signals": ["学园", "工作"], "dialogue_style_signals": [], "key_evidence": [{"source_row": "5", "speaker": "琴音", "text_zh": "还不如咲季的直觉准呢。"}, {"source_row": "17", "speaker": "麻央", "text_zh": "我可不能眼睁睁看着可爱的学妹淋着雨离开啊。"}, {"source_row": "20", "speaker": "琴音", "text_zh": "……初星学园的小王子吗。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["突降暴雨，琴音未带伞被淋湿。", "麻央将伞让给琴音，自己冒雨离开。", "琴音感叹麻央是初星学园的小王子。"], "relationship_facts": ["琴音称呼麻央为学姐。", "麻央是琴音的守护者。", "琴音视麻央为王子般的存在。"], "worldbuilding_facts": ["初星学园存在被称为小王子的角色。", "学园天气预报有时不准。", "麻央常备折叠伞。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00113", "scene_id": "scene-00113", "source_file": "CSV/csprt/csprt-3-0023/adv_csprt-3-0023_01.csv", "source_kind": "csprt", "chapter": "csprt/csprt-3-0023", "scene": "adv_csprt-3-0023_01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-3-0023/adv_csprt-3-0023_01.csv:1-20"], "line_count": 20, "speakers": ["佑芽", "咲季"], "topics": ["relationships", "team_story", "dialogue_style", "worldbuilding"], "title": "雨中共伞的甜蜜互动", "summary": "佑芽未带伞，咲季主动提议共撑一把。两人借此调侃恋爱话题，咲季因偶像身份自嘲无时间恋爱，随后佑芽提议扮演男友，咲季则坚持自己才是男友，在雨中展开充满童趣的甜蜜对话。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "姐姐", "朋友"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["当然", "嘿嘿", "啦"], "key_evidence": [{"source_row": "2", "speaker": "咲季", "text_zh": "不过还是问一下……你带伞了吗？"}, {"source_row": "12", "speaker": "咲季", "text_zh": "成为偶像之后，哪还有时间谈恋爱啊。"}, {"source_row": "16", "speaker": "咲季", "text_zh": "撑伞的我应该当佑芽的男朋友才对吧？"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["佑芽忘记带伞，咲季主动提出共撑一把。", "咲季表示成为偶像后没有恋爱时间。", "佑芽提议扮演咲季的男朋友。", "咲季坚持自己才是佑芽的男朋友。"], "relationship_facts": ["咲季是佑芽的姐姐。", "咲季是偶像。", "咲季与佑芽关系亲密，常开玩笑。"], "worldbuilding_facts": ["咲季是偶像团体成员。", "咲季有恋人的朋友从小学就常共撑一把伞。", "咲季因工作忙碌，恋爱话题对她来说很遥远。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00114", "scene_id": "scene-00114", "source_file": "CSV/csprt/csprt-3-0023/adv_csprt-3-0023_02.csv", "source_kind": "csprt", "chapter": "csprt/csprt-3-0023", "scene": "adv_csprt-3-0023_02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-3-0023/adv_csprt-3-0023_02.csv:1-20"], "line_count": 20, "speakers": ["佑芽", "咲季"], "topics": ["relationships", "dialogue_style", "character_arc", "worldbuilding"], "title": "雨天室内器械训练", "summary": "雨天佑芽抱怨无法户外运动，咲季提议利用室内最新健身器材进行训练。咲季解释拍摄视频是为了向父亲汇报学校设施，并邀请佑芽挑选心仪器材。两人决定将雨天转化为室内器械训练日，咲季准备向佑芽介绍推荐设备。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "姐姐"], "worldbuilding_signals": ["训练"], "dialogue_style_signals": ["真是的", "呵呵", "啦"], "key_evidence": [{"source_row": "4", "speaker": "咲季", "text_zh": "今天虽然因为下雨不能外出"}, {"source_row": "5", "speaker": "咲季", "text_zh": "但这不是试用最新健身器材的大好机会吗"}, {"source_row": "15", "speaker": "咲季", "text_zh": "我跟爸爸炫耀了学校的训练设施后"}, {"source_row": "16", "speaker": "咲季", "text_zh": "他就拜托我拍视频整理成报告交给他看呢"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["因下雨无法户外运动，咲季提议进行室内器械训练。", "咲季拍摄视频是为了向父亲汇报学校训练设施。", "佑芽和咲季决定将今天定为器械训练日。", "咲季家中拥有齐全的训练设施。"], "relationship_facts": ["咲季是佑芽的姐姐。", "咲季的父亲是视频接收者。", "咲季与父亲关系亲密，常向其炫耀学校设施。"], "worldbuilding_facts": ["咲季的学校拥有齐全的训练设施。", "咲季家中也配备了齐全的训练设施。", "咲季负责拍摄视频整理报告交给父亲。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00115", "scene_id": "scene-00115", "source_file": "CSV/csprt/csprt-3-0023/adv_csprt-3-0023_03.csv", "source_kind": "csprt", "chapter": "csprt/csprt-3-0023", "scene": "adv_csprt-3-0023_03", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-3-0023/adv_csprt-3-0023_03.csv:1-20"], "line_count": 20, "speakers": ["佑芽", "咲季"], "topics": ["relationships", "dialogue_style", "team_story", "worldbuilding"], "title": "雨天室内与身体交换", "summary": "雨天佑芽因取消购物计划而消气，咲季安抚其留在室内休息。咲季称赞佑芽变时髦，佑芽提及想与咲季交换身体穿可爱衣服或拍泳装照，咲季以同样理由回应，引发佑芽害羞反应。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "妹妹", "姐姐", "朋友"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["呵呵", "嘿嘿"], "key_evidence": [{"source_row": "3", "speaker": "咲季", "text_zh": "下这么大的雨，出门太危险了吧。"}, {"source_row": "12", "speaker": "佑芽", "text_zh": "要是能和姐姐交换身体就好了——"}, {"source_row": "19", "speaker": "咲季", "text_zh": "我也要用佑芽的身体，拍一大堆超级适合的"}, {"source_row": "20", "speaker": "佑芽", "text_zh": "姐、姐姐好下流！？"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["因大雨，咲季取消与佑芽的购物计划，建议留在室内休息。", "佑芽表示想与咲季交换身体，以便穿更可爱的衣服或拍泳装照。", "咲季回应若交换身体，自己也想用佑芽的身体拍大胆泳装照。", "佑芽对咲季的回应感到害羞，称其下流。"], "relationship_facts": ["咲季是佑芽的姐姐。", "咲季与佑芽关系亲密，咲季会直接称呼佑芽为妹妹。", "咲季对佑芽的时尚变化表示认可和赞赏。"], "worldbuilding_facts": ["咲季和佑芽拥有交换身体的能力或幻想。", "咲季和佑芽都热衷于拍照和时尚。", "咲季和佑芽对泳装照有共同的兴趣。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00116", "scene_id": "scene-00116", "source_file": "CSV/csprt/csprt-3-0024/adv_csprt-3-0024_01.csv", "source_kind": "csprt", "chapter": "csprt/csprt-3-0024", "scene": "adv_csprt-3-0024_01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-3-0024/adv_csprt-3-0024_01.csv:1-20"], "line_count": 20, "speakers": ["咲季", "手毬", "琴音"], "topics": ["team_story", "relationships", "dialogue_style"], "title": "咲季鼓励琴音补考", "summary": "咲季指导琴音解题，琴音虽害羞但成功解出。咲季表扬琴音并强调伙伴间应互相支持，手毬则在一旁吐槽拒绝帮忙。三人围绕补考与互助展开轻松互动。", "saki_role": "同学/对手：咲季在群像关系中以好胜、直率和带头推进对话的姿态出现。", "relationship_signals": ["琴音", "手毬", "伙伴"], "worldbuilding_signals": [], "dialogue_style_signals": ["啦"], "key_evidence": [{"source_row": "5", "speaker": "咲季", "text_zh": "喂喂，琴音！这样可没法通过补考啊！"}, {"source_row": "14", "speaker": "咲季", "text_zh": "不需要。等我遇到困难的时候，琴音也会帮我的对吧？"}, {"source_row": "16", "speaker": "手毬", "text_zh": "我不会帮忙的。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["琴音在咲季指导下成功解出题目。", "咲季认为伙伴间应互相支持。", "手毬拒绝在关键时刻帮忙。"], "relationship_facts": ["咲季与琴音是同班同学。", "咲季视琴音为追逐相同梦想的伙伴。", "手毬与咲季关系亲密但性格傲娇。"], "worldbuilding_facts": ["角色们面临补考压力。", "咲季擅长教导他人解题方法。", "手毬平时傲娇，关键时刻会帮忙。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00117", "scene_id": "scene-00117", "source_file": "CSV/csprt/csprt-3-0024/adv_csprt-3-0024_02.csv", "source_kind": "csprt", "chapter": "csprt/csprt-3-0024", "scene": "adv_csprt-3-0024_02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-3-0024/adv_csprt-3-0024_02.csv:1-20"], "line_count": 20, "speakers": ["咲季", "星南", "琴音"], "topics": ["relationships", "team_story", "dialogue_style", "character_arc"], "title": "琴音的补习危机", "summary": "咲季与琴音闲聊时，琴音因不及格试卷烦恼留级。星南作为琴音粉丝得知此事，主动提出一对一辅导，展现可靠前辈风范。咲季作为姐姐角色给予支持，场景聚焦于学业危机与人际互动。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["琴音", "星南", "姐姐"], "worldbuilding_signals": [], "dialogue_style_signals": ["当然", "哼", "呵呵", "啦"], "key_evidence": [{"source_row": "5", "speaker": "咲季", "text_zh": "姐姐会帮你想办法的。"}, {"source_row": "7", "speaker": "琴音", "text_zh": "这些不及格的试卷"}, {"source_row": "14", "speaker": "星南", "text_zh": "因为我是你的粉丝呀。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["琴音因试卷不及格面临留级风险。", "星南是琴音的粉丝并知晓其成绩问题。", "星南提议为琴音提供一对一辅导。"], "relationship_facts": ["咲季是琴音的姐姐（非亲生）。", "星南是十王会的会长。", "星南是琴音的粉丝。"], "worldbuilding_facts": ["存在补考制度，不及格可能导致留级。", "星南会长拥有辅导他人的能力。", "角色间存在粉丝与偶像的互动关系。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00118", "scene_id": "scene-00118", "source_file": "CSV/csprt/csprt-3-0029/adv_csprt-3-0029_01.csv", "source_kind": "csprt", "chapter": "csprt/csprt-3-0029", "scene": "adv_csprt-3-0029_01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-3-0029/adv_csprt-3-0029_01.csv:1-20"], "line_count": 20, "speakers": ["咲季", "手毬", "琴音"], "topics": ["relationships", "team_story", "character_arc", "worldbuilding"], "title": "咲季因佑芽炫耀而不甘", "summary": "暑假将至，手毬与琴音抱怨训练辛苦。咲季因好友佑芽去朋友家过夜并炫耀其宽敞训练室及泳池计划而心生不甘。琴音提议大家去河边玩以回敬佑芽，咲季欣然接受，决心向佑芽展示自己更会享受夏天。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "琴音", "手毬", "姐姐", "朋友"], "worldbuilding_signals": ["偶像", "训练", "试镜"], "dialogue_style_signals": ["当然", "哼", "啦"], "key_evidence": [{"source_row": "9", "speaker": "咲季", "text_zh": "佑芽她啊……去朋友家过夜了。"}, {"source_row": "12", "speaker": "咲季", "text_zh": "佑芽那家伙一直炫耀说留宿处的训练室有多宽敞多厉害"}, {"source_row": "14", "speaker": "咲季", "text_zh": "好不甘心～！简直像试镜落选时一样不甘心～！"}, {"source_row": "20", "speaker": "咲季", "text_zh": "你姐姐我可是比你更会享受夏天哦！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季因佑芽炫耀留宿处的训练室和泳池计划而感到不甘心。", "琴音提议大家一起去河边玩，以此向佑芽炫耀并回敬她。", "咲季表示要让大家见识自己比佑芽更会享受夏天。"], "relationship_facts": ["咲季与佑芽是好友，咲季对佑芽的炫耀行为感到嫉妒。", "手毬与琴音是咲季的朋友，她们在讨论训练和暑假计划。", "琴音提议集体行动以回应咲季对佑芽的不满。"], "worldbuilding_facts": ["当前正值暑假前夕，偶像们面临训练任务。", "佑芽的朋友家拥有宽敞的训练室和泳池。", "角色们计划利用暑假时间进行户外活动，如去河边玩。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00119", "scene_id": "scene-00119", "source_file": "CSV/csprt/csprt-3-0029/adv_csprt-3-0029_02.csv", "source_kind": "csprt", "chapter": "csprt/csprt-3-0029", "scene": "adv_csprt-3-0029_02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-3-0029/adv_csprt-3-0029_02.csv:1-20"], "line_count": 20, "speakers": ["咲季", "手毬", "琴音"], "topics": ["team_story", "relationships", "dialogue_style", "worldbuilding"], "title": "初星学园玩水对决", "summary": "咲季自信宣称初星学园有河滩可玩水，并随时接受挑战。然而琴音与手毬联手偷袭，利用夹击战术让咲季落败。咲季虽被偷袭感到愤怒，但承认两人默契十足，展现了偶像间的活泼互动。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["琴音", "手毬"], "worldbuilding_signals": ["学园", "偶像"], "dialogue_style_signals": ["当然", "哼", "啦"], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "初星学园里有能玩水的河滩"}, {"source_row": "13", "speaker": "手毬", "text_zh": "琴音！就是现在！"}, {"source_row": "18", "speaker": "琴音", "text_zh": "好～嘞，我们来夹击吧～！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["初星学园内存在可供玩水的河滩。", "琴音与手毬联手对咲季实施了夹击战术。", "咲季在宣言中途遭到水枪偷袭。"], "relationship_facts": ["咲季、琴音、手毬均为初星学园偶像。", "琴音与手毬配合默契，擅长夹击对手。", "咲季视琴音为偶像对手，对其偷袭表示不满。"], "worldbuilding_facts": ["初星学园拥有适合玩水的河滩环境。", "偶像之间存在玩水对决的娱乐活动。", "偶像间存在互相偷袭的玩笑式互动。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00120", "scene_id": "scene-00120", "source_file": "CSV/csprt/csprt-3-0029/adv_csprt-3-0029_03.csv", "source_kind": "csprt", "chapter": "csprt/csprt-3-0029", "scene": "adv_csprt-3-0029_03", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-3-0029/adv_csprt-3-0029_03.csv:1-20"], "line_count": 20, "speakers": ["佑芽", "咲季", "手毬", "琴音"], "topics": ["relationships", "team_story", "dialogue_style", "worldbuilding"], "title": "咲季河边玩水被误会", "summary": "咲季向佑芽讲述自主训练后与好友在河边玩水的经历，试图排解消沉心情。手毬质疑其态度，琴音则借机炫耀与咲季的关系并邀请同睡。咲季对琴音的作秀感到反感，并澄清琴音并非自己最好的朋友，最终因被误解而感到困扰。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "琴音", "手毬", "妹妹", "姐姐", "朋友"], "worldbuilding_signals": ["学园", "训练"], "dialogue_style_signals": ["才不是", "啦"], "key_evidence": [{"source_row": "7", "speaker": "咲季", "text_zh": "其实我最近有点消沉正觉得郁闷呢……"}, {"source_row": "8", "speaker": "咲季", "text_zh": "然后我最好的朋友就说我们去学园河边玩嘛～"}, {"source_row": "15", "speaker": "琴音", "text_zh": "喂咲～季♪今晚好朋友一起睡嘛～♡"}, {"source_row": "18", "speaker": "咲季", "text_zh": "这种做作的演技怎么可能骗到我妹妹……"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季在自主训练后感到消沉郁闷。", "咲季最好的朋友邀请她去学园河边玩水。", "琴音声称自己是咲季最好的朋友并邀请同睡。", "咲季认为琴音是在向佑芽炫耀关系。"], "relationship_facts": ["咲季与琴音是好朋友。", "咲季与手毬是朋友。", "佑芽是咲季的妹妹。"], "worldbuilding_facts": ["角色们有自主训练的习惯。", "学园附近有可供玩水的河边。", "角色们会进行夜间聚会或同睡活动。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00121", "scene_id": "scene-00121", "source_file": "CSV/csprt/csprt-3-0032/adv_csprt-3-0032_02.csv", "source_kind": "csprt", "chapter": "csprt/csprt-3-0032", "scene": "adv_csprt-3-0032_02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-3-0032/adv_csprt-3-0032_02.csv:1-20"], "line_count": 20, "speakers": ["佑芽", "咲季", "星南"], "topics": ["relationships", "dialogue_style", "worldbuilding", "character_arc"], "title": "星南晨跑与咲季登场", "summary": "星南观摩佑芽晨跑，虽自称游刃有余实则体力透支。佑芽请求示范舞蹈时，咲季突然插话打断，令星南感到作为“可靠学姐”的处境相当费劲。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "星南"], "worldbuilding_signals": ["偶像", "训练"], "dialogue_style_signals": ["当然", "哼", "呵呵", "嘿嘿", "啦"], "key_evidence": [{"source_row": "12", "speaker": "星南", "text_zh": "不愧是前运动员呢。"}, {"source_row": "14", "speaker": "佑芽", "text_zh": "能给我示范下舞蹈动作吗？"}, {"source_row": "18", "speaker": "咲季", "text_zh": "喂？"}, {"source_row": "20", "speaker": "星南", "text_zh": "要当佑芽心中『可靠的学姐』……"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["星南前来观摩佑芽的自主晨跑训练。", "星南在跑步过程中体力已达极限。", "佑芽请求星南示范舞蹈动作。", "咲季突然出声打断星南与佑芽的互动。"], "relationship_facts": ["星南是佑芽的前辈。", "星南是前运动员。", "咲季是星南的熟人或同僚。"], "worldbuilding_facts": ["佑芽是学院第一偶像。", "星南曾是运动员。", "训练课包含舞蹈环节。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00122", "scene_id": "scene-00122", "source_file": "CSV/csprt/csprt-3-0033/adv_csprt-3-0033_03.csv", "source_kind": "csprt", "chapter": "csprt/csprt-3-0033", "scene": "adv_csprt-3-0033_03", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-3-0033/adv_csprt-3-0033_03.csv:1-20"], "line_count": 20, "speakers": ["咲季", "手毬", "琴音", "美铃"], "topics": ["relationships", "team_story", "dialogue_style", "worldbuilding"], "title": "咲季点评手毬体重管理", "summary": "手毬与美铃互动中，手毬因美铃的照顾体重反复波动。咲季与琴音出现，咲季称赞手毬近期体重管理出色，手毬谦虚回应这是偶像的自我管理。咲季作为旁观者评价了手毬的自律表现。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["琴音", "手毬", "美铃"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["当然", "啦"], "key_evidence": [{"source_row": "18", "speaker": "咲季", "text_zh": "最近的手毬，体重管理做得很好呢。"}, {"source_row": "20", "speaker": "手毬", "text_zh": "没什么？只是作为偶像，做了理所当然的自我管理而已。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["手毬在美铃的照顾下体重出现反复波动。", "咲季指出手毬最近的体重管理做得很好。", "手毬将体重控制归因于偶像身份下的自我管理。"], "relationship_facts": ["美铃是手毬的照顾者兼好友。", "咲季与琴音是手毬的同伴或熟人。", "手毬与咲季、琴音处于同一社交圈层。"], "worldbuilding_facts": ["手毬作为偶像需要严格的自我管理。", "角色间存在互相调侃与关心的日常互动模式。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00123", "scene_id": "scene-00123", "source_file": "CSV/csprt/csprt-3-0035/adv_csprt-3-0035_01.csv", "source_kind": "csprt", "chapter": "csprt/csprt-3-0035", "scene": "adv_csprt-3-0035_01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-3-0035/adv_csprt-3-0035_01.csv:1-20"], "line_count": 20, "speakers": ["佑芽", "咲季", "旁白"], "topics": ["relationships", "dialogue_style", "team_story"], "title": "假日夜晚的食谱改良", "summary": "假日夜晚，佑芽与姐姐咲季闲聊。咲季正在改良营养学食谱，佑芽称赞其口感进步。咲季提议下次休息日一起看佑芽推荐的恋爱漫画，两人约定共度闲暇时光。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "姐姐", "朋友"], "worldbuilding_signals": [], "dialogue_style_signals": ["哼", "呵呵", "啦"], "key_evidence": [{"source_row": "3", "speaker": "咲季", "text_zh": "营养学的书。因为除了佑芽之外给其他孩子做饭的机会也变多了……"}, {"source_row": "7", "speaker": "佑芽", "text_zh": "是口感吧？"}, {"source_row": "10", "speaker": "咲季", "text_zh": "对下巴和牙齿也有好处，离完美的料理又近了一步呢！"}, {"source_row": "19", "speaker": "咲季", "text_zh": "呵呵……那下次休息日就看看吧。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季正在改良营养学食谱。", "佑芽称赞咲季改良后的便当口感更好。", "咲季提议下次休息日一起看漫画。", "佑芽正在看朋友推荐的恋爱喜剧漫画。"], "relationship_facts": ["咲季是佑芽的姐姐。", "咲季经常为佑芽和其他孩子做饭。", "佑芽和咲季关系亲密，经常一起度过假日。"], "worldbuilding_facts": ["咲季对料理的口感和营养（如下巴和牙齿健康）很在意。", "咲季正在通过改良食谱提升料理水平。", "佑芽正在阅读恋爱喜剧类型的漫画。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00124", "scene_id": "scene-00124", "source_file": "CSV/csprt/csprt-3-0035/adv_csprt-3-0035_02.csv", "source_kind": "csprt", "chapter": "csprt/csprt-3-0035", "scene": "adv_csprt-3-0035_02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-3-0035/adv_csprt-3-0035_02.csv:1-20"], "line_count": 20, "speakers": ["佑芽", "咲季"], "topics": ["relationships", "dialogue_style", "character_arc", "worldbuilding"], "title": "咲季与佑芽的休息日", "summary": "休息日上午，咲季迎接刚结束学习的佑芽。咲季通过问答确认佑芽的学习状态，并引导其思考偶像活动后的未来规划。面对佑芽‘赢了再想’的回答，咲季流露出既欣慰又困扰的复杂心情，展现了姐姐对妹妹成长的关切与引导。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "妹妹", "姐姐"], "worldbuilding_signals": ["偶像", "训练"], "dialogue_style_signals": ["哼", "啦"], "key_evidence": [{"source_row": "2", "speaker": "咲季", "text_zh": "哎呀，欢迎光临。"}, {"source_row": "8", "speaker": "佑芽", "text_zh": "学、学习…………"}, {"source_row": "15", "speaker": "佑芽", "text_zh": "成绩不好的话就不能继续偶像活动了。"}, {"source_row": "20", "speaker": "咲季", "text_zh": "真是让人困扰的回答呢。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["休息日上午，佑芽完成了学习。", "咲季引导佑芽思考偶像活动胜利后的未来。", "佑芽表示要努力赢过姐姐。", "咲季对佑芽的回答感到开心又困扰。"], "relationship_facts": ["咲季是佑芽的姐姐。", "两人是偶像组合成员。", "咲季关心佑芽的未来发展。"], "worldbuilding_facts": ["偶像活动需要良好的成绩支持。", "休息日上午通常是学习时间。", "姐姐与妹妹共同进行偶像训练。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00125", "scene_id": "scene-00125", "source_file": "CSV/csprt/csprt-3-0035/adv_csprt-3-0035_03.csv", "source_kind": "csprt", "chapter": "csprt/csprt-3-0035", "scene": "adv_csprt-3-0035_03", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-3-0035/adv_csprt-3-0035_03.csv:1-20"], "line_count": 20, "speakers": ["佑芽", "咲季"], "topics": ["relationships", "dialogue_style", "plot", "worldbuilding"], "title": "咲季与佑芽的假期约定", "summary": "咲季提议午睡休息，佑芽表示效仿并立志成为顶尖偶像。咲季认可了佑芽的决心，称其为棘手的竞争对手，并约定醒来后进行拉伸和观看演唱会录像，两人确立了共同奋斗的关系。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "姐姐", "朋友", "对手"], "worldbuilding_signals": ["偶像", "演唱会"], "dialogue_style_signals": ["当然", "真是的", "嘿嘿", "啦"], "key_evidence": [{"source_row": "2", "speaker": "咲季", "text_zh": "当然是要睡觉啦！"}, {"source_row": "13", "speaker": "佑芽", "text_zh": "因为我想成为姐姐那样的人。"}, {"source_row": "16", "speaker": "咲季", "text_zh": "你真是个棘手的竞争对手呢。"}, {"source_row": "19", "speaker": "咲季", "text_zh": "睡醒后要做拉伸运动还要看演唱会的录像哦！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季计划通过午睡来好好休息身体。", "佑芽立志成为像咲季那样的顶尖偶像。", "咲季将佑芽视为棘手的竞争对手。", "两人约定醒来后做拉伸并看演唱会录像。"], "relationship_facts": ["咲季是佑芽的姐姐。", "佑芽以咲季为榜样并想胜过她。", "咲季认可并接纳了佑芽的竞争心。"], "worldbuilding_facts": ["咲季不擅长静下来待着。", "咲季在班上交到了朋友。", "假期期间有演唱会录像可看。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00126", "scene_id": "scene-00126", "source_file": "CSV/csprt/csprt-3-0043/adv_csprt-3-0043_01.csv", "source_kind": "csprt", "chapter": "csprt/csprt-3-0043", "scene": "adv_csprt-3-0043_01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-3-0043/adv_csprt-3-0043_01.csv:1-20"], "line_count": 20, "speakers": ["咲季", "清夏"], "topics": ["team_story", "dialogue_style", "relationships"], "title": "咲季与清夏的跑步对决", "summary": "清夏因寒冷提议跑步，咲季欣然加入并发起挑战。两人约定绕操场跑十圈，咲季凭借运动员背景轻松获胜。清夏感叹咲季体力惊人，咲季则称赞清夏身体线条优美，展现了两人间轻松友好的互动氛围。", "saki_role": "同学/对手：咲季在群像关系中以好胜、直率和带头推进对话的姿态出现。", "relationship_signals": ["清夏", "对手"], "worldbuilding_signals": [], "dialogue_style_signals": ["当然", "真是的", "哼", "啦"], "key_evidence": [{"source_row": "6", "speaker": "咲季", "text_zh": "那正好呢。我可以一起吗？"}, {"source_row": "10", "speaker": "咲季", "text_zh": "规则是绕操场跑10圈！"}, {"source_row": "18", "speaker": "清夏", "text_zh": "说起来你以前是运动员来着……"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季是前运动员，体力优于清夏。", "咲季主动邀请清夏一起跑步。", "咲季在跑步中轻松击败了清夏。"], "relationship_facts": ["咲季与清夏是朋友。", "咲季欣赏清夏的身体线条。", "清夏对咲季的好胜心感到无奈。"], "worldbuilding_facts": ["场景位于有操场的户外。", "咲季拥有运动员背景。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00127", "scene_id": "scene-00127", "source_file": "CSV/csprt/csprt-3-0043/adv_csprt-3-0043_02.csv", "source_kind": "csprt", "chapter": "csprt/csprt-3-0043", "scene": "adv_csprt-3-0043_02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-3-0043/adv_csprt-3-0043_02.csv:1-20"], "line_count": 20, "speakers": ["咲季", "清夏"], "topics": ["team_story", "dialogue_style", "character_arc", "worldbuilding"], "title": "咲季挑战游戏中心", "summary": "咲季与清夏进行体能训练后，清夏提议去游戏中心一决胜负。咲季虽鲜少涉足，但迅速掌握射击游戏规则并通关，展现出认真严谨的态度。清夏对此感到敬佩，两人关系融洽。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["清夏"], "worldbuilding_signals": ["训练"], "dialogue_style_signals": ["当然", "哼", "啦"], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "来吧清夏。接下来要一决胜负的项目是什么？"}, {"source_row": "8", "speaker": "咲季", "text_zh": "游戏中心？为什么要特意去……"}, {"source_row": "13", "speaker": "咲季", "text_zh": "倒也不是第一次……只是很少来而已。"}, {"source_row": "19", "speaker": "咲季", "text_zh": "要做就要认真做。这不是理所当然的吗。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季与清夏在体能训练后前往游戏中心。", "咲季第一次正式进入游戏中心（虽非首次但很少来）。", "咲季在射击游戏中迅速掌握走位诀窍并通关。", "清夏对咲季认真严谨的态度表示敬佩。"], "relationship_facts": ["咲季与清夏是同学关系。", "咲季与清夏正在进行训练或比赛。", "清夏视咲季为值得敬佩的对象。"], "worldbuilding_facts": ["咲季休息日通常只用于学习和睡觉。", "游戏中心提供射击僵尸等街机游戏。", "游戏中心位于两人可步行到达的地点。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00128", "scene_id": "scene-00128", "source_file": "CSV/csprt/csprt-3-0043/adv_csprt-3-0043_03.csv", "source_kind": "csprt", "chapter": "csprt/csprt-3-0043", "scene": "adv_csprt-3-0043_03", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-3-0043/adv_csprt-3-0043_03.csv:1-20"], "line_count": 20, "speakers": ["咲季", "清夏"], "topics": ["team_story", "dialogue_style", "worldbuilding", "character_arc"], "title": "咲季与清夏的游戏对决", "summary": "咲季提议通过舞蹈游戏一决胜负，尽管清夏多次获胜，咲季仍将其视为训练坚持挑战。两人虽在分数上分出胜负，但清夏更看重咲季玩得开心，最终咲季同意偶尔陪清夏放松游玩，展现了两人间轻松友好的互动氛围。", "saki_role": "同学/对手：咲季在群像关系中以好胜、直率和带头推进对话的姿态出现。", "relationship_signals": ["清夏", "对手"], "worldbuilding_signals": ["偶像", "训练"], "dialogue_style_signals": ["才不是", "哼", "嘿嘿", "不是吗", "啦"], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "不是有舞蹈游戏嘛！作为偶像就用那个来一决胜负吧！"}, {"source_row": "3", "speaker": "清夏", "text_zh": "反正最后都是小咲季反败为胜，应该已经满足了吧？"}, {"source_row": "4", "speaker": "咲季", "text_zh": "本来是这么打算的，但这个游戏我觉得还能当作训练呢！"}, {"source_row": "18", "speaker": "清夏", "text_zh": "不～过小咲季玩得开心就好啦。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季提议用舞蹈游戏与清夏进行对决。", "清夏在多次游戏中均战胜了咲季。", "咲季将游戏视为训练机会并坚持挑战。", "清夏认为咲季玩得开心比输赢更重要。"], "relationship_facts": ["咲季与清夏是经常一起玩游戏的朋友。", "清夏在咲季面前表现得自信且喜欢调侃。", "咲季对清夏持有竞争心态但愿意配合。"], "worldbuilding_facts": ["角色们参与舞蹈游戏等电子游戏活动。", "游戏厅是角色们放松娱乐的场所。", "舞蹈游戏被用作偶像训练的一种方式。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00129", "scene_id": "scene-00129", "source_file": "CSV/csprt/csprt-3-0044/adv_csprt-3-0044_01.csv", "source_kind": "csprt", "chapter": "csprt/csprt-3-0044", "scene": "adv_csprt-3-0044_01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-3-0044/adv_csprt-3-0044_01.csv:1-20"], "line_count": 20, "speakers": ["众人", "咲季", "手毬", "清夏", "琴音", "莉莉娅"], "topics": ["team_story", "dialogue_style", "relationships", "worldbuilding"], "title": "咲季展现偶像觉悟", "summary": "众人练习歌曲时因难度与评价感到疲惫，手毬指出需有觉悟。咲季反驳散漫言论，表示早已拥有觉悟，决心让大家承认她们是最棒的，并激励众人继续练习，重振士气。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["琴音", "手毬", "清夏", "莉莉娅"], "worldbuilding_signals": ["学园", "偶像"], "dialogue_style_signals": ["哼", "啦"], "key_evidence": [{"source_row": "5", "speaker": "咲季", "text_zh": "这不是很有挑战性的曲子吗！"}, {"source_row": "11", "speaker": "手毬", "text_zh": "作为歌唱的偶像需要『觉悟』。"}, {"source_row": "18", "speaker": "咲季", "text_zh": "觉悟的话我早就有了哦。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季认为挑战高难度歌曲是偶像的觉悟。", "咲季反驳手毬关于散漫的批评，声称自己早有觉悟。", "咲季激励众人继续练习，目标是获得大家认可。"], "relationship_facts": ["咲季与手毬存在关于偶像态度的观点冲突。", "咲季是团队中鼓舞士气的核心成员。", "咲季与清夏、琴音、莉莉娅共同组成练习团体。"], "worldbuilding_facts": ["初星学园被称为『Campus mode』，存在残酷评价机制。", "作为歌唱偶像需要具备特定的『觉悟』。", "团队正在练习一首被认为很难且很有初星感觉的歌曲。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00130", "scene_id": "scene-00130", "source_file": "CSV/csprt/csprt-3-0044/adv_csprt-3-0044_03.csv", "source_kind": "csprt", "chapter": "csprt/csprt-3-0044", "scene": "adv_csprt-3-0044_03", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-3-0044/adv_csprt-3-0044_03.csv:1-20"], "line_count": 20, "speakers": ["咲季", "手毬", "琴音"], "topics": ["team_story", "relationships", "dialogue_style"], "title": "咲季观察手毬练习", "summary": "咲季与琴音观察手毬练习，咲季称以此学习。手毬虽惊讶但同意被观摩，并提议若两人达到同等水平可同台演出。咲季自信地要求担任C位，引发手毬不满，琴音则吐槽她们无意义的争吵并提议离开。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["琴音", "手毬", "姐姐"], "worldbuilding_signals": [], "dialogue_style_signals": ["当然"], "key_evidence": [{"source_row": "3", "speaker": "咲季", "text_zh": "我们是在观察你的动作来学习啊。"}, {"source_row": "13", "speaker": "手毬", "text_zh": "让你们一起站上舞台也不是不可以哦？"}, {"source_row": "15", "speaker": "咲季", "text_zh": "好呀！到时候就由我来站C位吧！"}, {"source_row": "20", "speaker": "琴音", "text_zh": "我们去那边的小组吧♪"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季和琴音正在观察手毬的动作进行练习。", "手毬提议若咲季和琴音达到同等水平，可以一起站上舞台。", "咲季坚持认为作为姐姐理应担任舞台C位。", "琴音认为咲季和手毬的争吵毫无意义并想离开。"], "relationship_facts": ["咲季是手毬和琴音的姐姐。", "咲季和琴音是手毬的同伴或后辈。", "手毬是咲季和琴音的练习对象或前辈。"], "worldbuilding_facts": ["存在名为『Campus mode!!』的曲子。", "舞台演出中有C位（中心位置）的概念。", "角色们正在进行舞蹈或表演相关的练习。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00131", "scene_id": "scene-00131", "source_file": "CSV/csprt/csprt-3-0047/adv_csprt-3-0047_01.csv", "source_kind": "csprt", "chapter": "csprt/csprt-3-0047", "scene": "adv_csprt-3-0047_01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-3-0047/adv_csprt-3-0047_01.csv:1-20"], "line_count": 20, "speakers": ["佑芽", "咲季", "莉波"], "topics": ["relationships", "team_story", "dialogue_style"], "title": "佑芽为咲季选礼物", "summary": "佑芽向莉波请教为姐姐咲季准备情人节巧克力的主意。咲季表示最喜欢佑芽，但佑芽发现食物喜好难以参考。莉波提议结合咲季喜欢的食材制作，并计划次日一同尝试，展现了三人间的温馨互动。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "莉波", "妹妹", "姐姐"], "worldbuilding_signals": [], "dialogue_style_signals": ["当然", "呵呵", "啦"], "key_evidence": [{"source_row": "3", "speaker": "佑芽", "text_zh": "我每年都会给姐姐准备情人节巧克力……"}, {"source_row": "13", "speaker": "咲季", "text_zh": "最喜欢佑芽啦♡你可是我最骄傲的妹妹哦！"}, {"source_row": "17", "speaker": "佑芽", "text_zh": "食物的话她喜欢高蛋白的……比如蛋白粉和鸡胸肉！！！！"}, {"source_row": "20", "speaker": "莉波", "text_zh": "明天我们一起试着做做看！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["佑芽每年都会为姐姐咲季准备情人节巧克力。", "咲季几乎不吃巧克力或普通点心，偏好高蛋白食物如蛋白粉和鸡胸肉。", "莉波提议将咲季喜欢的元素组合起来制作礼物。", "莉波和佑芽计划第二天一起去购买材料并尝试制作。"], "relationship_facts": ["佑芽是咲季的妹妹。", "莉波是佑芽的学姐。", "咲季是莉波的同学。"], "worldbuilding_facts": ["情人节期间有给女性长辈或姐姐准备巧克力的习俗。", "咲季偏好高蛋白饮食，如蛋白粉和鸡胸肉。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00132", "scene_id": "scene-00132", "source_file": "CSV/csprt/csprt-3-0047/adv_csprt-3-0047_02.csv", "source_kind": "csprt", "chapter": "csprt/csprt-3-0047", "scene": "adv_csprt-3-0047_02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-3-0047/adv_csprt-3-0047_02.csv:1-20"], "line_count": 20, "speakers": ["众人", "佑芽", "咲季", "莉波"], "topics": ["relationships", "team_story", "dialogue_style", "character_arc"], "title": "佑芽制作蛋白棒", "summary": "佑芽展示试作1号蛋白棒，莉波品尝并称赞。两人收到姐姐的限时食用提醒，佑芽懊恼忘记惊喜。众人合影纪念成果，咲季提及姬崎学姐发来消息，佑芽为咲季考虑而接受安排。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "莉波", "姐姐"], "worldbuilding_signals": [], "dialogue_style_signals": ["真是的", "哼", "呵呵", "嘿嘿", "啦"], "key_evidence": [{"source_row": "2", "speaker": "佑芽", "text_zh": "用蛋白粉、坚果和果干裹上黑巧克力做成蛋白棒！"}, {"source_row": "12", "speaker": "咲季", "text_zh": "仅限今天哦？注意别吃太多呢。"}, {"source_row": "20", "speaker": "咲季", "text_zh": "啊，姬崎学姐发来……佑芽真是的♡"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["佑芽完成了试作1号蛋白棒。", "莉波和佑芽都收到了姐姐的限时食用提醒。", "众人正在为蛋白棒制作成果拍照纪念。", "咲季提到姬崎学姐发来了消息。"], "relationship_facts": ["莉波是佑芽的学姐。", "咲季是佑芽的姐姐。", "姬崎是咲季的姐姐（或相关长辈）。"], "worldbuilding_facts": ["角色们有制作和食用蛋白棒的习惯。", "角色之间存在通过消息提醒饮食限制的互动。", "角色们重视制作成果并拍照留念。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00133", "scene_id": "scene-00133", "source_file": "CSV/csprt/csprt-3-0052/adv_csprt-3-0052_01.csv", "source_kind": "csprt", "chapter": "csprt/csprt-3-0052", "scene": "adv_csprt-3-0052_01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-3-0052/adv_csprt-3-0052_01.csv:1-20"], "line_count": 20, "speakers": ["佑芽", "咲季"], "topics": ["relationships", "worldbuilding", "dialogue_style", "team_story"], "title": "佑芽的偶像觉悟", "summary": "咲季询问佑芽是否记得决定成为偶像的日子。佑芽坦言自己曾一直追逐咲季背影，直到确定能一起入学才真正心动，但认为那并非梦想起点。咲季肯定佑芽已是出色偶像，佑芽则坚持想独自寻找答案。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "姐姐"], "worldbuilding_signals": ["学园", "偶像"], "dialogue_style_signals": ["当然", "嘿嘿", "啦"], "key_evidence": [{"source_row": "4", "speaker": "咲季", "text_zh": "我要进入初星学园，成为顶尖偶像！"}, {"source_row": "10", "speaker": "佑芽", "text_zh": "当确定能一起入学，一起拍纪念照的时候"}, {"source_row": "16", "speaker": "咲季", "text_zh": "现在的你，已经是一位出色的偶像了。"}, {"source_row": "20", "speaker": "佑芽", "text_zh": "我想自己烦恼，自己想出答案。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季与佑芽决定共同成为偶像。", "佑芽梦想成为偶像的瞬间是确定能一起入学时。", "咲季认为佑芽已是出色的偶像。", "佑芽希望独自烦恼并寻找答案。"], "relationship_facts": ["咲季是佑芽的姐姐。", "咲季愿意为佑芽担保。", "佑芽超级相信咲季的话。"], "worldbuilding_facts": ["两人决定进入初星学园。", "初星学园是顶尖偶像的培养地。", "成为偶像需要一起入学并拍纪念照。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00134", "scene_id": "scene-00134", "source_file": "CSV/csprt/csprt-3-0052/adv_csprt-3-0052_02.csv", "source_kind": "csprt", "chapter": "csprt/csprt-3-0052", "scene": "adv_csprt-3-0052_02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-3-0052/adv_csprt-3-0052_02.csv:1-20"], "line_count": 20, "speakers": ["佑芽", "咲季"], "topics": ["relationships", "dialogue_style", "worldbuilding", "team_story"], "title": "咲季与佑芽的休息时光", "summary": "花海咲季来到佑芽房间共度休息日，承认偶像日程严酷并决定优先恢复。咲季起初想直接睡觉，后认同聊天能消除疲惫，决定与佑芽彻夜长谈，展现了对妹妹的宠溺与自我调节。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "妹妹", "姐姐"], "worldbuilding_signals": ["偶像", "工作"], "dialogue_style_signals": ["哼", "啦"], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "佑芽！姐姐来陪你啦！"}, {"source_row": "10", "speaker": "咲季", "text_zh": "重新认识到……偶像的日程原来这么严酷啊。"}, {"source_row": "20", "speaker": "咲季", "text_zh": "今天要一直聊天哦，佑芽。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["花海咲季来到佑芽房间共度休息日。", "咲季承认偶像日程严酷，决定优先恢复。", "咲季决定与佑芽彻夜聊天以消除疲惫。"], "relationship_facts": ["咲季是佑芽的姐姐。", "佑芽是咲季的妹妹。", "两人关系亲密，咲季宠溺佑芽。"], "worldbuilding_facts": ["花海咲季是偶像。", "偶像的日程非常严酷。", "聊天是消除心灵疲惫的有效方式。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00135", "scene_id": "scene-00135", "source_file": "CSV/csprt/csprt-3-0052/adv_csprt-3-0052_03.csv", "source_kind": "csprt", "chapter": "csprt/csprt-3-0052", "scene": "adv_csprt-3-0052_03", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-3-0052/adv_csprt-3-0052_03.csv:1-20"], "line_count": 20, "speakers": ["佑芽", "咲季"], "topics": ["relationships", "worldbuilding", "team_story"], "title": "咲季憧憬的偶像揭晓", "summary": "佑芽向咲季提起其成为偶像的契机，咲季承认曾想成为某位帅气偶像。佑芽推算出该偶像是自己，虽一度视其为对手，咲季却表白佑芽才是她心中从相遇起最棒的偶像，化解了敌对情绪。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "姐姐", "朋友"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": [], "key_evidence": [{"source_row": "6", "speaker": "咲季", "text_zh": "有一个很帅气的偶像呢。"}, {"source_row": "11", "speaker": "佑芽", "text_zh": "让姐姐憧憬的那个人。"}, {"source_row": "20", "speaker": "咲季", "text_zh": "从相遇的那天起，就是最棒的偶像了。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季成为偶像的契机是憧憬一位帅气的偶像。", "佑芽通过朋友推算出咲季憧憬的偶像就是自己。", "咲季最终承认佑芽是她心中最棒的偶像。"], "relationship_facts": ["佑芽与咲季是姐妹关系。", "咲季视佑芽为最棒的偶像。", "佑芽曾将咲季视为偶像竞争上的敌人。"], "worldbuilding_facts": ["咲季和佑芽都是偶像。", "咲季对成为偶像的动机曾长期保密。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00136", "scene_id": "scene-00136", "source_file": "CSV/csprt/csprt-3-0054/adv_csprt-3-0054_01.csv", "source_kind": "csprt", "chapter": "csprt/csprt-3-0054", "scene": "adv_csprt-3-0054_01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-3-0054/adv_csprt-3-0054_01.csv:1-20"], "line_count": 20, "speakers": ["咲季", "莉莉娅"], "topics": ["character_arc"], "title": "咲季向莉莉娅求教", "summary": "咲季在格斗游戏对战中败给莉莉娅，感叹自己作为新手难以战胜老手。她决定重新练习并再次挑战，随后恳求莉莉娅担任教练。莉莉娅欣然答应，两人通过特训增进感情，咲季对格斗游戏产生了浓厚兴趣，并约定下次再决胜负。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["莉莉娅"], "worldbuilding_signals": [], "dialogue_style_signals": [], "key_evidence": [{"source_row": "2", "speaker": "咲季", "text_zh": "又是我输了呢，莉莉娅。"}, {"source_row": "10", "speaker": "咲季", "text_zh": "我要重新好好练习，再来挑战你！"}, {"source_row": "12", "speaker": "莉莉娅", "text_zh": "……要我教你吗？"}, {"source_row": "19", "speaker": "莉莉娅", "text_zh": "我觉得小咲季很适合玩格斗游戏。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季在格斗游戏对战中输给了莉莉娅。", "咲季决定重新练习并再次向莉莉娅挑战。", "莉莉娅同意担任咲季的格斗游戏教练。", "咲季认为莉莉娅是格斗游戏的老手。"], "relationship_facts": ["咲季与莉莉娅是朋友关系。", "莉莉娅是咲季在格斗游戏上的指导者。", "咲季对莉莉娅喜欢的游戏表现出兴趣。"], "worldbuilding_facts": ["格斗游戏是咲季和莉莉娅共同参与的娱乐活动。", "咲季此前在卡牌游戏和桌游中常输给莉莉娅。", "咲季认为新手想赢过老手并不容易。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00137", "scene_id": "scene-00137", "source_file": "CSV/csprt/csprt-3-0054/adv_csprt-3-0054_02.csv", "source_kind": "csprt", "chapter": "csprt/csprt-3-0054", "scene": "adv_csprt-3-0054_02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-3-0054/adv_csprt-3-0054_02.csv:1-20"], "line_count": 20, "speakers": ["咲季", "莉莉娅"], "topics": ["dialogue_style", "team_story"], "title": "咲季热爱格斗游戏", "summary": "咲季向莉莉娅展示自己在格斗游戏上的巨大进步，强调练习与战术预判的重要性。她认为室内电竞与户外运动同样有趣，打破了莉莉娅对她只喜欢户外运动的刻板印象，两人随即准备共同享受游戏。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["莉莉娅"], "worldbuilding_signals": [], "dialogue_style_signals": ["哼", "呵呵", "啦"], "key_evidence": [{"source_row": "3", "speaker": "咲季", "text_zh": "记住了所有角色的技能。"}, {"source_row": "6", "speaker": "咲季", "text_zh": "格斗游戏，和体育竞技真的很像呢。"}, {"source_row": "15", "speaker": "咲季", "text_zh": "好玩的东西就是好玩！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季通过大量练习掌握了游戏角色技能、连招及战术预判。", "咲季认为格斗游戏与体育竞技非常相似，电子竞技的说法很贴切。", "咲季表示无论是室内还是户外，好玩的事物都值得投入。"], "relationship_facts": ["咲季与莉莉娅是共同游玩游戏的伙伴。", "莉莉娅原本认为咲季更喜欢户外运动，对咲季喜欢室内游戏感到意外。", "咲季邀请莉莉娅一起享受这部名作游戏。"], "worldbuilding_facts": ["咲季在游戏中记住了所有角色的技能、特征、动作及连招。", "游戏涉及走位、流行战术及攻防预判等竞技要素。", "游戏被咲季视为一部值得享受的‘名作’。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00138", "scene_id": "scene-00138", "source_file": "CSV/csprt/csprt-3-0054/adv_csprt-3-0054_03.csv", "source_kind": "csprt", "chapter": "csprt/csprt-3-0054", "scene": "adv_csprt-3-0054_03", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-3-0054/adv_csprt-3-0054_03.csv:1-20"], "line_count": 20, "speakers": ["咲季", "莉莉娅"], "topics": ["dialogue_style"], "title": "咲季发现莉莉娅猛犸象级", "summary": "咲季因想进步而询问莉莉娅的游戏等级，得知自己刚升大象级后，惊讶发现莉莉娅已是传说中的猛犸象级。咲季想以此调侃，莉莉娅因实力过于强大且不愿炫耀而感到困扰，咲季随即道歉并理解莉莉娅的性格。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["莉莉娅"], "worldbuilding_signals": [], "dialogue_style_signals": ["真是的", "啦"], "key_evidence": [{"source_row": "5", "speaker": "咲季", "text_zh": "我昨天才刚升到大象级"}, {"source_row": "10", "speaker": "咲季", "text_zh": "传……传说中的猛犸象级……"}, {"source_row": "17", "speaker": "咲季", "text_zh": "莉莉娅是那种不太喜欢炫耀自己实力的类型呢"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季昨天刚升到大象级。", "莉莉娅的游戏等级是传说中的猛犸象级。", "咲季想给莉莉娅起猛犸象级的绰号。", "莉莉娅不喜欢在外人面前炫耀自己的实力。"], "relationship_facts": ["咲季与莉莉娅是同学关系。", "咲季对莉莉娅的实力感到惊讶并带有调侃。", "莉莉娅对咲季的调侃感到困扰并请求停止。"], "worldbuilding_facts": ["游戏等级分为大象级和猛犸象级。", "猛犸象级是传说中的顶级领域。", "游戏排名榜是公开查询等级的途径。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00139", "scene_id": "scene-00139", "source_file": "CSV/csprt/csprt-3-0057/adv_csprt-3-0057_01.csv", "source_kind": "csprt", "chapter": "csprt/csprt-3-0057", "scene": "adv_csprt-3-0057_01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-3-0057/adv_csprt-3-0057_01.csv:1-20"], "line_count": 20, "speakers": ["咲季", "手毬", "琴音"], "topics": ["relationships", "team_story", "dialogue_style", "worldbuilding"], "title": "咲季与队友的感谢时刻", "summary": "训练结束后，咲季提议回宿舍并主动为队友按摩。手毬与琴音借此机会表达感激，手毬感谢咲季的支持助其恢复状态，琴音则称咲季是救命恩人。咲季谦虚回应并展望未来成为顶级偶像支援者，众人约定明年继续同班。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["琴音", "手毬"], "worldbuilding_signals": ["偶像", "训练"], "dialogue_style_signals": ["啦"], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "呼～！自主训练结束！辛苦了，你们两个。"}, {"source_row": "5", "speaker": "手毬", "text_zh": "一直以来谢谢你的支持。"}, {"source_row": "13", "speaker": "琴音", "text_zh": "要是没有咲季的按摩，我肯定早就累垮了。"}, {"source_row": "20", "speaker": "手毬", "text_zh": "希望明年也能同班呢。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季结束自主训练后提议回宿舍并为队友按摩。", "手毬感谢咲季的支持，认为其帮助自己从低谷恢复。", "琴音感谢咲季的按摩，称其为救命恩人。", "咲季表示从队友身上也收获良多，并立志成为顶级偶像支援者。"], "relationship_facts": ["咲季与手毬、琴音是队友关系。", "咲季与手毬、琴音之间互相关心且关系亲密。", "咲季与手毬、琴音约定明年继续同班。"], "worldbuilding_facts": ["咲季目前是偶像支援者，目标是成为顶级偶像支援者。", "手毬之前状态很差，现已恢复。", "琴音曾在春天时期因打工而非常劳累。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00140", "scene_id": "scene-00140", "source_file": "CSV/csprt/csprt-3-0057/adv_csprt-3-0057_02.csv", "source_kind": "csprt", "chapter": "csprt/csprt-3-0057", "scene": "adv_csprt-3-0057_02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-3-0057/adv_csprt-3-0057_02.csv:1-20"], "line_count": 20, "speakers": ["咲季", "手毬", "琴音"], "topics": ["team_story", "relationships", "dialogue_style", "character_arc"], "title": "三人互助训练总结", "summary": "手毬结束训练，称赞咲季与琴音进步显著。咲季感谢手毬教导，手毬表示只是复习旧法。三人互相学习唱歌、舞蹈及训练菜单，建立了互利关系。咲季将这种关系定义为无可替代的友情之力，手毬虽调侃实为利用，但也认可这种关系即为朋友。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "琴音", "手毬", "朋友"], "worldbuilding_signals": ["偶像", "训练"], "dialogue_style_signals": ["嘿嘿", "啦"], "key_evidence": [{"source_row": "3", "speaker": "咲季", "text_zh": "嘿嘿～没错吧～♪"}, {"source_row": "6", "speaker": "咲季", "text_zh": "托你的福我的唱功提升了很多。"}, {"source_row": "13", "speaker": "咲季", "text_zh": "没想到在班级里能建立起这么互利的关系呢。"}, {"source_row": "14", "speaker": "咲季", "text_zh": "佑芽！我也终于获得了！无可替代的友情之力！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["手毬结束训练并肯定咲季与琴音的进步。", "咲季感谢手毬，手毬称教学是复习旧法。", "三人互相学习唱歌、舞蹈及训练菜单。", "咲季将互利关系定义为友情之力。"], "relationship_facts": ["手毬是咲季和琴音的同伴及教导者。", "咲季与琴音、手毬之间建立了互利关系。", "咲季视手毬为无可替代的朋友。"], "worldbuilding_facts": ["手毬曾是中等部的首席偶像。", "咲季从手毬处学习了唱歌技巧。", "手毬从琴音处学习了舞蹈和应援动作。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00141", "scene_id": "scene-00141", "source_file": "CSV/csprt/csprt-3-0057/adv_csprt-3-0057_03.csv", "source_kind": "csprt", "chapter": "csprt/csprt-3-0057", "scene": "adv_csprt-3-0057_03", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-3-0057/adv_csprt-3-0057_03.csv:1-20"], "line_count": 20, "speakers": ["众人", "咲季", "手毬", "清夏", "琴音"], "topics": ["team_story", "relationships", "dialogue_style"], "title": "咲季厨艺与组合风波", "summary": "咲季展示厨艺获众人称赞，随后话题转向三人组合构想。手毬担忧咲季强势个性会导致组合内争吵，咲季则反驳手毬会引发混乱，两人激烈争执，琴音感叹若组队精神恐会崩溃。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["琴音", "手毬", "清夏"], "worldbuilding_signals": [], "dialogue_style_signals": ["当然", "嘿嘿", "啦"], "key_evidence": [{"source_row": "4", "speaker": "琴音", "text_zh": "哎呀，咲季的厨艺，真的进步好多呢～"}, {"source_row": "16", "speaker": "手毬", "text_zh": "因为要是同舟共济的话，你会比现在更强势地推行自己的想法吧。"}, {"source_row": "17", "speaker": "咲季", "text_zh": "像手毬你这样的，肯定会把组合卷入麻烦闹得鸡飞狗跳啦！"}, {"source_row": "20", "speaker": "琴音", "text_zh": "要是和这些人组队……我的精神恐怕会崩溃吧……"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季的厨艺获得手毬和琴音的高度评价。", "手毬认为咲季在组合中会因强势推行想法而引发争吵。", "咲季反驳手毬，认为手毬会因卷入麻烦导致组合鸡飞狗跳。", "琴音担心与咲季和手毬组队会导致自己精神崩溃。"], "relationship_facts": ["咲季与手毬因性格差异对组合构想产生激烈争执。", "琴音作为旁观者，对咲季和手毬的冲突感到担忧。", "咲季与手毬互相指责对方是组合失败的潜在原因。"], "worldbuilding_facts": ["咲季近期厨艺有了显著进步。", "咲季性格强势，习惯推行自己的想法。", "手毬性格强势，容易将组合卷入麻烦。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00142", "scene_id": "scene-00142", "source_file": "CSV/csprt/csprt-3-0059/adv_csprt-3-0059_01.csv", "source_kind": "csprt", "chapter": "csprt/csprt-3-0059", "scene": "adv_csprt-3-0059_01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-3-0059/adv_csprt-3-0059_01.csv:1-20"], "line_count": 20, "speakers": ["咲季", "手毬", "清夏", "琴音", "莉莉娅"], "topics": ["team_story", "relationships", "dialogue_style"], "title": "彩票游戏与CD出道", "summary": "众人庆祝琴音中奖，手毬宣布CD出道并收取祝贺金。咲季作为第一名被调侃，清夏宣布写真集发售。莉莉娅因购买手办已付钱，决心要赢过咲季。大家在游戏中互动，关系更加融洽。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["琴音", "手毬", "清夏", "莉莉娅"], "worldbuilding_signals": [], "dialogue_style_signals": ["真是的", "啦"], "key_evidence": [{"source_row": "5", "speaker": "手毬", "text_zh": "作为祝贺从每个人那里拿到5000万……"}, {"source_row": "7", "speaker": "咲季", "text_zh": "真是的，既然是祝贺就痛快付钱嘛！"}, {"source_row": "14", "speaker": "莉莉娅", "text_zh": "因为已经得到手办了，所以相当于免费！"}, {"source_row": "20", "speaker": "清夏", "text_zh": "我们也变得要好了呢。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["手毬宣布CD出道决定，并向每人收取5000万日元祝贺金。", "清夏宣布写真集发售决定，同样向每人收取5000万日元祝贺金。", "莉莉娅因已购买等身大手办，认为相当于免费，决心要赢过咲季。", "琴音因连续支付祝贺金，感叹自己的1亿日元已归零。"], "relationship_facts": ["咲季在游戏中排名第一，被琴音调侃摆架子。", "手毬和清夏作为前辈或朋友，主导游戏并收取祝贺金。", "莉莉娅视咲季为追赶目标，决心在游戏中胜过她。"], "worldbuilding_facts": ["游戏设定为每人需支付5000万日元作为祝贺金。", "中奖金额为1亿日元，足以支付多次祝贺金。", "角色间存在购买等身大手办等消费行为。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00143", "scene_id": "scene-00143", "source_file": "CSV/csprt/csprt-3-0059/adv_csprt-3-0059_02.csv", "source_kind": "csprt", "chapter": "csprt/csprt-3-0059", "scene": "adv_csprt-3-0059_02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-3-0059/adv_csprt-3-0059_02.csv:1-20"], "line_count": 20, "speakers": ["众人", "咲季", "琴音", "莉莉娅"], "topics": ["team_story", "relationships", "dialogue_style"], "title": "咲季接受莉莉娅饼干", "summary": "莉莉娅为班级同学制作低糖低卡饼干，邀请咲季和琴音品尝。咲季起初因顾虑拒绝，得知是剩余材料制作后接受心意。众人品尝后大赞美味，咲季决定向莉莉娅学习烘焙，并计划给佑芽制作，同时提议放学后运动消耗热量。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "琴音", "清夏", "莉莉娅"], "worldbuilding_signals": [], "dialogue_style_signals": ["当然", "啦"], "key_evidence": [{"source_row": "6", "speaker": "莉莉娅", "text_zh": "是用低糖低卡的配方做的……！"}, {"source_row": "11", "speaker": "咲季", "text_zh": "原来考虑到这种程度啊……谢谢你。"}, {"source_row": "17", "speaker": "咲季", "text_zh": "我也想给佑芽做呢！莉莉娅能教我吗？"}, {"source_row": "20", "speaker": "咲季", "text_zh": "得把刚才摄入的热量消耗掉才行。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["莉莉娅用剩余材料制作了低糖低卡饼干分给同学。", "咲季在了解饼干制作初衷后接受了莉莉娅的心意。", "咲季决定向莉莉娅学习烘焙并计划给佑芽制作。", "咲季提议放学后运动以消耗摄入的热量。"], "relationship_facts": ["咲季与琴音是亲密的朋友。", "咲季与佑芽关系亲密，计划为其制作点心。", "咲季与莉莉娅是朋友，咲季向莉莉娅学习烘焙。"], "worldbuilding_facts": ["班级同学之间存在分享自制点心的社交活动。", "角色们关注饮食健康，偏好低糖低卡配方。", "角色们有通过运动消耗热量的生活习惯。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00144", "scene_id": "scene-00144", "source_file": "CSV/csprt/csprt-3-0068/adv_csprt-3-0068_01.csv", "source_kind": "csprt", "chapter": "csprt/csprt-3-0068", "scene": "adv_csprt-3-0068_01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-3-0068/adv_csprt-3-0068_01.csv:1-20"], "line_count": 20, "speakers": ["咲季", "手毬", "琴音"], "topics": ["relationships", "team_story", "plot", "worldbuilding"], "title": "咲季立志超越会长", "summary": "咲季、手毬与琴音在星南会长演唱会后聚餐。咲季受演唱会激励，立志通过努力站上同样舞台并超越会长。她强调饮食均衡，教导手毬摄取膳食纤维与蔬菜，展现出作为前辈的关怀与决心。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["琴音", "手毬", "星南", "妹妹"], "worldbuilding_signals": ["演唱会"], "dialogue_style_signals": ["当然", "啦"], "key_evidence": [{"source_row": "8", "speaker": "咲季", "text_zh": "今天的演唱会对我来说，也是很好的激励呢。"}, {"source_row": "11", "speaker": "咲季", "text_zh": "我很快就要站上同样的舞台，超越会长给你看！"}, {"source_row": "17", "speaker": "咲季", "text_zh": "摄取膳食纤维可以减缓脂肪的吸收哦。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季受星南会长演唱会激励，决心超越会长。", "咲季教导手毬饮食需均衡，强调摄取膳食纤维。", "咲季在聚餐中展现出对后辈的关怀与指导。"], "relationship_facts": ["咲季与手毬、琴音关系亲密，常一起活动。", "咲季视手毬为需要指导的后辈。", "咲季与星南会长存在竞争关系。"], "worldbuilding_facts": ["星南会长是偶像团体成员，拥有极高人气。", "咲季的目标是站上与会长同样的舞台。", "咲季具备营养学知识，了解膳食纤维作用。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00145", "scene_id": "scene-00145", "source_file": "CSV/csprt/csprt-3-0068/adv_csprt-3-0068_02.csv", "source_kind": "csprt", "chapter": "csprt/csprt-3-0068", "scene": "adv_csprt-3-0068_02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-3-0068/adv_csprt-3-0068_02.csv:1-20"], "line_count": 20, "speakers": ["咲季", "手毬", "琴音", "配膳ロボ"], "topics": ["relationships", "team_story", "dialogue_style"], "title": "咲季与甜点时光", "summary": "琴音提议打折甜点，咲季与手毬讨论游玩乐趣，咲季提议下次叫上佑芽。手毬想摸送餐机器人，机器人做出可爱表情，手毬惊喜互动，琴音调侃机器人似乎被讨厌。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "琴音", "手毬"], "worldbuilding_signals": [], "dialogue_style_signals": ["哼", "呵呵"], "key_evidence": [{"source_row": "1", "speaker": "琴音", "text_zh": "甜点选什么好呢♪难得有30%的折扣呢。"}, {"source_row": "7", "speaker": "咲季", "text_zh": "我也玩得非常开心哦。不过一天时间根本玩不够呢。"}, {"source_row": "16", "speaker": "配膳ロボ", "text_zh": "＾▽＾"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["甜点店正在提供30%折扣优惠。", "咲季表示和手毬、琴音玩得很开心但时间不够。", "手毬对配膳机器人的可爱反应感到惊喜。"], "relationship_facts": ["咲季、手毬、琴音是经常一起玩耍的熟人。", "琴音提到咲季和手毬已经和佑芽混熟了。", "手毬与配膳机器人有轻松互动的关系。"], "worldbuilding_facts": ["餐厅提供由配膳机器人送餐的服务。", "配膳机器人具有简单的表情反馈功能。", "角色们正在参与五人制足球等体育活动。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00146", "scene_id": "scene-00146", "source_file": "CSV/csprt/csprt-3-0068/adv_csprt-3-0068_03.csv", "source_kind": "csprt", "chapter": "csprt/csprt-3-0068", "scene": "adv_csprt-3-0068_03", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-3-0068/adv_csprt-3-0068_03.csv:1-20"], "line_count": 20, "speakers": ["ことねの妹", "咲季", "手毬", "琴音"], "topics": ["relationships", "team_story", "dialogue_style", "worldbuilding"], "title": "咲季探访初星学园", "summary": "咲季与手毬偶遇正在参观校园开放日的琴音之妹。咲季确认妹妹并非报考初星，而是为看姐姐演唱会而来。随后咲季带众人前往食堂，推荐偶像盖饭，并安抚琴音之妹不必担心琴音的适应情况。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["琴音", "手毬", "妹妹", "姐姐"], "worldbuilding_signals": ["学园", "偶像", "演唱会"], "dialogue_style_signals": ["呵呵", "嘿嘿", "啦"], "key_evidence": [{"source_row": "7", "speaker": "ことねの妹", "text_zh": "我报名参加了初星学园的校园开放日。"}, {"source_row": "10", "speaker": "ことねの妹", "text_zh": "难得有机会，就想看看姐姐平时都在做些什么嘛……"}, {"source_row": "20", "speaker": "咲季", "text_zh": "我推荐健康又营养的偶像盖饭哦！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["琴音之妹参加了初星学园的校园开放日。", "咲季确认琴音之妹并非为了报考初星而来。", "咲季向众人推荐了食堂的偶像盖饭。"], "relationship_facts": ["咲季是琴音的姐姐。", "手毬是咲季的同伴。", "琴音之妹是琴音的妹妹。"], "worldbuilding_facts": ["初星学园正在举办校园开放日活动。", "初星学园食堂提供名为“偶像盖饭”的菜品。", "桥对面有一座礼堂。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00147", "scene_id": "scene-00147", "source_file": "CSV/csprt/csprt-3-0075/adv_csprt-3-0075_03.csv", "source_kind": "csprt", "chapter": "csprt/csprt-3-0075", "scene": "adv_csprt-3-0075_03", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-3-0075/adv_csprt-3-0075_03.csv:1-20"], "line_count": 20, "speakers": ["佑芽", "千奈", "咲季", "广", "手毬", "琴音"], "topics": ["team_story", "relationships", "dialogue_style", "worldbuilding"], "title": "家政课回礼与学园交流", "summary": "千奈与佑芽、广在家政课制作蝴蝶结饼干回礼给藤田。咲季品尝后称赞味道不错。千奈借此机会向藤田表达跨越班级界限与大家交流的开心心情，藤田则询问其身体状况。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "琴音", "手毬", "广", "姐姐"], "worldbuilding_signals": ["学园"], "dialogue_style_signals": ["呵呵", "嘿嘿", "啦"], "key_evidence": [{"source_row": "14", "speaker": "咲季", "text_zh": "嘿！做得相当不错嘛！"}, {"source_row": "15", "speaker": "千奈", "text_zh": "各位如果不介意的话也请用如何？"}, {"source_row": "20", "speaker": "千奈", "text_zh": "能跨越班级的界限和大家交流，我也非常开心呢！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["千奈、佑芽和广共同制作了蝴蝶结造型的饼干作为回礼。", "咲季品尝了饼干并称赞制作水平相当不错。", "千奈向藤田同学表达了跨越班级界限与大家交流的愉快心情。"], "relationship_facts": ["千奈与佑芽、广是亲密的朋友，经常一起制作点心。", "千奈与藤田同学关系良好，藤田曾为千奈制作发饰造型饼干。", "咲季与千奈、佑芽等人处于同一社交圈，能参与分享食物。"], "worldbuilding_facts": ["学校设有家政课，学生在此学习制作点心。", "学园内不同班级之间存在交流机会，并非完全隔绝。", "学园生活丰富多彩，能带来跨越班级界限的愉快体验。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00148", "scene_id": "scene-00148", "source_file": "CSV/csprt/csprt-3-0077/adv_csprt-3-0077_01.csv", "source_kind": "csprt", "chapter": "csprt/csprt-3-0077", "scene": "adv_csprt-3-0077_01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-3-0077/adv_csprt-3-0077_01.csv:1-20"], "line_count": 20, "speakers": ["優", "千奈", "咲季"], "topics": ["worldbuilding", "character_arc", "dialogue_style", "relationships"], "title": "咲季指导千奈拉伸", "summary": "训练结束后，咲季指导千奈进行拉伸以缓解乳酸堆积。千奈称赞咲季特制的SSD饮品效果显著，咲季则透露刚为真城学姐制作了新品。此时优突然出现，千奈热情招呼，咲季顺势提及正在谈论真城学姐，让优感到不安。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["姐姐"], "worldbuilding_signals": ["训练", "工作"], "dialogue_style_signals": ["呵呵"], "key_evidence": [{"source_row": "7", "speaker": "咲季", "text_zh": "训练结束后，让身体冷静下来很重要。"}, {"source_row": "12", "speaker": "千奈", "text_zh": "是咲季姐姐特制的SSD！对吧！"}, {"source_row": "15", "speaker": "咲季", "text_zh": "其实我为真城学姐做了新品。"}, {"source_row": "19", "speaker": "咲季", "text_zh": "真城学姐！我们刚刚正好在谈论学姐呢！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["训练结束后咲季指导千奈进行身体拉伸。", "千奈认为咲季特制的SSD饮品改善了身体状况。", "咲季透露刚为真城学姐制作了以茶为基础的新品SSD。", "优突然出现，千奈热情招呼，咲季顺势提及正在谈论真城学姐。"], "relationship_facts": ["咲季是千奈的姐姐。", "咲季与真城学姐关系良好，常为其制作饮品。", "优是咲季和千奈的同伴或后辈。"], "worldbuilding_facts": ["SSD是一种具有健康功效的饮品。", "训练后需要拉伸以缓解乳酸堆积。", "咲季制作的SSD味道评价并不好。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00149", "scene_id": "scene-00149", "source_file": "CSV/csprt/csprt-3-0077/adv_csprt-3-0077_02.csv", "source_kind": "csprt", "chapter": "csprt/csprt-3-0077", "scene": "adv_csprt-3-0077_02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-3-0077/adv_csprt-3-0077_02.csv:1-20"], "line_count": 20, "speakers": ["優", "千奈", "咲季"], "topics": ["dialogue_style", "team_story"], "title": "咲季改良花草茶", "summary": "咲季为真城学姐改良了以花草茶为基础的茶饮，特别针对运动量少的人群研发，兼具排毒与美白功效。优品尝后赞不绝口，形容其风味壮丽热情且充满活力，千奈也对此感到惊喜。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["广"], "worldbuilding_signals": [], "dialogue_style_signals": ["当然", "呵呵"], "key_evidence": [{"source_row": "4", "speaker": "咲季", "text_zh": "我试着为真城学姐改良了SSD。"}, {"source_row": "7", "speaker": "咲季", "text_zh": "这次是以花草茶为基础进行了调配。"}, {"source_row": "14", "speaker": "優", "text_zh": "仿佛置身南国般的壮丽风味。"}, {"source_row": "20", "speaker": "千奈", "text_zh": "SST！诞生的瞬间呢～～～！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季为真城学姐改良了SSD（此处指代茶饮产品）", "该茶饮以花草茶为基础，添加了玫瑰果、木槿等成分", "优对改良后的茶饮评价极高，要求续杯", "千奈认为该茶饮诞生瞬间如同SST（特殊时刻）"], "relationship_facts": ["咲季与真城学姐存在前辈后辈关系", "优与咲季是同事或同学关系", "千奈与咲季是同事或同学关系"], "worldbuilding_facts": ["咲季具备调配花草茶的专业技能", "该茶饮具有排毒和美白功效", "SST是千奈用来形容重要时刻的术语"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00150", "scene_id": "scene-00150", "source_file": "CSV/csprt/csprt-3-0077/adv_csprt-3-0077_03.csv", "source_kind": "csprt", "chapter": "csprt/csprt-3-0077", "scene": "adv_csprt-3-0077_03", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-3-0077/adv_csprt-3-0077_03.csv:1-20"], "line_count": 20, "speakers": ["千奈", "咲季"], "topics": ["relationships", "dialogue_style", "team_story"], "title": "咲季赠予千奈SSD", "summary": "千奈感谢咲季姐姐的晨练指导与餐点准备，咲季表示这是自愿且乐在其中的事。咲季称赞千奈作为二班首领的潜力，并赠予其改良口味的SSD，鼓励千奈像真城前辈一样豪爽，千奈则坚持要效果最好的版本。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["姐姐"], "worldbuilding_signals": [], "dialogue_style_signals": ["呵呵"], "key_evidence": [{"source_row": "14", "speaker": "咲季", "text_zh": "来，给你。这是千奈那份SSD。"}, {"source_row": "5", "speaker": "咲季", "text_zh": "因为大家都说想通过晨练来增强体力，我只是顺便照看下而已。"}, {"source_row": "16", "speaker": "咲季", "text_zh": "对了，你要不要也像真城前辈那样——"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季为千奈准备了改良口味的SSD。", "咲季认为晨练和准备餐点是自愿且乐在其中的事。", "咲季称赞千奈作为二班首领拥有许多值得学习之处。"], "relationship_facts": ["咲季与千奈是同级生关系。", "咲季视千奈为值得学习的二班首领。", "咲季与真城前辈存在前辈后辈的关联。"], "worldbuilding_facts": ["角色们会进行晨间练习以增强体力。", "SSD是一种需要改良口味或追求效果的物品。", "筱泽同学和花海同学也是咲季照顾的对象。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00151", "scene_id": "scene-00151", "source_file": "CSV/csprt/csprt-3-0078/adv_csprt-3-0078_01.csv", "source_kind": "csprt", "chapter": "csprt/csprt-3-0078", "scene": "adv_csprt-3-0078_01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-3-0078/adv_csprt-3-0078_01.csv:1-20"], "line_count": 20, "speakers": ["众人", "佑芽", "千奈", "广", "舞蹈训练师", "麻央"], "topics": ["relationships", "team_story", "dialogue_style", "character_arc"], "title": "咲季奥义压制佑芽", "summary": "佑芽在腕相扑连胜十人后，被麻央用从咲季处继承的合气道奥义击败。麻央将对方力量化解引导，佑芽攻势停住。众人被舞蹈训练师制止，咲季虽未现身，但其传授的招式成为关键转折。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "麻央", "广", "姐姐"], "worldbuilding_signals": ["训练"], "dialogue_style_signals": ["哼"], "key_evidence": [{"source_row": "2", "speaker": "千奈", "text_zh": "这已经是连胜十人了呢！"}, {"source_row": "17", "speaker": "麻央", "text_zh": "就用从咲季那里继承的这招奥义"}, {"source_row": "16", "speaker": "麻央", "text_zh": "这是合气道的应用"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["佑芽在腕相扑挑战中连胜十人。", "麻央使用从咲季继承的合气道奥义击败佑芽。", "舞蹈训练师制止了众人的玩耍行为。"], "relationship_facts": ["麻央是佑芽的前辈。", "麻央从咲季处继承了合气道奥义。", "千奈和广是佑芽的同伴。"], "worldbuilding_facts": ["麻央略懂腕相扑。", "合气道可用于化解对方力量。", "训练室禁止玩耍。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00152", "scene_id": "scene-00152", "source_file": "CSV/csprt/csprt-3-0080/adv_csprt-3-0080_03.csv", "source_kind": "csprt", "chapter": "csprt/csprt-3-0080", "scene": "adv_csprt-3-0080_03", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-3-0080/adv_csprt-3-0080_03.csv:1-20"], "line_count": 20, "speakers": ["清夏", "莉莉娅"], "topics": ["team_story", "dialogue_style", "worldbuilding", "character_arc"], "title": "清夏与莉莉娅的歌唱对决", "summary": "清夏与莉莉娅进行卡拉OK分数对战，清夏获胜。清夏提及咲季常想玩此游戏，随后两人决定唱《西尔维斯塔》片头曲。清夏表示喜欢莉莉娅谈论热爱事物，鼓励其继续歌唱，两人约定再来一局。", "saki_role": "被提及对象：咲季未必直接发言，但场景信息与她的关系或评价有关。", "relationship_signals": ["清夏", "莉莉娅"], "worldbuilding_signals": ["偶像", "训练"], "dialogue_style_signals": ["当然", "哼", "呵呵", "啦"], "key_evidence": [{"source_row": "5", "speaker": "清夏", "text_zh": "虽然咲季同学经常想玩这个。"}, {"source_row": "8", "speaker": "清夏", "text_zh": "又是我赢了！"}, {"source_row": "11", "speaker": "清夏", "text_zh": "比如西尔维斯塔的片头曲"}, {"source_row": "15", "speaker": "清夏", "text_zh": "因为我最喜欢看莉莉娅谈论自己热爱事物的样子了。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["清夏与莉莉娅进行了卡拉OK分数对战。", "清夏在歌唱对战中获胜。", "两人决定演唱《西尔维斯塔》的片头曲。", "清夏表示最喜欢看莉莉娅谈论热爱事物的样子。"], "relationship_facts": ["清夏与莉莉娅是朋友，经常一起唱歌。", "清夏是立志成为偶像的人。", "清夏喜欢莉莉娅谈论自己热爱事物的样子。"], "worldbuilding_facts": ["清夏立志成为偶像。", "清夏非常擅长唱歌。", "《西尔维斯塔》是一部有片头曲的动漫。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00153", "scene_id": "scene-00153", "source_file": "CSV/csprt/csprt-3-0081/adv_csprt-3-0081_01.csv", "source_kind": "csprt", "chapter": "csprt/csprt-3-0081", "scene": "adv_csprt-3-0081_01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-3-0081/adv_csprt-3-0081_01.csv:1-20"], "line_count": 20, "speakers": ["佑芽", "咲季"], "topics": ["relationships", "dialogue_style"], "title": "佑芽给姐姐留礼物", "summary": "佑芽趁咲季熟睡时，悄悄将礼物放在枕边并欣赏其睡颜，回忆起儿时情景。因动作不慎吵醒咲季，咲季醒来后表达爱意，佑芽也回应了这份感情，两人温馨互动。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "姐姐"], "worldbuilding_signals": [], "dialogue_style_signals": ["呵呵", "嘿嘿", "啦"], "key_evidence": [{"source_row": "4", "speaker": "佑芽", "text_zh": "趁现在把礼物放在枕头边～啦。"}, {"source_row": "13", "speaker": "佑芽", "text_zh": "小时候经常这样，看着先睡着的姐姐的睡颜呢～。"}, {"source_row": "18", "speaker": "咲季", "text_zh": "……最喜欢你了，梅。"}, {"source_row": "20", "speaker": "佑芽", "text_zh": "我也最喜欢你啦！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["佑芽趁咲季熟睡时偷偷放置礼物。", "佑芽因戳醒咲季而感到惊慌。", "咲季醒来后直接对佑芽表达爱意。", "佑芽回应了咲季的爱意。"], "relationship_facts": ["咲季是佑芽的姐姐。", "咲季称呼佑芽为梅。", "两人是亲密的姐妹关系。"], "worldbuilding_facts": ["咲季睡觉时非常安静。", "咲季的脸蛋很软。", "佑芽小时候常看姐姐睡觉。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00154", "scene_id": "scene-00154", "source_file": "CSV/csprt/csprt-3-0081/adv_csprt-3-0081_02.csv", "source_kind": "csprt", "chapter": "csprt/csprt-3-0081", "scene": "adv_csprt-3-0081_02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-3-0081/adv_csprt-3-0081_02.csv:1-20"], "line_count": 20, "speakers": ["佑芽", "咲季"], "topics": ["relationships", "dialogue_style", "character_arc", "worldbuilding"], "title": "圣诞礼物与手工围巾", "summary": "咲季作为“姐姐圣诞老人”登场，为佑芽准备了大量礼物，包括训练器具、护肤品及亲手编织的围巾。佑芽感动于姐姐多年来的关爱，回忆了从过去到现在的温暖，并回赠了给咲季的礼物。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "姐姐"], "worldbuilding_signals": ["训练"], "dialogue_style_signals": ["嘿嘿", "啦"], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "姐姐圣诞老人登场啦！"}, {"source_row": "11", "speaker": "咲季", "text_zh": "今年的重头戏是这个！亲手编织的围巾！！"}, {"source_row": "20", "speaker": "佑芽", "text_zh": "我也在准备给你的礼物呢要好好期待哦！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季为佑芽准备了大量圣诞礼物。", "礼物中包含亲手编织的围巾。", "佑芽回赠了给咲季的礼物。"], "relationship_facts": ["咲季是佑芽的姐姐。", "两人关系亲密，互相表达爱意。", "咲季每年为佑芽准备手工制品。"], "worldbuilding_facts": ["场景设定在圣诞节期间。", "咲季拥有在房间锻炼的训练器具。", "咲季具备编织围巾的手工技能。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00155", "scene_id": "scene-00155", "source_file": "CSV/csprt/csprt-3-0081/adv_csprt-3-0081_03.csv", "source_kind": "csprt", "chapter": "csprt/csprt-3-0081", "scene": "adv_csprt-3-0081_03", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-3-0081/adv_csprt-3-0081_03.csv:1-20"], "line_count": 20, "speakers": ["佑芽", "咲季"], "topics": ["relationships", "team_story", "dialogue_style", "plot"], "title": "圣诞礼物与星南演唱会", "summary": "咲季与佑芽互赠周边并寄送老家礼物，随后观看星南前辈的圣诞演唱会直播。咲季视演出为学习对象，将其视为『一等星』的圣诞礼物，并以此转化为追求目标的动力。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "星南", "姐姐", "对手"], "worldbuilding_signals": ["演唱会"], "dialogue_style_signals": ["哼"], "key_evidence": [{"source_row": "3", "speaker": "咲季", "text_zh": "看来我们想到一块儿去了呢。"}, {"source_row": "10", "speaker": "佑芽", "text_zh": "正在直播星南前辈的圣诞演唱会！！"}, {"source_row": "16", "speaker": "咲季", "text_zh": "正是朝着『一等星』目标前进的"}, {"source_row": "19", "speaker": "咲季", "text_zh": "是『一等星』送来的圣诞礼物呢！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季与佑芽互相准备了大量对方喜欢的周边礼物。", "两人计划将给爷爷奶奶的留言和礼物一同寄回老家。", "咲季将星南前辈的演唱会视为『一等星』送来的圣诞礼物。", "咲季认为观看演出能转化为追求『一等星』目标的动力。"], "relationship_facts": ["咲季与佑芽是亲密的伙伴，互相支持对方。", "咲季视星南前辈为竞争对手及学习榜样。", "咲季以成为『一等星』为目标。"], "worldbuilding_facts": ["星南前辈正在举办圣诞演唱会。", "星南前辈的演唱会通过街头大屏幕进行直播。", "咲季的目标是成为『一等星』。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00156", "scene_id": "scene-00156", "source_file": "CSV/csprt/csprt-3-0085/adv_csprt-3-0085_01.csv", "source_kind": "csprt", "chapter": "csprt/csprt-3-0085", "scene": "adv_csprt-3-0085_01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-3-0085/adv_csprt-3-0085_01.csv:1-20"], "line_count": 20, "speakers": ["佑芽", "咲季", "燕"], "topics": ["relationships", "character_arc", "worldbuilding", "dialogue_style"], "title": "咲季坐禅心得与燕的点评", "summary": "佑芽因坐禅腿麻而抱怨，咲季与燕讨论坐禅心境。燕指出咲季容易混淆，但肯定其每日坚持10分钟坐禅统一精神的努力。咲季领悟到将坐禅用于训练即是实践，决定在演出前尝试，佑芽感叹这是理想的前辈后辈关系。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "姐姐"], "worldbuilding_signals": ["训练"], "dialogue_style_signals": ["哼"], "key_evidence": [{"source_row": "17", "speaker": "咲季", "text_zh": "是的。我每天都会坐禅10分钟，努力统一精神。"}, {"source_row": "8", "speaker": "燕", "text_zh": "这方面，花海姐姐就……容易混淆呢。咲季做得很好。"}, {"source_row": "19", "speaker": "咲季", "text_zh": "原来如此……！我也要试试看！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季每天坚持坐禅10分钟以统一精神。", "燕认为咲季在坐禅心境上容易混淆，但做得很好。", "咲季决定在演出前尝试坐禅。", "燕指出坐禅有助于精神安定和提升专注力。"], "relationship_facts": ["燕是咲季的前辈或指导者。", "佑芽是咲季的后辈。", "燕与咲季在坐禅修行上存在互动与评价。"], "worldbuilding_facts": ["坐禅可用于训练以统一精神。", "坐禅能提升专注力并安定精神。", "坐禅姿势需端正，呼吸需调整。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00157", "scene_id": "scene-00157", "source_file": "CSV/csprt/csprt-3-0085/adv_csprt-3-0085_02.csv", "source_kind": "csprt", "chapter": "csprt/csprt-3-0085", "scene": "adv_csprt-3-0085_02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-3-0085/adv_csprt-3-0085_02.csv:1-20"], "line_count": 20, "speakers": ["众人", "佑芽", "咲季", "燕"], "topics": ["relationships", "dialogue_style"], "title": "书法练习与成语纠错", "summary": "燕指导众人端正姿势书写，咲季自评不足并询问如何写出如前辈般漂亮的字。佑芽因用力过猛写坏字迹，燕误以为其写错成语，咲季纠正其应为“七转八起”，佑芽解释这是跌倒后站起的座右铭。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽"], "worldbuilding_signals": [], "dialogue_style_signals": ["嘿嘿", "不是吗", "啦"], "key_evidence": [{"source_row": "4", "speaker": "咲季", "text_zh": "嗯……还差点意思呢。"}, {"source_row": "7", "speaker": "咲季", "text_zh": "要怎样才能像雨夜前辈那样，写出漂亮的字呢？"}, {"source_row": "14", "speaker": "咲季", "text_zh": "佑芽，你笔上用力过猛了。"}, {"source_row": "19", "speaker": "咲季", "text_zh": "……你是想说“七转八起”吧？"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["燕指导众人悬空手臂书写以保持线条稳定。", "咲季自评写得差点意思，并询问如何写出漂亮字迹。", "佑芽因笔力过猛导致字迹粗大，被燕误认为写错成语。", "咲季指出佑芽本想写“七转八起”而非“七转八倒”。"], "relationship_facts": ["燕是众人的书法指导者。", "咲季与雨夜前辈存在仰慕关系。", "佑芽与咲季是同伴，互相纠正书写内容。"], "worldbuilding_facts": ["书法练习强调手臂悬空与中心线意识。", "“七转八倒”被用作跌倒后站起的座右铭。", "“不挠不屈”是燕对咲季书写状态的肯定。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00158", "scene_id": "scene-00158", "source_file": "CSV/csprt/csprt-3-0085/adv_csprt-3-0085_03.csv", "source_kind": "csprt", "chapter": "csprt/csprt-3-0085", "scene": "adv_csprt-3-0085_03", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-3-0085/adv_csprt-3-0085_03.csv:1-20"], "line_count": 20, "speakers": ["咲季", "燕"], "topics": ["worldbuilding", "character_arc", "relationships", "team_story"], "title": "咲季与燕的训练交流", "summary": "咲季向雨夜前辈燕展示最新科学训练菜单，燕虽习惯传统修行但认可其合理性。两人决定融合彼此优点，并在训练中互相鼓舞。尽管咲季视燕为试镜对手，燕也对其挑战精神表示关注，双方约定合力应对共同目标。", "saki_role": "同学/对手：咲季在群像关系中以好胜、直率和带头推进对话的姿态出现。", "relationship_signals": ["对手"], "worldbuilding_signals": ["偶像", "训练", "试镜"], "dialogue_style_signals": [], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "我的训练菜单。"}, {"source_row": "5", "speaker": "燕", "text_zh": "我总是不知不觉地拘泥于古老的修行方法。"}, {"source_row": "18", "speaker": "咲季", "text_zh": "在试镜中我们可是竞争对手哦。"}, {"source_row": "20", "speaker": "咲季", "text_zh": "是的！因为是偶像！无论对手是谁都会全力挑战！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季向燕展示了运用最新器材的科学训练方式。", "咲季认为传统修行方法并非不好，主张融合两者优点。", "咲季与燕在试镜中是竞争对手，但决定合力而为。", "咲季作为偶像，无论对手是谁都会全力挑战。"], "relationship_facts": ["咲季称呼燕为雨夜前辈。", "咲季与燕在试镜中是竞争对手。", "燕认为有咲季在会感到受到鼓舞。"], "worldbuilding_facts": ["燕习惯拘泥于古老的修行方法。", "咲季使用最新器材进行科学训练。", "咲季是偶像，具有挑战任何对手的精神。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00159", "scene_id": "scene-00159", "source_file": "CSV/csprt/csprt-3-0087/adv_csprt-3-0087_02.csv", "source_kind": "csprt", "chapter": "csprt/csprt-3-0087", "scene": "adv_csprt-3-0087_02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-3-0087/adv_csprt-3-0087_02.csv:1-20"], "line_count": 20, "speakers": ["咲季", "广", "手毬", "清夏", "琴音", "莉波", "麻央"], "topics": ["team_story", "relationships", "dialogue_style", "worldbuilding"], "title": "初星寮章鱼烧派对", "summary": "初星寮众人齐聚准备传统章鱼烧派对，麻央展示代代相传的铁板。广、清夏、琴音等自由搭配配料，莉波带回下酒菜。咲季宣布训练组汇合，众人开始享用美食，手毬认出章鱼烧王子的广告歌曲。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["琴音", "手毬", "清夏", "麻央", "广", "莉波"], "worldbuilding_signals": ["训练", "工作"], "dialogue_style_signals": ["当然", "呵呵", "啦"], "key_evidence": [{"source_row": "13", "speaker": "咲季", "text_zh": "训练组的也汇合了！"}, {"source_row": "4", "speaker": "麻央", "text_zh": "初星寮代代相传、传统的章鱼烧烤盘哦。"}, {"source_row": "17", "speaker": "手毬", "text_zh": "啊，这首歌我知道！小学的时候很流行呢。"}, {"source_row": "12", "speaker": "莉波", "text_zh": "饮料和下酒菜买来了哦。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["初星寮正在举办传统的章鱼烧派对。", "莉波买来了饮料和下酒菜。", "手毬认出了章鱼烧王子的广告歌曲。", "训练组成员已经与寮内成员汇合。"], "relationship_facts": ["麻央是初星寮的寮长。", "琴音、清夏、广、手毬、莉波、咲季都是初星寮成员。", "手毬是京都人，其他成员多来自关西地区。"], "worldbuilding_facts": ["章鱼烧烤盘是初星寮代代相传的传统物品。", "维护铁板是寮长的重要工作。", "章鱼烧王子是关西地区流行的广告角色。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00160", "scene_id": "scene-00160", "source_file": "CSV/csprt/csprt-3-0089/adv_csprt-3-0089_01.csv", "source_kind": "csprt", "chapter": "csprt/csprt-3-0089", "scene": "adv_csprt-3-0089_01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-3-0089/adv_csprt-3-0089_01.csv:1-20"], "line_count": 20, "speakers": ["佑芽", "咲季", "旁白", "星南"], "topics": ["relationships", "dialogue_style", "worldbuilding"], "title": "咲季视察佑芽工作", "summary": "新学生会成立后，咲季以帮忙大扫除为由来到学生会室，实则想观察佑芽的工作表现并审查星南会长。咲季担心妹妹被托付给他人，星南会长则欣然接受咲季的严格审查，展现了三人间亲密且充满活力的互动。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "星南", "妹妹", "姐姐"], "worldbuilding_signals": ["工作"], "dialogue_style_signals": ["当然", "真是的", "呵呵", "啦"], "key_evidence": [{"source_row": "5", "speaker": "咲季", "text_zh": "今天有大扫除对吧？我来帮忙了。"}, {"source_row": "10", "speaker": "咲季", "text_zh": "我想看看佑芽在学生会里是怎么工作的呀。"}, {"source_row": "18", "speaker": "咲季", "text_zh": "十王星南！我是来评判要培育佑芽的你的！"}, {"source_row": "20", "speaker": "星南", "text_zh": "呵——正合我意！尽管放马过来！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["新学生会诞生后不久，咲季来到学生会室。", "咲季声称来帮忙大扫除，实则是为了观察佑芽。", "咲季明确表示目的是审查星南会长是否适合培育佑芽。", "星南会长欢迎咲季的审查，表示正合心意。"], "relationship_facts": ["咲季是佑芽的姐姐，对妹妹过度保护。", "星南会长是佑芽的上级，负责培育佑芽。", "咲季与星南会长之间是互相认可、充满默契的关系。"], "worldbuilding_facts": ["新学生会刚刚诞生，成员包括佑芽和星南会长。", "学生会室正在进行大扫除活动。", "星南会长被赋予培育佑芽的职责。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00161", "scene_id": "scene-00161", "source_file": "CSV/csprt/csprt-3-0089/adv_csprt-3-0089_02.csv", "source_kind": "csprt", "chapter": "csprt/csprt-3-0089", "scene": "adv_csprt-3-0089_02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-3-0089/adv_csprt-3-0089_02.csv:1-20"], "line_count": 20, "speakers": ["佑芽", "千奈", "咲季", "星南"], "topics": ["dialogue_style", "relationships", "worldbuilding", "team_story"], "title": "学生会室大扫除", "summary": "星南组织一年级生加入学生会室大扫除，提醒众人注意安全。咲季主动提出帮忙搬重物并擦拭桌子，展现体贴一面。千奈搬运纸箱时险些损坏桌子，被星南及时制止并更换新桌，众人对星南的细心关怀表示赞赏。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "星南"], "worldbuilding_signals": ["偶像", "工作"], "dialogue_style_signals": ["呵呵", "啦"], "key_evidence": [{"source_row": "9", "speaker": "星南", "text_zh": "咲季，那边的行李我来搬吧。你能帮忙用抹布擦一下桌子吗？"}, {"source_row": "10", "speaker": "咲季", "text_zh": "搬重物的话，我已经习惯了，没关系的。"}, {"source_row": "12", "speaker": "咲季", "text_zh": "那我也一起搬吧。这样就能快点结束了吧？"}, {"source_row": "15", "speaker": "星南", "text_zh": "千奈，停下。那张桌子，是不是坏了？"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["学生会室正在进行大扫除工作。", "咲季主动提出帮忙搬重物并擦拭桌子。", "千奈搬运纸箱时险些损坏桌子，被星南制止。", "星南及时更换了损坏的桌子。"], "relationship_facts": ["星南是学生会会长，关心成员安全。", "咲季是学生会成员，积极参与工作。", "佑芽和千奈是一年级生，协助大扫除。"], "worldbuilding_facts": ["学生会室需要定期大扫除。", "一年级生加入学生会，行李增多。", "学生会室有损坏的桌子需要更换。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00162", "scene_id": "scene-00162", "source_file": "CSV/csprt/csprt-3-0089/adv_csprt-3-0089_03.csv", "source_kind": "csprt", "chapter": "csprt/csprt-3-0089", "scene": "adv_csprt-3-0089_03", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-3-0089/adv_csprt-3-0089_03.csv:1-20"], "line_count": 20, "speakers": ["咲季", "星南"], "topics": ["dialogue_style", "relationships", "worldbuilding"], "title": "咲季认可星南的决心", "summary": "咲季坦言无法立刻认可星南培育佑芽的提议，仅因窥见其工作一面。但她高度肯定星南作为学生会长的出色实力，视其为十王星南。两人互诉曾有的失望与失礼，最终星南感谢咲季，咲季表示将继承学姐超越极限的榜样精神，全力协助。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "星南"], "worldbuilding_signals": ["工作"], "dialogue_style_signals": ["当然", "呵呵", "制作人"], "key_evidence": [{"source_row": "3", "speaker": "咲季", "text_zh": "我可没法那么快就给出答案。"}, {"source_row": "7", "speaker": "咲季", "text_zh": "但你是一位出色的学生会长这一点，我已经感受到了。"}, {"source_row": "18", "speaker": "星南", "text_zh": "超越极限的榜样。"}, {"source_row": "20", "speaker": "咲季", "text_zh": "就交给我这个学妹吧！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季表示无法立刻给出是否认可星南培育佑芽的答案。", "咲季认为星南是一位出色的学生会长。", "咲季决定继承星南作为超越极限的榜样精神。", "星南感谢咲季，咲季表示要展示给星南看。"], "relationship_facts": ["咲季与星南是学妹与学姐的关系。", "咲季对星南抱有尊敬与期待。", "星南视咲季为重要的后辈与榜样继承者。"], "worldbuilding_facts": ["星南被称为『一等星』。", "咲季是星南的学妹。", "星南正在尝试培育名为佑芽的角色或事物。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00163", "scene_id": "scene-00163", "source_file": "CSV/csprt/csprt-3-0092/adv_csprt-3-0092_01.csv", "source_kind": "csprt", "chapter": "csprt/csprt-3-0092", "scene": "adv_csprt-3-0092_01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-3-0092/adv_csprt-3-0092_01.csv:1-20"], "line_count": 20, "speakers": ["佑芽", "咲季", "广"], "topics": ["relationships", "team_story", "dialogue_style"], "title": "咲季改良便当与广加入", "summary": "咲季在入口休息区准备便当，经佑芽建议改良外观与营养后，广请求加入共餐。咲季热情接纳，广表达对姐姐的喜爱，佑芽随即因被忽视而抗议，场面温馨又带点小插曲。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "广", "姐姐"], "worldbuilding_signals": [], "dialogue_style_signals": ["当然", "哼"], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "今天就在这里吃午饭吧！"}, {"source_row": "5", "speaker": "咲季", "text_zh": "听取了周围的意见，对卖相进行了改良"}, {"source_row": "12", "speaker": "广", "text_zh": "我也可以一起吃午饭吗？"}, {"source_row": "19", "speaker": "广", "text_zh": "好温柔。姐姐…………最喜欢了。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季在入口休息区准备便当。", "广请求加入咲季和佑芽的午餐。", "咲季接受了广的请求并让他坐下。", "广称赞咲季温柔并表达喜爱。"], "relationship_facts": ["佑芽是咲季的妹妹。", "广是咲季的弟弟。", "咲季是佑芽和广的姐姐。"], "worldbuilding_facts": ["入口休息区设有空桌子可供用餐。", "咲季的便当经过改良后外观、味道和营养都变得完美。", "广对咲季的便当进化感到在意。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00164", "scene_id": "scene-00164", "source_file": "CSV/csprt/csprt-3-0092/adv_csprt-3-0092_02.csv", "source_kind": "csprt", "chapter": "csprt/csprt-3-0092", "scene": "adv_csprt-3-0092_02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-3-0092/adv_csprt-3-0092_02.csv:1-20"], "line_count": 20, "speakers": ["佑芽", "優", "咲季", "广"], "topics": ["team_story", "dialogue_style", "relationships", "worldbuilding"], "title": "花海咲季指导练习", "summary": "优因无法唱好歌曲而烦恼，且担心打扰偶像科同学吃饭。广突然出现安慰优，咲季则指出此时有几种有效的练习方法，并提醒广不要吓唬优，三人随后决定一起吃饭。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["佑芽", "广"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["呵呵", "啦"], "key_evidence": [{"source_row": "5", "speaker": "咲季", "text_zh": "这种时候，其实有几种有效的练习方法——"}, {"source_row": "12", "speaker": "咲季", "text_zh": "小广，你呀……别这样突然冒出来吓唬人啦。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["优因唱不好歌曲而感到烦恼。", "优担心打扰正在吃饭的偶像科同学。", "广主动介入帮助优解决烦恼。", "咲季提出有效的练习方法并制止广吓唬优。"], "relationship_facts": ["优与广是同学关系。", "咲季与广是同学关系。", "优与偶像科同学是后辈与前辈关系。"], "worldbuilding_facts": ["存在偶像科这一班级或社团。", "该场景发生在午休或用餐时间。", "优与广似乎处于某种需要拉近关系的阶段。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00165", "scene_id": "scene-00165", "source_file": "CSV/csprt/csprt-3-0092/adv_csprt-3-0092_03.csv", "source_kind": "csprt", "chapter": "csprt/csprt-3-0092", "scene": "adv_csprt-3-0092_03", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/csprt/csprt-3-0092/adv_csprt-3-0092_03.csv:1-20"], "line_count": 20, "speakers": ["佑芽", "咲季", "广"], "topics": ["relationships", "team_story", "dialogue_style"], "title": "料理美味的秘密", "summary": "咲季与广讨论让料理变美味的关键，从化学反应如美拉德反应，升华到对享用者倾注的爱。咲季自豪地表示在佑芽的便当中也倾注了爱，揭示了美味料理背后蕴含的爱与科学。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "广", "姐姐"], "worldbuilding_signals": [], "dialogue_style_signals": ["哼", "呵呵"], "key_evidence": [{"source_row": "6", "speaker": "咲季", "text_zh": "答案是，化学反应哦！"}, {"source_row": "8", "speaker": "广", "text_zh": "比如说，加热时发生的美拉德反应。"}, {"source_row": "16", "speaker": "咲季", "text_zh": "要好好考虑到享用者的喜好和体质"}, {"source_row": "18", "speaker": "咲季", "text_zh": "没错，就是爱！！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["让料理变美味需要利用化学反应。", "烹饪过程中会发生如美拉德反应等多种化学反应。", "美味的料理需要考虑到享用者的喜好和体质。", "美味的料理中蕴含着对享用者的爱。"], "relationship_facts": ["咲季是佑芽的姐姐。", "咲季和广是讨论伙伴。", "咲季为佑芽制作便当。"], "worldbuilding_facts": ["料理的美味可以通过化学反应来理解。", "美拉德反应是加热时发生的化学反应。", "料理中倾注的爱是重要的秘方。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00166", "scene_id": "scene-00166", "source_file": "CSV/dear/amao/adv_dear_amao_012.csv", "source_kind": "dear", "chapter": "dear/amao", "scene": "adv_dear_amao_012", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "80", "line_count": 80}, {"block_index": 2, "start_row": "81", "end_row": "115", "line_count": 35}], "source_refs": ["CSV/dear/amao/adv_dear_amao_012.csv:1-115"], "line_count": 115, "speakers": ["制作人", "女の子A", "女の子B", "琴音", "莉莉娅", "麻央"], "topics": ["team_story", "relationships", "dialogue_style", "worldbuilding"], "title": "咲季未出场场景", "summary": "本场景聚焦于麻央与粉丝互动、鼓励夜练的莉莉娅，以及与琴音关于N.I.A竞争的对话。琴音提及咲季作为培养对手的‘怪人’，但咲季本人未直接登场或被提及，仅作为背景概念存在。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人", "琴音", "手毬", "麻央", "莉莉娅", "对手"], "worldbuilding_signals": ["学园", "偶像", "课程", "训练", "演唱会"], "dialogue_style_signals": ["当然", "呵呵", "制作人", "啦"], "key_evidence": [{"source_row": "102", "speaker": "琴音", "text_zh": "嘛～虽然也有像咲季那样培养竞争对手的怪人啦……"}, {"source_row": "110", "speaker": "琴音", "text_zh": "无论是麻央前辈、咲季还是手毬，我可都没打算输给任何人哦。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["麻央在迷你演唱会后与粉丝互动并感到疲惫。", "琴音决定参加N.I.A，并认为麻央应优先训练而非照顾学妹。", "琴音提到咲季是像她一样培养竞争对手的‘怪人’。", "麻央最终承认琴音是竞争对手，重新振作准备全力以赴。"], "relationship_facts": ["麻央与琴音是N.I.A舞台上的竞争对手。", "琴音视咲季为懂得培养竞争对手的‘怪人’偶像。", "麻央与莉莉娅是前辈与一年级学妹的关系。"], "worldbuilding_facts": ["N.I.A是偶像选拔或竞争舞台。", "初星学园设有中等部和高等部，麻央为三年级，琴音为二年级，莉莉娅为一年级。", "偶像科学生需要通过SNS宣传、迷你演唱会及投票来争取机会。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00167", "scene_id": "scene-00167", "source_file": "CSV/dear/amao/adv_dear_amao_027.csv", "source_kind": "dear", "chapter": "dear/amao", "scene": "adv_dear_amao_027", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "80", "line_count": 80}, {"block_index": 2, "start_row": "81", "end_row": "107", "line_count": 27}], "source_refs": ["CSV/dear/amao/adv_dear_amao_027.csv:1-107"], "line_count": 107, "speakers": ["制作人", "十王社長", "咲季", "学园长", "手毬", "星南", "清夏", "琴音", "莉波", "选项", "麻央"], "topics": ["team_story", "relationships", "dialogue_style", "character_arc"], "title": "冬季H.I.F决战前夜", "summary": "星南夺冠后，麻央决心在冬季H.I.F击败她以保住制作人职位。制作人制定严苛训练计划，将赛事更名为P.M.R。咲季在场关注手毬，未直接参与对话。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人", "琴音", "手毬", "清夏", "麻央", "莉波", "星南", "对手"], "worldbuilding_signals": ["学园", "偶像", "训练"], "dialogue_style_signals": ["当然", "呵呵", "制作人", "啦"], "key_evidence": [{"source_row": "35", "speaker": "星南", "text_zh": "如果我夺冠，你的制作人职务就会被解除。"}, {"source_row": "86", "speaker": "制作人", "text_zh": "我制定了一份为了在冬季『H.I.F』中夺冠的方案。"}, {"source_row": "91", "speaker": "制作人", "text_zh": "而是被称为——『P.M.R』吧。"}, {"source_row": "69", "speaker": "咲季", "text_zh": "……手毬。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["星南在冬季H.I.F夺冠将导致麻央失去制作人职务。", "制作人决定对麻央实施严苛训练以备战冬季决赛。", "冬季H.I.F赛事被重新命名为P.M.R（王子麻央革命）。"], "relationship_facts": ["麻央与星南是冬季H.I.F决赛的宿敌。", "制作人与麻央是搭档，共同追求顶级偶像梦想。", "手毬与咲季是关系亲密的同伴。"], "worldbuilding_facts": ["冬季H.I.F是决定麻央制作人职位的关键赛事。", "星南被称为『一等星』，是顶级偶像。", "H.I.F赛事名称可因主角表现而变更。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00168", "scene_id": "scene-00168", "source_file": "CSV/dear/fktn/adv_dear_fktn_025.csv", "source_kind": "dear", "chapter": "dear/fktn", "scene": "adv_dear_fktn_025", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "38", "line_count": 38}], "source_refs": ["CSV/dear/fktn/adv_dear_fktn_025.csv:1-38"], "line_count": 38, "speakers": ["制作人", "学园长", "琴音", "选项"], "topics": ["relationships", "team_story", "dialogue_style", "worldbuilding"], "title": "琴音败北后的感伤", "summary": "夏日祭典 H.I.F 决赛落幕，十王星南夺冠，琴音虽败犹荣却难掩失落。面对制作人，琴音坦言自己仍不配与咲季等顶尖偶像为伍，甚至因情绪激动无法参加庆功宴。制作人提议共赴庆功宴被拒，琴音只想与制作人一同哭泣，享受此刻的陪伴。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人", "琴音", "星南", "对手"], "worldbuilding_signals": ["学园", "偶像", "演唱会", "工作"], "dialogue_style_signals": ["嘿嘿", "制作人", "啦"], "key_evidence": [{"source_row": "13", "speaker": "琴音", "text_zh": "雨夜前辈她们……还有咲季她们……"}, {"source_row": "11", "speaker": "琴音", "text_zh": "我……真的有资格成为星南同学的对手吗。"}, {"source_row": "35", "speaker": "琴音", "text_zh": "请陪在我身边。"}, {"source_row": "37", "speaker": "制作人", "text_zh": "这次要一起哭吗？"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["十王星南在 H.I.F 决赛中获胜，琴音承认败北。", "琴音认为咲季等前辈表现超群，自己难以追上。", "琴音因情绪激动决定放弃庆功宴，只想与制作人独处。", "制作人表示本想独自哭泣，提议与琴音一起哭。"], "relationship_facts": ["琴音视咲季为顶尖偶像及难以企及的对手。", "制作人作为藤田琴音的经纪人/制作人，在决赛后陪伴她。", "琴音与制作人关系亲密，愿意在失败后向对方倾诉脆弱。"], "worldbuilding_facts": ["H.I.F 是重要的偶像竞赛活动，设有冠军与名次。", "十王星南被誉为“夏日一等星”，拥有极高人气。", "偶像行业存在知名度与收入挂钩的机制。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00169", "scene_id": "scene-00169", "source_file": "CSV/dear/hmsz/adv_dear_hmsz_007.csv", "source_kind": "dear", "chapter": "dear/hmsz", "scene": "adv_dear_hmsz_007", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "66", "line_count": 66}], "source_refs": ["CSV/dear/hmsz/adv_dear_hmsz_007.csv:1-66"], "line_count": 66, "speakers": ["制作人", "咲季", "手毬", "清夏", "琴音", "美铃", "莉莉娅"], "topics": ["team_story", "relationships", "dialogue_style", "plot"], "title": "咲季斥责手毬任性", "summary": "咲季因手毬演唱会前夜失眠打电话打扰众人而严厉斥责。手毬向美铃倾诉演出心声，美铃随后也向手毬表达关心并邀请其观看演唱会。咲季作为团队核心，展现了维护同伴健康的责任感，与手毬形成鲜明对比。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人", "琴音", "手毬", "清夏", "美铃", "莉莉娅", "朋友", "伙伴"], "worldbuilding_signals": ["演唱会"], "dialogue_style_signals": ["真是的", "哼", "制作人", "啦"], "key_evidence": [{"source_row": "30", "speaker": "咲季", "text_zh": "真是的～笨蛋手毬！给大家添麻烦了啦！"}, {"source_row": "36", "speaker": "咲季", "text_zh": "演唱会前夜别因为睡不着就到处打电话！"}, {"source_row": "65", "speaker": "制作人", "text_zh": "把今天的培育情况记录下来吧。秦谷同学干劲十足呢。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季因手毬在演唱会前夜失眠且到处打电话打扰他人而严厉斥责。", "咲季认为手毬的行为给大家添了麻烦，并指出手毬过于任性。", "咲季在众人面前直接出面制止手毬的过度行为，维护团队秩序。", "咲季对清夏提到的手毬睡过头一事表示不满，认为不应因失眠到处打电话。"], "relationship_facts": ["咲季与手毬是亲密的同伴关系，咲季会直接批评手毬的任性行为。", "咲季与清夏、琴音等人共同关心手毬的身体状况，形成互助的团队氛围。", "咲季与制作人存在上下级或指导关系，制作人记录了咲季干劲十足的表现。"], "worldbuilding_facts": ["咲季是团队中负责督促和照顾同伴情绪与健康的角色。", "手毬为了演唱会进行了特训，但身体状态不佳，容易力竭倒下。", "团队内部存在互相监督、互相提醒的机制，以防止成员过度劳累。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00170", "scene_id": "scene-00170", "source_file": "CSV/dear/hmsz/adv_dear_hmsz_014.csv", "source_kind": "dear", "chapter": "dear/hmsz", "scene": "adv_dear_hmsz_014", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "53", "line_count": 53}], "source_refs": ["CSV/dear/hmsz/adv_dear_hmsz_014.csv:1-53"], "line_count": 53, "speakers": ["佑芽", "佑芽と佑芽？", "千奈", "手毬", "燐羽", "美铃"], "topics": ["relationships", "character_arc", "team_story", "worldbuilding"], "title": "咲季南瓜与特训风波", "summary": "美铃与千奈讨论咲季炖南瓜美味，但手毬却只愿吃咲季自家蔬菜。燐羽带佑芽来训练室特训，提及咲季被妹妹打倒的场面。美铃察觉咲季与佑芽相似，并因燐羽提及咲季而生气，欲与燐羽争吵。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "手毬", "美铃", "妹妹", "姐姐", "朋友"], "worldbuilding_signals": ["训练"], "dialogue_style_signals": ["哼", "啦"], "key_evidence": [{"source_row": "7", "speaker": "手毬", "text_zh": "明明咲季做的炖南瓜有着高雅的甜味"}, {"source_row": "10", "speaker": "美铃", "text_zh": "变得只愿意吃花海农场的蔬菜了"}, {"source_row": "35", "speaker": "燐羽", "text_zh": "咲季姐姐被妹妹打得落花流水的样子"}, {"source_row": "40", "speaker": "美铃", "text_zh": "是因为她长得…有点像某个人吧"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["手毬无法吃下咲季做的炖南瓜，只愿吃咲季自家蔬菜。", "燐羽带佑芽来训练室进行特训，并提及咲季被妹妹打倒。", "美铃认为咲季与佑芽长相相似，因此对燐羽提及此事感到生气。"], "relationship_facts": ["燐羽与佑芽因在选拔赛相识而成为朋友，燐羽负责特训佑芽。", "咲季是手毬的姐姐，手毬是咲季的妹妹。", "美铃与燐羽是朋友，但因燐羽提及咲季而引发争执。"], "worldbuilding_facts": ["咲季的祖父种植蔬菜，品质出色。", "咲季做的炖南瓜具有高雅的甜味。", "燐羽在『N.I.A』选拔赛上认识了佑芽。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00171", "scene_id": "scene-00171", "source_file": "CSV/dear/hmsz/adv_dear_hmsz_024.csv", "source_kind": "dear", "chapter": "dear/hmsz", "scene": "adv_dear_hmsz_024", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "80", "line_count": 80}, {"block_index": 2, "start_row": "81", "end_row": "88", "line_count": 8}], "source_refs": ["CSV/dear/hmsz/adv_dear_hmsz_024.csv:1-88"], "line_count": 88, "speakers": ["制作人", "手毬", "燐羽", "美铃"], "topics": ["worldbuilding", "relationships", "dialogue_style", "team_story"], "title": "咲季老家特训与燐羽心结", "summary": "美铃、燐羽与手毬在花海咲季的老家接受严苛特训。手毬赞叹设施完美，美铃则感叹强度之大，联想到佑芽的遭遇。燐羽因非偶像身份而抗拒训练，美铃却愿等待其找回初心，两人约定回归初心，面对燐羽心中偶像定义的挣扎。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "手毬", "星南", "美铃"], "worldbuilding_signals": ["偶像", "训练", "演唱会"], "dialogue_style_signals": ["当然", "真是的", "哼", "呵呵", "制作人", "啦"], "key_evidence": [{"source_row": "21", "speaker": "手毬", "text_zh": "听说这是咲季的老家"}, {"source_row": "35", "speaker": "美铃", "text_zh": "我好像亲身感受到佑芽同学会变成‘那样’的原因了"}, {"source_row": "74", "speaker": "燐羽", "text_zh": "我本来就不是偶像啊"}, {"source_row": "85", "speaker": "美铃", "text_zh": "让我们回归初心"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["特训地点是花海咲季的老家设施。", "燐羽因缺乏偶像觉悟而抗拒训练。", "美铃认为设施强度让燐羽联想到佑芽。", "十王星南成为顶级偶像，周边售罄。"], "relationship_facts": ["美铃与燐羽约定等待燐羽找回偶像初心。", "手毬视咲季老家为理想训练环境。", "燐羽不承认自己为偶像，仅愿做粉丝。"], "worldbuilding_facts": ["花海咲季的老家拥有完美的偶像特训设施。", "顶级偶像十王星南的股价暴涨，周边售罄。", "设施内设有午睡胶囊供成员休息。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00172", "scene_id": "scene-00172", "source_file": "CSV/dear/hski/adv_dear_hski_001.csv", "source_kind": "dear", "chapter": "dear/hski", "scene": "adv_dear_hski_001", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "73", "line_count": 73}], "source_refs": ["CSV/dear/hski/adv_dear_hski_001.csv:1-73"], "line_count": 73, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "character_arc", "worldbuilding"], "title": "咲季的决心与制作人", "summary": "制作人发掘咲季，咲季虽因好胜心担忧会输，但坚定选择成为世界第一偶像。制作人指出其怯懦，咲季为证明决心正式接受制作人身份，誓言绝不逃避挑战。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "姐姐"], "worldbuilding_signals": ["偶像", "制作人科"], "dialogue_style_signals": ["才不是", "真是的", "哼", "嘿嘿", "制作人", "啦"], "key_evidence": [{"source_row": "31", "speaker": "咲季", "text_zh": "运动神经超群、容貌秀丽、学业优秀！"}, {"source_row": "36", "speaker": "制作人", "text_zh": "非常非常非常非常好胜心强"}, {"source_row": "58", "speaker": "咲季", "text_zh": "已经决定要成为世界第一的偶像了。"}, {"source_row": "72", "speaker": "咲季", "text_zh": "因为我是那孩子的姐姐啊！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季拥有运动、学业、容貌等全能特质。", "咲季极度好胜，认为不拿第一绝不罢休。", "咲季因担心在偶像道路上输给不想输的人而动摇。", "咲季正式决定成为世界第一的偶像。"], "relationship_facts": ["制作人是发掘咲季的新人。", "咲季视制作人为自己的制作人。", "咲季是某位孩子的姐姐。"], "worldbuilding_facts": ["咲季是制作人科的同学。", "咲季的目标是成为世界第一的偶像。", "咲季在入学考试中获得榜首。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00173", "scene_id": "scene-00173", "source_file": "CSV/dear/hski/adv_dear_hski_002.csv", "source_kind": "dear", "chapter": "dear/hski", "scene": "adv_dear_hski_002", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "61", "line_count": 61}], "source_refs": ["CSV/dear/hski/adv_dear_hski_002.csv:1-61"], "line_count": 61, "speakers": ["佑芽", "制作人", "咲季", "选项"], "topics": ["relationships", "dialogue_style", "character_arc", "worldbuilding"], "title": "咲季与佑芽的对决", "summary": "咲季在训练室击败妹妹佑芽，炫耀自己作为入学第一名的实力。制作人指出咲季虽优秀但尚未达到学园第一，且战胜妹妹比获得一等星更难。咲季坚信佑芽会追上自己，制作人决定从明天开始正式培育咲季，以助其赢得胜利。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "妹妹", "姐姐", "对手"], "worldbuilding_signals": ["学园", "偶像", "训练"], "dialogue_style_signals": ["当然", "哼", "呵呵", "嘿嘿", "制作人", "啦"], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "是我赢了哦，佑芽！"}, {"source_row": "14", "speaker": "制作人", "text_zh": "她是花海佑芽。咲季同学的妹妹"}, {"source_row": "33", "speaker": "制作人", "text_zh": "但还不是学园第一的偶像。"}, {"source_row": "56", "speaker": "制作人", "text_zh": "从明天开始正式进行培育计划。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季在训练室中击败了妹妹佑芽。", "制作人指出咲季目前还不是学园第一的偶像。", "制作人决定从明天开始正式进行培育计划。", "咲季认为战胜妹妹比获得一等星称号更困难。"], "relationship_facts": ["咲季是佑芽的姐姐。", "佑芽是咲季最大的竞争对手。", "制作人是咲季的培育者。"], "worldbuilding_facts": ["花海咲季是入学考试第一名的偶像。", "H.I.F 学园中存在『一等星』的称号。", "训练室可以供偶像借用进行练习。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00174", "scene_id": "scene-00174", "source_file": "CSV/dear/hski/adv_dear_hski_003.csv", "source_kind": "dear", "chapter": "dear/hski", "scene": "adv_dear_hski_003", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "80", "line_count": 80}, {"block_index": 2, "start_row": "81", "end_row": "81", "line_count": 1}], "source_refs": ["CSV/dear/hski/adv_dear_hski_003.csv:1-81"], "line_count": 81, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "worldbuilding", "character_arc"], "title": "咲季的早熟烦恼与梦想", "summary": "咲季在事务所教室向制作人坦白自己记忆力超群却易触达极限的烦恼。制作人肯定了她即使梦想破碎仍不屈不挠的精神，并决定培育她成为真正的偶像。咲季对此感到既害羞又热血，决心展示实力。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人", "对手"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["当然", "呵呵", "嘿嘿", "制作人", "让你见识", "啦"], "key_evidence": [{"source_row": "22", "speaker": "咲季", "text_zh": "我呢，从小……就记忆力超～级好。"}, {"source_row": "31", "speaker": "咲季", "text_zh": "我啊，很快就会到达极限。"}, {"source_row": "74", "speaker": "制作人", "text_zh": "我就是想培育这样不屈不挠的偶像。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季拥有超群的记忆力和学习能力，但很快会到达成长极限。", "咲季高中时因无法成为世界第一而放弃运动，转而寻找新梦想。", "制作人认为咲季的梦想并非妥协，而是历经挫折后重新站起的证明。", "咲季被制作人定义为“超级早熟型”，并认为其烦恼有被帮助的空间。"], "relationship_facts": ["咲季与制作人建立了专属的偶像事务所关系。", "制作人是咲季的发掘者，了解她过去的梦想与放弃经历。", "咲季视制作人为能彻底了解她一切烦恼的专属制作人。"], "worldbuilding_facts": ["事务所的教室被咲季视为属于两人的偶像事务所据点。", "咲季曾从事过运动，但因体格和极限问题在高中放弃。", "咲季将偶像界视为需要不断超越中等水平、追求世界第一的领域。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00175", "scene_id": "scene-00175", "source_file": "CSV/dear/hski/adv_dear_hski_004.csv", "source_kind": "dear", "chapter": "dear/hski", "scene": "adv_dear_hski_004", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "55", "line_count": 55}], "source_refs": ["CSV/dear/hski/adv_dear_hski_004.csv:1-55"], "line_count": 55, "speakers": ["众人", "制作人", "咲季", "舞蹈训练师"], "topics": ["dialogue_style", "relationships", "worldbuilding", "character_arc"], "title": "咲季与制作人的午餐", "summary": "咲季感谢舞蹈训练师后，邀请制作人共进亲手制作的营养便当。她解释这是为佑芽准备的饮食，并透露姐妹俩一直由她照顾饮食。制作人赞赏其自律与多才多艺，咲季则强调对妹妹的珍视，展现了其作为偶像的贴心与责任感。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "妹妹", "对手"], "worldbuilding_signals": ["偶像", "训练"], "dialogue_style_signals": ["当然", "呵呵", "制作人", "啦"], "key_evidence": [{"source_row": "3", "speaker": "咲季", "text_zh": "谢谢您，训练员！"}, {"source_row": "26", "speaker": "咲季", "text_zh": "这可是我亲手做的哦！"}, {"source_row": "40", "speaker": "咲季", "text_zh": "我们姐妹一直都是吃我做的料理长大的。"}, {"source_row": "54", "speaker": "制作人", "text_zh": "连专业训练师都要自叹不如的知识储备。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季亲手制作了包含蔬菜泥和鸡胸肉泥的营养便当。", "咲季透露姐妹俩一直由她负责饮食并以此取得成果。", "咲季表示既是对手也是妹妹，会珍惜佑芽的成长。", "制作人记录咲季在训练和烹饪方面展现出的多才多艺。"], "relationship_facts": ["咲季与舞蹈训练师是受助者与帮助者的关系。", "咲季与制作人是同事兼朋友关系。", "咲季与花海佑芽是姐妹及偶像竞争对手关系。"], "worldbuilding_facts": ["偶像训练需要请教专业人士以增强实力。", "咲季通过严格的饮食管理来维持状态和成果。", "制作人有记录偶像培育情况的职责。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00176", "scene_id": "scene-00176", "source_file": "CSV/dear/hski/adv_dear_hski_005.csv", "source_kind": "dear", "chapter": "dear/hski", "scene": "adv_dear_hski_005", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "70", "line_count": 70}], "source_refs": ["CSV/dear/hski/adv_dear_hski_005.csv:1-70"], "line_count": 70, "speakers": ["佑芽", "制作人", "千奈", "咲季"], "topics": ["relationships", "dialogue_style", "team_story", "character_arc"], "title": "咲季为妹妹与千奈按摩", "summary": "佑芽回家向咲季撒娇，千奈来访请求按摩。咲季先为千奈按摩使其入睡，随后为佑芽按摩。佑芽表达幸福与亏欠感，咲季鼓励其成长。制作人点评两人实力提升但竞争加剧。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "广", "妹妹", "姐姐", "朋友", "对手"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["真是的", "制作人", "不是吗", "啦"], "key_evidence": [{"source_row": "7", "speaker": "咲季", "text_zh": "要成为顶级偶像的话文化课也很重要哦。"}, {"source_row": "51", "speaker": "佑芽", "text_zh": "我觉得这都是托姐姐的福。"}, {"source_row": "60", "speaker": "咲季", "text_zh": "就快点成长起来，让我感受到威胁吧。"}, {"source_row": "70", "speaker": "制作人", "text_zh": "……但是，竞争对手的进步速度更快呢。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季为千奈和佑芽进行了按摩。", "佑芽认为自己的幸福是托咲季的福。", "咲季希望佑芽能成长到让她感到威胁。", "制作人评价两人实力提升但对手进步更快。"], "relationship_facts": ["咲季是佑芽的姐姐。", "千奈是佑芽的朋友。", "制作人是两人的指导者。"], "worldbuilding_facts": ["成为顶级偶像需要重视文化课。", "偶像团体之间存在激烈的竞争。", "筱泽同学（小广）也是咲季的妹妹。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00177", "scene_id": "scene-00177", "source_file": "CSV/dear/hski/adv_dear_hski_006.csv", "source_kind": "dear", "chapter": "dear/hski", "scene": "adv_dear_hski_006", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "75", "line_count": 75}], "source_refs": ["CSV/dear/hski/adv_dear_hski_006.csv:1-75"], "line_count": 75, "speakers": ["佑芽", "制作人", "咲季", "选项"], "topics": ["relationships", "dialogue_style", "character_arc", "plot"], "title": "咲季的成长与依赖", "summary": "咲季在制作人面前坦言自己虽努力却停滞不前，因无法同时兼顾妹妹与竞争对手而感到不甘心。制作人指出咲季作为姐姐的榜样作用，并承诺提供全方位支持，帮助咲季成为无敌偶像，两人关系更加紧密。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "妹妹", "姐姐", "对手", "家人"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["当然", "哼", "嘿嘿", "制作人", "啦"], "key_evidence": [{"source_row": "40", "speaker": "咲季", "text_zh": "可是……我的成长却停滞了。"}, {"source_row": "54", "speaker": "制作人", "text_zh": "是姐姐哦。"}, {"source_row": "64", "speaker": "制作人", "text_zh": "我会准备好的。为了让咲季同学成为无敌偶像所需的一切。"}, {"source_row": "75", "speaker": "制作人", "text_zh": "咲季同学正在稳步成长……每天都持续付出最大的努力……"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季在偶像练习中感到成长停滞，无法同时满足妹妹与竞争对手的需求。", "制作人指出咲季是佑芽成长的榜样，并承诺提供成为无敌偶像所需的一切支持。", "咲季承认自己太小看偶像职业，意识到人外有人，决心继续成长。", "咲季对制作人表示完全信任，愿意依靠制作人解决自身困境。"], "relationship_facts": ["咲季是佑芽的姐姐，也是她的专属教练和竞争对手。", "咲季与制作人之间是信任的上下级及家人般的关系。", "制作人是咲季在偶像道路上的重要支持者与引导者。"], "worldbuilding_facts": ["咲季入学前就开始为成为偶像锻炼身体，入学时考试第一名。", "咲季在一年级中名列前茅，但并非第一名，意识到偶像职业竞争激烈。", "咲季在理想的环境中生活，由制作人提前打点一切。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00178", "scene_id": "scene-00178", "source_file": "CSV/dear/hski/adv_dear_hski_007.csv", "source_kind": "dear", "chapter": "dear/hski", "scene": "adv_dear_hski_007", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "74", "line_count": 74}], "source_refs": ["CSV/dear/hski/adv_dear_hski_007.csv:1-74"], "line_count": 74, "speakers": ["佑芽", "制作人", "咲季", "选项"], "topics": ["relationships", "dialogue_style", "worldbuilding", "plot"], "title": "咲季与佑芽的演唱会", "summary": "咲季在佑芽首次演唱会前因等待而急躁，演出结束后询问制作人谁更优秀。制作人肯定咲季，并指出佑芽知名度提升。咲季虽感焦虑但坚持既定训练方案，最终在制作人鼓励下重拾干劲，决心继续稳步成长。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "妹妹", "对手"], "worldbuilding_signals": ["偶像", "训练", "试镜", "演唱会"], "dialogue_style_signals": ["才不是", "真是的", "哼", "制作人", "啦"], "key_evidence": [{"source_row": "4", "speaker": "咲季", "text_zh": "今天可是佑芽的首次演唱会哦！"}, {"source_row": "28", "speaker": "咲季", "text_zh": "告诉我。我和佑芽，谁更优秀？"}, {"source_row": "30", "speaker": "制作人", "text_zh": "花海同学更胜一筹。"}, {"source_row": "70", "speaker": "咲季", "text_zh": "多亏了佑芽！我现在干劲十足！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["佑芽举办了在校内外的首次演唱会，知名度大幅提升。", "咲季询问制作人自己与佑芽谁更优秀，制作人明确回答咲季更胜一筹。", "咲季坚持执行与制作人商定的最佳训练方案，不进行额外特训。", "咲季在经历情绪波动后，被制作人的肯定激励，决心继续练习。"], "relationship_facts": ["咲季与制作人是搭档关系，制作人负责指导咲季。", "咲季与佑芽是竞争对手关系，两人都有专属制作人。", "制作人对咲季的能力表示认可，认为其潜力巨大。"], "worldbuilding_facts": ["偶像行业存在既定的培育计划，新人需等待时机。", "偶像的知名度提升会吸引怀揣愿望的人出现，推动其发展。", "偶像需要通过心技体、气场与光彩来超越对手。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00179", "scene_id": "scene-00179", "source_file": "CSV/dear/hski/adv_dear_hski_008.csv", "source_kind": "dear", "chapter": "dear/hski", "scene": "adv_dear_hski_008", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "80", "line_count": 80}, {"block_index": 2, "start_row": "81", "end_row": "83", "line_count": 3}], "source_refs": ["CSV/dear/hski/adv_dear_hski_008.csv:1-83"], "line_count": 83, "speakers": ["制作人", "咲季", "选项"], "topics": ["relationships", "dialogue_style", "character_arc", "plot"], "title": "咲季直面恐惧与逃避", "summary": "咲季因长期无法战胜妹妹佑芽而陷入焦虑与自我厌恶，承认自己习惯逃避必败的对决。制作人指出这是绝佳成长机会，咲季最终决定不再逃避，决心在偶像道路上与强敌正面对决，争取首场演出的胜利。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "妹妹", "姐姐", "对手"], "worldbuilding_signals": ["学园", "偶像", "训练"], "dialogue_style_signals": ["当然", "哼", "制作人", "啦"], "key_evidence": [{"source_row": "52", "speaker": "咲季", "text_zh": "其实我啊！从来就没有赢过妹妹哪怕一次！"}, {"source_row": "54", "speaker": "咲季", "text_zh": "每次快要输的时候，我就逃去参加别的比赛。"}, {"source_row": "76", "speaker": "咲季", "text_zh": "但是，我已经不会再逃跑了。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季承认自己从未赢过妹妹，习惯在即将输掉时逃避比赛。", "咲季认为偶像竞技是即使先天不足也能挑战世界第一的领域。", "咲季决定不再逃跑，要面对实力高出一筹的对手并争取胜利。"], "relationship_facts": ["咲季是佑芽的姐姐，两人是偶像竞争对手。", "制作人是咲季的导师，致力于将其培养成顶尖偶像。", "咲季极度依赖制作人的信任，害怕让制作人失望。"], "worldbuilding_facts": ["咲季与佑芽即将进行下一次偶像对决。", "咲季选择偶像作为梦想是因为其竞技性质允许挑战世界第一。", "制作人计划为咲季安排与强敌的正式对决以助其成长。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00180", "scene_id": "scene-00180", "source_file": "CSV/dear/hski/adv_dear_hski_009.csv", "source_kind": "dear", "chapter": "dear/hski", "scene": "adv_dear_hski_009", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "80", "line_count": 80}, {"block_index": 2, "start_row": "81", "end_row": "83", "line_count": 3}], "source_refs": ["CSV/dear/hski/adv_dear_hski_009.csv:1-83"], "line_count": 83, "speakers": ["佑芽", "制作人", "咲季", "选项"], "topics": ["relationships", "dialogue_style", "character_arc", "plot"], "title": "咲季与佑芽的胜负", "summary": "演出前咲季因害怕输给佑芽而紧张，制作人鼓励她。咲季虽险胜但承认实力不如妹妹，认为未来胜算渺茫。制作人指出咲季的魅力是关键，并展望其未来。咲季决心在 H.I.F 对决中绝不落败，两人约定共同见证未来。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "妹妹", "姐姐", "对手"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["当然", "真是的", "哼", "呵呵", "制作人", "啦"], "key_evidence": [{"source_row": "10", "speaker": "咲季", "text_zh": "要是输了的话，我就再也……当不成可靠的姐姐了。"}, {"source_row": "58", "speaker": "咲季", "text_zh": "是、是吗……我居然……其实记不太清了。"}, {"source_row": "70", "speaker": "咲季", "text_zh": "哼哼，当然啦。只要输过一次，我可没信心能重新振作呢！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季在演出前因害怕输给佑芽而手抖、想哭。", "咲季承认唱歌和舞蹈都输给了佑芽，但享受了胜利的特权。", "制作人指出咲季的魅力是逆转胜的关键因素。", "咲季决心在 H.I.F 对决中绝不落败，否则无法振作。"], "relationship_facts": ["咲季是佑芽的姐姐，佑芽是咲季的妹妹。", "咲季视佑芽为强劲的对手和追赶的目标。", "制作人是咲季的指导者和支持者。"], "worldbuilding_facts": ["咲季自认为是早熟型偶像，佑芽是大器晚成型。", "偶像实力不仅由技术和外表决定，还受关键因素影响。", "H.I.F 是一场严峻的对决，需要创造奇迹才能取胜。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00181", "scene_id": "scene-00181", "source_file": "CSV/dear/hski/adv_dear_hski_010-01.csv", "source_kind": "dear", "chapter": "dear/hski", "scene": "adv_dear_hski_010-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "30", "line_count": 30}], "source_refs": ["CSV/dear/hski/adv_dear_hski_010-01.csv:1-30"], "line_count": 30, "speakers": ["制作人", "咲季", "四音", "黒井"], "topics": ["worldbuilding", "relationships", "dialogue_style", "character_arc"], "title": "咲季渴望外界挑战", "summary": "制作人向咲季解释新建训练设施旨在提供非专业人士建议及跨校联合训练机会，助其突破瓶颈。咲季对此充满期待，渴望与外界对手较量。此时黒井与四音登场，极月学园计划利用此局势践踏初星学园，四音表示将亲自收拾对手。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "姐姐", "对手", "父母"], "worldbuilding_signals": ["学园", "偶像", "训练", "工作"], "dialogue_style_signals": ["真是的", "呵呵", "制作人"], "key_evidence": [{"source_row": "12", "speaker": "制作人", "text_zh": "来自非偶像专业人士的建议。"}, {"source_row": "13", "speaker": "制作人", "text_zh": "还有与其他学校的偶像…进行联合训练"}, {"source_row": "22", "speaker": "黒井", "text_zh": "终于到来了。我极月学园践踏初星学园的时刻！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["制作人透露咲季父母与其关系因发掘咲季而变好。", "初星学园外将新建偶像专用训练设施，配备顶尖训练师。", "设施完工前，咲季已渴望与其他学校学生进行联合训练。", "极月学园理事长黒井计划利用此局势对初星学园发起挑战。"], "relationship_facts": ["制作人与咲季：培育者与偶像，制作人负责咲季的未来规划。", "咲季与父母：关系亲密，父母支持咲季成为偶像。", "黒井与四音：理事长与下属，四音听从黒井指令准备攻击初星学园。"], "worldbuilding_facts": ["初星学园是咲季所在的偶像培育学校。", "极月学园是初星学园的主要竞争对手。", "存在非初星学园的其他偶像培育学校，可进行联合训练。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00182", "scene_id": "scene-00182", "source_file": "CSV/dear/hski/adv_dear_hski_010.csv", "source_kind": "dear", "chapter": "dear/hski", "scene": "adv_dear_hski_010", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "80", "line_count": 80}], "source_refs": ["CSV/dear/hski/adv_dear_hski_010.csv:1-80"], "line_count": 80, "speakers": ["佑芽", "制作人", "咲季", "广"], "topics": ["relationships", "dialogue_style", "team_story", "worldbuilding"], "title": "咲季的复仇与成长", "summary": "咲季因佑芽成绩优异而焦虑，决心成为世界第一偶像以守护妹妹的骄傲。她向制作人倾诉父母缺席、独自带妹成长的经历，以及为证明佑芽所言非虚而立志的初衷。尽管自嘲是垂死挣扎，咲季仍请求制作人陪伴她坚持到底。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "广", "妹妹", "姐姐", "朋友", "父母"], "worldbuilding_signals": ["偶像", "训练", "工作"], "dialogue_style_signals": ["真是的", "哼", "呵呵", "制作人", "啦"], "key_evidence": [{"source_row": "67", "speaker": "咲季", "text_zh": "所以决定要把谎言变成现实……"}, {"source_row": "55", "speaker": "咲季", "text_zh": "但他们几乎不回家呢，那些人总是很忙。"}, {"source_row": "79", "speaker": "咲季", "text_zh": "所以……那个……也就是说……可以吧，制作人！"}, {"source_row": "64", "speaker": "佑芽", "text_zh": "我姐姐可是全世界最厉害的人！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季立志成为世界第一偶像，是为了让妹妹佑芽不再需要说谎。", "咲季的父母是著名运动员，常年忙碌，由祖父母照顾姐妹俩。", "咲季在妹妹面前扮演全能可靠的姐姐，独自承担保护责任。", "咲季请求制作人陪伴她完成最后的挑战，展现出不轻言放弃的决心。"], "relationship_facts": ["咲季与佑芽是姐妹，咲季视佑芽为必须守护的骄傲。", "咲季与父母关系疏远，父母因工作常年不在家。", "咲季与制作人关系亲密，制作人理解并支持咲季的梦想。"], "worldbuilding_facts": ["咲季和佑芽的父母都是退役的著名运动员。", "咲季的日常作息是上午学习，下午休息。", "咲季认为全力休息也是训练的一部分。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00183", "scene_id": "scene-00183", "source_file": "CSV/dear/hski/adv_dear_hski_011.csv", "source_kind": "dear", "chapter": "dear/hski", "scene": "adv_dear_hski_011", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "48", "line_count": 48}], "source_refs": ["CSV/dear/hski/adv_dear_hski_011.csv:1-48"], "line_count": 48, "speakers": ["众人", "佑芽", "制作人", "咲季"], "topics": ["relationships", "dialogue_style", "team_story", "worldbuilding"], "title": "咲季与佑芽的N.I.A对决", "summary": "咲季确立参加『NEXT IDOL AUDITION』(N.I.A) 的目标，认为粉丝支持至关重要。她与佑芽约定在最终选拔赛『FINALE』进行粉丝投票对决，旨在通过比赛提升知名度并实现各自的偶像梦想，将舞台变为姐妹的主场。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "姐姐"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["当然", "呵呵", "制作人", "不是吗"], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "『NEXT IDOL AUDITION』。"}, {"source_row": "9", "speaker": "咲季", "text_zh": "那就是一直支持着我的粉丝们呀。"}, {"source_row": "47", "speaker": "咲季", "text_zh": "让我们在『FINALE』相见吧，佑芽。"}, {"source_row": "22", "speaker": "众人", "text_zh": "『N.I.A』！！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季将参加名为『NEXT IDOL AUDITION』的偶像选拔活动。", "咲季与佑芽约定在最终日举行的『FINALE』进行粉丝投票对决。", "咲季认为不增加粉丝数量就无法在偶像界取得成就。"], "relationship_facts": ["咲季与佑芽是姐妹关系。", "咲季与制作人讨论偶像发展的目标。", "佑芽立志要在N.I.A中胜过咲季以雪前耻。"], "worldbuilding_facts": ["『N.I.A』设有粉丝投票排行榜，类似全国高中联赛。", "成为顶级偶像需要歌唱舞蹈实力、魅力、体魄及粉丝支持。", "N.I.A 最终日将举行最大规模的公开选拔赛。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00184", "scene_id": "scene-00184", "source_file": "CSV/dear/hski/adv_dear_hski_012.csv", "source_kind": "dear", "chapter": "dear/hski", "scene": "adv_dear_hski_012", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "64", "line_count": 64}], "source_refs": ["CSV/dear/hski/adv_dear_hski_012.csv:1-64"], "line_count": 64, "speakers": ["众人", "佑芽", "制作人", "咲季"], "topics": ["relationships", "dialogue_style", "worldbuilding", "team_story"], "title": "咲季决战FINALE舞台", "summary": "咲季因粉丝激增而得意忘形，被制作人提醒需展示真实自我。面对佑芽的强势回归，咲季意识到竞争加剧，决心在最终舞台'FINALE'全力以赴，不输给任何对手，并请求制作人继续指导。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "妹妹", "姐姐", "对手"], "worldbuilding_signals": ["偶像", "试镜"], "dialogue_style_signals": ["当然", "真是的", "嘿嘿", "制作人", "啦"], "key_evidence": [{"source_row": "2", "speaker": "咲季", "text_zh": "我的粉丝数量，是不是增加了不少呀？"}, {"source_row": "39", "speaker": "佑芽", "text_zh": "明明刚才姐姐的名字根本不在榜上的～"}, {"source_row": "47", "speaker": "咲季", "text_zh": "唯有『N.I.A』最大的试镜——『FINALE』舞台"}, {"source_row": "52", "speaker": "制作人", "text_zh": "为数不多的缺点就是容易轻视妹妹以外的其他偶像呢。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季粉丝数量与票数稳步增长，排名上升。", "佑芽粉丝数暴涨，与咲季排名并列第一。", "咲季决定在'FINALE'舞台与佑芽决一胜负。", "制作人指出咲季轻视其他偶像的缺点。"], "relationship_facts": ["咲季与制作人是指导与被指导关系。", "咲季与佑芽是姐妹且为偶像竞争对手。", "众人是咲季与佑芽的观众或竞争者。"], "worldbuilding_facts": ["存在偶像粉丝投票排名机制。", "偶像界有'FINALE'舞台这一最大试镜。", "不同学校之间存在偶像竞争关系。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00185", "scene_id": "scene-00185", "source_file": "CSV/dear/hski/adv_dear_hski_013.csv", "source_kind": "dear", "chapter": "dear/hski", "scene": "adv_dear_hski_013", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "42", "line_count": 42}], "source_refs": ["CSV/dear/hski/adv_dear_hski_013.csv:1-42"], "line_count": 42, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "worldbuilding", "character_arc"], "title": "咲季直面成长危机", "summary": "咲季坦言虽已全力以赴，但面对佑芽仍感实力差距，无法复制上次胜利。制作人鼓励她增加人气，并指出粉丝如肌肉般重要。咲季对极月学园等强敌产生兴趣，决心将其转化为成长养分，享受与制作人的共同危机。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "对手"], "worldbuilding_signals": ["学园", "偶像", "训练"], "dialogue_style_signals": ["当然", "真是的", "哼", "制作人", "啦"], "key_evidence": [{"source_row": "8-10", "speaker": "咲季", "text_zh": "那次胜利……虽然不想说是侥幸……但那不是随时能发挥的实力。"}, {"source_row": "20", "speaker": "制作人", "text_zh": "粉丝们对偶像来说，就像是外接的肌肉组织呢。"}, {"source_row": "33-34", "speaker": "制作人", "text_zh": "极月学园的精锐们将会在『N.I.A』与我们多次交锋吧。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季认为上次战胜佑芽是侥幸，无法随时发挥同等实力。", "制作人将粉丝比作偶像的外接肌肉组织，鼓励咲季提升人气。", "咲季决定将极月学园等强敌视为成长的养分，享受当前危机。"], "relationship_facts": ["咲季与制作人：互相鼓励，共同面对偶像生涯的逆境与快乐。", "咲季与佑芽：竞争对手，咲季承认对方偶像实力远超自己。", "咲季与极月学园：潜在对手，咲季对其精锐成员充满挑战欲。"], "worldbuilding_facts": ["极月学园是由多家事务所联合出资新建的偶像培养学校。", "极月学园理事长黑井崇男也是961プロ的社长。", "极月学园的精锐偶像将在『N.I.A』与咲季所在团队多次交锋。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00186", "scene_id": "scene-00186", "source_file": "CSV/dear/hski/adv_dear_hski_014.csv", "source_kind": "dear", "chapter": "dear/hski", "scene": "adv_dear_hski_014", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "71", "line_count": 71}], "source_refs": ["CSV/dear/hski/adv_dear_hski_014.csv:1-71"], "line_count": 71, "speakers": ["佑芽", "制作人", "咲季", "燐羽", "？？？"], "topics": ["relationships", "dialogue_style", "worldbuilding", "plot"], "title": "燐羽回归选拔赛", "summary": "咲季为佑芽参加演唱会，却得知燐羽落选。燐羽现身安慰佑芽并宣布退出，咲季不服挑战。燐羽决定参加决赛揭穿咲季，约定在 FINALE 对决。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "妹妹", "姐姐", "对手"], "worldbuilding_signals": ["学园", "偶像", "试镜", "演唱会", "工作"], "dialogue_style_signals": ["哼", "呵呵", "制作人", "啦"], "key_evidence": [{"source_row": "18", "speaker": "佑芽", "text_zh": "我输啦～～～～～～～～～～！"}, {"source_row": "23", "speaker": "咲季", "text_zh": "贺阳燐羽……！"}, {"source_row": "56", "speaker": "燐羽", "text_zh": "我之后不会再参加任何选拔赛了哦？"}, {"source_row": "71", "speaker": "燐羽", "text_zh": "我要在你妹妹面前，揭穿你的假面具。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["佑芽在选拔中落选，燐羽成为获胜者。", "燐羽宣布契约期工作完成，不再参加选拔。", "燐羽决定参加 FINALE 选拔试镜与咲季对决。"], "relationship_facts": ["咲季与佑芽是姐妹关系。", "咲季与燐羽是宿敌关系。", "燐羽是佑芽的粉丝。"], "worldbuilding_facts": ["佑芽是初星学园中等部最强组合 SyngUp! 的前任队长。", "燐羽是初星学园 1 年 3 班的学生。", "FINALE 是咲季与佑芽约定的直接对决舞台。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00187", "scene_id": "scene-00187", "source_file": "CSV/dear/hski/adv_dear_hski_015.csv", "source_kind": "dear", "chapter": "dear/hski", "scene": "adv_dear_hski_015", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "24", "line_count": 24}], "source_refs": ["CSV/dear/hski/adv_dear_hski_015.csv:1-24"], "line_count": 24, "speakers": ["制作人", "咲季", "选项"], "topics": ["relationships", "dialogue_style", "plot", "team_story"], "title": "咲季挑战燐羽大人", "summary": "咲季宣布参加『QUARTET』试镜，制作人称赞其实力足以击败佑芽。咲季虽知胜算渺茫，但受粉丝支持鼓舞，决心克服手抖，为妹妹报仇，准备在演出中重新征服制作人。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "妹妹", "对手"], "worldbuilding_signals": ["试镜"], "dialogue_style_signals": ["当然", "呵呵", "嘿嘿", "制作人"], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "制作人！我们要参加的试镜是——"}, {"source_row": "9", "speaker": "制作人", "text_zh": "足以击败『现在的花海佑芽』的超强敌手。"}, {"source_row": "24", "speaker": "咲季", "text_zh": "我要去替妹妹报仇！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季决定参加『QUARTET』的试镜。", "咲季认为制作人等粉丝是她的力量源泉。", "咲季决心在演出中为妹妹报仇。"], "relationship_facts": ["咲季与制作人关系亲密，制作人支持咲季。", "咲季视燐羽为击败过佑芽的强大对手。", "咲季与妹妹关系紧密，决心为妹妹复仇。"], "worldbuilding_facts": ["『QUARTET』是一个需要参加试镜的团体。", "粉丝的支持被视为咲季的外接肌肉和力量源泉。", "燐羽被尊称为大人，且击败过花海佑芽。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00188", "scene_id": "scene-00188", "source_file": "CSV/dear/hski/adv_dear_hski_016.csv", "source_kind": "dear", "chapter": "dear/hski", "scene": "adv_dear_hski_016", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "56", "line_count": 56}], "source_refs": ["CSV/dear/hski/adv_dear_hski_016.csv:1-56"], "line_count": 56, "speakers": ["众人", "佑芽", "制作人", "咲季", "燐羽", "选项"], "topics": ["relationships", "dialogue_style", "worldbuilding", "plot"], "title": "咲季与燐羽的偶像对决", "summary": "咲季在制作人面前展示了对佑芽的守护，并自信宣称自己是未来顶级偶像。面对燐羽的质问，咲季承认对方能力更强，但强调自己因与妹妹的约定及非偶像身份而必胜。燐羽被咲季不镀金的魅力打动，以亲吻告别，令咲季与佑芽震惊。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "妹妹", "姐姐", "对手"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["当然", "哼", "呵呵", "制作人", "啦"], "key_evidence": [{"source_row": "35", "speaker": "咲季", "text_zh": "我可是未来的顶级偶像啊。"}, {"source_row": "40", "speaker": "咲季", "text_zh": "和妹妹的约定，可不能违背呢。"}, {"source_row": "48", "speaker": "燐羽", "text_zh": "你啊，不镀金反而更迷人哦。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季将燐羽击败归功于与妹妹佑芽的约定及复仇誓言。", "咲季承认燐羽作为偶像的能力远超自己，但坚持自己必胜。", "燐羽因咲季不镀金反而更迷人的特质而对其产生好感。"], "relationship_facts": ["咲季是佑芽的姐姐，两人有互相守护的约定。", "咲季与制作人之间存在互相欣赏的暧昧关系。", "燐羽对咲季表现出超越对手的欣赏与喜爱。"], "worldbuilding_facts": ["咲季自视为未来的顶级偶像，对偶像身份有强烈认同。", "燐羽并非偶像，但拥有超越咲季的偶像所需能力。", "咲季认为输给非偶像的人是不被允许的。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00189", "scene_id": "scene-00189", "source_file": "CSV/dear/hski/adv_dear_hski_017.csv", "source_kind": "dear", "chapter": "dear/hski", "scene": "adv_dear_hski_017", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "41", "line_count": 41}], "source_refs": ["CSV/dear/hski/adv_dear_hski_017.csv:1-41"], "line_count": 41, "speakers": ["佑芽", "制作人", "咲季", "燐羽"], "topics": ["relationships", "dialogue_style", "plot", "character_arc"], "title": "咲季与佑芽的决胜负", "summary": "咲季结束演出归来，因燐羽的赞美被佑芽误会吃醋。咲季为消除误会，提议与佑芽进行『FINALE』对决。制作人指出咲季面对对手时能激发潜能，咲季决心挑战最强曲目，两人约定赛后和好如初。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "姐姐", "对手"], "worldbuilding_signals": [], "dialogue_style_signals": ["真是的", "哼", "制作人", "不是吗", "啦"], "key_evidence": [{"source_row": "15", "speaker": "燐羽", "text_zh": "你不镀金的样子反而更迷人哦。"}, {"source_row": "20", "speaker": "佑芽", "text_zh": "按照约定用『FINALE』和我一决胜负！"}, {"source_row": "37", "speaker": "制作人", "text_zh": "只有在和咲季同学对决时会进一步激发潜能。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季因燐羽的赞美被佑芽误会而生气。", "咲季提议与佑芽进行『FINALE』对决以证明实力。", "制作人指出咲季在与对手对决时会激发潜能。", "咲季决心挑战『FINALE』并向前进发。"], "relationship_facts": ["咲季与佑芽是竞争对手兼好友。", "燐羽是咲季的熟人，曾对咲季进行评价。", "制作人是咲季的上级或指导者，负责收集数据。"], "worldbuilding_facts": ["咲季拥有在对手面前激发潜能的『某个显著特征』。", "『FINALE』是咲季与佑芽约定对决的曲目。", "燐羽曾对咲季进行过镀金（或类似）的评价。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00190", "scene_id": "scene-00190", "source_file": "CSV/dear/hski/adv_dear_hski_018.csv", "source_kind": "dear", "chapter": "dear/hski", "scene": "adv_dear_hski_018", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "17", "line_count": 17}], "source_refs": ["CSV/dear/hski/adv_dear_hski_018.csv:1-17"], "line_count": 17, "speakers": ["制作人", "咲季", "选项"], "topics": ["relationships", "dialogue_style", "worldbuilding", "plot"], "title": "咲季决心重返舞台", "summary": "咲季得知将参加『FINALE』试镜，意识到自己与妹妹佑芽实力差距巨大，昔日奇迹不再。她承认自己无法再靠垂死挣扎取胜，但坚信自己已抓住超越过去的力量，决定不再逃避，要堂堂正正地赢回一切。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "妹妹", "姐姐", "对手"], "worldbuilding_signals": ["偶像", "试镜"], "dialogue_style_signals": ["制作人"], "key_evidence": [{"source_row": "2", "speaker": "制作人", "text_zh": "『FINALE』。"}, {"source_row": "5", "speaker": "咲季", "text_zh": "身为姐姐却在偶像事业上被妹妹超越……"}, {"source_row": "9", "speaker": "咲季", "text_zh": "和那孩子的实力差距……肯定没有缩小。"}, {"source_row": "17", "speaker": "咲季", "text_zh": "我会赢着回来的！制作人！！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季将参加名为『FINALE』的试镜。", "咲季认为与妹妹佑芽的实力差距已无法缩小。", "咲季决定不再垂死挣扎，要赢回比赛。"], "relationship_facts": ["咲季是制作人。", "咲季是佑芽的姐姐。", "佑芽是咲季的妹妹。"], "worldbuilding_facts": ["咲季在偶像事业上曾被妹妹超越。", "咲季曾有过险胜对手的奇迹经历。", "咲季目前处于偶像事业低谷期。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00191", "scene_id": "scene-00191", "source_file": "CSV/dear/hski/adv_dear_hski_019.csv", "source_kind": "dear", "chapter": "dear/hski", "scene": "adv_dear_hski_019", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "29", "line_count": 29}], "source_refs": ["CSV/dear/hski/adv_dear_hski_019.csv:1-29"], "line_count": 29, "speakers": ["佑芽", "咲季"], "topics": ["relationships", "dialogue_style", "character_arc", "plot"], "title": "势均力敌的夏日约定", "summary": "佑芽在与咲季的比赛中认输，坦言因无法追上姐姐而感到不甘心。咲季鼓励她，表示不再逃避，要在更盛大的舞台上与她进行热血对决。两人约定要变得更强，共同迎接夏天的欢呼，确立了并肩成长的羁绊。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "妹妹", "姐姐"], "worldbuilding_signals": [], "dialogue_style_signals": ["当然", "真是的", "呵呵", "让你见识"], "key_evidence": [{"source_row": "10", "speaker": "佑芽", "text_zh": "和姐姐一起……进行这么久势均力敌的比赛，还是第一次。"}, {"source_row": "16", "speaker": "咲季", "text_zh": "我已经……不会再逃跑了。"}, {"source_row": "20", "speaker": "咲季", "text_zh": "在比今天更盛大的舞台上。让夏天的欢呼声为你响起。"}, {"source_row": "29", "speaker": "咲季", "text_zh": "让你见识见识姐姐帅气的一面！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["佑芽在与咲季的比赛中首次感到势均力敌。", "咲季承诺不再逃跑，要在更盛大的舞台与佑芽对决。", "两人约定在下次对决前都要变得更强。"], "relationship_facts": ["咲季是佑芽的姐姐。", "咲季是佑芽想要追赶和超越的对象。", "两人是约定共同成长的伙伴。"], "worldbuilding_facts": ["故事背景设定在充满夏日氛围的环境中。", "咲季视创造让自己自豪的热血对决为人生目标。", "比赛是两人情感交流的重要媒介。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00192", "scene_id": "scene-00192", "source_file": "CSV/dear/hski/adv_dear_hski_020.csv", "source_kind": "dear", "chapter": "dear/hski", "scene": "adv_dear_hski_020", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "76", "line_count": 76}], "source_refs": ["CSV/dear/hski/adv_dear_hski_020.csv:1-76"], "line_count": 76, "speakers": ["制作人", "咲季", "选项"], "topics": ["relationships", "dialogue_style", "worldbuilding", "plot"], "title": "咲季与制作人的羁绊", "summary": "咲季在大赛后感谢粉丝与制作人，坦言若输给佑芽将彻底崩溃。制作人指出她必须学会面对失败，即便倒下也要匍匐前行。咲季最终接纳这份沉重信赖，确认两人是最佳搭档，誓言不再让制作人逃离。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "妹妹", "姐姐", "对手"], "worldbuilding_signals": ["偶像", "演唱会"], "dialogue_style_signals": ["当然", "真是的", "制作人"], "key_evidence": [{"source_row": "35", "speaker": "咲季", "text_zh": "我……如果输给了佑芽，就再也、再也无法振作起来了。"}, {"source_row": "61", "speaker": "制作人", "text_zh": "若是无法站立，那就匍匐前行——这才是花海咲季。"}, {"source_row": "75", "speaker": "咲季", "text_zh": "制作人。你是我，最棒的搭档哦。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季认为粉丝是勇气源泉，但极度恐惧输给佑芽导致精神崩溃。", "制作人指出咲季必须学会接受失败，即使武器折断也要战斗。", "咲季最终承认自己拥有不屈的灵魂，并誓言永远追随制作人。"], "relationship_facts": ["咲季与制作人是搭档关系，制作人视咲季为最出色的偶像。", "咲季与佑芽是竞争对手，咲季担心输给妹妹会一蹶不振。", "咲季与粉丝关系紧密，视粉丝为战胜强敌的武器。"], "worldbuilding_facts": ["偶像大赛中存在激烈的粉丝投票竞争与排行榜排名。", "偶像需要积累粉丝作为实力证明，但过度依赖可能导致脆弱。", "N.I.A 活动被视为偶像成长的宝贵养分与武器来源。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00193", "scene_id": "scene-00193", "source_file": "CSV/dear/hski/adv_dear_hski_021.csv", "source_kind": "dear", "chapter": "dear/hski", "scene": "adv_dear_hski_021", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "80", "line_count": 80}], "source_refs": ["CSV/dear/hski/adv_dear_hski_021.csv:1-80"], "line_count": 80, "speakers": ["佑芽", "制作人", "咲季", "选项"], "topics": ["relationships", "dialogue_style", "worldbuilding", "team_story"], "title": "咲季与制作人的约定", "summary": "咲季在『一等星』舞台前回顾与制作人相遇至今的历程。她坦言若无制作人，自己无法成为现在的偶像，两人共同培育了花海咲季。咲季向制作人表达坚定决心，誓言不再让其逃离，并邀请其一同见证属于两人的星星，强调唯有制作人能给予她勇气。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "星南", "姐姐", "对手"], "worldbuilding_signals": ["偶像", "制作人科", "课程", "训练", "试镜", "演唱会"], "dialogue_style_signals": ["当然", "真是的", "呵呵", "制作人", "啦"], "key_evidence": [{"source_row": "19", "speaker": "咲季", "text_zh": "那个舞台正是……偶像·花海咲季的起点。"}, {"source_row": "49", "speaker": "咲季", "text_zh": "至少我不认为能在『N.I.A』夺得冠军"}, {"source_row": "64", "speaker": "咲季", "text_zh": "我们两个人……共同培育了偶像·花海咲季。"}, {"source_row": "73", "speaker": "咲季", "text_zh": "别人可不行哦。不是你的话就不行。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季将『ENDLESS DANCE』视为偶像生涯的起点。", "咲季认为若无制作人，自己无法在『N.I.A』夺冠。", "咲季与制作人约定共同挑战盛大的舞台。"], "relationship_facts": ["咲季与制作人是并肩同行的搭档。", "咲季视制作人为唯一能给予她勇气的人。", "咲季与佑芽有着实现约定的羁绊。"], "worldbuilding_facts": ["『一等星』是咲季渴望获得的最高荣誉。", "『H.I.F』是咲季梦想开始的特别舞台。", "『N.I.A』是咲季曾试图夺冠但认为会落败的赛事。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00194", "scene_id": "scene-00194", "source_file": "CSV/dear/hski/adv_dear_hski_022.csv", "source_kind": "dear", "chapter": "dear/hski", "scene": "adv_dear_hski_022", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "61", "line_count": 61}], "source_refs": ["CSV/dear/hski/adv_dear_hski_022.csv:1-61"], "line_count": 61, "speakers": ["佑芽", "制作人", "咲季", "学园长"], "topics": ["relationships", "worldbuilding", "dialogue_style", "plot"], "title": "佑芽加冕一等星", "summary": "咲季演出结束后，见证妹妹佑芽在舞台上光芒万丈，正式加冕为夏日一等星。咲季由衷赞叹佑芽超越极限，并承认其已追上自己。佑芽确立独立成为顶尖偶像的梦想，咲季祝福其诞生，姐妹羁绊在相互成就中升华。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "妹妹", "姐姐", "对手"], "worldbuilding_signals": ["学园", "偶像", "演唱会"], "dialogue_style_signals": ["当然", "真是的", "呵呵", "制作人", "啦"], "key_evidence": [{"source_row": "19", "speaker": "学园长", "text_zh": "我校引以为傲的夏日一等星，其名为——花海佑芽！！"}, {"source_row": "44", "speaker": "佑芽", "text_zh": "我，追上了哦。花了15年，终于追上了哦。"}, {"source_row": "54", "speaker": "佑芽", "text_zh": "我想成为顶尖偶像。不是为了追赶姐姐。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["佑芽在演出中正式加冕为夏日一等星。", "咲季承认佑芽已追上自己并确立独立梦想。", "佑芽花费15年终于追上姐姐并决定成为偶像。"], "relationship_facts": ["咲季是佑芽的姐姐。", "佑芽是咲季的妹妹。", "咲季与佑芽是偶像搭档。"], "worldbuilding_facts": ["花海咲季与花海佑芽是姐妹。", "花海佑芽是学园长引以为傲的夏日一等星。", "成为顶尖偶像需要花费15年努力。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00195", "scene_id": "scene-00195", "source_file": "CSV/dear/hski/adv_dear_hski_023.csv", "source_kind": "dear", "chapter": "dear/hski", "scene": "adv_dear_hski_023", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "80", "line_count": 80}, {"block_index": 2, "start_row": "81", "end_row": "88", "line_count": 8}], "source_refs": ["CSV/dear/hski/adv_dear_hski_023.csv:1-88"], "line_count": 88, "speakers": ["制作人", "咲季", "选项"], "topics": ["relationships", "dialogue_style", "team_story", "worldbuilding"], "title": "咲季与制作人的新约定", "summary": "咲季承认输给佑芽后不甘，决心不再独自逞强。制作人放弃原有严酷方案，选择陪伴咲季。咲季接受帮助，承诺将制作人的选择变为正确，两人决定共同培育崭新的自己，迈向未来。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "妹妹", "姐姐"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["当然", "呵呵", "制作人"], "key_evidence": [{"source_row": "15", "speaker": "咲季", "text_zh": "有生以来第一次——……输给了妹妹。"}, {"source_row": "37", "speaker": "咲季", "text_zh": "那是积累了15年的我在呐喊。"}, {"source_row": "64", "speaker": "制作人", "text_zh": "我要舍弃所有的方案。"}, {"source_row": "88", "speaker": "咲季", "text_zh": "让我们一起培育吧，崭新的花海咲季。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季承认自己输给了妹妹佑芽，感到不甘心。", "咲季表示无法继续独自逞强，决定不再故作坚强。", "制作人决定舍弃所有既定方案，选择陪伴咲季。", "咲季承诺将制作人的选择变为正确的答案。"], "relationship_facts": ["咲季与制作人互为搭档，共同经历成长。", "咲季视制作人为可以依靠的伙伴。", "制作人视咲季为需要培育的偶像，但方式发生改变。"], "worldbuilding_facts": ["咲季积累了15年的偶像生涯经验。", "咲季曾追求无敌、孤高且严酷的偶像道路。", "制作人原本计划让咲季独自燃烧殆尽以成就传说。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00196", "scene_id": "scene-00196", "source_file": "CSV/dear/hski/adv_dear_hski_024.csv", "source_kind": "dear", "chapter": "dear/hski", "scene": "adv_dear_hski_024", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "80", "line_count": 80}, {"block_index": 2, "start_row": "81", "end_row": "81", "line_count": 1}], "source_refs": ["CSV/dear/hski/adv_dear_hski_024.csv:1-81"], "line_count": 81, "speakers": ["众人", "制作人", "咲季", "星南", "燐羽"], "topics": ["dialogue_style", "relationships", "team_story", "worldbuilding"], "title": "星屑同盟正式结成", "summary": "咲季与制作人决定联手培育新偶像，并邀请星南与燐羽加入。面对星南因佑芽表现而受挫的失落，咲季感同身受，三人正式结成同盟，启动项目『星屑』，誓要夺回辉煌并挑战『一等星』。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "星南", "妹妹", "姐姐"], "worldbuilding_signals": ["偶像", "训练", "演唱会"], "dialogue_style_signals": ["当然", "真是的", "呵呵", "制作人"], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "就让我们两个人一起培育吧"}, {"source_row": "46", "speaker": "星南", "text_zh": "败给了超越极限的咲季"}, {"source_row": "79", "speaker": "星南", "text_zh": "项目『星屑』正式启动"}, {"source_row": "81", "speaker": "星南", "text_zh": "打倒『一等星』"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季与制作人决定共同培育新的偶像。", "星南因佑芽的表现感到失落，但决定响应咲季邀请加入同盟。", "燐羽与星南正式加入咲季与制作人的团队。", "众人正式宣布启动项目『星屑』，目标是挑战『一等星』。"], "relationship_facts": ["咲季与制作人决定共同培育新偶像。", "星南与燐羽正式成为咲季与制作人的同盟者。", "咲季与星南因共同经历失败而建立深厚共鸣。"], "worldbuilding_facts": ["咲季老家拥有花海训练中心。", "星南曾是偶像『一等星』，现负责培育佑芽。", "项目『星屑』旨在让成员进一步成长并夺回辉煌。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00197", "scene_id": "scene-00197", "source_file": "CSV/dear/hski/adv_dear_hski_025.csv", "source_kind": "dear", "chapter": "dear/hski", "scene": "adv_dear_hski_025", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "80", "line_count": 80}, {"block_index": 2, "start_row": "81", "end_row": "108", "line_count": 28}], "source_refs": ["CSV/dear/hski/adv_dear_hski_025.csv:1-108"], "line_count": 108, "speakers": ["众人", "制作人", "咲季", "星南", "燐羽", "选项"], "topics": ["relationships", "dialogue_style", "worldbuilding", "team_story"], "title": "咲季特训与试镜挑战", "summary": "咲季带领燐羽与星南在花海训练中心进行特训，制定强化佑芽及自身成长的计划。面对职业偶像试镜，咲季虽感压力但仍接受制作人挑战，誓要每晚展示软弱以突破极限。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "星南", "美铃", "姐姐"], "worldbuilding_signals": ["学园", "偶像", "训练", "试镜", "演唱会"], "dialogue_style_signals": ["当然", "哼", "呵呵", "制作人", "啦"], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "你回来啦——回到怀念的我家了！"}, {"source_row": "26", "speaker": "星南", "text_zh": "我将其命名为『超新星』计划！！"}, {"source_row": "88", "speaker": "制作人", "text_zh": "咲季同学她……『VisuaL master』。"}, {"source_row": "108", "speaker": "咲季", "text_zh": "来倾听我的软弱！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季、燐羽与星南结成同盟，共同进行偶像特训。", "咲季计划参加职业偶像『VisuaL master』试镜。", "咲季因面对职业偶像而感到自信受挫，决心接受制作人挑战。"], "relationship_facts": ["咲季是燐羽和星南的姐姐及同盟者。", "制作人是咲季的指导者与策划者。", "星南是佑芽的制作人，负责其『超新星』计划。"], "worldbuilding_facts": ["花海训练中心拥有预开放期间可全使用的最新培育设施。", "职业偶像试镜『VisuaL master』规模大，形式接近『N.I.A』的『QUARTET』。", "通过科学方法与设施可将偶像数值无限提升。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00198", "scene_id": "scene-00198", "source_file": "CSV/dear/hski/adv_dear_hski_026.csv", "source_kind": "dear", "chapter": "dear/hski", "scene": "adv_dear_hski_026", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "61", "line_count": 61}], "source_refs": ["CSV/dear/hski/adv_dear_hski_026.csv:1-61"], "line_count": 61, "speakers": ["咲季", "旁白", "星南", "燐羽"], "topics": ["relationships", "team_story", "worldbuilding", "dialogue_style"], "title": "燐羽的憧憬与咲季的觉悟", "summary": "咲季与燐羽深夜谈心，燐羽坦言因憧憬姐姐佑芽而将咲季视为目标，却因过度追逐导致咲季身心受损。咲季理解后决定不再逃避，次日星南激励咲季挑战顶点，咲季回应以超越极限的决心，三人羁绊加深。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "星南", "妹妹", "姐姐", "伙伴"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["才不是", "制作人", "不是吗"], "key_evidence": [{"source_row": "23", "speaker": "燐羽", "text_zh": "因为很像。我也有一个当偶像的姐姐。"}, {"source_row": "29", "speaker": "燐羽", "text_zh": "发现我追逐的那个人已经破败不堪。"}, {"source_row": "57", "speaker": "咲季", "text_zh": "我，是因为憧憬你才成为偶像的。"}, {"source_row": "61", "speaker": "咲季", "text_zh": "让我们超越极限吧！彼此一起！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["燐羽因憧憬偶像姐姐佑芽，将咲季视为目标进行追逐。", "燐羽过度追逐导致咲季身心受损，咲季对此感到自责。", "咲季决定不再逃避，与星南约定共同超越极限。"], "relationship_facts": ["燐羽视咲季为偶像目标，但承认咲季并非其憧憬的姐姐。", "星南是咲季的前辈，咲季因憧憬星南而成为偶像。", "咲季与燐羽是姐妹关系，燐羽是咲季的妹妹。"], "worldbuilding_facts": ["咲季因失眠而显得软弱，燐羽对此表示理解。", "星南挑战偶像顶点，目标是重振十王星南的声威。", "冬季『H.I.F』演出即将开始，咲季与星南需为此做准备。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00199", "scene_id": "scene-00199", "source_file": "CSV/dear/hski/adv_dear_hski_027.csv", "source_kind": "dear", "chapter": "dear/hski", "scene": "adv_dear_hski_027", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "80", "line_count": 80}, {"block_index": 2, "start_row": "81", "end_row": "85", "line_count": 5}], "source_refs": ["CSV/dear/hski/adv_dear_hski_027.csv:1-85"], "line_count": 85, "speakers": ["众人", "制作人", "咲季", "星南", "选项"], "topics": ["dialogue_style", "relationships", "worldbuilding", "character_arc"], "title": "咲季的不屈之心", "summary": "咲季与星南结束特训后，向制作人倾诉胜利后的不安与脆弱。制作人肯定了她虽非昔日无敌，却因倾注心意而更耀眼的演出。咲季决心燃烧折断的心灵，成为不屈的顶级偶像。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人", "星南", "对手"], "worldbuilding_signals": ["偶像", "训练", "工作"], "dialogue_style_signals": ["当然", "真是的", "哼", "呵呵", "制作人", "不是吗", "啦"], "key_evidence": [{"source_row": "17", "speaker": "咲季", "text_zh": "这次是我赢了。"}, {"source_row": "59", "speaker": "制作人", "text_zh": "仿佛全身都沐浴在花海咲季的精神性之中。"}, {"source_row": "75", "speaker": "制作人", "text_zh": "是即使倒下折断，仍继续前行之人。"}, {"source_row": "85", "speaker": "咲季", "text_zh": "即将成为不屈不挠的顶级偶像！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季在特训后战胜了对手，但对自己能否持续获胜感到不安。", "制作人指出咲季现在的演出比想象中更耀眼，充满精神性。", "咲季决定不再逞强，要燃烧自己的心灵成为真正的偶像。"], "relationship_facts": ["咲季与制作人之间存在着深厚的信任与情感羁绊。", "星南作为前辈指导了咲季，并因咲季获胜而感到开心。", "咲季视制作人为可以完全依靠和倾诉的对象。"], "worldbuilding_facts": ["偶像的演出魅力源于将心意传递给粉丝。", "真正的强者并非不会倒下，而是倒下后仍能前行。", "粉丝的支持是偶像重要的外置肌肉。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00200", "scene_id": "scene-00200", "source_file": "CSV/dear/hume/adv_dear_hume_001.csv", "source_kind": "dear", "chapter": "dear/hume", "scene": "adv_dear_hume_001", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "69", "line_count": 69}], "source_refs": ["CSV/dear/hume/adv_dear_hume_001.csv:1-69"], "line_count": 69, "speakers": ["佑芽", "制作人", "咲季", "选项", "？？？"], "topics": ["relationships", "dialogue_style", "worldbuilding", "team_story"], "title": "咲季憧憬与佑芽入学", "summary": "咲季独白偶像如星辰花朵，渴望成为美好之人。佑芽开学典礼迟到，请求制作人培育。她立志战胜一直竞争的对手，决心成为学园最棒偶像。制作人接受请求，期待佑芽成长。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽"], "worldbuilding_signals": ["学园", "偶像", "制作人科"], "dialogue_style_signals": ["哼", "嘿嘿", "制作人", "啦"], "key_evidence": [{"source_row": "2", "speaker": "咲季", "text_zh": "那是我们永恒的憧憬"}, {"source_row": "15", "speaker": "佑芽", "text_zh": "我是偶像科的新生"}, {"source_row": "44", "speaker": "佑芽", "text_zh": "因为有想要战胜的人"}, {"source_row": "65", "speaker": "选项", "text_zh": "请让我来培育你吧"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["咲季视偶像为永恒憧憬，渴望成为美好之人。", "佑芽开学典礼迟到，请求制作人培育。", "佑芽立志战胜一直竞争的对手，决心成为学园最棒偶像。", "制作人接受佑芽请求，期待其成长。"], "relationship_facts": ["佑芽请求制作人培育自己。", "佑芽与一直竞争的对手存在竞争关系。", "制作人与佑芽建立师徒关系。"], "worldbuilding_facts": ["初星学园设有偶像科和制作人科。", "入学成绩及格者可能为候补录取。", "学园内存在偶像与制作人之间的培育关系。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00201", "scene_id": "scene-00201", "source_file": "CSV/dear/hume/adv_dear_hume_002.csv", "source_kind": "dear", "chapter": "dear/hume", "scene": "adv_dear_hume_002", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "76", "line_count": 76}], "source_refs": ["CSV/dear/hume/adv_dear_hume_002.csv:1-76"], "line_count": 76, "speakers": ["佑芽", "制作人", "咲季"], "topics": ["relationships", "dialogue_style", "team_story", "worldbuilding"], "title": "咲季考验制作人", "summary": "制作人向咲季展示佑芽培育计划，咲季质疑其了解程度。制作人解释已拜访咲季父母并获取资料，令咲季震惊。咲季认可制作人能力后撤退，佑芽与制作人击退姐姐，关系融洽。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "妹妹", "姐姐", "父母"], "worldbuilding_signals": ["学园", "偶像"], "dialogue_style_signals": ["当然", "哼", "嘿嘿", "制作人", "啦"], "key_evidence": [{"source_row": "17", "speaker": "咲季", "text_zh": "没错……既是佑芽的姐姐"}, {"source_row": "58", "speaker": "制作人", "text_zh": "通过您父母官网预约会面后"}, {"source_row": "60", "speaker": "佑芽", "text_zh": "在那之后还特意跑去爱知了吗"}, {"source_row": "67", "speaker": "咲季", "text_zh": "今天我就先撤退了！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季是佑芽的姐姐，学园第一美少女兼年级首席。", "制作人通过咲季父母官网预约会面，并前往爱知拜访。", "咲季要求制作人接受考验以证明其培育佑芽的实力。", "咲季在认可制作人能力后宣布撤退。"], "relationship_facts": ["咲季是佑芽的姐姐。", "制作人是佑芽的偶像培育者。", "佑芽视咲季为宿敌兼最棒的姐姐。"], "worldbuilding_facts": ["偶像培育被视作一项需要适应的『竞技运动』。", "制作人的事务所设在作为活动据点的教室。", "咲季的父母拥有官网，可预约会面。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00202", "scene_id": "scene-00202", "source_file": "CSV/dear/hume/adv_dear_hume_003.csv", "source_kind": "dear", "chapter": "dear/hume", "scene": "adv_dear_hume_003", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "79", "line_count": 79}], "source_refs": ["CSV/dear/hume/adv_dear_hume_003.csv:1-79"], "line_count": 79, "speakers": ["佑芽", "制作人", "咲季", "选项"], "topics": ["relationships", "dialogue_style", "character_arc", "worldbuilding"], "title": "佑芽的觉醒与训练", "summary": "佑芽在训练赛中输给咲季后，制作人肯定了她作为偶像的潜力，特别是其优秀的肉体数值。尽管咲季父母对培养方针有争议，制作人仍坚持按原计划培育佑芽。佑芽决心追赶咲季，两人约定共同挑战最强偶像。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "妹妹", "姐姐", "对手", "父母"], "worldbuilding_signals": ["偶像", "训练", "工作"], "dialogue_style_signals": ["当然", "呵呵", "嘿嘿", "制作人", "啦"], "key_evidence": [{"source_row": "5", "speaker": "咲季", "text_zh": "因为听说从今天开始可以借用训练室了"}, {"source_row": "16", "speaker": "咲季", "text_zh": "最后是采纳了我们父母的意见吗"}, {"source_row": "50", "speaker": "制作人", "text_zh": "而是作为偶像拥有最顶尖数值的肉体"}, {"source_row": "75", "speaker": "佑芽", "text_zh": "我们开始吧！一起把姐姐打败"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["佑芽在训练室与咲季进行了偶像实力比试并落败。", "咲季的父母对佑芽的培养方针与制作人发生了激烈争论。", "制作人指出佑芽拥有不输给咲季的顶级肉体数值和巨大潜力。", "佑芽决定全力追赶咲季，目标是击败这位最强偶像。"], "relationship_facts": ["咲季是佑芽的姐姐，也是佑芽想要超越的对手。", "制作人是佑芽的培育者，负责制定并执行其偶像培养计划。", "咲季的父母是咲季的监护人，对女儿的培养方针持有不同意见。"], "worldbuilding_facts": ["偶像行业存在训练室借用等日常运营机制。", "成为顶级偶像需要顶尖的肉体数值作为坚实基础。", "偶像培育计划需经过偶像本人及其父母的共同确认。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00203", "scene_id": "scene-00203", "source_file": "CSV/dear/hume/adv_dear_hume_004.csv", "source_kind": "dear", "chapter": "dear/hume", "scene": "adv_dear_hume_004", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "80", "line_count": 80}], "source_refs": ["CSV/dear/hume/adv_dear_hume_004.csv:1-80"], "line_count": 80, "speakers": ["佑芽", "制作人", "选项"], "topics": ["relationships", "dialogue_style", "worldbuilding", "character_arc"], "title": "咲季缺席的偶像对决", "summary": "佑芽渴望在偶像舞台上战胜姐姐咲季，但咲季并未在场。制作人指出佑芽对咲季的执着是双刃剑，需突破瓶颈。佑芽因从未赢过姐姐而苦恼，制作人建议通过爆发式成长实现胜利，并记录培育情况作为第一步。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "姐姐"], "worldbuilding_signals": ["学园", "偶像", "工作"], "dialogue_style_signals": ["当然", "制作人", "啦"], "key_evidence": [{"source_row": "14", "speaker": "佑芽", "text_zh": "因为姐姐开始以偶像为目标了。"}, {"source_row": "53", "speaker": "佑芽", "text_zh": "单纯就是姐姐太厉害了啦！"}, {"source_row": "62", "speaker": "佑芽", "text_zh": "只要能让姐姐说出『我输了』，就是我的胜利啦！"}, {"source_row": "79", "speaker": "制作人", "text_zh": "把今天的培育情况记录下来吧。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["佑芽立志成为学园第一偶像，目标是打败姐姐咲季。", "佑芽从未在猜拳、掰手腕或任何游戏中赢过咲季。", "制作人指出佑芽对咲季的热情既是武器也是枷锁。", "佑芽认为只有在舞台上堂堂正正获胜才算数。"], "relationship_facts": ["佑芽视咲季为必须超越的偶像目标。", "制作人作为引导者，试图帮助佑芽理清心态。", "咲季是佑芽的姐姐，在体能和学业上均优于佑芽。"], "worldbuilding_facts": ["学园偶像被视为一种需要突破瓶颈的竞技。", "胜利需要双方认可，舞台对决是最高标准。", "佑芽在体能测试中曾胜过咲季，但未被认可。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00204", "scene_id": "scene-00204", "source_file": "CSV/dear/hume/adv_dear_hume_005.csv", "source_kind": "dear", "chapter": "dear/hume", "scene": "adv_dear_hume_005", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "80", "line_count": 80}, {"block_index": 2, "start_row": "81", "end_row": "82", "line_count": 2}], "source_refs": ["CSV/dear/hume/adv_dear_hume_005.csv:1-82"], "line_count": 82, "speakers": ["佑芽", "制作人", "咲季"], "topics": ["relationships", "dialogue_style", "character_arc", "plot"], "title": "咲季佑芽成长突破", "summary": "咲季与佑芽比赛后，制作人指出佑芽虽常败但心态转变，正突破临界点。咲季作为最强宿敌与可靠姐姐，是佑芽成长的动力源泉，两人差距缩小，佑芽即将挑战其他偶像。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "姐姐", "对手"], "worldbuilding_signals": ["偶像", "训练", "试镜"], "dialogue_style_signals": ["呵呵", "制作人", "啦"], "key_evidence": [{"source_row": "53", "speaker": "制作人", "text_zh": "让佑芽同学获得爆发性成长的正是咲季同学。"}, {"source_row": "55", "speaker": "制作人", "text_zh": "对佑芽同学来说，咲季同学既是最强的宿敌，又是可靠的姐姐"}, {"source_row": "80", "speaker": "制作人", "text_zh": "下次要让佑芽同学——和咲季同学以外的偶像一决胜负！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["佑芽在咲季面前常败，但心态从输不起转变为坦然接受。", "咲季是佑芽突破临界点的关键契机，而非仅靠制作人培育。", "制作人决定让佑芽下次挑战咲季以外的偶像。"], "relationship_facts": ["咲季与佑芽是姐妹关系。", "咲季是佑芽的宿敌、榜样与动力源泉。", "制作人是佑芽的经纪人及训练师。"], "worldbuilding_facts": ["佑芽体内蕴藏巨大潜力，拥有最佳数值的偶像肉体。", "战胜咲季可获得飞跃性成长，但突破契机可多样化。", "咲季进步速度极快，是难以对付的强敌。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00205", "scene_id": "scene-00205", "source_file": "CSV/dear/hume/adv_dear_hume_006.csv", "source_kind": "dear", "chapter": "dear/hume", "scene": "adv_dear_hume_006", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "80", "line_count": 80}, {"block_index": 2, "start_row": "81", "end_row": "82", "line_count": 2}], "source_refs": ["CSV/dear/hume/adv_dear_hume_006.csv:1-82"], "line_count": 82, "speakers": ["佑芽", "制作人", "咲季", "选项"], "topics": ["relationships", "dialogue_style", "worldbuilding", "character_arc"], "title": "咲季登场与佑芽的决心", "summary": "选拔考试结束后，佑芽战胜前辈获得第一，但仍以姐姐咲季为唯一目标。咲季现身肯定佑芽成长，指出其实力差距。佑芽坚定表示要战胜咲季成为世界第一，制作人认可其决心并决定记录培育情况，目标确立。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "姐姐", "对手"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["当然", "制作人"], "key_evidence": [{"source_row": "41", "speaker": "咲季", "text_zh": "制作人说得没错哦。"}, {"source_row": "43", "speaker": "咲季", "text_zh": "佑芽已经成长很多了。"}, {"source_row": "68", "speaker": "佑芽", "text_zh": "对我来说，世界第一的偶像就是姐姐。"}, {"source_row": "82", "speaker": "制作人", "text_zh": "目标已经确定了。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["佑芽在选拔考试中战胜了多位前辈获得第一名。", "咲季指出佑芽不应再以自己为基准，需认清自身实力水平。", "佑芽明确表示世界第一的偶像就是咲季，目标是战胜她。", "制作人决定记录佑芽的培育情况，目标已确定为更进一步。"], "relationship_facts": ["佑芽视咲季为姐姐及偶像榜样。", "咲季是佑芽想要战胜的对象。", "制作人是佑芽的导师与观察者。"], "worldbuilding_facts": ["选拔考试是获得夏季大型活动资格的实战考核。", "夏季大型活动是决定学院第一偶像的庆典。", "Hatsuboshi IDOL FESTIVAL 是决定学院第一偶像的庆典。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00206", "scene_id": "scene-00206", "source_file": "CSV/dear/hume/adv_dear_hume_007.csv", "source_kind": "dear", "chapter": "dear/hume", "scene": "adv_dear_hume_007", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "72", "line_count": 72}], "source_refs": ["CSV/dear/hume/adv_dear_hume_007.csv:1-72"], "line_count": 72, "speakers": ["佑芽", "制作人", "咲季"], "topics": ["relationships", "dialogue_style", "team_story", "worldbuilding"], "title": "咲季与佑芽的夏日约定", "summary": "休息日咲季与佑芽在房间学习，咲季强调学业对偶像活动的重要性。两人互相鼓励，约定在下次选拔考试中一决胜负。咲季表示没有佑芽就没有现在的自己，两人相互成就，共同期待夏天的到来。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "姐姐"], "worldbuilding_signals": ["学园", "偶像"], "dialogue_style_signals": ["当然", "真是的", "呵呵", "嘿嘿", "制作人", "啦"], "key_evidence": [{"source_row": "30", "speaker": "咲季", "text_zh": "在初星学园是必须的哦。"}, {"source_row": "31", "speaker": "咲季", "text_zh": "偶像活动也会受到限制"}, {"source_row": "67", "speaker": "咲季", "text_zh": "下个月要举行的第二次『选拔考试』"}, {"source_row": "56", "speaker": "咲季", "text_zh": "我肯定也不会变成现在这样的我。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季与佑芽在休息日进行复习学习。", "咲季指出学业成绩不佳会限制偶像活动。", "两人约定在下个月举行的第二次选拔考试中对决。", "咲季认为没有佑芽就不会成为现在的自己。"], "relationship_facts": ["咲季是佑芽的姐姐。", "咲季与佑芽是互相竞争又相互成就的伙伴。", "制作人认为佑芽和咲季在一起。"], "worldbuilding_facts": ["在初星学园，偶像活动需要良好的学业成绩。", "学业成绩不好会导致偶像活动受到限制。", "下个月将举行第二次选拔考试。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00207", "scene_id": "scene-00207", "source_file": "CSV/dear/hume/adv_dear_hume_008.csv", "source_kind": "dear", "chapter": "dear/hume", "scene": "adv_dear_hume_008", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "80", "line_count": 80}, {"block_index": 2, "start_row": "81", "end_row": "82", "line_count": 2}], "source_refs": ["CSV/dear/hume/adv_dear_hume_008.csv:1-82"], "line_count": 82, "speakers": ["佑芽", "制作人", "选项"], "topics": ["relationships", "dialogue_style", "character_arc", "plot"], "title": "佑芽决心战胜咲季", "summary": "制作人告知佑芽选拔考试是与咲季决战的舞台，希望她在此之前获胜。佑芽虽感困惑，但意识到必须赢过姐姐才能成长。两人因长期竞争产生的复杂情感爆发，最终握手约定明日全力对决，佑芽誓要完成完美冲刺。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "姐姐"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["呵呵", "制作人", "啦"], "key_evidence": [{"source_row": "12", "speaker": "制作人", "text_zh": "H.I.F是与咲季同学决战的舞台。"}, {"source_row": "16", "speaker": "制作人", "text_zh": "战胜咲季同学，说是人生目标也不为过。"}, {"source_row": "36", "speaker": "佑芽", "text_zh": "现在立刻！！和花海咲季！！我想赢"}, {"source_row": "82", "speaker": "制作人", "text_zh": "终于要正面对决了。现在的我们，连获胜都不再是梦想！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["明日举行的选拔考试是佑芽与咲季的巅峰对决。", "制作人希望佑芽在 H.I.F 之前先战胜咲季。", "佑芽认为只有赢过姐姐才能证明自己的成长。"], "relationship_facts": ["佑芽视咲季为姐姐及无可替代的存在。", "制作人培养佑芽是为了让她能与咲季竞争。", "佑芽与咲季既是姐妹也是长期的竞争对手。"], "worldbuilding_facts": ["H.I.F 是与咲季进行最终决战的舞台。", "选拔考试是偶像成长的关键节点。", "姐妹间的竞争是剧情核心驱动力。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00208", "scene_id": "scene-00208", "source_file": "CSV/dear/hume/adv_dear_hume_009.csv", "source_kind": "dear", "chapter": "dear/hume", "scene": "adv_dear_hume_009", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "76", "line_count": 76}], "source_refs": ["CSV/dear/hume/adv_dear_hume_009.csv:1-76"], "line_count": 76, "speakers": ["佑芽", "制作人", "咲季", "选项"], "topics": ["relationships", "dialogue_style", "character_arc", "plot"], "title": "姐妹对决后的平局", "summary": "决战中佑芽与咲季打成平手，咲季既为妹妹追上自己感到开心，又因未能拉开差距而不甘心。她建议佑芽冷静后再决定情绪，并预告下次要在 H.I.F 进行最终对决，誓言要再次拉开差距。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "妹妹", "姐姐", "对手"], "worldbuilding_signals": ["偶像", "演唱会"], "dialogue_style_signals": ["真是的", "呵呵", "嘿嘿", "制作人", "啦"], "key_evidence": [{"source_row": "49", "speaker": "咲季", "text_zh": "居然能和我打成平手！！"}, {"source_row": "64", "speaker": "咲季", "text_zh": "佑芽的成长，让我好开心！！"}, {"source_row": "70", "speaker": "咲季", "text_zh": "果然还是要在 H.I.F 上一较高下呢。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["佑芽与咲季的正式对决以平局告终。", "咲季对佑芽的成长感到开心，但对自己未能拉开差距感到不甘心。", "咲季预告下次对决将在 H.I.F 举行。"], "relationship_facts": ["咲季是佑芽的姐姐。", "咲季与佑芽是宿命的对手。", "咲季与佑芽约定下次在 H.I.F 进行最终对决。"], "worldbuilding_facts": ["H.I.F 是姐妹俩约定进行最终对决的舞台。", "对决结果会影响佑芽对能否追上姐姐的判断。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00209", "scene_id": "scene-00209", "source_file": "CSV/dear/hume/adv_dear_hume_010-01.csv", "source_kind": "dear", "chapter": "dear/hume", "scene": "adv_dear_hume_010-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "30", "line_count": 30}], "source_refs": ["CSV/dear/hume/adv_dear_hume_010-01.csv:1-30"], "line_count": 30, "speakers": ["佑芽", "制作人", "四音", "黒井"], "topics": ["relationships", "dialogue_style", "worldbuilding", "team_story"], "title": "咲季作为最强对手", "summary": "制作人询问佑芽讨厌何种偶像，佑芽表示若出现实力强于姐姐、类型相似且被认可的对手会超级讨厌。制作人将其解读为拥有压倒性数值的怪物级竞争对手。随后黒井与四音登场，极月学园准备对初星学园展开行动。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "姐姐", "对手"], "worldbuilding_signals": ["学园", "偶像"], "dialogue_style_signals": ["呵呵", "嘿嘿", "制作人", "啦"], "key_evidence": [{"source_row": "11", "speaker": "佑芽", "text_zh": "非常喜欢姐姐，实力又比我强"}, {"source_row": "18", "speaker": "制作人", "text_zh": "拥有压倒性数值的超人"}, {"source_row": "22", "speaker": "黒井", "text_zh": "践踏初星学园的时刻"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["佑芽认为实力强于姐姐且类型相似的偶像是最讨厌的竞争对手。", "制作人将佑芽形容为拥有压倒性数值的超人。", "黒井与四音决定由极月学园对初星学园展开行动。"], "relationship_facts": ["佑芽与咲季是姐妹关系，佑芽非常崇拜咲季。", "咲季是佑芽在偶像界的主要竞争对手。", "黒井是四音的上级，被称为理事长。"], "worldbuilding_facts": ["存在极月学园与初星学园两个对立团体。", "偶像界存在实力差距巨大的‘怪物’级选手。", "四音是极月学园中负责执行任务的成员。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00210", "scene_id": "scene-00210", "source_file": "CSV/dear/hume/adv_dear_hume_010.csv", "source_kind": "dear", "chapter": "dear/hume", "scene": "adv_dear_hume_010", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "80", "line_count": 80}], "source_refs": ["CSV/dear/hume/adv_dear_hume_010.csv:1-80"], "line_count": 80, "speakers": ["佑芽", "制作人"], "topics": ["relationships", "dialogue_style", "character_arc", "plot"], "title": "佑芽立志超越咲季", "summary": "佑芽向制作人倾诉未能战胜咲季的挫败感与矛盾心情。制作人指出咲季虽非无敌但佑芽拥有直觉优势，建议通过提升可见数值来弥补不可量化的差距。两人决定以压倒性数值碾压咲季为目标，佑芽接受挑战，立志成为顶级偶像回应期待。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "妹妹", "姐姐", "对手"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["当然", "嘿嘿", "制作人", "啦"], "key_evidence": [{"source_row": "15", "speaker": "佑芽", "text_zh": "明明约好了要让你看到我战胜姐姐的样子。"}, {"source_row": "36", "speaker": "佑芽", "text_zh": "因为我希望姐姐永远是无敌的。"}, {"source_row": "66", "speaker": "制作人", "text_zh": "拼命堆砌那些看得见的数值吧。"}, {"source_row": "80", "speaker": "佑芽", "text_zh": "我花海佑芽！一定会回应您的期待！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["佑芽在跑步中向制作人倾诉未能战胜咲季的烦恼。", "佑芽承认自己希望咲季永远无敌，不希望输给对方。", "制作人建议佑芽通过提升歌唱、舞蹈等数值来取胜。", "佑芽接受挑战，决心以压倒性数值赢得胜利。"], "relationship_facts": ["佑芽与咲季是姐妹关系，咲季是佑芽的偶像榜样。", "佑芽与制作人关系亲密，制作人负责指导佑芽。", "咲季与制作人相识，制作人了解咲季的实力与背景。"], "worldbuilding_facts": ["偶像界存在可量化的能力数值与不可量化的觉悟、心意。", "咲季在各大赛事中成绩优异，但并非从未败绩。", "佑芽拥有敏锐的直觉，能凭直觉选择最短路径。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00211", "scene_id": "scene-00211", "source_file": "CSV/dear/hume/adv_dear_hume_011.csv", "source_kind": "dear", "chapter": "dear/hume", "scene": "adv_dear_hume_011", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "47", "line_count": 47}], "source_refs": ["CSV/dear/hume/adv_dear_hume_011.csv:1-47"], "line_count": 47, "speakers": ["佑芽", "制作人", "咲季"], "topics": ["relationships", "dialogue_style", "worldbuilding", "character_arc"], "title": "咲季参战NIA决赛", "summary": "佑芽确立参加NEXT IDOL AUDITION，咲季宣布参战并与佑芽约定在最终日进行姐妹对决。制作人建议将直接对决留到最后，咲季接受提议，期待在盛大舞台上与成长后的佑芽一决高下，两人对公平对决感到开心。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "姐姐", "对手"], "worldbuilding_signals": ["偶像", "试镜"], "dialogue_style_signals": ["当然", "制作人", "啦"], "key_evidence": [{"source_row": "21", "speaker": "咲季", "text_zh": "佑芽！『NEXT IDOL AUDITION』——这次我也要参战哦！"}, {"source_row": "31", "speaker": "制作人", "text_zh": "请把你们姐妹的直接对决留到最终日吧。"}, {"source_row": "47", "speaker": "咲季", "text_zh": "在『FINALE』上再见吧，佑芽。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季决定参加NEXT IDOL AUDITION比赛。", "咲季与佑芽约定在最终日进行直接对决。", "咲季认为在盛大舞台上与佑芽对决是最佳安排。"], "relationship_facts": ["咲季是佑芽的姐姐。", "咲季与佑芽是宿命对手。", "咲季与佑芽曾打成平手。"], "worldbuilding_facts": ["NEXT IDOL AUDITION是偶像争夺粉丝的活动。", "比赛规则允许偶像互相争夺粉丝。", "最终日将举行最大规模的公开试镜FINALE。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00212", "scene_id": "scene-00212", "source_file": "CSV/dear/hume/adv_dear_hume_012.csv", "source_kind": "dear", "chapter": "dear/hume", "scene": "adv_dear_hume_012", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "79", "line_count": 79}], "source_refs": ["CSV/dear/hume/adv_dear_hume_012.csv:1-79"], "line_count": 79, "speakers": ["佑芽", "制作人", "咲季", "燐羽"], "topics": ["relationships", "dialogue_style", "worldbuilding", "plot"], "title": "佑芽败北咲季登场", "summary": "佑芽在选拔赛中意外输给极月学园的燐羽，情绪崩溃。姐姐咲季及时出现安慰并承诺替其复仇。燐羽表示是佑芽粉丝，随后决定陪她们玩。咲季无视燐羽的挑衅，坚定表示要替妹妹赢回尊严，佑芽重拾信心。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "美铃", "姐姐", "对手"], "worldbuilding_signals": ["学园", "偶像", "试镜", "演唱会", "工作"], "dialogue_style_signals": ["嘿嘿", "制作人", "啦"], "key_evidence": [{"source_row": "25", "speaker": "佑芽", "text_zh": "输掉了啦～～～～～～～！！"}, {"source_row": "40", "speaker": "咲季", "text_zh": "佑芽！！姐姐来给你打气啦！"}, {"source_row": "56", "speaker": "燐羽", "text_zh": "其实我是你的粉丝。"}, {"source_row": "66", "speaker": "咲季", "text_zh": "贺阳燐羽！来和我一决胜负吧！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["佑芽在选拔赛中输给了极月学园的贺阳燐羽。", "咲季出现安慰哭泣的佑芽，并承诺替她向燐羽复仇。", "燐羽透露自己是佑芽的粉丝，并决定暂时陪她们玩耍。", "咲季无视燐羽的挑衅，坚持要替佑芽赢得胜利。"], "relationship_facts": ["佑芽与咲季是姐妹关系，咲季是佑芽的偶像姐姐。", "燐羽是佑芽的粉丝，并安慰了刚输掉比赛的佑芽。", "咲季与燐羽存在竞争关系，咲季向燐羽发起对决挑战。"], "worldbuilding_facts": ["『N.I.A』是新人偶像大赛，『一等星』的三组不会参加。", "极月学园是初星学园的竞争对手学校。", "贺阳燐羽曾是中等部最强组合『SyngUp!』的前任队长。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00213", "scene_id": "scene-00213", "source_file": "CSV/dear/hume/adv_dear_hume_013.csv", "source_kind": "dear", "chapter": "dear/hume", "scene": "adv_dear_hume_013", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "72", "line_count": 72}], "source_refs": ["CSV/dear/hume/adv_dear_hume_013.csv:1-72"], "line_count": 72, "speakers": ["众人", "佑芽", "制作人", "咲季", "燐羽"], "topics": ["relationships", "dialogue_style", "worldbuilding", "plot"], "title": "咲季与燐羽的宿命对决", "summary": "制作人宣布燐羽与咲季决战，佑芽坚信姐姐必胜。咲季虽承认燐羽实力超群，但强调自己为未来顶级偶像且背负对妹妹的约定。燐羽被咲季的决心打动，认可佑芽是出色姐姐，随后告别众人。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "妹妹", "姐姐", "对手"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["当然", "哼", "呵呵", "制作人", "啦"], "key_evidence": [{"source_row": "44", "speaker": "咲季", "text_zh": "偶像所需的一切才能，都比我……要出色得多。"}, {"source_row": "51", "speaker": "咲季", "text_zh": "不是偶像。"}, {"source_row": "64", "speaker": "燐羽", "text_zh": "佑芽……真是个出色的姐姐呢。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季承认燐羽在歌唱舞蹈等偶像才能上比自己出色。", "咲季认为燐羽缺少成为偶像最重要的东西，判定其并非偶像。", "燐羽被咲季的决心感动，认可佑芽是出色的姐姐并告别。"], "relationship_facts": ["咲季与佑芽是姐妹，咲季为佑芽的复仇挺身而出。", "燐羽与咲季是即将对决的对手，燐羽对咲季抱有敬意。", "燐羽与佑芽关系融洽，燐羽称赞佑芽是出色的姐姐。"], "worldbuilding_facts": ["咲季自称为未来的顶级偶像，拥有神秘力量。", "燐羽经过N.I.A历练，实力已成长后的佑芽不相上下。", "咲季认为偶像最重要的东西是燐羽所缺少的。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00214", "scene_id": "scene-00214", "source_file": "CSV/dear/hume/adv_dear_hume_014.csv", "source_kind": "dear", "chapter": "dear/hume", "scene": "adv_dear_hume_014", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "50", "line_count": 50}], "source_refs": ["CSV/dear/hume/adv_dear_hume_014.csv:1-50"], "line_count": 50, "speakers": ["佑芽", "制作人"], "topics": ["relationships", "dialogue_style", "worldbuilding", "character_arc"], "title": "佑芽备战咲季选拔", "summary": "佑芽因燐羽与咲季冲突而愤怒，决心在选拔赛击败燐羽。制作人安排观摩顶级偶像练习，并透露已为佑芽争取到特殊席位。制作人愿为培育佑芽不择手段，甚至考虑转会，佑芽则坚持先赢过咲季再谈未来。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "姐姐", "对手"], "worldbuilding_signals": ["偶像", "训练", "演唱会"], "dialogue_style_signals": ["当然", "制作人", "啦"], "key_evidence": [{"source_row": "6", "speaker": "佑芽", "text_zh": "我要在选拔赛上把燐羽打得落花流水来报仇！"}, {"source_row": "19", "speaker": "制作人", "text_zh": "和顶级偶像级别的对手进行观摩练习。"}, {"source_row": "49", "speaker": "制作人", "text_zh": "为了获得能击败无敌的咲季同学的新武器！"}, {"source_row": "47", "speaker": "佑芽", "text_zh": "一定、全部、我的……都要在那之后才能开始。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["佑芽要在选拔赛上击败燐羽以报仇。", "制作人安排了观摩顶级偶像的练习机会。", "制作人为了培育佑芽愿意采取非常手段。", "佑芽坚持要等打败咲季后才考虑未来。"], "relationship_facts": ["佑芽与燐羽存在竞争与冲突关系。", "制作人与佑芽是师徒/培养关系。", "咲季被描述为佑芽需要击败的顶级偶像。"], "worldbuilding_facts": ["存在选拔赛作为偶像竞争舞台。", "大型事务所社长具有慧眼且能协调资源。", "偶像界存在顶级偶像级别的高门槛。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00215", "scene_id": "scene-00215", "source_file": "CSV/dear/hume/adv_dear_hume_015.csv", "source_kind": "dear", "chapter": "dear/hume", "scene": "adv_dear_hume_015", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "63", "line_count": 63}], "source_refs": ["CSV/dear/hume/adv_dear_hume_015.csv:1-63"], "line_count": 63, "speakers": ["佑芽", "制作人", "燐羽"], "topics": ["relationships", "dialogue_style", "worldbuilding", "character_arc"], "title": "燐羽特训佑芽", "summary": "制作人安排宿敌燐羽为佑芽特训，旨在助其战胜咲季。燐羽虽表面嫌弃，实则渴望见证佑芽击败姐姐咲季。佑芽接受特训，决心在试镜中超越燐羽，三人关系在竞争与羁绊中交织。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "美铃", "姐姐"], "worldbuilding_signals": ["偶像", "课程", "训练", "试镜"], "dialogue_style_signals": ["当然", "哼", "呵呵", "制作人", "啦"], "key_evidence": [{"source_row": "37", "speaker": "燐羽", "text_zh": "想看咲季姐姐……败给你的样子。"}, {"source_row": "13", "speaker": "制作人", "text_zh": "咲季同学才是不正常的特例。"}, {"source_row": "63", "speaker": "佑芽", "text_zh": "我要在试镜中把你彻底击败！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["燐羽主动提出为佑芽进行特训。", "燐羽特训的目的是想看佑芽战胜咲季。", "佑芽决心在试镜中击败燐羽。"], "relationship_facts": ["燐羽视咲季为姐姐。", "燐羽与佑芽是竞争对手。", "制作人与燐羽是合作关系。"], "worldbuilding_facts": ["咲季是原特待生，实力超群。", "燐羽是原特待生，实力强大。", "燐羽能即兴模仿并超越他人。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00216", "scene_id": "scene-00216", "source_file": "CSV/dear/hume/adv_dear_hume_016.csv", "source_kind": "dear", "chapter": "dear/hume", "scene": "adv_dear_hume_016", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "63", "line_count": 63}], "source_refs": ["CSV/dear/hume/adv_dear_hume_016.csv:1-63"], "line_count": 63, "speakers": ["佑芽", "制作人", "燐羽", "选项", "黒井"], "topics": ["relationships", "dialogue_style", "worldbuilding", "plot"], "title": "咲季缺席的姐妹对决", "summary": "黑井祝贺制作人获胜，并试图招募佑芽，被制作人拒绝。燐羽承认输给佑芽，表示若姐妹俩早点出现局面会更好，并提及咲季姐姐。燐羽向佑芽表白粉丝身份，随后亲吻佑芽，佑芽大受惊吓。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "姐姐"], "worldbuilding_signals": ["学园", "偶像", "演唱会"], "dialogue_style_signals": ["哼", "呵呵", "制作人", "啦"], "key_evidence": [{"source_row": "45", "speaker": "燐羽", "text_zh": "现在的话……说不定能追上咲季姐姐了。"}, {"source_row": "41", "speaker": "燐羽", "text_zh": "……要是你们姐妹能早点出现就好了……"}, {"source_row": "12", "speaker": "黒井", "text_zh": "带着花海佑芽来961事务所吧。"}, {"source_row": "13", "speaker": "制作人", "text_zh": "我拒绝。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["黑井祝贺制作人获胜并试图招募佑芽", "燐羽承认输给佑芽并提及咲季姐姐", "燐羽向佑芽表白并亲吻了她", "制作人拒绝了黑井的招募提议"], "relationship_facts": ["燐羽是佑芽的粉丝", "燐羽称呼花海咲季为姐姐", "黑井与制作人是对手关系"], "worldbuilding_facts": ["存在初星学园和极月学园", "存在961事务所和100事务所", "燐羽是偶像，佑芽也是偶像"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00217", "scene_id": "scene-00217", "source_file": "CSV/dear/hume/adv_dear_hume_017.csv", "source_kind": "dear", "chapter": "dear/hume", "scene": "adv_dear_hume_017", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "59", "line_count": 59}], "source_refs": ["CSV/dear/hume/adv_dear_hume_017.csv:1-59"], "line_count": 59, "speakers": ["佑芽", "制作人", "咲季"], "topics": ["relationships", "dialogue_style", "character_arc", "plot"], "title": "咲季登场与决胜负宣言", "summary": "佑芽与制作人讨论咲季周边及粉丝身份，咲季突然现身打断二人。咲季称赞佑芽成长，并重申作为姐姐绝不认输的立场，宣告姐妹决胜负之日到来，展现其生存之道。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "姐姐"], "worldbuilding_signals": ["偶像", "训练"], "dialogue_style_signals": ["当然", "真是的", "哼", "嘿嘿", "制作人", "啦"], "key_evidence": [{"source_row": "30", "speaker": "咲季", "text_zh": "——真失礼！我才没有偷听呢！"}, {"source_row": "44", "speaker": "佑芽", "text_zh": "这是我们姐妹俩的……决胜负的日子。"}, {"source_row": "57", "speaker": "咲季", "text_zh": "因为我是你的姐姐啊！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["休息室堆满了花海咲季的限定周边商品。", "制作人将咲季周边作为佑芽胜利的贺礼。", "咲季现身并打断佑芽与制作人的对话。", "咲季承诺绝不会输给变得强大的佑芽。"], "relationship_facts": ["佑芽与咲季是姐妹关系。", "制作人是佑芽的偶像支持者。", "咲季与制作人存在竞争关系。"], "worldbuilding_facts": ["『N.I.A』是偶像团体名称。", "花海咲季拥有魔性的魅力。", "佑芽是制作人负责的专属偶像。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00218", "scene_id": "scene-00218", "source_file": "CSV/dear/hume/adv_dear_hume_018.csv", "source_kind": "dear", "chapter": "dear/hume", "scene": "adv_dear_hume_018", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "18", "line_count": 18}], "source_refs": ["CSV/dear/hume/adv_dear_hume_018.csv:1-18"], "line_count": 18, "speakers": ["佑芽", "制作人", "选项"], "topics": ["relationships", "dialogue_style", "plot", "team_story"], "title": "佑芽挑战咲季试镜", "summary": "佑芽得知试镜作品为『FINALE』，激动地表示终于能追上姐姐。她视此次挑战为人生集大成之作，决心在眼前战胜咲季，实现儿时梦想。制作人鼓励她超越咲季，佑芽接受挑战，请求见证她一生一次的决胜负。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "姐姐"], "worldbuilding_signals": ["试镜"], "dialogue_style_signals": ["制作人"], "key_evidence": [{"source_row": "2", "speaker": "制作人", "text_zh": "试镜是『FINALE』。"}, {"source_row": "9", "speaker": "佑芽", "text_zh": "花了15年……终于……追上姐姐了。"}, {"source_row": "13", "speaker": "佑芽", "text_zh": "我要战胜姐姐！！！"}, {"source_row": "15", "speaker": "选项", "text_zh": "让我们一起超越咲季同学吧！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["佑芽参加名为『FINALE』的试镜。", "佑芽认为这是她15年努力后追上姐姐的时刻。", "佑芽的目标是战胜咲季。", "制作人提议与咲季一起超越她。"], "relationship_facts": ["佑芽视咲季为姐姐。", "佑芽与咲季存在竞争关系。", "制作人与佑芽是搭档关系。"], "worldbuilding_facts": ["咲季是佑芽儿时的梦想对象。", "佑芽花费15年追赶咲季。", "『FINALE』是重要的试镜作品。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00219", "scene_id": "scene-00219", "source_file": "CSV/dear/hume/adv_dear_hume_019.csv", "source_kind": "dear", "chapter": "dear/hume", "scene": "adv_dear_hume_019", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "63", "line_count": 63}], "source_refs": ["CSV/dear/hume/adv_dear_hume_019.csv:1-63"], "line_count": 63, "speakers": ["佑芽", "咲季", "星南", "燐羽"], "topics": ["relationships", "dialogue_style", "worldbuilding", "team_story"], "title": "咲季决定不再逃避", "summary": "佑芽赢得比赛后感动落泪，担心咲季因自己迟钝而消失。咲季承诺不再逃跑，决定与星南、燐羽一同特训，以偶像身份全力挑战佑芽，约定在 H.I.F 舞台上再决胜负。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "星南", "姐姐", "对手", "伙伴"], "worldbuilding_signals": ["偶像", "工作"], "dialogue_style_signals": ["真是的", "呵呵", "制作人", "啦"], "key_evidence": [{"source_row": "37", "speaker": "咲季", "text_zh": "我已经……不会再逃跑了！！"}, {"source_row": "58", "speaker": "星南", "text_zh": "咲季。我不记得什么时候成了你的伙伴呢。"}, {"source_row": "56", "speaker": "咲季", "text_zh": "在『H.I.F』开始前的最后一刻，我要回老家进行特训"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季承诺不再离开，决定与星南和燐羽一同回老家特训。", "咲季表示即使佑芽消失，自己也无法放弃当偶像。", "咲季决定在 H.I.F 开始前全力以赴，与佑芽再一决胜负。"], "relationship_facts": ["咲季与佑芽是竞争对手兼姐妹。", "星南和燐羽是咲季的新伙伴。", "咲季与佑芽约定在 H.I.F 舞台上再次对决。"], "worldbuilding_facts": ["咲季将参加名为『H.I.F』的活动。", "咲季老家有工作人员和妈妈可以协助照顾佑芽。", "咲季决定与星南、燐羽等新伙伴一起进行特训。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00220", "scene_id": "scene-00220", "source_file": "CSV/dear/hume/adv_dear_hume_020.csv", "source_kind": "dear", "chapter": "dear/hume", "scene": "adv_dear_hume_020", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "70", "line_count": 70}], "source_refs": ["CSV/dear/hume/adv_dear_hume_020.csv:1-70"], "line_count": 70, "speakers": ["佑芽", "制作人", "选项"], "topics": ["relationships", "dialogue_style", "worldbuilding", "plot"], "title": "咲季缺席的对话", "summary": "佑芽在制作人面前庆祝战胜姐姐咲季，实现了成为顶级偶像的梦想。她虽未直接出场，但作为佑芽的姐姐、偶像界的顶尖存在及佑芽的竞争对手被频繁提及。两人约定在『H.I.F』再次对决，咲季正为追赶佑芽而特训，佑芽对此既感动又期待。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "姐姐"], "worldbuilding_signals": ["学园", "偶像", "演唱会", "工作"], "dialogue_style_signals": ["呵呵", "嘿嘿", "制作人", "啦"], "key_evidence": [{"source_row": "32", "speaker": "佑芽", "text_zh": "我和姐姐约好了，要再比一次。"}, {"source_row": "36", "speaker": "佑芽", "text_zh": "要成为姐姐的目标！"}, {"source_row": "59", "speaker": "佑芽", "text_zh": "姐姐现在，为了打败我，正在进行特训。"}, {"source_row": "64", "speaker": "制作人", "text_zh": "无敌的咲季同学，怎么可能因为那种程度就放弃。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["佑芽在优胜演唱会中战胜了姐姐咲季。", "佑芽实现了成为顶级偶像的梦想，并确立了新的目标。", "咲季为了追赶佑芽正在进行特训。", "佑芽与咲季约定在『H.I.F』中再次一决高下。"], "relationship_facts": ["佑芽是咲季的妹妹。", "咲季是佑芽的偶像榜样与竞争对手。", "制作人是佑芽的经纪人兼支持者。"], "worldbuilding_facts": ["『一等星』是顶级偶像的称号。", "『N.I.A』和『H.I.F』是偶像竞赛或活动的名称。", "初星学园是培养偶像的学校。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00221", "scene_id": "scene-00221", "source_file": "CSV/dear/hume/adv_dear_hume_021.csv", "source_kind": "dear", "chapter": "dear/hume", "scene": "adv_dear_hume_021", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "80", "line_count": 80}, {"block_index": 2, "start_row": "81", "end_row": "82", "line_count": 2}], "source_refs": ["CSV/dear/hume/adv_dear_hume_021.csv:1-82"], "line_count": 82, "speakers": ["众人", "佑芽", "制作人", "咲季", "选项"], "topics": ["relationships", "dialogue_style", "worldbuilding", "team_story"], "title": "佑芽成为顶级偶像", "summary": "在『初星偶像节』前夕，制作人祝贺佑芽成为学园第一偶像。咲季虽缺席进行魔鬼特训，但佑芽在制作人鼓励下，集齐心技体，正式迈向顶级偶像之路，准备在众人见证下登台演出。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "星南", "姐姐", "伙伴"], "worldbuilding_signals": ["学园", "偶像", "训练", "工作"], "dialogue_style_signals": ["当然", "真是的", "制作人", "啦"], "key_evidence": [{"source_row": "9", "speaker": "制作人", "text_zh": "花海佑芽成为学园第一偶像"}, {"source_row": "22", "speaker": "咲季", "text_zh": "我都要回老家进行魔鬼特训"}, {"source_row": "69", "speaker": "制作人", "text_zh": "偶像所需的心、技、体全部集齐"}, {"source_row": "79", "speaker": "制作人", "text_zh": "花海佑芽的初次登台"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["佑芽正式成为学园第一偶像『一等星』。", "咲季缺席现场，回老家进行魔鬼特训。", "佑芽集齐偶像所需的心、技、体。", "佑芽即将在众人见证下进行初次登台。"], "relationship_facts": ["佑芽视咲季为姐姐及目标。", "制作人是佑芽的导师与伙伴。", "佑芽与母亲及工作人员关系亲密。"], "worldbuilding_facts": ["『初星偶像节』是优秀偶像的庆典。", "成为顶级偶像需集齐心、技、体。", "偶像训练设施已建成并投入使用。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00222", "scene_id": "scene-00222", "source_file": "CSV/dear/hume/adv_dear_hume_022.csv", "source_kind": "dear", "chapter": "dear/hume", "scene": "adv_dear_hume_022", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "66", "line_count": 66}], "source_refs": ["CSV/dear/hume/adv_dear_hume_022.csv:1-66"], "line_count": 66, "speakers": ["众人", "佑芽", "制作人", "咲季", "学园长"], "topics": ["relationships", "dialogue_style", "team_story", "worldbuilding"], "title": "姐妹对决与宿敌宣言", "summary": "佑芽与咲季在演出后重逢，两人因争夺制作人关注而互相调侃。咲季指出两人皆败于前辈，随即宣告将佑芽视为唯一宿敌，决心超越前辈。最终姐妹互诉衷肠，确认彼此深厚的羁绊与共同成长的决心。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "星南", "姐姐", "对手"], "worldbuilding_signals": ["学园", "偶像"], "dialogue_style_signals": ["当然", "才不是", "呵呵", "嘿嘿", "制作人", "啦"], "key_evidence": [{"source_row": "34", "speaker": "咲季", "text_zh": "佑芽！！"}, {"source_row": "45", "speaker": "咲季", "text_zh": "把我们姐妹的胜负搅得一塌糊涂的"}, {"source_row": "60", "speaker": "咲季", "text_zh": "我的宿敌是你才对——佑芽！！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季与佑芽在演出结束后同时抵达现场。", "咲季指出两人皆败于前辈，决定暂时忘却前辈之事。", "咲季正式宣告佑芽是她唯一的宿敌，拒绝被前辈妨碍。", "姐妹二人最终互表爱意，确认了深厚的羁绊。"], "relationship_facts": ["咲季是佑芽的姐姐。", "咲季与佑芽是竞争对手兼亲密姐妹。", "咲季与佑芽共同面对前辈的挑战。"], "worldbuilding_facts": ["咲季是初星学园最强的偶像，被称为“一等星”。", "咲季是佑芽一直憧憬的偶像。", "咲季是佑芽命中注定的对手。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00223", "scene_id": "scene-00223", "source_file": "CSV/dear/hume/adv_dear_hume_023.csv", "source_kind": "dear", "chapter": "dear/hume", "scene": "adv_dear_hume_023", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "79", "line_count": 79}], "source_refs": ["CSV/dear/hume/adv_dear_hume_023.csv:1-79"], "line_count": 79, "speakers": ["佑芽", "制作人", "选项"], "topics": ["relationships", "dialogue_style", "worldbuilding", "character_arc"], "title": "咲季登场与特训计划", "summary": "佑芽与制作人因花海咲季的惊人演出而振奋，决定为冬季 H.I.F 特训。咲季虽未直接对话，但其演出震撼全场，被赞为无敌。制作人感叹若重来绝不会放弃佑芽，两人重拾信心，准备迎接挑战。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "星南", "妹妹", "姐姐"], "worldbuilding_signals": ["偶像", "工作"], "dialogue_style_signals": ["呵呵", "制作人", "啦"], "key_evidence": [{"source_row": "56", "speaker": "制作人", "text_zh": "——然后，是咲季同学。"}, {"source_row": "58", "speaker": "制作人", "text_zh": "那场帅气的演出。……我真的很感动。"}, {"source_row": "67", "speaker": "制作人", "text_zh": "她是无敌、不屈、蛮不讲理……"}, {"source_row": "75", "speaker": "制作人", "text_zh": "为了冬季的『H.I.F』开始特训吧。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["花海咲季的演出让制作人感到极度震撼与感动。", "咲季被描述为无敌、不屈且蛮不讲理的顶级偶像。", "制作人表示无论重来多少次都不会做出放弃咲季的选择。", "两人决定开始特训以备战冬季的 H.I.F 比赛。"], "relationship_facts": ["花海咲季是花海佑芽的姐姐。", "咲季是制作人极力想要保护的偶像。", "佑芽与制作人之间是互相扶持的搭档关系。"], "worldbuilding_facts": ["当前偶像业界正热议星南学姐的三连冠成就。", "冬季将举行重要的 H.I.F 比赛。", "制作人通过计算运气与策略来策划偶像的演出。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00224", "scene_id": "scene-00224", "source_file": "CSV/dear/hume/adv_dear_hume_024.csv", "source_kind": "dear", "chapter": "dear/hume", "scene": "adv_dear_hume_024", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "80", "line_count": 80}, {"block_index": 2, "start_row": "81", "end_row": "95", "line_count": 15}], "source_refs": ["CSV/dear/hume/adv_dear_hume_024.csv:1-95"], "line_count": 95, "speakers": ["佑芽", "佑芽が参考にした人物", "千奈", "广", "手毬", "星南", "燐羽"], "topics": ["relationships", "team_story", "dialogue_style", "worldbuilding"], "title": "咲季舞台与集训启程", "summary": "佑芽与燐羽讨论咲季舞台及粉丝活动，燐羽欲言又止。随后众人得知将前往爱知参加选拔考试集训，并期待见到前辈。途中众人互开玩笑，气氛轻松。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "手毬", "广", "星南", "美铃", "姐姐"], "worldbuilding_signals": ["偶像", "演唱会"], "dialogue_style_signals": ["当然", "哼", "嘿嘿", "制作人", "啦"], "key_evidence": [{"source_row": "19", "speaker": "燐羽", "text_zh": "是关于咲季姐姐的事……"}, {"source_row": "20", "speaker": "佑芽", "text_zh": "十王星南亲传的『ENDLESS DANCE』！！"}, {"source_row": "69", "speaker": "广", "text_zh": "接下来要去佑芽的老家。为了『选拔考试』，去爱知进行强化集训。"}, {"source_row": "75", "speaker": "佑芽", "text_zh": "会安排我们和有名的偶像前辈们见面！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["燐羽委托佑芽照顾咲季的粉丝，要求定期举办演唱会及交流活动。", "佑芽与星南正在为咲季创作新歌，视其为劲敌与礼物。", "众人即将前往爱知参加选拔考试的强化集训。", "佑芽被制作人安排与有名偶像前辈见面。"], "relationship_facts": ["燐羽与手毬约定秘密见面讨论咲季相关事务。", "佑芽视咲季为偶像生涯的榜样与劲敌。", "广负责协调团队行程，千奈与手毬关系亲密。"], "worldbuilding_facts": ["咲季拥有星南亲传的『ENDLESS DANCE』舞台。", "偶像需要定期为粉丝举办演唱会、签名会及交流活动。", "选拔考试期间允许偶像前往爱知进行强化集训。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00225", "scene_id": "scene-00225", "source_file": "CSV/dear/hume/adv_dear_hume_025.csv", "source_kind": "dear", "chapter": "dear/hume", "scene": "adv_dear_hume_025", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "80", "line_count": 80}, {"block_index": 2, "start_row": "81", "end_row": "83", "line_count": 3}], "source_refs": ["CSV/dear/hume/adv_dear_hume_025.csv:1-83"], "line_count": 83, "speakers": ["众人", "佑芽", "制作人", "千奈", "广", "花海社長"], "topics": ["relationships", "dialogue_style", "team_story", "worldbuilding"], "title": "花海训练中心合宿", "summary": "众人受邀参加花海训练中心合宿，旨在通过选拔考试特训。花海社长提出以竞赛形式招募宣传大使，广与千奈决定参赛。咲季作为佑芽父亲登场，其保养身体及过往偶像经历被提及，众人将在此开启集训。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "广", "星南", "姐姐", "朋友", "对手"], "worldbuilding_signals": ["学园", "偶像", "训练", "工作"], "dialogue_style_signals": ["当然", "真是的", "呵呵", "嘿嘿", "制作人", "啦"], "key_evidence": [{"source_row": "48", "speaker": "广", "text_zh": "这是咲季的爸爸。"}, {"source_row": "46", "speaker": "花海社長", "text_zh": "为了长久保持全盛时期的身体状态"}, {"source_row": "63", "speaker": "佑芽", "text_zh": "我们家被叫做赛博格生产工厂。"}, {"source_row": "71", "speaker": "众人", "text_zh": "全国放送！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["合宿主要目的是为选拔考试进行特训。", "花海社长提议通过竞赛决定宣传大使人选。", "广和千奈决定参加花海训练中心的竞赛。", "花海训练中心被戏称为赛博格生产工厂。"], "relationship_facts": ["花海社长是佑芽的父亲。", "花海社长是前偶像，出版过相关书籍。", "广和千奈是佑芽的朋友，被制作人邀请参加合宿。"], "worldbuilding_facts": ["花海训练中心拥有最新设备用于训练与分析。", "训练中心计划举办全国放送的竞赛活动。", "花海社长为了保持身体状态会进行彻底保养。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00226", "scene_id": "scene-00226", "source_file": "CSV/dear/hume/adv_dear_hume_026.csv", "source_kind": "dear", "chapter": "dear/hume", "scene": "adv_dear_hume_026", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "80", "line_count": 80}, {"block_index": 2, "start_row": "81", "end_row": "98", "line_count": 18}], "source_refs": ["CSV/dear/hume/adv_dear_hume_026.csv:1-98"], "line_count": 98, "speakers": ["众人", "佑芽", "制作人", "千奈", "广", "花海社長"], "topics": ["relationships", "team_story", "worldbuilding", "dialogue_style"], "title": "佑芽特训与咲季缺席", "summary": "众人讨论佑芽的体能特训，广与千奈承认实力不如职业偶像前辈。佑芽决定通过互相评价提升，并邀请父亲加入。花海社长表示不再抱期待，只支持佑芽尽情挑战，视咲季为缺席的伙伴。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "广", "对手", "伙伴"], "worldbuilding_signals": ["偶像", "训练", "工作"], "dialogue_style_signals": ["当然", "呵呵", "嘿嘿", "制作人", "啦"], "key_evidence": [{"source_row": "72", "speaker": "花海社長", "text_zh": "明明和咲季分开了……"}, {"source_row": "42", "speaker": "广", "text_zh": "作为艺人实力最强的就是仓本千奈。"}, {"source_row": "85", "speaker": "花海社長", "text_zh": "我一开始就没抱什么期待。"}, {"source_row": "97", "speaker": "佑芽", "text_zh": "在竞赛里爸爸也是敌人呢！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["广与千奈承认在竞赛中败给职业偶像前辈。", "佑芽决定与广、千奈互相评价以弥补差距。", "花海社长表示不再对佑芽抱期待，只支持其挑战。", "花海社长提到自己与咲季已分开。"], "relationship_facts": ["花海社长是佑芽的父亲。", "广与千奈是佑芽的前辈与竞争对手。", "花海社长与咲季已分开。"], "worldbuilding_facts": ["竞赛规则为依次进行自由表演。", "花海社长曾是运动员及地方艺人。", "花海社长自称是健身大叔且做饭难吃。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00227", "scene_id": "scene-00227", "source_file": "CSV/dear/hume/adv_dear_hume_027.csv", "source_kind": "dear", "chapter": "dear/hume", "scene": "adv_dear_hume_027", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "80", "line_count": 80}, {"block_index": 2, "start_row": "81", "end_row": "104", "line_count": 24}], "source_refs": ["CSV/dear/hume/adv_dear_hume_027.csv:1-104"], "line_count": 104, "speakers": ["佑芽", "制作人", "选项"], "topics": ["relationships", "dialogue_style", "worldbuilding", "plot"], "title": "咲季作为榜样与宿敌", "summary": "佑芽在竞赛中败给制作人，却因制作人成为咲季的竞争对手而深受触动。她意识到咲季不仅是宿敌，更是引导她成长的榜样。佑芽决心超越咲季，用现场演出点燃姐姐的激情，成为一等星，证明偶像能引导偶像。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "广", "星南", "姐姐", "对手"], "worldbuilding_signals": ["偶像", "演唱会", "工作"], "dialogue_style_signals": ["当然", "哼", "嘿嘿", "制作人", "啦"], "key_evidence": [{"source_row": "75", "speaker": "制作人", "text_zh": "在『H.I.F』里看到的咲季同学，有着短命偶像特有的、那种危险而迷人的魅力。"}, {"source_row": "87", "speaker": "制作人", "text_zh": "还记得吗，你曾发誓这次要让自己成为咲季同学的目标。"}, {"source_row": "103", "speaker": "佑芽", "text_zh": "成为『一等星』后，就由我来点燃姐姐的激情！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["制作人接受委托培育佑芽，并让佑芽与咲季进行竞争。", "佑芽在竞赛中败北，但认为这是必要的成长过程。", "佑芽决定成为一等星，目标是点燃咲季的激情。", "制作人表示与咲季一同燃尽的未来是他所求之不得的。"], "relationship_facts": ["佑芽视咲季为宿敌，但也承认其作为榜样的价值。", "制作人与咲季存在竞争关系，制作人希望佑芽向咲季学习。", "佑芽与制作人既是师徒也是竞争对手。"], "worldbuilding_facts": ["咲季是短命偶像，拥有危险而迷人的魅力。", "偶像能够引导偶像，劲敌能够引导劲敌。", "成为一等星后，偶像可以点燃他人的激情。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00228", "scene_id": "scene-00228", "source_file": "CSV/dear/jsna/adv_dear_jsna_016.csv", "source_kind": "dear", "chapter": "dear/jsna", "scene": "adv_dear_jsna_016", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "74", "line_count": 74}], "source_refs": ["CSV/dear/jsna/adv_dear_jsna_016.csv:1-74"], "line_count": 74, "speakers": ["星南", "琴音"], "topics": ["relationships", "team_story", "dialogue_style", "worldbuilding"], "title": "咲季缺席的冠军之路", "summary": "星南与琴音庆祝特训成果，星南宣布不再视琴音为继承人，而是培养为最强对手。针对琴音资金问题，星南透露夺冠即可获官方优待，激励琴音全力备战，两人约定共同迈向顶级偶像之路。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人", "琴音", "莉波", "星南", "对手"], "worldbuilding_signals": ["学园", "偶像", "训练"], "dialogue_style_signals": ["当然", "才不是", "呵呵", "制作人", "啦"], "key_evidence": [{"source_row": "7", "speaker": "琴音", "text_zh": "还吃了咲季特制料理的原型版本"}, {"source_row": "37", "speaker": "星南", "text_zh": "让她成为『一等星』的继承人。"}, {"source_row": "40", "speaker": "星南", "text_zh": "亲手培养出最强的对手。"}, {"source_row": "53", "speaker": "星南", "text_zh": "去申请无需偿还的给付型奖学金吧。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["星南决定亲自实现愿望，将琴音培养为最强对手而非继承人。", "琴音在合宿期间未参加训练，主要依靠特殊胶囊舱和咲季料理恢复。", "在N.I.A夺冠可获得无需偿还的给付型奖学金及正式制作人同等待遇。", "琴音已战胜极月学园王牌，但星南认为她仍需更多磨练。"], "relationship_facts": ["星南是琴音的制作人，两人关系亲密且互相尊重。", "星南视琴音为未来的顶级偶像竞争对手。", "咲季是琴音的料理提供者，对琴音有照顾之恩。"], "worldbuilding_facts": ["偶像界存在极月学园等顶尖学园及王牌偶像。", "N.I.A夺冠是偶像界的重大成就，能带来官方优待。", "存在无需偿还的给付型奖学金制度，需特定成就方可申请。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00229", "scene_id": "scene-00229", "source_file": "CSV/dear/jsna/adv_dear_jsna_022.csv", "source_kind": "dear", "chapter": "dear/jsna", "scene": "adv_dear_jsna_022", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "80", "line_count": 80}, {"block_index": 2, "start_row": "81", "end_row": "85", "line_count": 5}], "source_refs": ["CSV/dear/jsna/adv_dear_jsna_022.csv:1-85"], "line_count": 85, "speakers": ["众人", "佑芽", "千奈", "旁白", "星南", "美铃"], "topics": ["relationships", "worldbuilding", "dialogue_style", "character_arc"], "title": "咲季缺席的偶像对决", "summary": "星南安排美铃负责 SyngUp! 解散演唱会，并决定亲自接手。她鼓励佑芽以击败自己为目标，同时任命千奈为下任学生会长。咲季虽被提及，但并未直接出现在当前场景中。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "星南", "美铃", "姐姐"], "worldbuilding_signals": ["学园", "偶像", "训练", "演唱会", "工作"], "dialogue_style_signals": ["真是的", "呵呵", "嘿嘿", "制作人", "啦"], "key_evidence": [{"source_row": "43", "speaker": "星南", "text_zh": "没想到我居然……要接手『SyngUp!』……"}, {"source_row": "50", "speaker": "星南", "text_zh": "千奈，无论『H.I.F』的结果如何。我要你——去竞选下任学生会长。"}, {"source_row": "54", "speaker": "星南", "text_zh": "佑芽，你在『N.I.A』上……和花海咲季一决胜负了。"}, {"source_row": "56", "speaker": "星南", "text_zh": "（那是花海佑芽的故事……我不该在这里多说什么）"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["星南决定亲自接手 SyngUp! 的培育工作。", "星南任命千奈为下任学生会长候选人。", "佑芽的目标是成为顶级偶像并击败星南。"], "relationship_facts": ["星南是制作人，负责指导佑芽和千奈。", "美铃是 SyngUp! 成员，将参加解散演唱会。", "佑芽与星南存在偶像间的竞争关系。"], "worldbuilding_facts": ["即将举行夏天的 H.I.F 大会。", "SyngUp! 即将举办解散演唱会。", "千奈的人气足以让她被选拔参加 H.I.F。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00230", "scene_id": "scene-00230", "source_file": "CSV/dear/jsna/adv_dear_jsna_025.csv", "source_kind": "dear", "chapter": "dear/jsna", "scene": "adv_dear_jsna_025", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "80", "line_count": 80}, {"block_index": 2, "start_row": "81", "end_row": "95", "line_count": 15}], "source_refs": ["CSV/dear/jsna/adv_dear_jsna_025.csv:1-95"], "line_count": 95, "speakers": ["众人", "制作人", "咲季", "星南", "燕"], "topics": ["dialogue_style", "relationships", "worldbuilding", "character_arc"], "title": "咲季与燕的联手挑战", "summary": "夏季H.I.F大赛前夕，制作人指出咲季与燕已组成共同战线，旨在通过挑战十王星南来改变比赛性质并证明偶像无极限。咲季感谢燕在花海训练中心的特训，两人决定共同为星南高歌，展现深厚的羁绊与对舞台的渴望。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "琴音", "星南", "对手"], "worldbuilding_signals": ["偶像", "训练"], "dialogue_style_signals": ["当然", "真是的", "哼", "呵呵", "制作人"], "key_evidence": [{"source_row": "81", "speaker": "咲季", "text_zh": "为了赶上H.I.F，我们需要身经百战的实力派协助才行。"}, {"source_row": "82", "speaker": "燕", "text_zh": "也就是说我们组成了共同战线。也可以说是意气相投吧。"}, {"source_row": "88", "speaker": "燕", "text_zh": "给来历不明的机器喂饭、默默埋头训练的有名运动员们……"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季与燕组成了共同战线，旨在挑战十王星南。", "咲季在花海训练中心接受了燕的协助与特训。", "咲季表示愿意再次站在佑芽面前，并感谢燕的帮助。"], "relationship_facts": ["咲季与燕因共同目标而结成同盟。", "燕在花海训练中心协助咲季进行特训。", "咲季视燕为重要的伙伴并表达感谢。"], "worldbuilding_facts": ["H.I.F是只有被选中偶像才能参加的比赛。", "花海训练中心是进行特训的场所。", "十王星南是备受期待的顶级偶像。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00231", "scene_id": "scene-00231", "source_file": "CSV/dear/jsna/adv_dear_jsna_026.csv", "source_kind": "dear", "chapter": "dear/jsna", "scene": "adv_dear_jsna_026", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "59", "line_count": 59}], "source_refs": ["CSV/dear/jsna/adv_dear_jsna_026.csv:1-59"], "line_count": 59, "speakers": ["制作人", "咲季", "旁白", "星南", "燕", "选项"], "topics": ["relationships", "dialogue_style", "worldbuilding", "character_arc"], "title": "咲季登场与星南的觉悟", "summary": "H.I.F 决赛现场，星南回顾其他偶像的精彩演出，感慨咲季等后辈的进步。咲季作为全人类姐姐登场，展现无畏笑容。星南意识到咲季等后辈已超越自己，决心在制作人培育下赢得比赛，实现成为顶级偶像的梦想。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "琴音", "星南", "姐姐", "对手"], "worldbuilding_signals": ["学园", "偶像"], "dialogue_style_signals": ["呵呵", "制作人"], "key_evidence": [{"source_row": "21", "speaker": "咲季", "text_zh": "你们好！我是花海咲季！作为全人类的姐姐——"}, {"source_row": "22", "speaker": "咲季", "text_zh": "也是未来的顶级偶像哦！！"}, {"source_row": "51", "speaker": "星南", "text_zh": "今天一结束，『一等星』就将成为顶级偶像的称号。"}, {"source_row": "59", "speaker": "星南", "text_zh": "只要我赢了就是满分！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["花海咲季作为全人类的姐姐登场，自称未来的顶级偶像。", "星南认为咲季等后辈的演出比之前的对手更容易应付。", "星南决心在制作人培育下赢得比赛，实现成为顶级偶像的梦想。"], "relationship_facts": ["星南与咲季是竞争对手关系，咲季已超越星南。", "星南与制作人是师徒关系，制作人培育星南成为顶级偶像。", "星南与其他偶像（琴音、佑芽、千奈、燕）是队友关系。"], "worldbuilding_facts": ["H.I.F 是偶像界的顶级盛会，参赛者为争夺顶级偶像称号。", "顶级偶像称号是偶像界的最高荣誉，需要赢得比赛才能获得。", "初星学园是培养偶像的学校，咲季等后辈来自该校。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00232", "scene_id": "scene-00232", "source_file": "CSV/dear/jsna/adv_dear_jsna_027.csv", "source_kind": "dear", "chapter": "dear/jsna", "scene": "adv_dear_jsna_027", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "80", "line_count": 80}, {"block_index": 2, "start_row": "81", "end_row": "121", "line_count": 41}], "source_refs": ["CSV/dear/jsna/adv_dear_jsna_027.csv:1-121"], "line_count": 121, "speakers": ["众人", "制作人", "学园长", "旁白", "星南", "琴音", "选项"], "topics": ["relationships", "team_story", "worldbuilding", "dialogue_style"], "title": "咲季缺席的庆功时刻", "summary": "星南在初星偶像祭夺冠后，因藤田琴音的感慨而反思。琴音表示若星南不在，咲季本应是冠军，自己不甘心成为唯一赢家。星南鼓励琴音在毕业前全力竞争，并决心在学园实现所有梦想，包括与黄金世代竞争，为 H.I.F 画上圆满句号。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人", "琴音", "星南", "对手"], "worldbuilding_signals": ["学园", "偶像", "演唱会", "工作"], "dialogue_style_signals": ["当然", "真是的", "呵呵", "制作人", "不是吗", "啦"], "key_evidence": [{"source_row": "63", "speaker": "琴音", "text_zh": "如果没有星南前辈的话，雨夜前辈肯定就是『一等星』了。"}, {"source_row": "64", "speaker": "琴音", "text_zh": "如果雨夜前辈也不在的话，咲季绝对就是『一等星』了。"}, {"source_row": "120", "speaker": "星南", "text_zh": "我要在这所学园里，实现所有的欲望之后再毕业。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["十王星南在初星偶像祭中实现三连冠。", "藤田琴音因咲季缺席夺冠而感到不甘心。", "星南决定在毕业前于学园实现所有梦想。"], "relationship_facts": ["星南是藤田琴音的制作人及前辈。", "藤田琴音视十王星南为特别的目标与竞争对手。", "咲季是琴音心中仅次于星南的潜在冠军。"], "worldbuilding_facts": ["初星偶像祭（H.I.F）是选拔顶尖偶像的大赛。", "「一等星」是顶尖偶像的称号。", "星南即将从初星学园毕业。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00233", "scene_id": "scene-00233", "source_file": "CSV/dear/kcna/adv_dear_kcna_012.csv", "source_kind": "dear", "chapter": "dear/kcna", "scene": "adv_dear_kcna_012", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "73", "line_count": 73}], "source_refs": ["CSV/dear/kcna/adv_dear_kcna_012.csv:1-73"], "line_count": 73, "speakers": ["众人", "制作人", "千奈", "广", "旁白"], "topics": ["team_story", "relationships", "dialogue_style", "worldbuilding"], "title": "千奈与广的偶像对决", "summary": "千奈人气飙升，广主动挑战其偶像排名。两人通过展示 N.I.A 进行对决，广凭借伙伴支持获胜。广借此机会表达对千奈的感激与友情，千奈虽不甘心但理解了花海咲季的心情，决心下次再战。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "广", "朋友", "对手", "伙伴"], "worldbuilding_signals": ["学园", "偶像", "训练", "演唱会"], "dialogue_style_signals": ["呵呵", "制作人", "啦"], "key_evidence": [{"source_row": "70", "speaker": "千奈", "text_zh": "我现在！完全能理解花海同学的心情了啦！"}, {"source_row": "37", "speaker": "广", "text_zh": "模仿咲季？"}, {"source_row": "48", "speaker": "广", "text_zh": "因为我拥有可靠的伙伴。"}, {"source_row": "57", "speaker": "千奈", "text_zh": "我们三个人啊，一直都形影不离呢。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["广与千奈进行 N.I.A 排名对决，广获胜。", "广指出千奈常利用金钱优势，而广有可靠伙伴支持。", "千奈表示完全理解了花海咲季的心情。", "千奈与广、佑芽三人形影不离，互相给予积极影响。"], "relationship_facts": ["广与千奈是挚友，互相竞争又互相支持。", "千奈视广为非常重要的朋友。", "广感激千奈和佑芽让自己成为不输的偶像。"], "worldbuilding_facts": ["N.I.A 是一种偶像排名或表演形式。", "极月学园和仓本千奈在社会上备受关注。", "星学园的生活曾被电视台报道。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00234", "scene_id": "scene-00234", "source_file": "CSV/dear/kcna/adv_dear_kcna_013.csv", "source_kind": "dear", "chapter": "dear/kcna", "scene": "adv_dear_kcna_013", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "54", "line_count": 54}], "source_refs": ["CSV/dear/kcna/adv_dear_kcna_013.csv:1-54"], "line_count": 54, "speakers": ["制作人", "千奈", "广"], "topics": ["relationships", "dialogue_style", "team_story", "worldbuilding"], "title": "咲季未出场剧情", "summary": "千奈与制作人讨论参加FINALE试镜，视筱泽广与蓝井抚子为竞争对手。广向千奈表白，千奈激动拒绝。咲季仅作为背景提及，未直接出场。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "广", "朋友", "对手"], "worldbuilding_signals": ["学园", "偶像", "试镜"], "dialogue_style_signals": ["呵呵", "制作人", "啦"], "key_evidence": [{"source_row": "1", "speaker": "千奈", "text_zh": "老师！老师！请您听我说！"}, {"source_row": "18", "speaker": "制作人", "text_zh": "首先是……人气急速上升的黑马，筱泽广同学。"}, {"source_row": "49", "speaker": "制作人", "text_zh": "实力与仓本同学比较接近的……极月学园的蓝井抚子同学。"}, {"source_row": "27", "speaker": "广", "text_zh": "眼神很不错……我可能，喜欢上你了。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["千奈决定参加FINALE公开试镜", "筱泽广是千奈的竞争对手之一", "蓝井抚子来自极月学园", "广向千奈表白被拒"], "relationship_facts": ["千奈与制作人是师徒关系", "千奈与筱泽广是竞争对手", "千奈与蓝井抚子想成为朋友"], "worldbuilding_facts": ["FINALE是N.I.A最后一天举行的公开试镜", "筱泽广拥有神级现场表演能力", "蓝井抚子是名门千金"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00235", "scene_id": "scene-00235", "source_file": "CSV/dear/shro/adv_dear_shro_013.csv", "source_kind": "dear", "chapter": "dear/shro", "scene": "adv_dear_shro_013", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "69", "line_count": 69}], "source_refs": ["CSV/dear/shro/adv_dear_shro_013.csv:1-69"], "line_count": 69, "speakers": ["制作人", "千奈", "广"], "topics": ["team_story", "relationships", "dialogue_style", "worldbuilding"], "title": "咲季被提及与竞争宣言", "summary": "千奈宣布加入广的后援会，并提议三人共同追赶领先的花海咲季。咲季虽未直接出场，但被作为三人组中实力最强的存在被提及。千奈与广决定在FINALE中超越咲季，并正式接受咲季的竞争挑战，誓要在舞台上甩开所有人。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "广", "星南", "姐姐", "朋友", "对手"], "worldbuilding_signals": ["学园", "偶像", "演唱会"], "dialogue_style_signals": ["真是的", "呵呵", "制作人", "啦"], "key_evidence": [{"source_row": "54", "speaker": "千奈", "text_zh": "花海同学已经远远走在我们前面了。"}, {"source_row": "55", "speaker": "广", "text_zh": "两个人一起追上去吧。"}, {"source_row": "68", "speaker": "千奈", "text_zh": "就让我来把你们统统甩在身后吧！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["千奈宣布加入筱泽广的后援会。", "千奈与广决定共同追赶花海咲季。", "千奈正式向花海咲季发起竞争挑战。"], "relationship_facts": ["千奈与广是好友兼后援会成员。", "千奈、广与花海咲季是同期偶像。", "花海咲季是千奈与广的竞争对手。"], "worldbuilding_facts": ["偶像需购买最新周边才能参加演唱会。", "FINALE是重要的偶像比赛。", "N.I.A是偶像所属的团体或组织。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00236", "scene_id": "scene-00236", "source_file": "CSV/dear/shro/adv_dear_shro_014.csv", "source_kind": "dear", "chapter": "dear/shro", "scene": "adv_dear_shro_014", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "45", "line_count": 45}], "source_refs": ["CSV/dear/shro/adv_dear_shro_014.csv:1-45"], "line_count": 45, "speakers": ["佑芽", "广", "撫子"], "topics": ["relationships", "team_story", "dialogue_style", "worldbuilding"], "title": "佑芽与广的试镜对决", "summary": "佑芽与抚子结束游戏后，广指出佑芽模仿咲季。佑芽得知广与千奈将参加『N.I.A』试镜，视其为重要对手。广表示若无制作人支持胜算渺茫，但坚信在『N.I.A』中能与制作人并肩获胜，两人约定通过试镜一决胜负。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "广", "姐姐", "朋友", "对手"], "worldbuilding_signals": ["学园", "偶像", "试镜"], "dialogue_style_signals": ["哼", "呵呵", "制作人", "啦"], "key_evidence": [{"source_row": "9", "speaker": "广", "text_zh": "佑芽在学咲季的样子呢。"}, {"source_row": "17", "speaker": "广", "text_zh": "千奈也是。"}, {"source_row": "44", "speaker": "广", "text_zh": "但是……如果是『N.I.A』的话。"}, {"source_row": "45", "speaker": "广", "text_zh": "我会赢的，一定。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["广指出佑芽正在模仿咲季的样子。", "佑芽得知广和千奈都将参加『N.I.A』试镜。", "广认为在普通试镜中自己无胜算，但在『N.I.A』中必胜。", "佑芽将这场对决视为与姐姐对决般重要。"], "relationship_facts": ["佑芽与广是好朋友兼竞争对手。", "广视佑芽为最好的朋友。", "佑芽将广视为重要的竞争对手。"], "worldbuilding_facts": ["佑芽、广、抚子均为偶像或相关角色。", "存在名为『FINALE』和『N.I.A』的偶像团体或活动。", "『N.I.A』中制作人与偶像共同行动。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00237", "scene_id": "scene-00237", "source_file": "CSV/dear/shro/adv_dear_shro_022.csv", "source_kind": "dear", "chapter": "dear/shro", "scene": "adv_dear_shro_022", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "79", "line_count": 79}], "source_refs": ["CSV/dear/shro/adv_dear_shro_022.csv:1-79"], "line_count": 79, "speakers": ["制作人", "广", "星南"], "topics": ["team_story", "dialogue_style", "relationships", "worldbuilding"], "title": "广的偶像能量觉醒", "summary": "制作人与广在休息时讨论挑战星南。广向星南请教才能评估，星南指出广当前实力仅为4。广随即施展爷爷传授的方法，瞬间将偶像能量从4提升至400以上，震惊了星南。广自称只是把偶像当兴趣的普通人，并表达了对星南的喜爱。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "广", "星南", "对手"], "worldbuilding_signals": ["学园", "偶像"], "dialogue_style_signals": ["当然", "哼", "呵呵", "制作人", "啦"], "key_evidence": [{"source_row": "24", "speaker": "广", "text_zh": "星南同学也……佑芽也……咲季也……"}, {"source_row": "60", "speaker": "星南", "text_zh": "4哦。"}, {"source_row": "71", "speaker": "星南", "text_zh": "难以置信……竟然突破400了。"}, {"source_row": "75", "speaker": "广", "text_zh": "只是个把偶像当兴趣的普通人，啦。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["广向星南请教偶像才能评估。", "星南指出广当前实力数值为4。", "广施展秘法后偶像能量突破400。", "广自称只是把偶像当兴趣的普通人。"], "relationship_facts": ["制作人与广是约会对象。", "广与星南是学妹与学姐关系。", "星南是十王星南会长。"], "worldbuilding_facts": ["存在名为『一等星』的称号。", "学园长爷爷能传授操控偶像能量的方法。", "星南拥有看穿偶像才能和实力的能力。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00238", "scene_id": "scene-00238", "source_file": "CSV/dear/shro/adv_dear_shro_023.csv", "source_kind": "dear", "chapter": "dear/shro", "scene": "adv_dear_shro_023", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "79", "line_count": 79}], "source_refs": ["CSV/dear/shro/adv_dear_shro_023.csv:1-79"], "line_count": 79, "speakers": ["学园长", "广", "星南"], "topics": ["team_story", "dialogue_style", "worldbuilding", "character_arc"], "title": "星南指导广特训", "summary": "星南祝贺广夺冠并提议切磋，建议其专精歌唱力以突破瓶颈。星南指出广拥有独特的“神格”特质，鼓励其提升偶像魅力与领袖光环，创造奇迹来战胜自己，并期待看到广的完美示范。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "广", "星南"], "worldbuilding_signals": ["学园", "偶像", "训练"], "dialogue_style_signals": ["当然", "真是的", "呵呵", "制作人"], "key_evidence": [{"source_row": "10", "speaker": "广", "text_zh": "我决定以『一等星』为目标了。"}, {"source_row": "32", "speaker": "星南", "text_zh": "因为筱泽广的潜在能力中，Vocal数值最高且成长性最好。"}, {"source_row": "70", "speaker": "星南", "text_zh": "在『H.I.F』中将我逼入绝境的、咲季的潜在实力。"}, {"source_row": "75", "speaker": "星南", "text_zh": "提升作为偶像的『神格』，去创造奇迹吧！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["星南在H.I.F决赛中因被狂妄学妹击败而计划被打乱。", "星南建议广专攻歌唱力，因其潜在能力中Vocal数值最高且成长性最好。", "星南指出广在舞台上展现的“神格”是难以名状的顶级偶像特质。", "星南鼓励广提升偶像魅力、领袖光环等无法用数值衡量的实力。"], "relationship_facts": ["星南与广是竞争对手，星南视广为后辈并愿意提供建议。", "广决定以“一等星”为目标，计划在下届H.I.F中打败星南。", "星南与学园长关系亲密，学园长能理解星南的偶像魅力。"], "worldbuilding_facts": ["H.I.F比赛通过Vocal、Dance、Visual三项指标评判。", "平均发展无法取胜，选手需专精一项进行突破。", "偶像实力包含明星气质、领袖魅力、光环等无法用数值衡量的特质。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00239", "scene_id": "scene-00239", "source_file": "CSV/dear/ssmk/adv_dear_ssmk_022.csv", "source_kind": "dear", "chapter": "dear/ssmk", "scene": "adv_dear_ssmk_022", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "72", "line_count": 72}], "source_refs": ["CSV/dear/ssmk/adv_dear_ssmk_022.csv:1-72"], "line_count": 72, "speakers": ["制作人", "清夏", "莉莉娅"], "topics": ["team_story", "dialogue_style", "relationships", "character_arc"], "title": "咲季未现身训练场景", "summary": "清夏因枯燥的肌肉训练感到无聊，制作人拿出特制干劲增强剂。清夏误以为是咲季的SSD，后得知是制作人特制良药。莉莉娅加入训练，三人讨论训练计划与清夏缺席夏季H.I.F的觉悟，气氛从抱怨转为互相鼓励。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "清夏", "莉莉娅", "妹妹"], "worldbuilding_signals": ["训练"], "dialogue_style_signals": ["呵呵", "制作人", "啦"], "key_evidence": [{"source_row": "15", "speaker": "清夏", "text_zh": "该不会是……咲季的SSD之类的东西吧？"}, {"source_row": "16", "speaker": "制作人", "text_zh": "那种东西的制作原理我完全不明白。"}, {"source_row": "64", "speaker": "莉莉娅", "text_zh": "小清夏之所以没有参加夏季的『H.I.F』是因为……"}, {"source_row": "66", "speaker": "清夏", "text_zh": "要在冬天来临前磨练舞蹈，拿出成果。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["清夏因肌肉训练枯燥无聊而缺乏干劲。", "制作人拿出特制干劲增强剂，被清夏误认为是咲季的SSD。", "清夏缺席夏季H.I.F是为了冬天前磨练舞蹈成果。", "莉莉娅加入训练并监督清夏，三人关系融洽。"], "relationship_facts": ["制作人与清夏是指导与被指导的亲密关系。", "清夏与莉莉娅是共同训练且互相了解的挚友。", "咲季是清夏的伙伴，其训练方法（SSD）被提及。"], "worldbuilding_facts": ["存在名为SSD的咲季训练方法，效果显著。", "制作人拥有特制干劲增强剂，原理不明但安全有效。", "夏季H.I.F是重要活动，缺席需付出努力弥补。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00240", "scene_id": "scene-00240", "source_file": "CSV/dear/ttmr/adv_dear_ttmr_013.csv", "source_kind": "dear", "chapter": "dear/ttmr", "scene": "adv_dear_ttmr_013", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "80", "line_count": 80}, {"block_index": 2, "start_row": "81", "end_row": "134", "line_count": 54}], "source_refs": ["CSV/dear/ttmr/adv_dear_ttmr_013.csv:1-134"], "line_count": 134, "speakers": ["制作人", "千奈", "咲季", "四音", "广", "手毬", "撫子", "極月学園のアイドル", "浅梨老师", "琴音", "选项"], "topics": ["relationships", "team_story", "worldbuilding", "dialogue_style"], "title": "咲季与手毬的反击", "summary": "制作人委托月村手毬应对极月学园挑衅。咲季与手毬联手嘲讽对方翻唱行为，并邀请961头牌对决。手毬因冲突泄露向制作人致歉，方案A面临崩溃。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "琴音", "手毬", "广", "星南", "姐姐", "对手"], "worldbuilding_signals": ["学园", "偶像", "工作"], "dialogue_style_signals": ["当然", "哼", "呵呵", "制作人", "不是吗", "啦"], "key_evidence": [{"source_row": "70", "speaker": "咲季", "text_zh": "辛苦了，手毬。今天表现不错嘛，很乖呢。"}, {"source_row": "114", "speaker": "手毬", "text_zh": "初星学园的花海咲季和月村手毬，会亲手击溃你们的！"}, {"source_row": "132", "speaker": "手毬", "text_zh": "和极月学园起了冲突……交涉内容被泄露到网上了。"}, {"source_row": "134", "speaker": "制作人", "text_zh": "方案A……正在崩溃……"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["手毬与咲季联手嘲讽极月学园偶像翻唱前辈作品。", "手毬因与极月学园冲突导致交涉内容泄露。", "制作人因冲突泄露而担忧，确认方案A正在崩溃。", "咲季与手毬约定若961头牌出现将共同挑战。"], "relationship_facts": ["咲季与手毬是初星学园同伴，关系亲密。", "四音与抚子来自极月学园，视初星学园为对手。", "制作人与月村手毬存在委托与被委托关系。"], "worldbuilding_facts": ["极月学园由多家事务所联合创办。", "961事务所拥有头牌偶像及二军三军杂兵。", "初星学园拥有『一等星』和三组偶像。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00241", "scene_id": "scene-00241", "source_file": "CSV/dear/ttmr/adv_dear_ttmr_020.csv", "source_kind": "dear", "chapter": "dear/ttmr", "scene": "adv_dear_ttmr_020", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "59", "line_count": 59}], "source_refs": ["CSV/dear/ttmr/adv_dear_ttmr_020.csv:1-59"], "line_count": 59, "speakers": ["众人", "制作人", "手毬", "旁白", "燐羽", "选项"], "topics": ["relationships", "team_story", "dialogue_style", "worldbuilding"], "title": "咲季缺席的特别时刻", "summary": "优胜演唱会落幕后，手毬因过度兴奋寻找燐羽未果，情绪低落。制作人点醒她，手毬意识到燐羽的陪伴与托举才是关键。她确信燐羽能将自己培养成顶级偶像，并感激制作人，决心证明其培育能力。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人", "琴音", "手毬", "美铃"], "worldbuilding_signals": ["学园", "偶像", "演唱会"], "dialogue_style_signals": ["当然", "制作人", "啦"], "key_evidence": [{"source_row": "29", "speaker": "手毬", "text_zh": "咲季也好琴音也好都行啊"}, {"source_row": "44", "speaker": "制作人", "text_zh": "你一定能成为顶级偶像"}, {"source_row": "56", "speaker": "手毬", "text_zh": "你一定会把我，培养成顶级偶像"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["优胜演唱会『NEXT IDOL AUDITION』刚刚结束。", "手毬在寻找燐羽时，将咲季和琴音也视为可以求助的对象。", "手毬确信燐羽能将她培养成顶级偶像。", "制作人确认手毬具备成为顶级偶像的潜力。"], "relationship_facts": ["燐羽是手毬的竞争对手兼支持者。", "制作人是手毬的导师与梦想引导者。", "咲季是手毬在学园内的同伴之一。"], "worldbuilding_facts": ["手毬代表初星学园参加『N.I.A』。", "燐羽成立了名为『SyngUp!』的团体。", "极月学园是咲季和琴音所在的学校。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00242", "scene_id": "scene-00242", "source_file": "CSV/event/001/adv_event_001_main-01.csv", "source_kind": "event", "chapter": "event/001", "scene": "adv_event_001_main-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "52", "line_count": 52}], "source_refs": ["CSV/event/001/adv_event_001_main-01.csv:1-52"], "line_count": 52, "speakers": ["咲季", "手毬", "旁白", "清夏", "琴音", "莉莉娅"], "topics": ["team_story", "relationships", "worldbuilding", "dialogue_style"], "title": "新生联谊会筹备", "summary": "1年1班新生自我介绍结束，班级氛围冷淡。咲季作为入学第一名的新生宣言，反对手毬的优越态度。清夏与莉莉娅因班级氛围不符预期而烦恼，咲季随后向手毬发起挑战。最终清夏提议举办全员联谊会以改善关系。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["琴音", "手毬", "清夏", "莉莉娅"], "worldbuilding_signals": ["学园", "偶像"], "dialogue_style_signals": ["当然", "真是的", "啦"], "key_evidence": [{"source_row": "10", "speaker": "咲季", "text_zh": "作为入学考试第一名的我"}, {"source_row": "5", "speaker": "手毬", "text_zh": "今年的目标是，成为学园第一的偶像"}, {"source_row": "12", "speaker": "咲季", "text_zh": "马上就用实力让你闭嘴！"}, {"source_row": "52", "speaker": "清夏", "text_zh": "要举办1年1班的联谊会啦！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季是入学考试第一名的新生。", "手毬是内部升学组，目标是成为学园第一偶像。", "清夏和莉莉娅对班级氛围感到失望。", "清夏提议放学后举办全员联谊会。"], "relationship_facts": ["清夏与莉莉娅是青梅竹马。", "咲季与手毬因态度问题发生争执。", "琴音作为调解者试图缓和气氛。"], "worldbuilding_facts": ["初星学园设有偶像科。", "内部升学组与外部新生存在竞争关系。", "班级氛围对偶像科学生至关重要。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00243", "scene_id": "scene-00243", "source_file": "CSV/event/001/adv_event_001_main-02.csv", "source_kind": "event", "chapter": "event/001", "scene": "adv_event_001_main-02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "74", "line_count": 74}], "source_refs": ["CSV/event/001/adv_event_001_main-02.csv:1-74"], "line_count": 74, "speakers": ["リーリヤ？", "咲季", "手毬", "旁白", "清夏", "琴音", "莉莉娅"], "topics": ["team_story", "relationships", "dialogue_style", "character_arc"], "title": "咲季缺席恳亲会风波", "summary": "放学后，清夏提议举办恳亲会，但咲季因想练习而拒绝，手毬与琴音亦因各自理由缺席。莉莉娅因担心拖后腿而情绪激动，手毬被其触动后决定协助班级活动，但最后向莉莉娅表达厌恶。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["琴音", "手毬", "清夏", "莉莉娅"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["哼", "啦"], "key_evidence": [{"source_row": "4", "speaker": "咲季", "text_zh": "我才不去！因为我想练习！"}, {"source_row": "21", "speaker": "手毬", "text_zh": "要是有那种空闲时间的话，我更想用来自主练习。"}, {"source_row": "74", "speaker": "手毬", "text_zh": "我，很讨厌你。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季因想练习而拒绝参加班级恳亲会。", "手毬最初拒绝参加，后受莉莉娅触动决定协助。", "清夏试图通过心电感应帮莉莉娅表达心声。"], "relationship_facts": ["清夏是班级凝聚力推动者，试图说服成员。", "手毬与莉莉娅存在竞争与矛盾关系。", "咲季与手毬因同样想练习而立场相似。"], "worldbuilding_facts": ["班级成员有各自的个人目标与练习计划。", "班级内部存在实力差距与协作需求。", "角色拥有心电感应等特殊能力。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00244", "scene_id": "scene-00244", "source_file": "CSV/event/001/adv_event_001_main-03.csv", "source_kind": "event", "chapter": "event/001", "scene": "adv_event_001_main-03", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "57", "line_count": 57}], "source_refs": ["CSV/event/001/adv_event_001_main-03.csv:1-57"], "line_count": 57, "speakers": ["咲季", "手毬", "清夏", "莉莉娅"], "topics": ["team_story", "relationships", "dialogue_style", "worldbuilding"], "title": "咲季挑战手毬决胜负", "summary": "清夏邀请咲季参加班级联谊，咲季提议由自己当领袖并欲与手毬比拼偶像实力。虽在歌唱比赛落败，咲季却欣赏手毬实力，提议下次以舞蹈一决高下。咲季决心与全班较量以加深理解，展现出自信与好胜心。", "saki_role": "同学/对手：咲季在群像关系中以好胜、直率和带头推进对话的姿态出现。", "relationship_signals": ["手毬", "清夏", "莉莉娅", "朋友"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["当然", "才不是", "哼", "啦"], "key_evidence": [{"source_row": "16", "speaker": "咲季", "text_zh": "就让我花海咲季来当1年1班的领袖吧！"}, {"source_row": "40", "speaker": "咲季", "text_zh": "居、居然在歌唱比赛里输给这种人……呜。"}, {"source_row": "44", "speaker": "咲季", "text_zh": "下次用舞蹈一决胜负吧！这次我一定会赢！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季提议由自己担任班级领袖。", "咲季在歌唱比赛中输给了手毬。", "咲季决定与全班同学较量以加深理解。"], "relationship_facts": ["咲季与清夏是同学且关系良好。", "咲季与手毬从对立转为互相认可实力。", "咲季视自己为班级最优秀的偶像。"], "worldbuilding_facts": ["班级间会举办活动或比赛。", "歌唱比赛是偶像实力的体现。", "舞蹈也是偶像间决胜负的方式。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00245", "scene_id": "scene-00245", "source_file": "CSV/event/001/adv_event_001_main-04.csv", "source_kind": "event", "chapter": "event/001", "scene": "adv_event_001_main-04", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "69", "line_count": 69}], "source_refs": ["CSV/event/001/adv_event_001_main-04.csv:1-69"], "line_count": 69, "speakers": ["众人", "咲季", "手毬", "清夏", "琴音"], "topics": ["team_story", "relationships", "dialogue_style", "worldbuilding"], "title": "咲季与清夏的约定", "summary": "咲季因缺乏朋友而向清夏发起挑战，约定日后比试。见琴音因打工疲惫，咲季主动为其按摩缓解疲劳，展现姐姐风范。众人决定举办午休派对，咲季与清夏互称名字，关系进一步拉近。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["琴音", "手毬", "清夏", "姐姐", "朋友", "对手"], "worldbuilding_signals": ["偶像", "训练"], "dialogue_style_signals": ["当然", "才不是", "哼", "呵呵", "啦"], "key_evidence": [{"source_row": "7", "speaker": "咲季", "text_zh": "除了手毬还没有其他朋友呢。"}, {"source_row": "35", "speaker": "咲季", "text_zh": "改天我们来比试吧，清夏。"}, {"source_row": "52", "speaker": "咲季", "text_zh": "想给你按摩一下。"}, {"source_row": "66", "speaker": "琴音", "text_zh": "总觉得花海你啊，很有姐姐风范呢？"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季因放学即回家而缺乏朋友，直到与手毬、清夏、琴音互动。", "咲季与清夏约定改天进行运动或其他方面的比试。", "咲季发现琴音疲劳后，主动为其按摩以恢复精神。", "众人决定在午休时间举办教室派对，邀请全员参加。"], "relationship_facts": ["咲季与手毬互称名字，确立挚友关系。", "咲季与清夏约定比试，并互称名字。", "琴音视咲季为有姐姐风范的可靠人物。"], "worldbuilding_facts": ["琴音放学后需打工，导致身体疲劳。", "班级计划举办午休时间的教室派对。", "咲季认为除了手毬外没有其他朋友。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00246", "scene_id": "scene-00246", "source_file": "CSV/event/001/adv_event_001_main-05.csv", "source_kind": "event", "chapter": "event/001", "scene": "adv_event_001_main-05", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "64", "line_count": 64}], "source_refs": ["CSV/event/001/adv_event_001_main-05.csv:1-64"], "line_count": 64, "speakers": ["众人", "咲季", "手毬", "清夏", "琴音", "莉莉娅"], "topics": ["team_story", "relationships", "dialogue_style", "character_arc"], "title": "教室派对与昵称风波", "summary": "众人举办第一届教室派对，琴音提议用昵称拉近关系，手毬虽抗拒但最终同意改口叫真名。咲季提议进行游戏对决，认为碰撞能增进理解，众人一致决定为班级胜利共同努力，正式开启新学年。", "saki_role": "同学/对手：咲季在群像关系中以好胜、直率和带头推进对话的姿态出现。", "relationship_signals": ["琴音", "手毬", "清夏", "莉莉娅", "朋友"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["呵呵", "啦"], "key_evidence": [{"source_row": "1", "speaker": "清夏", "text_zh": "为了加深一年一班的感情，增强凝聚力"}, {"source_row": "32", "speaker": "咲季", "text_zh": "嗯，是这样呢。"}, {"source_row": "51", "speaker": "咲季", "text_zh": "向我这个称霸所有派对游戏的无敌王者发起挑战吧"}, {"source_row": "64", "speaker": "众人", "text_zh": "这一年，请多指教！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["众人举办第一届教室派对以增强凝聚力。", "手毬提议大家互称真名而非昵称，随后被咲季提议进行游戏对决。", "咲季自称是称霸所有派对游戏的无敌王者。", "众人决定为了班级胜利而共同努力。"], "relationship_facts": ["咲季与手毬、琴音等人是同学关系。", "清夏与莉莉娅关系亲密，常互相调侃。", "手毬与莉莉娅之间存在竞争与互相督促的关系。"], "worldbuilding_facts": ["班级成员拥有各自不同的梦想和目标。", "教室派对是班级活动的一种形式。", "班级成员之间存在游戏对决的传统。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00247", "scene_id": "scene-00247", "source_file": "CSV/event/003/adv_event_003_main-02.csv", "source_kind": "event", "chapter": "event/003", "scene": "adv_event_003_main-02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "80", "line_count": 80}, {"block_index": 2, "start_row": "81", "end_row": "84", "line_count": 4}], "source_refs": ["CSV/event/003/adv_event_003_main-02.csv:1-84"], "line_count": 84, "speakers": ["旁白", "清夏", "舞蹈训练师", "莉波", "麻央", "？？？"], "topics": ["team_story", "worldbuilding", "dialogue_style", "character_arc"], "title": "夏日集训与清夏打工", "summary": "夏日集训期间，麻央与莉波讨论舞台压力及星南会长的缺席。训练结束后，清夏作为打工售货员出现，被麻央批评其打工行为影响偶像心志，并提及同宿舍成员也在训练，强调暑假时光宝贵。", "saki_role": "被提及对象：咲季未必直接发言，但场景信息与她的关系或评价有关。", "relationship_signals": ["琴音", "手毬", "清夏", "麻央", "莉波", "星南", "莉莉娅"], "worldbuilding_signals": ["偶像", "训练", "演唱会"], "dialogue_style_signals": ["哼", "呵呵", "啦"], "key_evidence": [{"source_row": "75", "speaker": "麻央", "text_zh": "同宿舍的咲季和手毬、莉莉娅，今天肯定也在训练。"}, {"source_row": "65", "speaker": "清夏", "text_zh": "夏日演唱会是最赚钱的时候，当天还要在会场当售货员呢~"}, {"source_row": "19", "speaker": "麻央", "text_zh": "说实话，星南会长没来参加合宿，我反而松了口气。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["麻央认为星南会长不参加合宿是夺走其他孩子机会的绝对王者作风。", "清夏在夏日演唱会当天于会场担任售货员打工。", "麻央指出同宿舍的咲季、手毬和莉莉娅今天也在进行训练。"], "relationship_facts": ["麻央与莉波是三年级生，面临毕业演唱会的压力。", "清夏是麻央和莉波的前辈后辈关系中的一年级生。", "咲季是麻央和莉波的同宿舍成员。"], "worldbuilding_facts": ["夏日集训包含严格的舞蹈训练和海边活动。", "夏日演唱会是偶像团体最赚钱且人最多的时期。", "清夏在会场打工，负责售卖刨冰、波子汽水等商品。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00248", "scene_id": "scene-00248", "source_file": "CSV/event/004/adv_event_004_main-01.csv", "source_kind": "event", "chapter": "event/004", "scene": "adv_event_004_main-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "53", "line_count": 53}], "source_refs": ["CSV/event/004/adv_event_004_main-01.csv:1-53"], "line_count": 53, "speakers": ["咲季", "手毬", "清夏", "琴音", "莉莉娅"], "topics": ["team_story", "relationships", "dialogue_style"], "title": "咲季决定参加夏日祭", "summary": "班级因联谊失败气氛低落，清夏提议去庙会。咲季起初拒绝并强调兼职，但在琴音以加强团结为由邀请后，咲季态度转变，决定参加。随后手毬、莉莉娅也加入，咲季更向莉莉娅发起游戏挑战，气氛转为热烈。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "琴音", "手毬", "清夏", "莉莉娅", "妹妹"], "worldbuilding_signals": [], "dialogue_style_signals": ["当然", "真是的", "哼", "啦"], "key_evidence": [{"source_row": "8", "speaker": "咲季", "text_zh": "我拒绝。还要练习呢！"}, {"source_row": "21", "speaker": "咲季", "text_zh": "你不是还有兼职吗？"}, {"source_row": "37", "speaker": "咲季", "text_zh": "我也要去。"}, {"source_row": "51", "speaker": "咲季", "text_zh": "在摊位的游戏上……和我一决胜负吧！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季最初拒绝去庙会，理由是还有兼职和练习。", "琴音邀请咲季参加夏日祭，理由是加强班级团结。", "咲季最终同意参加，并主动向莉莉娅发起游戏挑战。", "手毬和莉莉娅也决定一同前往夏日祭。"], "relationship_facts": ["咲季与琴音是队友，琴音试图说服咲季。", "咲季与莉莉娅之间存在游戏上的竞争或债务关系。", "清夏是班级的活跃分子，负责提议和协调大家。"], "worldbuilding_facts": ["班级刚刚举办过联谊会，但效果不佳。", "夏日祭是班级加强团结的重要活动。", "咲季有兼职工作，周末需要与佑芽一起处理事务。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00249", "scene_id": "scene-00249", "source_file": "CSV/event/004/adv_event_004_main-02.csv", "source_kind": "event", "chapter": "event/004", "scene": "adv_event_004_main-02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "75", "line_count": 75}], "source_refs": ["CSV/event/004/adv_event_004_main-02.csv:1-75"], "line_count": 75, "speakers": ["咲季", "清夏", "琴音", "莉莉娅"], "topics": ["team_story", "relationships", "dialogue_style", "character_arc"], "title": "花海咲季与射击对决", "summary": "人群散去后，咲季提议通过游戏决胜负以安抚不安的莉莉娅。两人约定若咲季赢则继续游戏，若莉莉娅赢则汇合。咲季先教莉莉娅套圈，随后提议射击游戏，并承诺会培养莉莉娅成为高手，最终约定输者听赢者话。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["琴音", "手毬", "清夏", "莉莉娅"], "worldbuilding_signals": [], "dialogue_style_signals": ["当然", "哼", "呵呵", "啦"], "key_evidence": [{"source_row": "11", "speaker": "咲季", "text_zh": "只要发个消息总能会合的啦。"}, {"source_row": "20", "speaker": "咲季", "text_zh": "这次我一定要赢过你！"}, {"source_row": "68", "speaker": "咲季", "text_zh": "我会马上！转眼间！把你培养成射击高手的！"}, {"source_row": "73", "speaker": "咲季", "text_zh": "输了就会乖乖听话啦。输了的话。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季提议通过游戏决胜负来安抚莉莉娅。", "咲季承诺会培养莉莉娅成为射击高手。", "两人约定输者需听赢者的话。"], "relationship_facts": ["咲季与莉莉娅约定进行游戏对决。", "琴音作为旁观者提议若莉莉娅赢可汇合。", "咲季与琴音之间存在互相调侃的关系。"], "worldbuilding_facts": ["场景位于日本祭典，有人潮和套圈游戏。", "弹珠汽水是祭典上的常见饮料。", "射击游戏是祭典上的娱乐项目。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00250", "scene_id": "scene-00250", "source_file": "CSV/event/004/adv_event_004_main-03.csv", "source_kind": "event", "chapter": "event/004", "scene": "adv_event_004_main-03", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "59", "line_count": 59}], "source_refs": ["CSV/event/004/adv_event_004_main-03.csv:1-59"], "line_count": 59, "speakers": ["咲季", "琴音", "莉莉娅"], "topics": ["relationships", "team_story", "dialogue_style"], "title": "咲季指导莉莉娅射击", "summary": "咲季指导莉莉娅射击技巧，纠正其姿势与专注力。两人从射击游戏比试延伸至套圈游戏，咲季展现严厉却热心的指导态度，琴音在一旁吐槽并感叹咲季与莉莉娅的互动。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "琴音", "清夏", "莉莉娅", "妹妹"], "worldbuilding_signals": [], "dialogue_style_signals": ["当然", "哼", "啦"], "key_evidence": [{"source_row": "5", "speaker": "咲季", "text_zh": "不比出胜负就无法罢休呢。"}, {"source_row": "18", "speaker": "咲季", "text_zh": "射击游戏本来就是三局制的呀！"}, {"source_row": "49", "speaker": "咲季", "text_zh": "我会全部教给你的！跟上来吧！"}, {"source_row": "53", "speaker": "咲季", "text_zh": "再从套圈开始比一次！！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季指导莉莉娅射击姿势，强调手腕支撑与紧盯靶子。", "咲季与莉莉娅进行射击及套圈游戏比试，咲季获胜。", "咲季表示会教给莉莉娅所有技巧，并提议边玩其他游戏边寻找同伴。", "琴音吐槽咲季与莉莉娅玩得开心，导致回复未收到。"], "relationship_facts": ["咲季与莉莉娅是正在互相切磋、咲季担任指导者的关系。", "琴音是旁观者，对咲季和莉莉娅的互动感到无奈与好笑。", "咲季与佑芽存在过往的较量关系。"], "worldbuilding_facts": ["射击游戏通常采用三局定输赢的规则。", "夜市摊位设有射击和套圈等游戏项目。", "咲季擅长射击，且对游戏胜负有执着的追求。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00251", "scene_id": "scene-00251", "source_file": "CSV/event/004/adv_event_004_main-04.csv", "source_kind": "event", "chapter": "event/004", "scene": "adv_event_004_main-04", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "70", "line_count": 70}], "source_refs": ["CSV/event/004/adv_event_004_main-04.csv:1-70"], "line_count": 70, "speakers": ["咲季", "手毬", "清夏", "琴音", "祭りの客A", "祭りの客B", "莉莉娅"], "topics": ["team_story", "relationships", "dialogue_style", "plot"], "title": "咲季特训莉莉娅获胜", "summary": "咲季与莉莉娅在祭典游戏摊位进行特训，咲季耐心教导莉莉娅投球技巧。面对观众围观，咲季激发斗志全力应战，最终两人合力获胜。琴音随后加入挑战，展现三人默契。", "saki_role": "同学/对手：咲季在群像关系中以好胜、直率和带头推进对话的姿态出现。", "relationship_signals": ["琴音", "手毬", "清夏", "莉莉娅", "对手"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["哼", "嘿嘿", "啦"], "key_evidence": [{"source_row": "8", "speaker": "咲季", "text_zh": "勉强算及格吧。"}, {"source_row": "14", "speaker": "莉莉娅", "text_zh": "一直教到我学会为止……"}, {"source_row": "58", "speaker": "咲季", "text_zh": "正是有观众才能发挥真正实力呀！"}, {"source_row": "70", "speaker": "琴音", "text_zh": "来当你们的对手吧~！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季教导莉莉娅投球游戏技巧直至其学会。", "咲季在观众围观下激发斗志，全力与莉莉娅对战。", "咲季与莉莉娅合作赢得投球游戏对决。", "琴音被咲季和莉莉娅吸引，主动加入游戏挑战。"], "relationship_facts": ["咲季是莉莉娅的教练与伙伴，两人关系亲密。", "琴音是咲季和莉莉娅的玩伴，三人互动频繁。", "咲季作为偶像在祭典上受到观众关注。"], "worldbuilding_facts": ["场景发生在初星祭典的摊位游戏区域。", "咲季身穿初星制服，身份为偶像。", "祭典现场有观众围观，气氛热烈。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00252", "scene_id": "scene-00252", "source_file": "CSV/event/004/adv_event_004_main-05.csv", "source_kind": "event", "chapter": "event/004", "scene": "adv_event_004_main-05", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "69", "line_count": 69}], "source_refs": ["CSV/event/004/adv_event_004_main-05.csv:1-69"], "line_count": 69, "speakers": ["咲季", "手毬", "清夏", "琴音", "莉莉娅"], "topics": ["team_story", "relationships", "dialogue_style", "character_arc"], "title": "咲季与莉莉娅的烟花对决", "summary": "咲季结束训练后与清夏、手毬、琴音汇合，见证莉莉娅融入团队。咲季鼓励莉莉娅继续练习投球，并提议以放烟花为下一场对决。尽管清夏调侃咲季的领导风范，咲季仍坚持训练优先，最终决定明日再战，展现了伙伴间的默契与竞争。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人", "琴音", "手毬", "清夏", "莉莉娅", "朋友", "伙伴"], "worldbuilding_signals": ["训练"], "dialogue_style_signals": ["当然", "才不是", "呵呵", "制作人", "啦"], "key_evidence": [{"source_row": "18", "speaker": "咲季", "text_zh": "嘛，当然是我。"}, {"source_row": "63", "speaker": "咲季", "text_zh": "训练就调整到明天之后吧。"}, {"source_row": "69", "speaker": "咲季", "text_zh": "连放烟花也要一决胜负哦！"}, {"source_row": "45", "speaker": "咲季", "text_zh": "哎呀，你承认我是领导啦？"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季在投球比赛中获胜，并鼓励莉莉娅继续练习。", "咲季决定将训练任务调整到明天之后进行。", "咲季提议将放烟花作为与莉莉娅的下一场对决。", "清夏调侃咲季作为队长的领导风范不足。"], "relationship_facts": ["咲季与清夏、琴音、手毬是队友兼伙伴。", "咲季与莉莉娅是正在建立友谊的伙伴。", "清夏与咲季之间存在互相调侃的轻松关系。"], "worldbuilding_facts": ["团队正在进行投球比赛等训练任务。", "团队计划在河滩放烟花作为奖励活动。", "咲季作为队长负责安排训练进度。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00253", "scene_id": "scene-00253", "source_file": "CSV/event/005/adv_event_005_main-04.csv", "source_kind": "event", "chapter": "event/005", "scene": "adv_event_005_main-04", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "74", "line_count": 74}], "source_refs": ["CSV/event/005/adv_event_005_main-04.csv:1-74"], "line_count": 74, "speakers": ["咲季", "手毬", "星南", "清夏", "燕", "琴音", "莉波", "莉莉娅"], "topics": ["team_story", "worldbuilding", "character_arc", "dialogue_style"], "title": "咲季挑战星南的极限", "summary": "星南在一年级教室寻找新人，偶遇咲季。咲季反驳星南关于偶像成长极限的悲观论调，誓言粉碎那道高墙成为其榜样。星南虽怒斥咲季狂妄，但燕与莉波指出咲季与过去的星南极为相似，展现了咲季的斗志与成长。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["琴音", "手毬", "清夏", "莉波", "星南", "莉莉娅"], "worldbuilding_signals": ["学园", "偶像", "训练"], "dialogue_style_signals": ["当然", "哼", "呵呵", "啦"], "key_evidence": [{"source_row": "43", "speaker": "星南", "text_zh": "绝对会遇到一道无法跨越的高墙。"}, {"source_row": "57", "speaker": "咲季", "text_zh": "我说要把你说的那道绝对无法跨越的墙，彻底粉碎给你看！"}, {"source_row": "72", "speaker": "燕", "text_zh": "说话方式。爱说大话这点。简直和以前的你一模一样。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["星南认为达到成长极限的偶像唯有消失一途。", "咲季誓言要粉碎星南所说的无法跨越的高墙。", "咲季立志成为取代过去星南的榜样。", "燕和莉波指出咲季的性格与过去的星南很像。"], "relationship_facts": ["星南视咲季为劲敌而非接班人。", "咲季视星南为曾经的偶像导师。", "燕和莉波是星南的同伴及劲敌。"], "worldbuilding_facts": ["初星学园招收新生，星南负责发掘新人。", "星南自诩拥有看透偶像实力与才能的慧眼。", "星南曾将‘没有触及梦想的星星唯有消失’作为座右铭。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00254", "scene_id": "scene-00254", "source_file": "CSV/event/005/adv_event_005_main-05.csv", "source_kind": "event", "chapter": "event/005", "scene": "adv_event_005_main-05", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "73", "line_count": 73}], "source_refs": ["CSV/event/005/adv_event_005_main-05.csv:1-73"], "line_count": 73, "speakers": ["佑芽", "星南", "燕", "莉波"], "topics": ["relationships", "dialogue_style", "team_story", "worldbuilding"], "title": "咲季妹妹加入学生会", "summary": "星南在寻找夏季活动潜力股时偶遇候补入学的佑芽。得知佑芽为战胜姐姐咲季而来且拥有惊人运动神经后，星南决定邀请她加入学生会，以此作为咲季的新对手，助其登顶。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "琴音", "莉波", "星南", "妹妹", "姐姐"], "worldbuilding_signals": ["学园", "偶像", "工作"], "dialogue_style_signals": ["当然", "呵呵", "嘿嘿", "啦"], "key_evidence": [{"source_row": "25", "speaker": "星南", "text_zh": "你难道是花海咲季同学的……"}, {"source_row": "26", "speaker": "佑芽", "text_zh": "妹妹！"}, {"source_row": "29", "speaker": "佑芽", "text_zh": "因为有想要战胜的人。"}, {"source_row": "67", "speaker": "星南", "text_zh": "如果想以偶像身份攀登高峰的话，就加入学生会吧。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["佑芽是候补录取的学生，拥有出色的运动神经。", "佑芽进入学园是为了战胜姐姐花海咲季。", "星南决定邀请佑芽加入学生会作为咲季的对手。", "学生会成员至此全员到齐。"], "relationship_facts": ["佑芽是花海咲季的妹妹。", "星南是十王星南，学生会会长。", "星南视佑芽为咲季的新对手。"], "worldbuilding_facts": ["学园存在候补录取制度，需通过学园长面谈获得认可。", "夏季活动（H.I.F）是重要的舞台，需要快速成长的偶像。", "学生会成员包括星南、燕、莉波及新加入的佑芽。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00255", "scene_id": "scene-00255", "source_file": "CSV/event/008/adv_event_008_main-01.csv", "source_kind": "event", "chapter": "event/008", "scene": "adv_event_008_main-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "67", "line_count": 67}], "source_refs": ["CSV/event/008/adv_event_008_main-01.csv:1-67"], "line_count": 67, "speakers": ["アナウンス", "咲季", "客A", "客B", "客C", "手毬", "琴音"], "topics": ["team_story", "relationships", "dialogue_style", "worldbuilding"], "title": "咲季立志超越会长", "summary": "咲季、琴音与手毬在动漫店打工前讨论偶像工作。咲季提及十王会长新闻，立志超越其观众人数成为下一任一等星。面对顾客，咲季自信展示偶像魅力，手毬则因紧张而笨拙，琴音则自然亲切。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["琴音", "手毬"], "worldbuilding_signals": ["学园", "偶像", "工作"], "dialogue_style_signals": ["当然", "哼", "呵呵", "啦"], "key_evidence": [{"source_row": "24", "speaker": "咲季", "text_zh": "目标只有一个！要超越会长的观众人数哦！"}, {"source_row": "28", "speaker": "咲季", "text_zh": "我要让全世界知道我才是下一任『一等星』！"}, {"source_row": "49", "speaker": "咲季", "text_zh": "必须让他们产生『想听我们唱歌』的念头才行！"}, {"source_row": "59", "speaker": "咲季", "text_zh": "是要拿下下届『一等星』的女人！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季立志要超越十王会长的观众人数。", "咲季认为仅靠打招呼无法吸引观众，必须让他们想听歌。", "咲季自信地宣称自己是拿下下一届一等星的女人。", "手毬因紧张无法自然微笑，与琴音形成对比。"], "relationship_facts": ["咲季与手毬是竞争对手，互相较劲争夺一等星称号。", "琴音是咲季和手毬的同伴，负责调节气氛并指导手毬。", "咲季、琴音、手毬三人共同作为初星学园的偶像候补生打工。"], "worldbuilding_facts": ["初星学园的学生会在学园外举办舞台表演。", "十王会长是当前的偶像明星，吸引了大量观众。", "动漫店允许偶像候补生进店帮忙接待顾客。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00256", "scene_id": "scene-00256", "source_file": "CSV/event/008/adv_event_008_main-02.csv", "source_kind": "event", "chapter": "event/008", "scene": "adv_event_008_main-02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "72", "line_count": 72}], "source_refs": ["CSV/event/008/adv_event_008_main-02.csv:1-72"], "line_count": 72, "speakers": ["咲季", "客C", "客D", "手毬", "琴音"], "topics": ["team_story", "relationships", "dialogue_style", "worldbuilding"], "title": "咲季策划宣传大作战", "summary": "咲季为帮助手毬提升人气，提议邀请电视台采访被手毬和琴音否决。咲季随即提出邀请 SNS 上传视频作为替代方案，并极力争取客 D 的同意。最终在咲季的坚持下，大家决定上传视频以抓住机会，展现了咲季积极争取曝光机会的性格。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["琴音", "手毬", "美铃"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["真是的", "哼", "呵呵", "啦"], "key_evidence": [{"source_row": "49", "speaker": "咲季", "text_zh": "就是邀请电视台来啊！"}, {"source_row": "59", "speaker": "客 D", "text_zh": "这个，可以上传到 SNS 吗？"}, {"source_row": "61", "speaker": "咲季", "text_zh": "好啊！我批准了！"}, {"source_row": "67", "speaker": "手毬", "text_zh": "要想超越会长的话……就必须抓住每一个机会。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季提议邀请电视台进行采访宣传。", "咲季主张将活动视频上传至 SNS。", "咲季认为粉丝见面会能带来大量人气。", "咲季坚持认为上传视频是抓住机会的务实做法。"], "relationship_facts": ["咲季与手毬是队友，咲季主动帮助手毬。", "咲季与琴音是队友，咲季经常与琴音互动。", "咲季与客 C、客 D 是偶像与粉丝的关系。"], "worldbuilding_facts": ["组合『SyngUp!』已解散，成员继续活动。", "『超越会长』是咲季等人组成的新组合。", "SNS 是偶像宣传的重要渠道，存在炎上风险。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00257", "scene_id": "scene-00257", "source_file": "CSV/event/008/adv_event_008_main-03.csv", "source_kind": "event", "chapter": "event/008", "scene": "adv_event_008_main-03", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "65", "line_count": 65}], "source_refs": ["CSV/event/008/adv_event_008_main-03.csv:1-65"], "line_count": 65, "speakers": ["众人", "咲季", "客E", "客F", "手毬", "琴音", "観客たち"], "topics": ["team_story", "relationships", "dialogue_style", "worldbuilding"], "title": "咲季直播问答与SSD风波", "summary": "咲季在直播中接受提问，展示特制SSD引发众人吐槽。随后视频意外上传，手毬慌张场面及咲季展示怪物的片段被观众热议，导致大量粉丝因好奇SSD而聚集现场，场面一度失控。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["琴音", "手毬"], "worldbuilding_signals": ["偶像", "训练", "工作"], "dialogue_style_signals": ["当然", "呵呵", "啦"], "key_evidence": [{"source_row": "18", "speaker": "咲季", "text_zh": "这就是花海咲季特制的SSD！"}, {"source_row": "22", "speaker": "琴音", "text_zh": "超级恶心啊笨蛋～～～～！"}, {"source_row": "44", "speaker": "琴音", "text_zh": "这个！快看这个！爆红了！"}, {"source_row": "65", "speaker": "众人", "text_zh": "还会，变得更多？"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季在直播中向观众展示特制的SSD游戏饮品。", "咲季与手毬的互动被意外拍摄并上传至网络。", "视频内容导致大量粉丝因好奇SSD而聚集现场。", "咲季因视频意外上传而感到惊慌失措。"], "relationship_facts": ["咲季与手毬是偶像团体成员，咲季擅长互动而手毬略显笨拙。", "琴音负责圆场并试图阻止咲季展示可疑物品。", "咲季与手毬在直播中展现了真实的互动状态。"], "worldbuilding_facts": ["咲季的特制SSD是一种颜色诡异且会发光的游戏饮品。", "偶像团体成员在直播中会进行提问环节。", "视频内容在网络上迅速传播并引发粉丝聚集。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00258", "scene_id": "scene-00258", "source_file": "CSV/event/008/adv_event_008_main-04.csv", "source_kind": "event", "chapter": "event/008", "scene": "adv_event_008_main-04", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "70", "line_count": 70}], "source_refs": ["CSV/event/008/adv_event_008_main-04.csv:1-70"], "line_count": 70, "speakers": ["咲季", "客G", "客H", "客I", "客J", "客K", "手毬", "琴音", "観客たち"], "topics": ["team_story", "relationships", "dialogue_style", "worldbuilding"], "title": "咲季守护舞台与偶像", "summary": "活动现场拥挤，咲季纠正观众对非卖品SSD的误解，并担忧过度劳累的琴音。面对琴音坚持不休息的倔强，咲季与手毬联手应援，鼓励琴音为了成为偶像的目标全力以赴，展现了三人深厚的羁绊。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["琴音", "手毬"], "worldbuilding_signals": ["偶像", "工作"], "dialogue_style_signals": ["当然", "啦"], "key_evidence": [{"source_row": "19", "speaker": "咲季", "text_zh": "那是SSD——非卖品！"}, {"source_row": "35", "speaker": "咲季", "text_zh": "你明明很累了可骗不过我的眼睛哦。"}, {"source_row": "38", "speaker": "咲季", "text_zh": "能利用的都要利用起来！"}, {"source_row": "61", "speaker": "咲季", "text_zh": "挺有骨气的嘛。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季指出SSD是Animate的非卖品，并非商品。", "咲季发现琴音虽然逞强但身体已极度疲惫。", "咲季与手毬共同应援，支持琴音继续演出。", "咲季认为只要观众能来，演出即算成功。"], "relationship_facts": ["咲季与琴音是共同奋斗的舞台搭档。", "咲季与手毬默契配合，共同照顾琴音。", "咲季作为前辈或核心成员，关注后辈状态。"], "worldbuilding_facts": ["SSD是Animate举办的活动非卖品。", "现场存在关于CG作假的传闻。", "舞台演出结束后有谈话环节。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00259", "scene_id": "scene-00259", "source_file": "CSV/event/008/adv_event_008_main-05.csv", "source_kind": "event", "chapter": "event/008", "scene": "adv_event_008_main-05", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "64", "line_count": 64}], "source_refs": ["CSV/event/008/adv_event_008_main-05.csv:1-64"], "line_count": 64, "speakers": ["众人", "咲季", "工作人员", "手毬", "琴音"], "topics": ["team_story", "relationships", "dialogue_style", "worldbuilding"], "title": "咲季鼓励全员喝下SSD", "summary": "咲季提议手毬与琴音共同饮用SSD以提振精神，并贴心准备第二瓶供手毬使用。三人干杯后，咲季确认药效显著，大家随即前往舞台准备表演，咲季以此展现偶像的自信与领导力。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["琴音", "手毬"], "worldbuilding_signals": ["学园", "偶像", "工作"], "dialogue_style_signals": ["当然", "让你见识", "啦"], "key_evidence": [{"source_row": "4", "speaker": "咲季", "text_zh": "好主意呢！琴音，快喝吧！"}, {"source_row": "12", "speaker": "咲季", "text_zh": "想着在大任务前，三个人一起喝。"}, {"source_row": "27", "speaker": "咲季", "text_zh": "感觉力量涌上来了！"}, {"source_row": "63", "speaker": "咲季", "text_zh": "来自初星学园的 未来顶级偶像的舞台表演！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季主动提议并鼓励琴音和手毬饮用SSD。", "咲季为手毬准备了第二瓶SSD，希望三人共同饮用。", "饮用SSD后，咲季确认琴音精神恢复并准备跳舞。", "咲季带领众人前往舞台，准备进行偶像表演。"], "relationship_facts": ["咲季与琴音、手毬是初星学园的同班同学及队友。", "咲季展现出对队友的关怀与照顾（如准备第二瓶、承诺按摩）。", "咲季在团队中担任鼓舞士气、凝聚人心的角色。"], "worldbuilding_facts": ["SSD是一种能迅速恢复精神但味道极差的饮料。", "SSD由工作人员制作，咲季等人是在制作者面前饮用。", "初星学园的学生们正在Animate举办舞台表演活动。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00260", "scene_id": "scene-00260", "source_file": "CSV/event/009/adv_event_009_main-01.csv", "source_kind": "event", "chapter": "event/009", "scene": "adv_event_009_main-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "56", "line_count": 56}], "source_refs": ["CSV/event/009/adv_event_009_main-01.csv:1-56"], "line_count": 56, "speakers": ["クラスメイトA", "クラスメイトB", "ケーキ屋の店主", "咲季", "手毬", "清夏", "琴音", "莉莉娅", "？？？"], "topics": ["team_story", "relationships", "worldbuilding", "dialogue_style"], "title": "咲季拒绝蛋糕兼职", "summary": "琴音为凑齐圣诞蛋糕摊人手向咲季求助，咲季以偶像训练为由拒绝，并强调偶像不宜吃蛋糕。随后琴音询问手毬也被拒，最终向清夏和莉莉娅求助。", "saki_role": "同学/对手：咲季在群像关系中以好胜、直率和带头推进对话的姿态出现。", "relationship_signals": ["琴音", "手毬", "清夏", "莉莉娅", "朋友", "对手", "家人"], "worldbuilding_signals": ["偶像", "训练", "工作"], "dialogue_style_signals": ["当然", "啦"], "key_evidence": [{"source_row": "38", "speaker": "咲季", "text_zh": "但我拒绝。蛋糕什么的根本不适合偶像吃。"}, {"source_row": "25", "speaker": "咲季", "text_zh": "我才不要！这个时间我要用来训练！"}, {"source_row": "36", "speaker": "琴音", "text_zh": "这次兼职的报酬真的超级丰厚哦……"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季因偶像训练拒绝参加圣诞蛋糕摊兼职。", "咲季认为蛋糕不适合偶像食用。", "琴音在多名朋友拒绝后向清夏和莉莉娅求助。"], "relationship_facts": ["咲季与琴音是朋友关系。", "咲季与手毬是朋友关系。", "清夏与莉莉娅是朋友关系。"], "worldbuilding_facts": ["学校正在筹备圣诞节活动摊位。", "蛋糕摊兼职报酬丰厚。", "偶像需要保持身材，不宜食用蛋糕。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00261", "scene_id": "scene-00261", "source_file": "CSV/event/009/adv_event_009_main-02.csv", "source_kind": "event", "chapter": "event/009", "scene": "adv_event_009_main-02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "70", "line_count": 70}], "source_refs": ["CSV/event/009/adv_event_009_main-02.csv:1-70"], "line_count": 70, "speakers": ["ケーキ屋の店主", "佑芽", "千奈", "广", "清夏", "琴音", "美铃", "莉莉娅"], "topics": ["team_story", "relationships", "dialogue_style", "worldbuilding"], "title": "咲季与莉莉娅的打工邀约", "summary": "广因晕倒放弃蛋糕店兼职，佑芽主动接替。琴音需再找一人，莉莉娅虽因社恐犹豫，但在清夏鼓励下决定尝试。咲季作为琴音妹妹被提及，清夏表示不参与打工但关注活动。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "琴音", "清夏", "广", "美铃", "莉莉娅", "妹妹"], "worldbuilding_signals": ["训练", "工作"], "dialogue_style_signals": ["不是吗", "啦"], "key_evidence": [{"source_row": "55", "speaker": "清夏", "text_zh": "那孩子不是咲季同学的妹妹嘛。"}, {"source_row": "61", "speaker": "清夏", "text_zh": "那要放弃吗？没必要执着于打工吧？"}, {"source_row": "65", "speaker": "莉莉娅", "text_zh": "我要再去追琴音同学一次。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["广因体力不支晕倒，决定放弃蛋糕店兼职。", "佑芽主动接替广的职位，并邀请琴音加入。", "莉莉娅在清夏鼓励下决定尝试蛋糕店工作。", "清夏决定不参与打工，但表示对活动感兴趣。"], "relationship_facts": ["琴音与咲季是姐妹关系。", "清夏是莉莉娅的朋友，给予其鼓励。", "佑芽与琴音是朋友，互相支持参与活动。"], "worldbuilding_facts": ["蛋糕店正在招募圣诞活动兼职人员。", "广晕倒是其平时常见的反应方式。", "二班成员抢先拉走了琴音的潜在同伴。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00262", "scene_id": "scene-00262", "source_file": "CSV/event/009/adv_event_009_main-03.csv", "source_kind": "event", "chapter": "event/009", "scene": "adv_event_009_main-03", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "64", "line_count": 64}], "source_refs": ["CSV/event/009/adv_event_009_main-03.csv:1-64"], "line_count": 64, "speakers": ["ケーキ屋の店主", "佑芽", "琴音", "莉莉娅"], "topics": ["relationships", "team_story", "dialogue_style", "worldbuilding"], "title": "咲季引荐莉莉娅打工", "summary": "琴音与佑芽因忘记向莉莉娅打招呼而尴尬，幸得咲季引荐，莉莉娅才找到琴音。莉莉娅为参加学园圣诞活动并制作蛋糕支持活动，决定加入蛋糕店兼职。三人关系破冰，正式组队准备打工。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "琴音", "清夏", "莉莉娅", "朋友", "家人"], "worldbuilding_signals": ["学园", "工作"], "dialogue_style_signals": ["当然", "哼", "嘿嘿", "啦"], "key_evidence": [{"source_row": "29", "speaker": "莉莉娅", "text_zh": "后来是从咲季同学那里听说，才出来找琴音同学的。"}, {"source_row": "52", "speaker": "莉莉娅", "text_zh": "我也想参加学园的圣诞活动……"}, {"source_row": "54", "speaker": "莉莉娅", "text_zh": "如果能用我做的蛋糕支持这次活动的话……"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["琴音和佑芽忘记了向莉莉娅打招呼。", "莉莉娅是通过咲季的介绍才找到琴音的。", "莉莉娅决定加入蛋糕店兼职以支持圣诞活动。"], "relationship_facts": ["琴音与莉莉娅是同学，但此前交流不多。", "佑芽与莉莉娅是同学，但此前交流不多。", "咲季是琴音和佑芽的朋友，并引荐了莉莉娅。"], "worldbuilding_facts": ["蛋糕店正在招募兼职帮手。", "学园有圣诞活动，幕后工作需要人手。", "莉莉娅来自一个圣诞节与家人一起过的国家。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00263", "scene_id": "scene-00263", "source_file": "CSV/event/009/adv_event_009_main-05.csv", "source_kind": "event", "chapter": "event/009", "scene": "adv_event_009_main-05", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "80", "line_count": 80}, {"block_index": 2, "start_row": "81", "end_row": "81", "line_count": 1}], "source_refs": ["CSV/event/009/adv_event_009_main-05.csv:1-81"], "line_count": 81, "speakers": ["ケーキ屋の店主", "佑芽", "咲季", "旁白", "清夏", "琴音", "莉莉娅"], "topics": ["relationships", "team_story", "dialogue_style", "character_arc"], "title": "蛋糕店里的姐妹情深", "summary": "初星学园圣诞活动，咲季与佑芽在蛋糕店忙碌。咲季品尝佑芽制作的蛋糕，虽被琴音调侃但特例允许。众人互动融洽，莉莉娅与清夏和解，琴音与佑芽关系升温。最终收到酬劳，大家约定未来共同制作点心，氛围温馨。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "琴音", "清夏", "莉莉娅", "姐姐", "朋友"], "worldbuilding_signals": ["学园", "偶像"], "dialogue_style_signals": ["当然", "真是的", "嘿嘿", "啦"], "key_evidence": [{"source_row": "10", "speaker": "咲季", "text_zh": "佑芽，我们来了！看起来很努力嘛。"}, {"source_row": "14", "speaker": "咲季", "text_zh": "这是特例。因为是佑芽做的蛋糕呀。"}, {"source_row": "19", "speaker": "咲季", "text_zh": "嗯，很好吃哦！"}, {"source_row": "76", "speaker": "ケーキ屋の店主", "text_zh": "我是来送这次酬劳的。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季与佑芽在蛋糕店进行圣诞活动并售卖蛋糕。", "咲季品尝了佑芽制作的蛋糕并给予好评。", "琴音因咲季吃蛋糕而调侃其偶像身份，咲季解释这是特例。", "活动结束收到酬劳，众人约定未来共同制作点心。"], "relationship_facts": ["咲季与佑芽是亲密的姐妹关系。", "琴音与佑芽在互动中关系变得更好。", "莉莉娅与清夏通过分享蛋糕消除了隔阂。"], "worldbuilding_facts": ["初星学园正在举办圣诞活动。", "偶像通常被禁止随意吃甜食，但咲季对此有特例。", "蛋糕店店主会支付酬劳给参与活动的学生。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00264", "scene_id": "scene-00264", "source_file": "CSV/event/010/adv_event_010_main-05.csv", "source_kind": "event", "chapter": "event/010", "scene": "adv_event_010_main-05", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "78", "line_count": 78}], "source_refs": ["CSV/event/010/adv_event_010_main-05.csv:1-78"], "line_count": 78, "speakers": ["众人", "佑芽", "千奈", "咲季", "广", "手毬", "旁白", "星南", "琴音", "美铃", "莉波"], "topics": ["team_story", "relationships", "dialogue_style", "worldbuilding"], "title": "情人节惊喜与快递", "summary": "情人节庆典当日，广在舞台空档为众人演唱并赠送亲手制作的友情巧克力。咲季提及琴音房前有冷藏箱包裹，琴音发现后发出尖叫。众人齐聚分享甜蜜时刻。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "琴音", "手毬", "广", "莉波", "星南", "美铃", "姐姐", "朋友"], "worldbuilding_signals": ["演唱会", "工作"], "dialogue_style_signals": ["真是的", "呵呵", "啦"], "key_evidence": [{"source_row": "76", "speaker": "咲季", "text_zh": "啊，琴音。你房门前好像有快递包裹哦。"}, {"source_row": "77", "speaker": "琴音", "text_zh": "包裹？是什么东西呢…嗯，冷藏箱……？"}, {"source_row": "78", "speaker": "琴音", "text_zh": "呜哇啊啊啊啊啊啊啊啊啊啊啊啊啊！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["广在舞台空档为众人演唱并赠送亲手制作的友情巧克力。", "咲季告知琴音房门前有冷藏箱包裹。", "琴音发现冷藏箱包裹后发出尖叫。"], "relationship_facts": ["广与莉波、千奈、佑芽、美铃是朋友。", "星南是学生会会长，广是学妹。", "咲季与琴音是室友或邻居关系。"], "worldbuilding_facts": ["情人节庆典当天天气放晴。", "庆典舞台有空档时段可供使用。", "广制作的巧克力是从可可豆开始亲手制作的。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00265", "scene_id": "scene-00265", "source_file": "CSV/event/012/adv_event_012_main-01.csv", "source_kind": "event", "chapter": "event/012", "scene": "adv_event_012_main-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "59", "line_count": 59}], "source_refs": ["CSV/event/012/adv_event_012_main-01.csv:1-59"], "line_count": 59, "speakers": ["咲季", "清夏", "莉莉娅"], "topics": ["team_story", "worldbuilding", "character_arc", "dialogue_style"], "title": "咲季劝导莉莉娅休息", "summary": "咲季制止莉莉娅过度训练，强调偶像职责与团队责任。清夏与莉莉娅回忆咲季入学前严苛训练及超越前辈的历程，肯定其领导力。咲季承认过去专注训练忽视社交，如今愿与大家分享休息时光，展现成长与关怀。", "saki_role": "同学/对手：咲季在群像关系中以好胜、直率和带头推进对话的姿态出现。", "relationship_signals": ["清夏", "莉莉娅", "朋友"], "worldbuilding_signals": ["学园", "偶像", "训练", "演唱会", "工作"], "dialogue_style_signals": ["当然", "真是的", "嘿嘿", "啦"], "key_evidence": [{"source_row": "7", "speaker": "咲季", "text_zh": "不行哦。今天就到此为止。"}, {"source_row": "23", "speaker": "咲季", "text_zh": "因为这是身为临时组合队长的我的责任啊。"}, {"source_row": "45", "speaker": "咲季", "text_zh": "我可是入学前就开始训练了！"}, {"source_row": "58", "speaker": "咲季", "text_zh": "没错！为了明天继续努力今天要好好休息！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季作为临时组合队长，强制莉莉娅停止训练以避免受伤。", "咲季承认自己入学前就开始训练，因此水平远超同期前辈。", "咲季过去因专注训练而疏于社交，现已愿意参与团队闲聊。"], "relationship_facts": ["咲季是清夏和莉莉娅的队友及临时组合队长。", "咲季与清夏、莉莉娅之间从单向崇拜转变为互相扶持的伙伴关系。", "清夏和莉莉娅视咲季为榜样，感激她带来的努力氛围。"], "worldbuilding_facts": ["咲季是初星学园偶像，入学前已接受长期专业训练。", "团队正在进行地区振兴活动的迷你演唱会排练。", "咲季所在的临时组合由咲季担任队长，负责统筹训练与休息。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00266", "scene_id": "scene-00266", "source_file": "CSV/event/012/adv_event_012_main-02.csv", "source_kind": "event", "chapter": "event/012", "scene": "adv_event_012_main-02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "80", "line_count": 80}, {"block_index": 2, "start_row": "81", "end_row": "94", "line_count": 14}], "source_refs": ["CSV/event/012/adv_event_012_main-02.csv:1-94"], "line_count": 94, "speakers": ["クラスメイトA", "咲季", "手毬", "旁白", "清夏", "琴音", "舞蹈训练师", "莉莉娅"], "topics": ["team_story", "character_arc", "relationships", "worldbuilding"], "title": "咲季引导咲季奔跑", "summary": "咲季指导莉莉娅舞蹈后，见其陷入自我怀疑与盲目奔跑的困境。咲季直言低效训练令人焦躁，主动提出传授高效方法，并指出莉莉娅想追上清夏的资格。最终莉莉娅重拾信念，决定追随咲季的背影继续奔跑，确立师徒关系。", "saki_role": "同学/对手：咲季在群像关系中以好胜、直率和带头推进对话的姿态出现。", "relationship_signals": ["琴音", "手毬", "清夏", "莉莉娅", "朋友"], "worldbuilding_signals": ["偶像", "训练"], "dialogue_style_signals": ["当然", "哼", "嘿嘿", "啦"], "key_evidence": [{"source_row": "78", "speaker": "咲季", "text_zh": "你，来当我的徒弟吧！"}, {"source_row": "84", "speaker": "咲季", "text_zh": "你不是想不惜一切代价追上清夏吗？"}, {"source_row": "93", "speaker": "莉莉娅", "text_zh": "但现在唯独小咲季的背影，还能依稀可见。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季主动提出指导莉莉娅，认为盲目努力效率低下。", "咲季指出莉莉娅想追上清夏，必须拥有相应资格。", "莉莉娅决定追随咲季的背影，重新确立奔跑目标。"], "relationship_facts": ["咲季是莉莉娅的舞蹈师父。", "清夏是莉莉娅追赶的目标与榜样。", "咲季与莉莉娅是朋友关系。"], "worldbuilding_facts": ["舞蹈训练存在合格与不合格之分，不合格者需特训。", "角色们面临入学考试及舞蹈技能考核。", "角色们有追逐偶像梦想的共同目标。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00267", "scene_id": "scene-00267", "source_file": "CSV/event/012/adv_event_012_main-03.csv", "source_kind": "event", "chapter": "event/012", "scene": "adv_event_012_main-03", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "80", "line_count": 80}, {"block_index": 2, "start_row": "81", "end_row": "84", "line_count": 4}], "source_refs": ["CSV/event/012/adv_event_012_main-03.csv:1-84"], "line_count": 84, "speakers": ["咲季", "旁白", "清夏", "琴音", "舞蹈训练师", "莉莉娅"], "topics": ["team_story", "dialogue_style", "character_arc", "worldbuilding"], "title": "咲季守护清夏", "summary": "清夏因身体症状隐瞒病情并逃避训练，咲季敏锐察觉其谎言，主动介入并鼓励其坦白。咲季表示愿成为清夏的力量，帮助她克服恐惧，重新面对舞蹈与约定，展现了深厚的友谊与关怀。", "saki_role": "同学/对手：咲季在群像关系中以好胜、直率和带头推进对话的姿态出现。", "relationship_signals": ["琴音", "清夏", "莉莉娅", "朋友", "对手"], "worldbuilding_signals": ["偶像", "训练"], "dialogue_style_signals": ["当然", "哼", "呵呵", "啦"], "key_evidence": [{"source_row": "17", "speaker": "清夏", "text_zh": "但是现在不是有咲季帮忙照顾着嘛！"}, {"source_row": "66", "speaker": "咲季", "text_zh": "你的眼睛。是双说谎者的眼睛呢。"}, {"source_row": "81", "speaker": "咲季", "text_zh": "因为我想成为你的力量呀。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["清夏因身体症状隐瞒病情并逃避舞蹈训练。", "咲季察觉清夏的谎言，鼓励其坦白全部真相。", "咲季表示愿意成为清夏的力量，帮助其克服恐惧。", "清夏在咲季的帮助下逐渐恢复训练信心。"], "relationship_facts": ["咲季与清夏是亲密的朋友，咲季主动关心清夏的身体状况。", "咲季与莉莉娅共同支持清夏，三人关系紧密。", "咲季视清夏为值得较量的好对手，但更在乎其健康。"], "worldbuilding_facts": ["舞蹈训练对清夏的身体造成负担，导致其出现症状。", "清夏隐瞒症状是为了履行成为偶像的约定。", "咲季对清夏的病情和谎言有深入了解。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00268", "scene_id": "scene-00268", "source_file": "CSV/event/012/adv_event_012_main-04.csv", "source_kind": "event", "chapter": "event/012", "scene": "adv_event_012_main-04", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "80", "line_count": 80}, {"block_index": 2, "start_row": "81", "end_row": "94", "line_count": 14}], "source_refs": ["CSV/event/012/adv_event_012_main-04.csv:1-94"], "line_count": 94, "speakers": ["众人", "佑芽", "咲季", "清夏", "莉莉娅"], "topics": ["team_story", "relationships", "worldbuilding", "character_arc"], "title": "咲季助清夏突破心魔", "summary": "咲季邀请莉莉娅加入训练，旨在帮助清夏克服舞蹈难题。面对清夏的动摇，咲季引导其分解问题并坚持。随后佑芽挑战失败，清夏成功完成练习。咲季鼓励莉莉娅成为清夏的力量，但莉莉娅因过度努力发烧。咲季点明自己无法永远守护，促使清夏决心不再逃避与说谎。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "清夏", "莉莉娅", "姐姐"], "worldbuilding_signals": ["训练", "演唱会", "工作"], "dialogue_style_signals": ["当然", "真是的", "呵呵", "啦"], "key_evidence": [{"source_row": "5", "speaker": "咲季", "text_zh": "我决定要帮忙解决清夏面临的问题！"}, {"source_row": "51", "speaker": "咲季", "text_zh": "很棒哦清夏。完整跳下来了呢。"}, {"source_row": "85", "speaker": "咲季", "text_zh": "我不可能永远守护在那孩子身边。"}, {"source_row": "94", "speaker": "清夏", "text_zh": "我都决定了不再停下脚步。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季邀请莉莉娅成为弟子，共同协助清夏解决训练问题。", "清夏在咲季与莉莉娅的陪伴下，成功克服了舞蹈动作的恐惧。", "莉莉娅因过度努力训练导致发烧，需要休息。", "咲季指出自己无法永远守护莉莉娅，促使清夏下定决心不再逃避。"], "relationship_facts": ["咲季是清夏的导师与朋友，致力于帮助她成长。", "莉莉娅视清夏为重要伙伴，渴望成为她的力量。", "佑芽是咲季的妹妹，与咲季关系亲密。"], "worldbuilding_facts": ["清夏因身体原因（如发烧）在舞蹈训练上存在困难。", "咲季作为前辈，主动介入并指导后辈解决心理障碍。", "团队通过共同训练和互相鼓励来应对挑战。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00269", "scene_id": "scene-00269", "source_file": "CSV/event/012/adv_event_012_main-05.csv", "source_kind": "event", "chapter": "event/012", "scene": "adv_event_012_main-05", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "63", "line_count": 63}], "source_refs": ["CSV/event/012/adv_event_012_main-05.csv:1-63"], "line_count": 63, "speakers": ["众人", "佑芽", "咲季", "旁白", "清夏", "莉莉娅"], "topics": ["team_story", "relationships", "plot", "worldbuilding"], "title": "迷你演唱会前的约定", "summary": "咲季与清夏、莉莉娅讨论迷你演唱会，清夏与莉莉娅互相支持。佑芽想参加被咲季拒绝，咲季解释莉莉娅与自己相似。演出前众人确认准备就绪，清夏与莉莉娅誓言并肩作战，展现羁绊。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "清夏", "莉莉娅", "姐姐"], "worldbuilding_signals": ["演唱会", "工作"], "dialogue_style_signals": ["当然", "呵呵", "啦"], "key_evidence": [{"source_row": "17", "speaker": "莉莉娅", "text_zh": "直到有一天我们两个能站上更大的舞台为止。"}, {"source_row": "39", "speaker": "咲季", "text_zh": "呵呵，佑芽和莉莉娅关系很好呢。"}, {"source_row": "44", "speaker": "咲季", "text_zh": "只是觉得，和她稍微有点相似呢。"}, {"source_row": "59", "speaker": "清夏", "text_zh": "但只要我们两个人一起就绝对不会输给咲季同学！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["清夏与莉莉娅约定共同站上更大的舞台。", "咲季认为佑芽与莉莉娅关系很好。", "咲季指出清夏与莉莉娅已下定决心。"], "relationship_facts": ["清夏与莉莉娅是互相支持的伙伴。", "咲季与清夏、莉莉娅是同事/前辈关系。", "佑芽是咲季的妹妹，想加入演出。"], "worldbuilding_facts": ["明日举行迷你演唱会。", "清夏与莉莉娅是临时组合成员。", "演出对象包括其他学生。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00270", "scene_id": "scene-00270", "source_file": "CSV/event/013/adv_event_013_main-05.csv", "source_kind": "event", "chapter": "event/013", "scene": "adv_event_013_main-05", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "80", "line_count": 80}, {"block_index": 2, "start_row": "81", "end_row": "85", "line_count": 5}], "source_refs": ["CSV/event/013/adv_event_013_main-05.csv:1-85"], "line_count": 85, "speakers": ["众人", "千奈", "星南", "燕", "美铃", "莉波", "麻央"], "topics": ["team_story", "worldbuilding", "character_arc", "dialogue_style"], "title": "星南的极限与成长", "summary": "星南在旅行中反思作为学生会长及偶像的局限，燕直言其自负。面对众人对 H.I.F 夺冠的期待，星南意识到自己已达成长极限，唯有势均力敌的对手才能推动其突破，决心全力应战。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "琴音", "麻央", "莉波", "星南", "美铃", "莉莉娅", "姐姐", "对手"], "worldbuilding_signals": ["学园", "偶像", "训练"], "dialogue_style_signals": ["当然", "哼", "制作人"], "key_evidence": [{"source_row": "31", "speaker": "星南", "text_zh": "作为学生会长，作为现任『一等星』，我认为这是必须履行的责任。"}, {"source_row": "29", "speaker": "燕", "text_zh": "就算是你，也太过自负了吧。"}, {"source_row": "83", "speaker": "星南", "text_zh": "如果……如果作为偶像已经到达成长极限的我"}, {"source_row": "85", "speaker": "星南", "text_zh": "那一定是与我势均力敌的对手——对吧"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["星南意识到自己作为偶像可能已到达成长极限。", "燕指出星南一边活动一边照顾他人是自负的表现。", "众人（麻央、莉波、燕）均希望星南在 H.I.F 中夺冠。", "星南认为只有势均力敌的对手才能让她继续成长。"], "relationship_facts": ["星南与燕是长期的竞争对手与知己。", "麻央视星南为追赶的目标并决心成为一等星。", "莉波将星南视为劲敌并渴望堂堂正正一决胜负。"], "worldbuilding_facts": ["H.I.F 是偶像界的重要赛事，夺冠者被称为『一等星』。", "初星学园的学生会由星南领导，负责培育一年级学生。", "当地神社供奉演艺之神，常有偶像参拜。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00271", "scene_id": "scene-00271", "source_file": "CSV/event/014/adv_event_014_main-03.csv", "source_kind": "event", "chapter": "event/014", "scene": "adv_event_014_main-03", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "72", "line_count": 72}], "source_refs": ["CSV/event/014/adv_event_014_main-03.csv:1-72"], "line_count": 72, "speakers": ["佑芽", "广", "旁白", "美铃"], "topics": ["team_story", "relationships", "character_arc", "worldbuilding"], "title": "广的觉悟与练习邀请", "summary": "次日，广向美铃和佑芽坦白自己因体力不足无法参加运动会，担心拖累大家。他决定专注于偶像演唱会训练，并请求咲季示范拔河姿势。佑芽鼓励大家共同承担失败，广最终决定坚持到底，邀请美铃一起练习铁人偶像竞速赛。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "广", "美铃", "姐姐", "朋友"], "worldbuilding_signals": ["学园", "偶像", "训练", "演唱会"], "dialogue_style_signals": ["当然", "呵呵", "啦"], "key_evidence": [{"source_row": "22", "speaker": "广", "text_zh": "拜托咲季示范给我们看的。"}, {"source_row": "23", "speaker": "广", "text_zh": "标准合理的拔河姿势。"}, {"source_row": "68", "speaker": "美铃", "text_zh": "搭档是我。"}, {"source_row": "69", "speaker": "美铃", "text_zh": "铁人偶像竞速赛。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["广因体力差距无法参加运动会，决定专注于偶像训练。", "广请求咲季示范标准合理的拔河姿势。", "广邀请美铃搭档参加铁人偶像竞速赛并共同练习。", "佑芽表示即使是不擅长的比赛也要全力以赴。"], "relationship_facts": ["广与咲季是同学，咲季擅长拔河。", "广与美铃是搭档，共同参加铁人偶像竞速赛。", "广与佑芽是好友，佑芽鼓励广坚持到底。"], "worldbuilding_facts": ["班级正在为即将到来的运动会做准备。", "广的爱好是偶像活动，计划举办演唱会。", "铁人偶像竞速赛是运动会中的比赛项目。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00272", "scene_id": "scene-00272", "source_file": "CSV/event/014/adv_event_014_main-04.csv", "source_kind": "event", "chapter": "event/014", "scene": "adv_event_014_main-04", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "56", "line_count": 56}], "source_refs": ["CSV/event/014/adv_event_014_main-04.csv:1-56"], "line_count": 56, "speakers": ["众人", "佑芽", "千奈", "咲季", "广", "手毬", "美铃", "莉莉娅"], "topics": ["team_story", "relationships", "dialogue_style", "character_arc"], "title": "运动会最终对决", "summary": "运动会拔河赛结束，1年2班险胜。1年1班咲季凭借长跑第一名的成绩追平比分，并派出莉莉娅与手毬组合作为最终兵器，准备与广、美铃进行最后的较量，气氛紧张激烈。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "手毬", "广", "星南", "美铃", "莉莉娅", "姐姐", "对手"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["当然", "才不是", "哼", "呵呵", "啦"], "key_evidence": [{"source_row": "33", "speaker": "咲季", "text_zh": "呵呵呵呵……追上你们了哦1年2班！"}, {"source_row": "38", "speaker": "咲季", "text_zh": "靠我的长跑第一名哦！"}, {"source_row": "42", "speaker": "咲季", "text_zh": "要与你们做个了断的一年一班最终兵器——"}, {"source_row": "43", "speaker": "咲季", "text_zh": "莉莉娅&手毬组合驾到！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["1年2班在拔河比赛中获胜。", "咲季以长跑第一名成绩帮助1年1班追平比分。", "咲季宣布派出莉莉娅和手毬组合作为最终兵器。", "广和美铃将作为对手迎接最终挑战。"], "relationship_facts": ["咲季是1年1班的领袖人物。", "手毬与美铃是搭档组合。", "广与美铃是1年2班的队友。"], "worldbuilding_facts": ["运动会包含个人项目与团体项目。", "1年1班与1年2班是主要竞争班级。", "咲季擅长长跑项目。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00273", "scene_id": "scene-00273", "source_file": "CSV/event/014/adv_event_014_main-05.csv", "source_kind": "event", "chapter": "event/014", "scene": "adv_event_014_main-05", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "80", "line_count": 80}], "source_refs": ["CSV/event/014/adv_event_014_main-05.csv:1-80"], "line_count": 80, "speakers": ["众人", "佑芽", "千奈", "咲季", "学园长", "广", "手毬", "清夏", "琴音", "美铃", "舞蹈训练师", "莉莉娅"], "topics": ["team_story", "relationships", "worldbuilding", "dialogue_style"], "title": "钢铁偶像赛跑与和解", "summary": "钢铁偶像竞赛中，广与美铃在两人三足及障碍物环节表现紧张，最终虽败给第一组，但广因美铃的鼓励重拾笑容。赛后众人提议唱歌，广向美铃表白心意，两人关系在欢笑与感动中进一步升华。", "saki_role": "同学/对手：咲季在群像关系中以好胜、直率和带头推进对话的姿态出现。", "relationship_signals": ["佑芽", "琴音", "手毬", "清夏", "广", "美铃", "莉莉娅", "朋友"], "worldbuilding_signals": ["学园", "偶像", "训练"], "dialogue_style_signals": ["真是的", "呵呵", "啦"], "key_evidence": [{"source_row": "28", "speaker": "咲季", "text_zh": "两人三足……差距不大。"}, {"source_row": "47", "speaker": "千奈", "text_zh": "简直就像花海同学一样呢……！"}, {"source_row": "78", "speaker": "广", "text_zh": "你是我……最重要的朋友。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["钢铁偶像竞赛中，广与美铃作为二组搭档参赛。", "在障碍物区域，广因紧张未能追上美铃，最终输掉比赛。", "赛后广向美铃表达感谢与爱意，两人关系得到确认。", "千奈指出广背负美铃奔跑的样子像花海咲季。"], "relationship_facts": ["广与美铃是重要的朋友及搭档。", "千奈认为广背负美铃奔跑的姿态像花海咲季。", "众人（佑芽、千奈等）是广与美铃的支持者。"], "worldbuilding_facts": ["钢铁偶像竞赛包含两人三足、卡拉OK、障碍物及牵手冲刺等关卡。", "障碍物区域要求搭档分开行动，各自跨越障碍。", "比赛获胜者将获得第一组的荣誉。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00274", "scene_id": "scene-00274", "source_file": "CSV/event/016/adv_event_016_main-01.csv", "source_kind": "event", "chapter": "event/016", "scene": "adv_event_016_main-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "67", "line_count": 67}], "source_refs": ["CSV/event/016/adv_event_016_main-01.csv:1-67"], "line_count": 67, "speakers": ["佑芽", "咲季", "店員", "手毬", "旁白", "琴音"], "topics": ["relationships", "team_story", "dialogue_style", "worldbuilding"], "title": "咲季与大家的温泉之旅", "summary": "咲季与佑芽逛街抽奖，佑芽中得火腿，咲季赢得体育中心门票并分给佑芽。次日咲季邀请琴音及妹妹前往运动中心，手毬也希望能同行，咲季欣然答应，展现了她照顾朋友与妹妹的温柔一面。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "琴音", "手毬", "广", "美铃", "妹妹", "姐姐", "朋友", "伙伴"], "worldbuilding_signals": ["训练", "工作"], "dialogue_style_signals": ["当然", "才不是", "哼", "呵呵", "不是吗", "啦"], "key_evidence": [{"source_row": "21", "speaker": "店員", "text_zh": "三等奖是体育中心的10张连票哦！"}, {"source_row": "27", "speaker": "咲季", "text_zh": "佑芽，分你一半。"}, {"source_row": "57", "speaker": "咲季", "text_zh": "当然没问题啦！"}, {"source_row": "66", "speaker": "手毬", "text_zh": "不是的……没问题。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季在商店街抽奖活动中赢得了体育中心的10张连票。", "咲季将门票分给佑芽，鼓励她与学生会的朋友们一起放松玩耍。", "咲季邀请琴音及其妹妹前往运动中心，并承诺下周预留时间。", "手毬表示自己也希望能参加运动中心的游玩活动。"], "relationship_facts": ["咲季是佑芽的姐姐，两人关系亲密。", "咲季与琴音是朋友，咲季愿意照顾琴音的妹妹。", "手毬是咲季的朋友，咲季没有排挤手毬，接纳了她同行的请求。"], "worldbuilding_facts": ["商店街设有抽奖活动，奖品包括温泉旅行和体育中心的连票。", "运动中心是学生们进行训练和游玩的场所。", "咲季作为学生会成员，平时工作繁忙，但会抽出时间陪伴朋友。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00275", "scene_id": "scene-00275", "source_file": "CSV/event/016/adv_event_016_main-02.csv", "source_kind": "event", "chapter": "event/016", "scene": "adv_event_016_main-02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "75", "line_count": 75}], "source_refs": ["CSV/event/016/adv_event_016_main-02.csv:1-75"], "line_count": 75, "speakers": ["ことねの妹", "咲季", "手毬", "琴音"], "topics": ["relationships", "team_story", "dialogue_style"], "title": "咲季面对妹妹离别的寂寞", "summary": "咲季与琴音、手毬及琴音妹妹游玩。咲季教导琴音打球，琴音察觉咲季因妹妹佑芽结交新朋友而感寂寞。咲季不愿承认脆弱，反而认为妹妹该感到寂寞，展现了她坚强外表下的细腻情感。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "琴音", "手毬", "广", "妹妹", "姐姐", "朋友"], "worldbuilding_signals": [], "dialogue_style_signals": ["当然", "哼", "嘿嘿", "啦"], "key_evidence": [{"source_row": "59", "speaker": "咲季", "text_zh": "佑芽不是加入学生会了吗？"}, {"source_row": "64", "speaker": "琴音", "text_zh": "该不会……是觉得寂寞了？"}, {"source_row": "66", "speaker": "咲季", "text_zh": "或许是吧。"}, {"source_row": "74", "speaker": "咲季", "text_zh": "倒不如说，该觉得寂寞的应该是佑芽才对。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季是佑芽的姐姐，两人通过比赛决胜负。", "咲季因佑芽加入学生会结交新朋友而感到寂寞。", "咲季不愿在妹妹面前表现出脆弱的一面。"], "relationship_facts": ["咲季与琴音是朋友。", "咲季与手毬是朋友。", "琴音与ことねの妹是姐妹关系。"], "worldbuilding_facts": ["咲季阅读了最新运动理论书籍并学习教练技巧。", "活动场地二楼有游泳池和球场，三楼是美食广场。", "咲季将佑芽视为需要锻炼的对象，希望其能稳定打出全垒打。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00276", "scene_id": "scene-00276", "source_file": "CSV/event/016/adv_event_016_main-03.csv", "source_kind": "event", "chapter": "event/016", "scene": "adv_event_016_main-03", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "62", "line_count": 62}], "source_refs": ["CSV/event/016/adv_event_016_main-03.csv:1-62"], "line_count": 62, "speakers": ["ことねの妹", "咲季", "手毬", "燐羽", "琴音"], "topics": ["relationships", "team_story", "dialogue_style", "character_arc"], "title": "咲季教导妹妹挥棒", "summary": "手毬教导ことねの妹挥棒技巧，燐羽加入鼓励。琴音与咲季出现，咲季称赞妹妹进步。手毬提及咲季曾严厉教导自己，并转述琴音对咲季的评价，揭示咲季私下温柔的一面。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["琴音", "手毬", "姐姐", "朋友"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["哼", "嘿嘿", "啦"], "key_evidence": [{"source_row": "1", "speaker": "手毬", "text_zh": "球棒要这样握。"}, {"source_row": "17", "speaker": "手毬", "text_zh": "燐羽啊……"}, {"source_row": "28", "speaker": "手毬", "text_zh": "没法像咲季那样教得那么好"}, {"source_row": "55", "speaker": "咲季", "text_zh": "真能干呢！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["手毬教导ことねの妹挥棒技巧，燐羽加入鼓励。", "咲季称赞妹妹进步，琴音表示理解咲季心情。", "手毬提及咲季曾严厉教导自己，并转述琴音对咲季的评价。"], "relationship_facts": ["手毬与ことねの妹是朋友/教导关系。", "手毬与燐羽是朋友/同事关系。", "咲季与琴音是朋友/同事关系。"], "worldbuilding_facts": ["手毬不擅长和小孩子交流。", "手毬很久没挥过球棒了。", "咲季经常向妹妹讲述学校的事。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00277", "scene_id": "scene-00277", "source_file": "CSV/event/016/adv_event_016_main-04.csv", "source_kind": "event", "chapter": "event/016", "scene": "adv_event_016_main-04", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "72", "line_count": 72}], "source_refs": ["CSV/event/016/adv_event_016_main-04.csv:1-72"], "line_count": 72, "speakers": ["ことねの妹", "咲季", "手毬", "琴音"], "topics": ["relationships", "team_story", "dialogue_style", "character_arc"], "title": "咲季与队友的足球对决", "summary": "咲季与手毬、琴音及ことねの妹进行五人制足球赛。咲季虽实力超群但故意放水，享受与妹妹互动的乐趣。最终对手利用战术配合获胜，咲季遵守约定请客，并因回忆起童年时光而感到怀念。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "琴音", "手毬", "妹妹", "姐姐", "对手"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["当然", "呵呵", "嘿嘿", "啦"], "key_evidence": [{"source_row": "66", "speaker": "咲季", "text_zh": "不是放水哦。只是把所有精力都放在进攻上了。"}, {"source_row": "49", "speaker": "咲季", "text_zh": "什、什么——啊，妹妹酱！？"}, {"source_row": "71", "speaker": "咲季", "text_zh": "不知怎么的，就想起小时候和佑芽一起玩耍的事"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季在足球赛中故意放水，专注于进攻体验。", "对手利用手毬的怪叫声和ことねの妹的奇袭战术获胜。", "咲季因与ことねの妹的互动而怀念起与佑芽的童年。"], "relationship_facts": ["咲季是ことねの的姐姐。", "手毬和琴音是咲季的队友或朋友。", "咲季与佑芽是儿时的玩伴。"], "worldbuilding_facts": ["五人制足球场是活动场地。", "食堂提供沙拉乌冬面作为非常规菜单。", "咲季拥有超乎常人的运动神经和体力。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00278", "scene_id": "scene-00278", "source_file": "CSV/event/016/adv_event_016_main-05.csv", "source_kind": "event", "chapter": "event/016", "scene": "adv_event_016_main-05", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "62", "line_count": 62}], "source_refs": ["CSV/event/016/adv_event_016_main-05.csv:1-62"], "line_count": 62, "speakers": ["ことねの妹", "众人", "佑芽", "咲季", "手毬", "琴音"], "topics": ["relationships", "team_story", "dialogue_style", "worldbuilding"], "title": "咲季与妹妹们的舞台时光", "summary": "咲季与琴音、手毬及ことね的妹在初星学园舞台互动，咲季展示偶像风采并提议众人合作演出。事后佑芽来访，咲季对比两人童年经历，引发佑芽醋意，最终约定一同游玩。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "琴音", "手毬", "妹妹", "姐姐", "朋友"], "worldbuilding_signals": ["学园", "偶像", "训练", "演唱会"], "dialogue_style_signals": ["当然", "哼", "呵呵", "啦"], "key_evidence": [{"source_row": "15", "speaker": "咲季", "text_zh": "要不要去跳支舞？"}, {"source_row": "24", "speaker": "琴音", "text_zh": "这可是姐姐们的特别演唱会哦。"}, {"source_row": "58", "speaker": "咲季", "text_zh": "就像以前的佑芽一样，超级可爱的~。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季在初星学园露天舞台与琴音等人进行即兴演出。", "咲季指出琴音的妹妹像以前的佑芽一样黏人。", "佑芽因咲季比较两人而生气，要求用咲季的票去游玩。"], "relationship_facts": ["咲季是琴音的姐姐。", "佑芽是咲季的妹妹。", "ことね的妹是琴音的妹妹。"], "worldbuilding_facts": ["初星学园设有供偶像自由演唱的开放式 Live 舞台。", "咲季拥有能够到达绝对不可能位置的钩爪技巧。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00279", "scene_id": "scene-00279", "source_file": "CSV/event/017/adv_event_017_main-02.csv", "source_kind": "event", "chapter": "event/017", "scene": "adv_event_017_main-02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "67", "line_count": 67}], "source_refs": ["CSV/event/017/adv_event_017_main-02.csv:1-67"], "line_count": 67, "speakers": ["咲季", "後輩", "手毬", "星南", "燕", "莉波", "麻央"], "topics": ["team_story", "worldbuilding", "character_arc", "dialogue_style"], "title": "清晨的初星学园日常", "summary": "清晨的初星学园，麻央进行晨跑与训练，展现其作为宿舍长的责任感。星南会长在学生会室处理公务，享受校园晨景。燕与星南既是竞争对手也是可靠搭档。莉波作为宿舍长记录大家日常，计划周末拍摄休假时的真实一面，展现偶像们的平凡与坚持。", "saki_role": "同学/对手：咲季在群像关系中以好胜、直率和带头推进对话的姿态出现。", "relationship_signals": ["手毬", "麻央", "莉波", "星南", "对手"], "worldbuilding_signals": ["学园", "偶像", "训练", "工作"], "dialogue_style_signals": ["呵呵", "啦"], "key_evidence": [{"source_row": "27", "speaker": "麻央", "text_zh": "遇到困难的孩子时，哪分什么普通科偶像科呀。"}, {"source_row": "46", "speaker": "星南", "text_zh": "因为清晨简单运动后头脑特别清醒，正好适合处理文书工作。"}, {"source_row": "62", "speaker": "燕", "text_zh": "啊不对，不是搭档，是竞争对手！"}, {"source_row": "65", "speaker": "莉波", "text_zh": "这周末我会贴身拍摄大家休假时的样子。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "background", "saki_actions": [], "story_facts": ["有村麻央坚持清晨跑步、自主训练及严格的日程管理。", "十王星南会长清晨在学生会室处理公务，喜欢聆听校园晨间声音。", "雨夜燕是星南的竞争对手，两人关系微妙且互相认可。", "莉波计划周末拍摄偶像们休假时的真实一面。"], "relationship_facts": ["有村麻央是宿舍长，照顾低年级后辈。", "星南是初星学园学生会长，被称为『一等星』。", "雨夜燕是副会长，与星南既是竞争对手又是可靠搭档。"], "worldbuilding_facts": ["初星学园偶像科与普通科界限模糊，麻央不分科别帮助后辈。", "学生会拥有偶像活动相关的特别预算。", "宿舍长莉波负责记录并展示偶像们的日常生活。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00280", "scene_id": "scene-00280", "source_file": "CSV/event/018/adv_event_018_main-02.csv", "source_kind": "event", "chapter": "event/018", "scene": "adv_event_018_main-02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "47", "line_count": 47}], "source_refs": ["CSV/event/018/adv_event_018_main-02.csv:1-47"], "line_count": 47, "speakers": ["广", "清夏", "麻央"], "topics": ["team_story", "worldbuilding", "plot", "character_arc"], "title": "清夏的膝盖与戏剧计划", "summary": "清夏因膝盖旧伤在训练中感到吃力，麻央察觉并建议调整舞步，清夏坦言心理障碍正在克服。广提议在演唱会上让麻央与清夏主演戏剧，以展现二人魅力，并计划由自己撰写剧本，三人决定互相支持。", "saki_role": "被提及对象：咲季未必直接发言，但场景信息与她的关系或评价有关。", "relationship_signals": ["清夏", "麻央", "广", "莉莉娅"], "worldbuilding_signals": ["学园", "训练", "演唱会"], "dialogue_style_signals": ["当然"], "key_evidence": [{"source_row": "16", "speaker": "清夏", "text_zh": "现在正请咲季和莉莉娅帮忙"}, {"source_row": "34", "speaker": "广", "text_zh": "麻央曾是童星，清夏曾是芭蕾舞者"}, {"source_row": "46", "speaker": "广", "text_zh": "想把麻央和清夏的魅力，传达给大家"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["清夏因膝盖旧伤在剧烈舞蹈中感到吃力，但心理障碍正在克服。", "广提议在演唱会上让麻央和清夏主演戏剧，由自己负责旁白和剧本。", "麻央和清夏的演技与表现力在学园中备受认可。", "广计划通过剧本向观众传达麻央和清夏的魅力。"], "relationship_facts": ["麻央是清夏的前辈，关心其身体状况并鼓励她。", "广是清夏和麻央的朋友，负责演唱会创意与剧本构思。", "三人（广、清夏、麻央）决定互相支持，共同面对困难。"], "worldbuilding_facts": ["麻央曾是童星，清夏曾是芭蕾舞者。", "学园中麻央和清夏的演技与表现力数一数二。", "组合活动前需确保成员身体状况良好，避免受伤。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00281", "scene_id": "scene-00281", "source_file": "CSV/event/019/adv_event_019_main-01.csv", "source_kind": "event", "chapter": "event/019", "scene": "adv_event_019_main-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "61", "line_count": 61}], "source_refs": ["CSV/event/019/adv_event_019_main-01.csv:1-61"], "line_count": 61, "speakers": ["众人", "咲季", "手毬", "星南", "燕", "琴音", "莉波"], "topics": ["team_story", "relationships", "dialogue_style", "worldbuilding"], "title": "咲季临危受命名古屋公演", "summary": "面对名古屋公演领队突发缺席的紧急状况，咲季在星南与燕的邀请下临危受命。她果断决定邀请手毬与琴音等朋友共同前往，并立即调整日程于次日出发，展现了非凡的决断力与领导力。", "saki_role": "同学/对手：咲季在群像关系中以好胜、直率和带头推进对话的姿态出现。", "relationship_signals": ["琴音", "手毬", "莉波", "星南", "朋友"], "worldbuilding_signals": ["学园", "演唱会"], "dialogue_style_signals": ["哼", "呵呵", "啦"], "key_evidence": [{"source_row": "14", "speaker": "燕", "text_zh": "原本预定担任领队的学生，突然无法参加了。"}, {"source_row": "26", "speaker": "咲季", "text_zh": "名古屋公演的代理领队，就由我来担任吧！"}, {"source_row": "39", "speaker": "咲季", "text_zh": "我打算带上朋友们！"}, {"source_row": "59", "speaker": "咲季", "text_zh": "——是明天哦。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["名古屋公演原定领队因故无法参加，急需寻找代理。", "咲季主动承担代理领队职责，并邀请手毬和琴音同行。", "团队决定将出发时间提前至次日，进行为期两晚三天的演出。"], "relationship_facts": ["星南、燕、莉波是咲季的前辈或学生会成员，负责邀请她。", "手毬与琴音是咲季认定的“朋友”，愿意接受邀请。", "咲季视手毬和琴音为可靠的伙伴，敢于直接下达指令。"], "worldbuilding_facts": ["演出团队面临人员变动时，需重新设计演出和歌单。", "名古屋公演是重要的地方性活动，粉丝期待度高。", "团队成员有各自的打工安排，需协调日程。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00282", "scene_id": "scene-00282", "source_file": "CSV/event/019/adv_event_019_main-02.csv", "source_kind": "event", "chapter": "event/019", "scene": "adv_event_019_main-02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "60", "line_count": 60}], "source_refs": ["CSV/event/019/adv_event_019_main-02.csv:1-60"], "line_count": 60, "speakers": ["ことねの妹", "佑芽", "咲季", "手毬", "琴音", "美铃"], "topics": ["relationships", "team_story", "dialogue_style", "character_arc"], "title": "咲季赴名古屋活动", "summary": "咲季告知佑芽将参加名古屋活动并交付训练计划，因有手毬和琴音同行而倍感安心。琴音与ことねの妹约定下周再聚，手毬与美铃则互相确认留守事宜，众人对咲季的演出充满期待。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "琴音", "手毬", "莉波", "美铃", "姐姐", "朋友"], "worldbuilding_signals": ["偶像", "训练", "演唱会", "工作"], "dialogue_style_signals": ["哼", "呵呵", "啦"], "key_evidence": [{"source_row": "5", "speaker": "咲季", "text_zh": "趁还没忘记先把这个交给你。"}, {"source_row": "7", "speaker": "咲季", "text_zh": "这是我不在期间的训练计划。"}, {"source_row": "12", "speaker": "咲季", "text_zh": "可能是因为有手毬和琴音在一起吧。"}, {"source_row": "52", "speaker": "手毬", "text_zh": "咲季和琴音的实力是确确实实的。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季将前往名古屋参加活动。", "咲季将手毬和琴音视为重要的朋友。", "手毬和琴音将留守协助美铃。"], "relationship_facts": ["咲季与佑芽是姐妹关系。", "手毬与琴音是咲季信赖的伙伴。", "美铃与手毬是亲密的同伴。"], "worldbuilding_facts": ["角色们有进行偶像训练和演出的设定。", "角色们会进行行李打包和远征旅行。", "角色之间存在互相照顾和留守看家的行为模式。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00283", "scene_id": "scene-00283", "source_file": "CSV/event/019/adv_event_019_main-03.csv", "source_kind": "event", "chapter": "event/019", "scene": "adv_event_019_main-03", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "63", "line_count": 63}], "source_refs": ["CSV/event/019/adv_event_019_main-03.csv:1-63"], "line_count": 63, "speakers": ["众人", "咲季", "手毬", "琴音"], "topics": ["relationships", "team_story", "dialogue_style", "character_arc"], "title": "咲季协调三人同住", "summary": "咲季在列车上为佑芽制定特训菜单，展现对妹妹的关爱。面对琴音对手毬、咲季同住的惊讶，咲季自然协调大家意见，安排演出分工。手毬虽对狭小空间担忧，但在咲季安抚下接受安排，众人顺利决定休息事宜。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "琴音", "手毬", "姐姐"], "worldbuilding_signals": ["训练"], "dialogue_style_signals": ["真是的", "呵呵", "嘿嘿", "啦"], "key_evidence": [{"source_row": "4", "speaker": "咲季", "text_zh": "是在给佑芽的训练做后续辅导哦。"}, {"source_row": "25", "speaker": "琴音", "text_zh": "三个人同住一间房这事我可没听说啊！"}, {"source_row": "43", "speaker": "咲季", "text_zh": "只是把大家的意见整合成能发挥各自优势的形式而已。"}, {"source_row": "61", "speaker": "手毬", "text_zh": "这房间，仔细一看……床不是只有两张吗？"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季为佑芽制定包含卡路里计算的特别训练菜单。", "咲季将手毬、琴音安排与自己同住一间房。", "咲季协调大家意见，决定将动作检查留到明天彩排。", "咲季为琴音争取了独唱前奏的互动时间。"], "relationship_facts": ["咲季是佑芽的姐姐，负责照顾其训练。", "咲季是琴音的姐姐，被琴音视为可靠的人。", "手毬与咲季、琴音同住，对狭小空间感到不安。"], "worldbuilding_facts": ["咲季擅长整合意见并发挥成员优势。", "手毬体力有所提升但已接近极限。", "琴音的特色是舞蹈和互动，能炒热气氛。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00284", "scene_id": "scene-00284", "source_file": "CSV/event/019/adv_event_019_main-04.csv", "source_kind": "event", "chapter": "event/019", "scene": "adv_event_019_main-04", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "61", "line_count": 61}], "source_refs": ["CSV/event/019/adv_event_019_main-04.csv:1-61"], "line_count": 61, "speakers": ["众人", "咲季", "手毬", "琴音"], "topics": ["relationships", "team_story", "dialogue_style"], "title": "三人同宿的尴尬青春", "summary": "咲季因单人间满员被迫与手毬、琴音同宿。咲季秒睡且睡相极差，被手毬踢醒。琴音爆料与手毬同床时手毬撒娇且脚凉，咲季则称手毬是寒性体质。手毬提及琴音曾梦话喊姐姐并摸头。众人感叹此乃满溢的青春，决定分享这份热闹回忆。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["琴音", "手毬", "美铃", "妹妹", "姐姐"], "worldbuilding_signals": [], "dialogue_style_signals": ["当然", "呵呵", "啦"], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "单人间也全满了。"}, {"source_row": "19", "speaker": "手毬", "text_zh": "把被子踢飞，睡成了安全出口标志的样子。"}, {"source_row": "28", "speaker": "琴音", "text_zh": "而且手毬的脚冰凉冰凉的。"}, {"source_row": "34", "speaker": "手毬", "text_zh": "姐姐会加油的哦。要当个好孩子呀～……这样。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季因单人间满员被迫与手毬、琴音同宿。", "咲季秒睡且睡相极差，被子踢飞像安全出口标志。", "琴音与手毬同床时，手毬撒娇且脚冰凉。", "手毬半夜梦话喊琴音姐姐并摸头。"], "relationship_facts": ["咲季、手毬、琴音为同班同学。", "琴音是咲季的妹妹（咲季误认或调侃）。", "手毬是寒性体质，琴音习惯与人并排睡。"], "worldbuilding_facts": ["单人间全部已满，需三人挤一间。", "咲季习惯晚上8点睡觉。", "手毬是寒性体质，脚冰凉。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00285", "scene_id": "scene-00285", "source_file": "CSV/event/019/adv_event_019_main-05.csv", "source_kind": "event", "chapter": "event/019", "scene": "adv_event_019_main-05", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "60", "line_count": 60}], "source_refs": ["CSV/event/019/adv_event_019_main-05.csv:1-60"], "line_count": 60, "speakers": ["ウェイトレス", "众人", "咲季", "手毬", "琴音"], "topics": ["relationships", "team_story", "dialogue_style", "worldbuilding"], "title": "咲季与父亲的特制早餐", "summary": "演出成功后，咲季、琴音与手毬在名古屋享用丰盛早餐。咲季透露特制菜单由其父亲设计，并提议将获胜方菜单作为学园提案。众人对咲季父亲的创意及手毬的半份吐司表示惊讶，气氛轻松愉快。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["琴音", "手毬", "美铃", "妹妹"], "worldbuilding_signals": ["学园", "演唱会"], "dialogue_style_signals": ["真是的", "呵呵", "啦"], "key_evidence": [{"source_row": "52", "speaker": "咲季", "text_zh": "合作方是我爸爸哦。"}, {"source_row": "53", "speaker": "咲季", "text_zh": "听说是他亲自设计的特制菜单呢。"}, {"source_row": "54", "speaker": "咲季", "text_zh": "自从听说名古屋公演后我就一直期待来吃这个呢。"}, {"source_row": "59", "speaker": "咲季", "text_zh": "把获胜方的菜单作为初星早餐向学园提案"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["演出成功结束后，咲季、琴音和手毬在名古屋咖啡店享用早餐。", "咲季的父亲设计了本店限定的特制合作早餐套餐。", "手毬为了控制热量只点了半份吐司，而咲季点了特制套餐。", "咲季提议将获胜方的早餐菜单作为初星早餐向学园提案。"], "relationship_facts": ["咲季与琴音是关系亲密的同伴，互相道歉并感谢对方。", "咲季与手毬是同学，咲季会调侃手毬的行李整理习惯。", "咲季的父亲是咖啡店的合作方，亲自设计了特制菜单。"], "worldbuilding_facts": ["名古屋的早餐以分量超多而闻名。", "咲季的父亲是咖啡店的合作方，设计了特制菜单。", "手毬在演出后仍保持对热量的注意，只点了半份吐司。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00286", "scene_id": "scene-00286", "source_file": "CSV/event/020/adv_event_020_main-05.csv", "source_kind": "event", "chapter": "event/020", "scene": "adv_event_020_main-05", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "76", "line_count": 76}], "source_refs": ["CSV/event/020/adv_event_020_main-05.csv:1-76"], "line_count": 76, "speakers": ["清夏", "莉莉娅"], "topics": ["team_story", "worldbuilding", "dialogue_style", "relationships"], "title": "咲季缺席的问卷对话", "summary": "清夏与莉莉娅填写问卷时互诉优点，随后讨论若未成为偶像的未来。清夏透露自己曾放弃偶像梦想成为化妆师，而莉莉娅虽未成偶像却仍坚持。两人确认此刻选择共同成为偶像，拒绝平行世界的遗憾未来。", "saki_role": "同学/对手：咲季在群像关系中以好胜、直率和带头推进对话的姿态出现。", "relationship_signals": ["琴音", "手毬", "清夏", "广", "莉莉娅", "朋友"], "worldbuilding_signals": ["学园", "偶像", "工作"], "dialogue_style_signals": ["当然", "真是的", "呵呵", "嘿嘿", "啦"], "key_evidence": [{"source_row": "67", "speaker": "清夏", "text_zh": "放弃当偶像，转做幕后工作。成为化妆师。"}, {"source_row": "58", "speaker": "莉莉娅", "text_zh": "和咲季、手毬、琴音一起进行谈话节目……"}, {"source_row": "75", "speaker": "莉莉娅", "text_zh": "一定要成为偶像。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["清夏曾放弃偶像梦想，毕业后成为化妆师。", "莉莉娅梦想成为翻译，但清夏指出她此刻选择成为偶像。", "清夏与莉莉娅在化妆工作中重逢并建立深厚羁绊。"], "relationship_facts": ["清夏与莉莉娅是关系亲密的挚友。", "清夏是莉莉娅的化妆师兼支持者。", "两人共同决定坚持成为偶像的约定。"], "worldbuilding_facts": ["清夏曾是初星学园同班同学，后转做幕后。", "清夏与咲季、手毬、琴音曾共同主持谈话节目。", "莉莉娅梦想从事动漫漫画的翻译推广工作。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00287", "scene_id": "scene-00287", "source_file": "CSV/event/022/adv_event_022_main-01.csv", "source_kind": "event", "chapter": "event/022", "scene": "adv_event_022_main-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "55", "line_count": 55}], "source_refs": ["CSV/event/022/adv_event_022_main-01.csv:1-55"], "line_count": 55, "speakers": ["琴音", "舞蹈训练师", "麻央"], "topics": ["team_story", "relationships", "worldbuilding", "character_arc"], "title": "咲季缺席的麻央感冒", "summary": "麻央在选拔考试前过度训练导致感冒发烧，舞蹈训练师劝其休息。琴音发现后将其带回宿舍照料。麻央感叹羡慕有姐妹的咲季等人，琴音则回忆起莉波前辈也未回老家，并注意到麻央房间里的奇怪道具。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["琴音", "麻央", "莉波", "姐姐"], "worldbuilding_signals": ["偶像", "训练"], "dialogue_style_signals": ["呵呵", "啦"], "key_evidence": [{"source_row": "44", "speaker": "麻央", "text_zh": "像咲季她们、琴音她们那样有姐妹"}, {"source_row": "34", "speaker": "琴音", "text_zh": "莉波前辈，也没有回老家"}, {"source_row": "36", "speaker": "琴音", "text_zh": "这根棒子……是什么？"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["麻央因过度训练在选拔考试前感冒发烧。", "琴音将病倒的麻央带回宿舍并为其换毛巾。", "麻央羡慕像咲季那样有姐妹的家庭。", "琴音注意到麻央房间里有名为『蹭蹭长高机』的道具。"], "relationship_facts": ["麻央是琴音的前辈。", "麻央是宿舍长。", "琴音是麻央的后辈。"], "worldbuilding_facts": ["选拔考试前是偶像训练的重要时期。", "宿舍长负责管理宿舍环境。", "宿舍内存在名为『蹭蹭长高机』的道具。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00288", "scene_id": "scene-00288", "source_file": "CSV/event/022/adv_event_022_main-03.csv", "source_kind": "event", "chapter": "event/022", "scene": "adv_event_022_main-03", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "71", "line_count": 71}], "source_refs": ["CSV/event/022/adv_event_022_main-03.csv:1-71"], "line_count": 71, "speakers": ["佑芽", "咲季", "广", "手毬", "星南", "清夏", "琴音", "美铃", "莉波", "莉莉娅", "麻央"], "topics": ["team_story", "relationships", "worldbuilding", "dialogue_style"], "title": "麻央感冒与演唱会邀约", "summary": "麻央因感冒发烧，在琴音照顾下逐渐康复。众人纷纷表达关心并分担工作。麻央提及母亲做的明石烧，并邀请琴音下周日去演唱会，作为谢礼亲自护送，展现两人间的深厚羁绊。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["佑芽", "琴音", "手毬", "清夏", "麻央", "广", "莉波", "星南", "美铃", "莉莉娅"], "worldbuilding_signals": ["课程", "训练", "演唱会", "工作"], "dialogue_style_signals": ["啦"], "key_evidence": [{"source_row": "54", "speaker": "咲季", "text_zh": "听说有村学姐感冒了呢，我待会儿把特制SSD送过去！"}, {"source_row": "28", "speaker": "麻央", "text_zh": "嗯……感冒的时候，妈妈会给我做……"}, {"source_row": "64", "speaker": "麻央", "text_zh": "（好像是……演唱会的门票？）"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["麻央因无视训练员忠告而感冒发烧，在琴音照顾下康复。", "宿舍成员（包括咲季）主动分担工作并准备特制 SSD 慰问麻央。", "星南会长将演唱会门票夹在笔记中交给麻央，麻央邀请琴音下周日一同前往。"], "relationship_facts": ["琴音与麻央：前辈与后辈，琴音照顾生病的麻央，麻央视琴音为重要伙伴。", "咲季与麻央：同宿舍成员，咲季主动提出送特制 SSD 慰问。", "星南与麻央：星南是麻央的竞争对手（一等星），但同样关心麻央并赠送门票。"], "worldbuilding_facts": ["宿舍成员之间关系紧密，生病时大家会共同分担工作和照顾病人。", "明石烧是麻央母亲在感冒时为她做的食物，麻央对此有特别记忆。", "星南被称为『一等星』，是麻央必须打倒的对手。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00289", "scene_id": "scene-00289", "source_file": "CSV/event/024/adv_event_024_main-03.csv", "source_kind": "event", "chapter": "event/024", "scene": "adv_event_024_main-03", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "54", "line_count": 54}], "source_refs": ["CSV/event/024/adv_event_024_main-03.csv:1-54"], "line_count": 54, "speakers": ["众人", "佑芽", "千奈", "旁白", "星南", "燕", "美铃"], "topics": ["relationships", "dialogue_style", "team_story", "character_arc"], "title": "学生会采访稿风波", "summary": "11月，佑芽、美铃、千奈展示完成的学生会采访稿。千奈稿中提及咲季，引发众人对美铃稿的担忧。燕严厉训斥美铃，星南随后安抚众人，肯定三人的成长，并因燕提及“安心毕业”而急忙赶去处理。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "莉波", "星南", "美铃", "姐姐"], "worldbuilding_signals": ["学园"], "dialogue_style_signals": ["当然", "真是的", "呵呵", "嘿嘿", "啦"], "key_evidence": [{"source_row": "10", "speaker": "千奈", "text_zh": "花海同学对咲季姐姐的深厚感情……"}, {"source_row": "23", "speaker": "千奈", "text_zh": "不行啊……！啊啊，不行啊秦谷同学……！"}, {"source_row": "49", "speaker": "星南", "text_zh": "那些孩子是初星学园的希望啊。"}, {"source_row": "53", "speaker": "燕", "text_zh": "……安心毕业，是什么意思？"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["11月，众人讨论星南布置的学生会采访作业完成情况。", "千奈的采访稿中包含了关于咲季的内容，令美铃感到不好意思。", "燕因美铃试图分享挨训而严厉斥责她，随后星南介入调解。", "星南称赞三人展现了成长，并因燕提到“安心毕业”而匆忙离开。"], "relationship_facts": ["星南是学生会会长，负责指导后辈。", "燕是星南的得力助手，负责严厉训斥犯错的后辈。", "佑芽、美铃、千奈是星南的后辈，正在接受采访训练。"], "worldbuilding_facts": ["当前时间为11月。", "星南即将毕业，因此希望后辈们能独立成长。", "采访对象包括初星学园的粉丝和编辑部。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00290", "scene_id": "scene-00290", "source_file": "CSV/event/029/adv_event_029_main-02.csv", "source_kind": "event", "chapter": "event/029", "scene": "adv_event_029_main-02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "33", "line_count": 33}], "source_refs": ["CSV/event/029/adv_event_029_main-02.csv:1-33"], "line_count": 33, "speakers": ["制作人", "咲季", "手毬", "浅梨老师", "琴音"], "topics": ["relationships", "dialogue_style", "team_story", "worldbuilding"], "title": "偶像选拔赛宣战", "summary": "浅梨老师通过选拔后，咲季与手毬等学生介入，以偶像身份向老师宣战，誓言下次选拔胜出。琴音斥责后离开。浅梨老师被激励，决心作为制作人引导学生们在选拔中胜出，面对即将到来的战斗感到震惊。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人", "琴音", "手毬"], "worldbuilding_signals": ["偶像", "工作"], "dialogue_style_signals": ["当然", "真是的", "制作人", "啦"], "key_evidence": [{"source_row": "11", "speaker": "咲季", "text_zh": "真是的……没想到出现了这么不得了的强敌呢。"}, {"source_row": "14", "speaker": "咲季", "text_zh": "我们，是来宣战的。"}, {"source_row": "17", "speaker": "咲季", "text_zh": "在下次选拔中胜出的，会是我！"}, {"source_row": "33", "speaker": "浅梨老师", "text_zh": "为什么……为什么会变成这样啊～～～！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["浅梨老师首次选拔合格。", "咲季与手毬代表学生向浅梨老师宣战。", "浅梨老师决定以制作人身份参与选拔。"], "relationship_facts": ["咲季与浅梨老师是师生。", "咲季与手毬是同学兼竞争对手。", "琴音是咲季等人的前辈或朋友。"], "worldbuilding_facts": ["存在偶像选拔赛。", "学生与老师可成为偶像竞争对手。", "制作人负责引导偶像科学生。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00291", "scene_id": "scene-00291", "source_file": "CSV/event/029/adv_event_029_main-04.csv", "source_kind": "event", "chapter": "event/029", "scene": "adv_event_029_main-04", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "36", "line_count": 36}], "source_refs": ["CSV/event/029/adv_event_029_main-04.csv:1-36"], "line_count": 36, "speakers": ["初星学園教師", "制作人", "咲季", "手毬", "浅梨老师", "琴音"], "topics": ["dialogue_style", "relationships", "worldbuilding", "plot"], "title": "亚纱里舞台后的感言", "summary": "演唱会结束后，咲季与手毬虽对选拔结果不甘心，但肯定演出精彩并立誓下次获胜。制作人盛赞演出超越梦想，浅梨老师对此感到害羞却十分开心，并承诺今后会继续努力，让偶像更加闪耀。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人", "琴音", "手毬"], "worldbuilding_signals": ["偶像", "演唱会"], "dialogue_style_signals": ["当然", "真是的", "呵呵", "制作人", "啦"], "key_evidence": [{"source_row": "2", "speaker": "咲季", "text_zh": "虽然很不甘心……但下次我会赢的！"}, {"source_row": "18", "speaker": "制作人", "text_zh": "如同梦想中的——不，是比梦想中还要精彩的演唱会。"}, {"source_row": "25", "speaker": "浅梨老师", "text_zh": "但这是一次很棒的培育哦。"}, {"source_row": "31", "speaker": "制作人", "text_zh": "作为偶像一定能更加闪耀的！绝对！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季和手毬对选拔结果不甘心，但认可了演出的精彩程度。", "制作人认为亚纱里的演唱会如同梦想中甚至更出色。", "浅梨老师表示虽然过程混乱，但培育偶像是一次很棒的成功。", "浅梨老师承诺今后会继续努力，让偶像更加闪耀。"], "relationship_facts": ["咲季与手毬是竞争对手关系。", "制作人是浅梨老师的负责制作人。", "初星学园教师是浅梨老师的同事兼粉丝。"], "worldbuilding_facts": ["初星学园教师既是同事也是粉丝。", "制作人的职责是培育偶像。", "选拔结果对咲季和手毬来说很重要。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00292", "scene_id": "scene-00292", "source_file": "CSV/live/hski/adv_live_hski_001_end-01-01.csv", "source_kind": "live", "chapter": "live/hski", "scene": "adv_live_hski_001_end-01-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "1", "line_count": 1}], "source_refs": ["CSV/live/hski/adv_live_hski_001_end-01-01.csv:1-1"], "line_count": 1, "speakers": ["咲季"], "topics": ["plot"], "title": "咲季登场发出笑声", "summary": "场景聚焦于角色咲季，她直接出现在对话中，仅发出一声轻快的笑声。目前剧情仅展示其出场瞬间，未涉及具体事件、人物关系或世界观设定，属于角色初次亮相的简短互动片段。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": [], "worldbuilding_signals": [], "dialogue_style_signals": [], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "嘻嘻"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季在场景中直接出现。", "咲季发出了笑声。"], "relationship_facts": [], "worldbuilding_facts": [], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00293", "scene_id": "scene-00293", "source_file": "CSV/live/hski/adv_live_hski_001_end-02-01.csv", "source_kind": "live", "chapter": "live/hski", "scene": "adv_live_hski_001_end-02-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "2", "line_count": 2}], "source_refs": ["CSV/live/hski/adv_live_hski_001_end-02-01.csv:1-2"], "line_count": 2, "speakers": ["咲季"], "topics": ["plot"], "title": "咲季感谢并评价手感", "summary": "咲季对当前情境表达感谢，并称赞手感良好。她直接参与对话，展现出积极互动的状态。场景聚焦于咲季的个人反馈，未涉及其他角色或复杂背景设定，整体氛围轻松愉快。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": [], "worldbuilding_signals": [], "dialogue_style_signals": [], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "非常感谢！"}, {"source_row": "2", "speaker": "咲季", "text_zh": "手感不错呢！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季表达了感谢之情。", "咲季评价手感不错。"], "relationship_facts": [], "worldbuilding_facts": [], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00294", "scene_id": "scene-00294", "source_file": "CSV/live/hski/adv_live_hski_001_end-03-01.csv", "source_kind": "live", "chapter": "live/hski", "scene": "adv_live_hski_001_end-03-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "1", "line_count": 1}], "source_refs": ["CSV/live/hski/adv_live_hski_001_end-03-01.csv:1-1"], "line_count": 1, "speakers": ["咲季"], "topics": ["plot"], "title": "咲季对局势的悲观判断", "summary": "咲季在对话中直接发言，表达了对当前局势无法取胜的悲观看法。她认为现有的策略或条件不足以达成胜利目标，暗示了角色面临的困境或挑战。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": [], "worldbuilding_signals": [], "dialogue_style_signals": [], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "这样可赢不了呢"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季认为当前情况无法获胜。"], "relationship_facts": [], "worldbuilding_facts": [], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00295", "scene_id": "scene-00295", "source_file": "CSV/live/hski/adv_live_hski_001_end-04-01.csv", "source_kind": "live", "chapter": "live/hski", "scene": "adv_live_hski_001_end-04-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "3", "line_count": 3}], "source_refs": ["CSV/live/hski/adv_live_hski_001_end-04-01.csv:1-3"], "line_count": 3, "speakers": ["咲季"], "topics": ["relationships"], "title": "咲季誓死守护小佑芽", "summary": "咲季在对话中表现出强烈的决心，她坚决否认自己不行，并流露出对输给小佑芽的极度恐惧。她认为若自己失败，小佑芽便会获胜，因此必须全力以赴。这段简短的独白展现了咲季为了守护同伴而爆发出的惊人意志与紧迫感，体现了她重视友情胜过胜负的性格特质。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽"], "worldbuilding_signals": [], "dialogue_style_signals": [], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "完全不是不行……！"}, {"source_row": "3", "speaker": "咲季", "text_zh": "会输给小佑芽的……！！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季坚决表示自己并非不行。", "咲季担心自己会输给小佑芽。", "咲季认为输给小佑芽是不可接受的结果。"], "relationship_facts": ["咲季与小佑芽存在竞争或比较关系。", "咲季非常在意小佑芽的胜负。", "咲季将守护小佑芽视为重要目标。"], "worldbuilding_facts": [], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00296", "scene_id": "scene-00296", "source_file": "CSV/live/hski/adv_live_hski_001_start-01-01.csv", "source_kind": "live", "chapter": "live/hski", "scene": "adv_live_hski_001_start-01-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "2", "line_count": 2}], "source_refs": ["CSV/live/hski/adv_live_hski_001_start-01-01.csv:1-2"], "line_count": 2, "speakers": ["咲季"], "topics": ["plot"], "title": "咲季宣告舞台时刻", "summary": "咲季在场景中直接登场，充满自信地宣告这是属于她的舞台。她鼓励他人尽情享受当下的氛围，展现出作为主角的活力与掌控力。整个场景聚焦于咲季个人的表现与宣言，确立了其核心地位。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": [], "worldbuilding_signals": [], "dialogue_style_signals": [], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "我的舞台"}, {"source_row": "2", "speaker": "咲季", "text_zh": "尽情享受吧！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季明确宣称当前场景是她的舞台。", "咲季邀请或鼓励他人尽情享受。"], "relationship_facts": [], "worldbuilding_facts": [], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00297", "scene_id": "scene-00297", "source_file": "CSV/live/hski/adv_live_hski_001_start-02-01.csv", "source_kind": "live", "chapter": "live/hski", "scene": "adv_live_hski_001_start-02-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "1", "line_count": 1}], "source_refs": ["CSV/live/hski/adv_live_hski_001_start-02-01.csv:1-1"], "line_count": 1, "speakers": ["咲季"], "topics": ["dialogue_style"], "title": "咲季准备出发", "summary": "咲季在场景开始时宣布自己即将出发。她以直接对话者的身份出现，表达了行动前的确认。目前场景仅包含她单方面的宣告，未涉及其他人物互动或背景设定，仅呈现了角色出发的初始状态。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": [], "worldbuilding_signals": [], "dialogue_style_signals": ["啦"], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "好，我出发啦！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季决定离开当前位置。", "咲季已做好出发准备。"], "relationship_facts": [], "worldbuilding_facts": [], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00298", "scene_id": "scene-00298", "source_file": "CSV/live/hski/adv_live_hski_001_start-03-01.csv", "source_kind": "live", "chapter": "live/hski", "scene": "adv_live_hski_001_start-03-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "2", "line_count": 2}], "source_refs": ["CSV/live/hski/adv_live_hski_001_start-03-01.csv:1-2"], "line_count": 2, "speakers": ["咲季"], "topics": ["plot"], "title": "咲季数数确认安全", "summary": "咲季在场景中独自出现，通过数数确认自身状态。她认为尚未被目标追上，表现出一种自我安慰或确认安全的心态。场景主要聚焦于咲季个人的心理活动与对当前处境的判断，未涉及其他人物互动或复杂世界观设定。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": [], "worldbuilding_signals": [], "dialogue_style_signals": [], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "1,2,3,4…1,2,3,4"}, {"source_row": "2", "speaker": "咲季", "text_zh": "应该还没被追上才对哦"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季正在数数。", "咲季认为自己尚未被追上。"], "relationship_facts": [], "worldbuilding_facts": [], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00299", "scene_id": "scene-00299", "source_file": "CSV/live/hski/adv_live_hski_001_start-04-01.csv", "source_kind": "live", "chapter": "live/hski", "scene": "adv_live_hski_001_start-04-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "2", "line_count": 2}], "source_refs": ["CSV/live/hski/adv_live_hski_001_start-04-01.csv:1-2"], "line_count": 2, "speakers": ["咲季"], "topics": ["dialogue_style", "relationships"], "title": "咲季确认姐姐身份", "summary": "咲季在对话中直接回应，强调自己作为姐姐的身份是理所当然的。她通过反问和感叹句，坚定地表达了自己作为姐姐的责任感与存在感，展现了角色对家庭角色的清晰认知与情感投入。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["姐姐"], "worldbuilding_signals": [], "dialogue_style_signals": ["当然"], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "这不是理所当然的吗…"}, {"source_row": "2", "speaker": "咲季", "text_zh": "因为我是姐姐啊…！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季认为身为姐姐是理所当然的事情。", "咲季通过言语直接确认了自己的姐姐身份。"], "relationship_facts": ["咲季是某人的姐姐。"], "worldbuilding_facts": [], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00300", "scene_id": "scene-00300", "source_file": "CSV/other/adv_startup_2024_user-bd-01_hski-01.csv", "source_kind": "other", "chapter": "other", "scene": "adv_startup_2024_user-bd-01_hski-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "6", "line_count": 6}], "source_refs": ["CSV/other/adv_startup_2024_user-bd-01_hski-01.csv:1-6"], "line_count": 6, "speakers": ["咲季"], "topics": ["dialogue_style", "relationships", "character_arc", "team_story"], "title": "花海咲季的生日庆典", "summary": "花海咲季邀请制作人在训练后单独庆祝生日，准备了手工蛋糕并唱生日歌。她希望每年都能让制作人感到幸福，证明选择她是正确的决定，展现了两人之间亲密且充满期待的羁绊。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人"], "worldbuilding_signals": ["训练"], "dialogue_style_signals": ["呵呵", "制作人"], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "制作人！生日快乐！"}, {"source_row": "2", "speaker": "咲季", "text_zh": "今天的训练结束后，就我们两个人一起庆祝吧。"}, {"source_row": "3", "speaker": "咲季", "text_zh": "花海咲季的生日歌，手工蛋糕……呵呵。"}, {"source_row": "6", "speaker": "咲季", "text_zh": "我都会让你觉得选择我真是太好了！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["花海咲季邀请制作人在训练结束后单独庆祝生日。", "咲季准备了手工蛋糕并演唱生日歌。", "咲季希望每年都能让制作人感到幸福。"], "relationship_facts": ["咲季与制作人关系亲密，视对方为特别的存在。", "咲季对制作人抱有强烈的依赖与喜爱。", "两人约定每年这一天共同庆祝。"], "worldbuilding_facts": ["咲季擅长制作手工蛋糕。", "咲季会主动为制作人准备生日惊喜。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00301", "scene_id": "scene-00301", "source_file": "CSV/other/adv_startup_2025_bd-01_hski-01.csv", "source_kind": "other", "chapter": "other", "scene": "adv_startup_2025_bd-01_hski-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "6", "line_count": 6}], "source_refs": ["CSV/other/adv_startup_2025_bd-01_hski-01.csv:1-6"], "line_count": 6, "speakers": ["制作人", "咲季"], "topics": ["dialogue_style", "relationships"], "title": "咲季的特别生日", "summary": "咲季在生日当天照常完成日程，拒绝打乱日常。制作人送上特制蛋糕并提及她生日与平日无异。咲季感谢制作人，度过特别的一天。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人"], "worldbuilding_signals": [], "dialogue_style_signals": ["嘿嘿", "制作人"], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "今天的日程表也顺利完成了呢。"}, {"source_row": "2", "speaker": "制作人", "text_zh": "就连生日也和平常一样呢。"}, {"source_row": "3", "speaker": "咲季", "text_zh": "因为不想打乱日常安排嘛。"}, {"source_row": "4", "speaker": "制作人", "text_zh": "请用制作人特制蛋糕。"}, {"source_row": "6", "speaker": "咲季", "text_zh": "今天度过了一个特别的生日。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季生日当天日程照常完成", "咲季不想打乱日常安排", "制作人准备了特制蛋糕"], "relationship_facts": ["咲季与制作人关系亲密", "制作人是咲季的生日礼物提供者"], "worldbuilding_facts": ["咲季习惯保持日常规律", "咲季生日日期与平日无异"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00302", "scene_id": "scene-00302", "source_file": "CSV/other/adv_startup_2025_bd-01_hume-01.csv", "source_kind": "other", "chapter": "other", "scene": "adv_startup_2025_bd-01_hume-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "6", "line_count": 6}], "source_refs": ["CSV/other/adv_startup_2025_bd-01_hume-01.csv:1-6"], "line_count": 6, "speakers": ["佑芽", "制作人"], "topics": ["relationships", "dialogue_style"], "title": "制作人庆贺咲季生日", "summary": "佑芽为制作人准备了姐姐特制的生日便当。制作人随后送上与咲季同学共同商制的蛋糕作为餐后甜点，并祝其生日快乐。佑芽对此感到超级开心并致谢，展现了制作人与咲季之间良好的互动关系。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "姐姐"], "worldbuilding_signals": [], "dialogue_style_signals": ["制作人"], "key_evidence": [{"source_row": "1", "speaker": "佑芽", "text_zh": "今天的午餐是～姐姐特制！"}, {"source_row": "4", "speaker": "制作人", "text_zh": "是和咲季同学一起商量着做的。"}, {"source_row": "4", "speaker": "制作人", "text_zh": "生日快乐。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["佑芽准备了姐姐特制的午餐便当。", "制作人为佑芽准备了蛋糕作为餐后甜点。", "蛋糕是制作人与咲季同学共同商制的。", "今天是咲季的生日。"], "relationship_facts": ["佑芽与制作人是同学关系。", "制作人与咲季是同学关系。", "佑芽称呼制作人为制作人同学。"], "worldbuilding_facts": ["佑芽的姐姐会制作特制便当。", "制作人与咲季有共同制作甜点的经历。", "场景发生在午餐时间。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00303", "scene_id": "scene-00303", "source_file": "CSV/other/adv_tutorial_first_hski-01.csv", "source_kind": "other", "chapter": "other", "scene": "adv_tutorial_first_hski-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "2", "line_count": 2}], "source_refs": ["CSV/other/adv_tutorial_first_hski-01.csv:1-2"], "line_count": 2, "speakers": ["咲季"], "topics": ["dialogue_style", "relationships"], "title": "咲季誓夺第一", "summary": "咲季向制作人发出挑战宣言，誓言要拿下第一。她展现出强烈的竞争意识和必胜决心，要求制作人全程见证她的表现。这段对话确立了咲季作为主角的自信形象，并暗示了即将展开的竞技或表演场景，充满了青春热血的氛围。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人"], "worldbuilding_signals": [], "dialogue_style_signals": ["制作人"], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "制作人，给我好好看着！"}, {"source_row": "2", "speaker": "咲季", "text_zh": "拿下第一的，会是我哦！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季向制作人发出挑战宣言", "咲季誓言要拿下第一", "咲季要求制作人全程见证", "咲季展现出强烈的竞争意识"], "relationship_facts": ["咲季与制作人存在互动关系", "咲季视制作人为见证者", "咲季对制作人态度自信直接"], "worldbuilding_facts": ["存在名为制作人的角色", "场景涉及竞技或表演活动", "咲季是主要参与者"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00304", "scene_id": "scene-00304", "source_file": "CSV/other/adv_tutorial_first_hski-02.csv", "source_kind": "other", "chapter": "other", "scene": "adv_tutorial_first_hski-02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "2", "line_count": 2}], "source_refs": ["CSV/other/adv_tutorial_first_hski-02.csv:1-2"], "line_count": 2, "speakers": ["咲季"], "topics": ["dialogue_style", "relationships"], "title": "咲季拒绝满足并提议反省", "summary": "咲季对当前状况表示不满，拒绝轻易满足。她随即向制作人发出指令，要求立即召开反省会。咲季展现出强烈的进取心和对现状的批判态度，直接推动剧情进入反思阶段，体现了其作为关键角色的主动性与责任感。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人"], "worldbuilding_signals": [], "dialogue_style_signals": ["制作人"], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "这种程度，我才不会满足呢！"}, {"source_row": "2", "speaker": "咲季", "text_zh": "制作人，马上开反省会！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季对当前程度表示不满足。", "咲季要求立即召开反省会。", "咲季直接向制作人下达指令。"], "relationship_facts": ["咲季与制作人存在上下级或工作关系。", "咲季对制作人拥有直接指挥权。"], "worldbuilding_facts": ["当前场景涉及需要召开反省会的事件。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00305", "scene_id": "scene-00305", "source_file": "CSV/other/adv_tutorial_first_hski-03.csv", "source_kind": "other", "chapter": "other", "scene": "adv_tutorial_first_hski-03", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "12", "line_count": 12}], "source_refs": ["CSV/other/adv_tutorial_first_hski-03.csv:1-12"], "line_count": 12, "speakers": ["浅梨老师"], "topics": ["worldbuilding", "character_arc", "plot", "team_story"], "title": "初星学园定期公演", "summary": "浅梨老师向咲季说明初星学园定期公演『初』的选拔机制。需通过中期与终期考核方可获得出演资格，而终期结果尤为关键，决定能否赢得主场演唱会举办权。老师描绘了偶像在万众欢呼中绽放光芒的愿景，鼓励咲季共同为实现这一光景而努力。", "saki_role": "被提及对象：咲季未必直接发言，但场景信息与她的关系或评价有关。", "relationship_signals": [], "worldbuilding_signals": ["学园", "偶像", "演唱会"], "dialogue_style_signals": [], "key_evidence": [{"source_row": "2", "speaker": "浅梨老师", "text_zh": "初星学园定期举办的公演名为『初』。"}, {"source_row": "3", "speaker": "浅梨老师", "text_zh": "只要通过中期和终期两次考核，"}, {"source_row": "5", "speaker": "浅梨老师", "text_zh": "想要赢得在主场舞台举办演唱会的权利，"}, {"source_row": "10", "speaker": "浅梨老师", "text_zh": "你负责的偶像在万众欢呼中绽放光芒的身姿。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["初星学园定期公演名为『初』。", "通过中期和终期两次考核可获得出演资格。", "终期考核结果决定能否赢得主场演唱会举办权。", "浅梨老师鼓励咲季为实现舞台光景共同努力。"], "relationship_facts": ["浅梨老师是咲季的指导者。", "浅梨老师负责向咲季说明公演事宜。", "咲季是浅梨老师负责指导的偶像。"], "worldbuilding_facts": ["初星学园定期举办名为『初』的公演。", "获得出演资格需通过两次考核。", "在主场舞台举办演唱会需满足严苛条件。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00306", "scene_id": "scene-00306", "source_file": "CSV/pevent/fktn/adv_pevent_001_fktn_activity_012.csv", "source_kind": "pevent", "chapter": "pevent/fktn", "scene": "adv_pevent_001_fktn_activity_012", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/pevent/fktn/adv_pevent_001_fktn_activity_012.csv:1-20"], "line_count": 20, "speakers": ["制作人", "琴音", "选项"], "topics": ["relationships", "dialogue_style", "team_story"], "title": "诡异的饮品与藤田", "summary": "琴音向制作人赠送花海咲季特制的诡异饮品，声称是为疲惫的制作人准备。制作人误以为这是给藤田同学的，拒绝饮用。琴音随即撒娇表示只愿制作人独享，并抢先喝下，展现了角色间微妙的情感互动与误会。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人", "琴音"], "worldbuilding_signals": [], "dialogue_style_signals": ["制作人", "啦"], "key_evidence": [{"source_row": "3", "speaker": "制作人", "text_zh": "（是花海咲季同学的东西吧。"}, {"source_row": "9", "speaker": "制作人", "text_zh": "这是为藤田同学准备的吧。"}, {"source_row": "13", "speaker": "琴音", "text_zh": "制作人～最喜欢你啦♡"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["琴音赠送给制作人的饮品是花海咲季特制的。", "制作人误认为该饮品是专门给藤田同学准备的。", "琴音因制作人拒绝独享而抢先喝下饮品。"], "relationship_facts": ["琴音与制作人之间存在暧昧的情感互动。", "花海咲季与藤田同学之间存在某种关联。", "琴音对制作人表现出强烈的喜爱与依赖。"], "worldbuilding_facts": ["场景发生在难得的假日。", "咲季制作的饮品颜色非常诡异。", "该饮品被描述为能补充元气的饮料。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00307", "scene_id": "scene-00307", "source_file": "CSV/pevent/fktn/adv_pevent_002_fktn_sales_1-002-01.csv", "source_kind": "pevent", "chapter": "pevent/fktn", "scene": "adv_pevent_002_fktn_sales_1-002-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "12", "line_count": 12}], "source_refs": ["CSV/pevent/fktn/adv_pevent_002_fktn_sales_1-002-01.csv:1-12"], "line_count": 12, "speakers": ["制作人", "琴音", "选项"], "topics": ["relationships", "team_story", "dialogue_style", "worldbuilding"], "title": "藤田琴音联名特饮", "summary": "在N.I.A参赛偶像联名咖啡店，制作人、琴音与手毬讨论特饮。琴音宣传藤田琴音的饮品营养低卡，制作人多次称赞其宣传词完美。咲季作为联名对象被提及，其特饮为选项之一，但未直接出场。", "saki_role": "被提及对象：咲季未必直接发言，但场景信息与她的关系或评价有关。", "relationship_signals": ["制作人", "琴音", "手毬"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["制作人"], "key_evidence": [{"source_row": "1", "speaker": "琴音", "text_zh": "今天来到了与『N.I.A』参赛偶像联名的主题咖啡店哟♪"}, {"source_row": "5", "speaker": "选项", "text_zh": "选项：花海咲季的联名特饮"}, {"source_row": "8", "speaker": "制作人", "text_zh": "不愧是藤田同学，宣传词说得太完美了。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["场景为N.I.A参赛偶像联名的主题咖啡店。", "琴音负责宣传藤田琴音的联名特饮。", "制作人多次称赞藤田琴音的宣传词完美。", "咲季的联名特饮是可供选择的选项之一。"], "relationship_facts": ["制作人与琴音关系亲密，常互相配合。", "藤田琴音是N.I.A参赛偶像之一。", "花海咲季是N.I.A参赛偶像之一。"], "worldbuilding_facts": ["N.I.A偶像团体与咖啡店进行联名活动。", "联名特饮具有独特外观和营养卖点。", "咖啡店鼓励顾客拍摄饮品照片。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00308", "scene_id": "scene-00308", "source_file": "CSV/pevent/fktn/adv_pevent_002_fktn_sales_1-002-02.csv", "source_kind": "pevent", "chapter": "pevent/fktn", "scene": "adv_pevent_002_fktn_sales_1-002-02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "12", "line_count": 12}], "source_refs": ["CSV/pevent/fktn/adv_pevent_002_fktn_sales_1-002-02.csv:1-12"], "line_count": 12, "speakers": ["制作人", "琴音", "选项"], "topics": ["relationships", "team_story", "dialogue_style", "worldbuilding"], "title": "咖啡厅合作饮品", "summary": "制作人与琴音在N.I.A参赛偶像主题咖啡厅，面对惊人客流量讨论宣传效果。琴音介绍藤田琴音、花海咲季及月村手毬的合作饮品，强调其可爱外观、营养满分及低卡路里美味，鼓励拍照宣传。", "saki_role": "被提及对象：咲季未必直接发言，但场景信息与她的关系或评价有关。", "relationship_signals": ["制作人", "琴音", "手毬"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["制作人", "啦"], "key_evidence": [{"source_row": "5", "speaker": "选项", "text_zh": "花海咲季的\n合作饮品"}, {"source_row": "7", "speaker": "琴音", "text_zh": "外观也超～可爱的，\n请多拍些照片哦！"}, {"source_row": "9", "speaker": "琴音", "text_zh": "听说营养满分哦！\n虽然颜色有点怪，但味道有保证♪"}, {"source_row": "11", "speaker": "琴音", "text_zh": "低卡路里又美味……\n是连偶像也能放心享用的一杯呢！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["咖啡厅是N.I.A参赛偶像合作主题店。", "花海咲季有专属合作饮品。", "饮品具有营养满分且低卡路里。"], "relationship_facts": ["制作人与琴音是同事或搭档。", "琴音、咲季、手毬均为N.I.A偶像。", "制作人与琴音共同负责咖啡厅宣传。"], "worldbuilding_facts": ["N.I.A是参赛偶像团体。", "咖啡厅提供偶像合作限定饮品。", "饮品设计注重外观与营养平衡。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00309", "scene_id": "scene-00309", "source_file": "CSV/pevent/hrnm/adv_pevent_001_hrnm_activity_005.csv", "source_kind": "pevent", "chapter": "pevent/hrnm", "scene": "adv_pevent_001_hrnm_activity_005", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "21", "line_count": 21}], "source_refs": ["CSV/pevent/hrnm/adv_pevent_001_hrnm_activity_005.csv:1-21"], "line_count": 21, "speakers": ["制作人", "莉波", "选项"], "topics": ["team_story", "worldbuilding", "dialogue_style", "relationships"], "title": "莉波寻求专栏写作建议", "summary": "莉波向制作人请教杂志专栏的写作主题，制作人建议从沉迷事物或努力完成的工作入手。莉波考虑了唇膏和咲季饮品的颜色，但被制作人劝阻。最终莉波决定从近期工作回顾开始写作，并请求制作人审阅初稿。", "saki_role": "被提及对象：咲季未必直接发言，但场景信息与她的关系或评价有关。", "relationship_signals": ["制作人", "莉波"], "worldbuilding_signals": ["偶像", "课程", "工作"], "dialogue_style_signals": ["制作人"], "key_evidence": [{"source_row": "4", "speaker": "莉波", "text_zh": "下次课程要练习写专栏文章"}, {"source_row": "14", "speaker": "莉波", "text_zh": "看到咲季同学拿的饮品颜色"}, {"source_row": "15", "speaker": "制作人", "text_zh": "这个还是别写了"}, {"source_row": "20", "speaker": "莉波", "text_zh": "那得先回顾一下近期工作才行"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["莉波正在为杂志专栏寻找写作主题。", "制作人建议莉波描写沉迷事物或努力完成的工作。", "莉波因咲季饮品的颜色被制作人劝阻不要作为主题。", "莉波决定从回顾近期工作开始撰写专栏。"], "relationship_facts": ["莉波与制作人是同事关系，莉波向制作人寻求建议。", "咲季是莉波的同学，莉波在讨论中提及咲季。", "制作人与咲季存在某种互动，使得咲季的饮品颜色成为话题。"], "worldbuilding_facts": ["存在一个偶像相关的杂志专栏。", "莉波需要练习撰写专栏文章。", "咲季有拿饮品的习惯，且饮品颜色具有话题性。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00310", "scene_id": "scene-00310", "source_file": "CSV/pevent/hski/adv_pevent_001_hski_activity_001.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_001_hski_activity_001", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "19", "line_count": 19}], "source_refs": ["CSV/pevent/hski/adv_pevent_001_hski_activity_001.csv:1-19"], "line_count": 19, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "worldbuilding", "character_arc"], "title": "咲季策划SNS运营", "summary": "咲季提议偶像SNS运营应展现个人特色，如训练日记或姐妹日常。制作人建议先制定策略，咲季起初因被要求思考而抱怨，后在确认方向正确后兴奋决定立即注册账号，双方就运营策略展开讨论。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人"], "worldbuilding_signals": ["偶像", "训练"], "dialogue_style_signals": ["真是的", "制作人", "啦"], "key_evidence": [{"source_row": "4", "speaker": "咲季", "text_zh": "要是让我来的话，估计会变成训练日记之类的呢。"}, {"source_row": "10", "speaker": "咲季", "text_zh": "不能这么随便啦！给我好好思考完再说啊，真是的！"}, {"source_row": "17", "speaker": "咲季", "text_zh": "这个主意太棒了！今天就开搞吧！马上注册账号！"}, {"source_row": "19", "speaker": "制作人", "text_zh": "……还是先制定一下运营策略比较好。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季认为偶像SNS运营重点在于展现个人特色。", "咲季提议发布训练日记或姐妹亲密日常等内容。", "咲季在确认方向后决定立即注册账号开始运营。", "制作人在咲季冲动前建议先制定运营策略。"], "relationship_facts": ["咲季与制作人讨论偶像SNS运营策略。", "咲季与制作人存在上下级或合作工作关系。", "咲季提及自己与另一位姐妹的亲密关系。"], "worldbuilding_facts": ["偶像需要运营SNS账号。", "SNS运营方式影响偶像形象。", "SSD是咲季提到的特定术语或概念。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00311", "scene_id": "scene-00311", "source_file": "CSV/pevent/hski/adv_pevent_001_hski_activity_002.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_001_hski_activity_002", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/pevent/hski/adv_pevent_001_hski_activity_002.csv:1-20"], "line_count": 20, "speakers": ["制作人", "咲季", "选项"], "topics": ["relationships", "dialogue_style"], "title": "咲季与佑芽的粉丝对决", "summary": "咲季观看花海佑芽的演出视频，直言其可爱并以此提升干劲。面对制作人的调侃，咲季毫不掩饰对佑芽的喜爱，自称头号粉丝。她自信地表示作为姐姐会关注对手，并期待下次对决，展现出既竞争又欣赏的复杂心态。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "姐姐", "对手"], "worldbuilding_signals": [], "dialogue_style_signals": ["当然", "制作人", "啦"], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "嗯～果然不管看多少遍佑芽都是最可爱的呢～♪"}, {"source_row": "18", "speaker": "咲季", "text_zh": "而且还是最早最早的头号粉丝哦！"}, {"source_row": "9", "speaker": "咲季", "text_zh": "下次对决也要让你好好领教！"}, {"source_row": "13", "speaker": "咲季", "text_zh": "身为姐姐当然会在意吧？"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季正在观看花海佑芽的演出视频。", "咲季自称是佑芽最早的头号粉丝。", "咲季表示下次对决要让制作人领教。", "咲季认为身为姐姐在意对手是理所当然的。"], "relationship_facts": ["咲季与制作人存在竞争关系。", "咲季是花海佑芽的粉丝。", "咲季自称为佑芽的姐姐（或年长者）"], "worldbuilding_facts": ["咲季和制作人之间存在某种对决或竞争活动。", "花海佑芽曾参与商演并穿着打歌服。", "观看偶像视频被视为提升干劲的有效方式。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00312", "scene_id": "scene-00312", "source_file": "CSV/pevent/hski/adv_pevent_001_hski_activity_003.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_001_hski_activity_003", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "18", "line_count": 18}], "source_refs": ["CSV/pevent/hski/adv_pevent_001_hski_activity_003.csv:1-18"], "line_count": 18, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "worldbuilding"], "title": "咲季赠糖与减肥话题", "summary": "咲季将买赠糖果送给制作人，鼓励其补充糖分以应对培育工作。面对制作人提及减肥，咲季表示糖果无妨，并自嘲不吃糖是习惯。最终因觉得浪费，决定将糖果转送给小佑芽。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽"], "worldbuilding_signals": ["工作"], "dialogue_style_signals": ["当然", "才不是", "哼", "制作人", "啦"], "key_evidence": [{"source_row": "3", "speaker": "咲季", "text_zh": "买其他东西送的赠品，喏，反正我也不吃。"}, {"source_row": "9", "speaker": "咲季", "text_zh": "把这个吃掉，好好补充糖分吧。"}, {"source_row": "12", "speaker": "咲季", "text_zh": "原本就不吃的。应该说已经成为习惯了吧。"}, {"source_row": "18", "speaker": "咲季", "text_zh": "丢掉又太浪费了，还是给小佑芽吧。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季将买赠糖果送给制作人。", "咲季认为制作人需要补充糖分。", "咲季表示不吃糖已成为习惯。", "咲季决定将糖果转送给小佑芽。"], "relationship_facts": ["咲季与制作人关系亲密。", "咲季与培育工作相关。", "咲季与角色小佑芽存在关联。"], "worldbuilding_facts": ["咲季有不吃糖果的习惯。", "制作人的工作涉及用脑思考。", "小佑芽是咲季认识的人。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00313", "scene_id": "scene-00313", "source_file": "CSV/pevent/hski/adv_pevent_001_hski_activity_004.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_001_hski_activity_004", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "19", "line_count": 19}], "source_refs": ["CSV/pevent/hski/adv_pevent_001_hski_activity_004.csv:1-19"], "line_count": 19, "speakers": ["制作人", "咲季", "选项"], "topics": ["relationships", "dialogue_style", "worldbuilding"], "title": "咲季为佑芽攻克难题", "summary": "咲季因作业陷入苦战，制作人鼓励她学习的重要性。咲季受佑芽影响，决心必须自己认真做完并彻底理解，以此作为教会佑芽的动力，展现了她作为姐姐的责任感与上进心。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "姐姐"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["制作人", "啦"], "key_evidence": [{"source_row": "2", "speaker": "咲季", "text_zh": "本来打算速战速决然后去开会的说"}, {"source_row": "9", "speaker": "咲季", "text_zh": "没错！作为姐姐，必须能教会佑芽才行"}, {"source_row": "14", "speaker": "咲季", "text_zh": "为了能教佑芽！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季因一道难题陷入苦战，原本计划速战速决去开会。", "咲季决定必须自己认真做完作业，以作为教会佑芽的动力。", "制作人认为学习对咲季而言如同偶像活动一样重要。"], "relationship_facts": ["咲季是佑芽的姐姐，立志要教会佑芽。", "制作人是咲季的对话者，给予她鼓励与肯定。"], "worldbuilding_facts": ["咲季将学习视为与偶像活动同等重要的事情。", "咲季作为姐姐，肩负着教导后辈（佑芽）的责任。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00314", "scene_id": "scene-00314", "source_file": "CSV/pevent/hski/adv_pevent_001_hski_activity_005.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_001_hski_activity_005", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "18", "line_count": 18}], "source_refs": ["CSV/pevent/hski/adv_pevent_001_hski_activity_005.csv:1-18"], "line_count": 18, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "worldbuilding", "character_arc"], "title": "咲季的假日与训练", "summary": "咲季向制作人解释其独特的休息日安排。她认为工作与休息需严格分开，平日已随制作人完成必要训练。假日时她上午学习功课，下午则彻底放松，有时还会与妹妹一起悠闲度过，强调身体休息的重要性。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "妹妹"], "worldbuilding_signals": ["训练", "工作"], "dialogue_style_signals": ["呵呵", "制作人", "啦"], "key_evidence": [{"source_row": "14", "speaker": "咲季", "text_zh": "必要的训练平时都和你一起完成了。"}, {"source_row": "16", "speaker": "咲季", "text_zh": "上午学习功课，下午就让身体休息。"}, {"source_row": "9", "speaker": "咲季", "text_zh": "然后两个人一起悠闲地待着。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季平日已与制作人完成必要训练。", "咲季休息日上午学习功课，下午休息。", "咲季有时会在休息日与妹妹一起玩耍。"], "relationship_facts": ["咲季与制作人是训练搭档。", "咲季与妹妹关系亲密。"], "worldbuilding_facts": ["咲季将工作与休息严格区分。", "咲季在休息日会进行上午的学习。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00315", "scene_id": "scene-00315", "source_file": "CSV/pevent/hski/adv_pevent_001_hski_activity_006.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_001_hski_activity_006", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "19", "line_count": 19}], "source_refs": ["CSV/pevent/hski/adv_pevent_001_hski_activity_006.csv:1-19"], "line_count": 19, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "plot", "team_story"], "title": "富士山演唱会计划", "summary": "咲季提议在日本最高的富士山举办演唱会，并自信表示只要足够红就能获得许可。她提议全员开始登山健身训练，展现了其充满干劲与自信的性格，同时也暗示了粉丝群体可能随之改变的有趣前景。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人"], "worldbuilding_signals": ["演唱会"], "dialogue_style_signals": ["呵呵", "制作人"], "key_evidence": [{"source_row": "4", "speaker": "咲季", "text_zh": "富士山！"}, {"source_row": "12", "speaker": "咲季", "text_zh": "只要红到能拿到许可的程度就行了对吧"}, {"source_row": "17", "speaker": "咲季", "text_zh": "我们也从今年开始练习登山吧！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季提议在富士山举办演唱会。", "咲季自信表示只要足够红就能获得许可。", "咲季提议全员开始登山健身训练。"], "relationship_facts": ["咲季与制作人关系亲密，能直接激发其干劲。", "咲季将制作人视为可以共同实现目标的伙伴。"], "worldbuilding_facts": ["富士山被设定为日本最高的地方。", "在富士山举办演唱会需要极高的知名度以获取许可。", "咲季的粉丝群体被暗示可能因登山训练而变得强壮。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00316", "scene_id": "scene-00316", "source_file": "CSV/pevent/hski/adv_pevent_001_hski_activity_007.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_001_hski_activity_007", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "19", "line_count": 19}], "source_refs": ["CSV/pevent/hski/adv_pevent_001_hski_activity_007.csv:1-19"], "line_count": 19, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "character_arc"], "title": "咲季的山里问卷调查", "summary": "咲季邀请制作人进行海边与山里的问卷调查，并鼓励凭直觉选择。制作人最终选择山里，咲季表示这与佑芽相同，并自称是山派。尽管咲季声称无特殊含义，但制作人察觉咲季似乎偏爱山里。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽"], "worldbuilding_signals": [], "dialogue_style_signals": ["哼", "制作人", "啦"], "key_evidence": [{"source_row": "2", "speaker": "咲季", "text_zh": "海边和山里，你想去哪里？"}, {"source_row": "5", "speaker": "选项", "text_zh": "山里"}, {"source_row": "15", "speaker": "咲季", "text_zh": "顺便说我是山派哦♪"}, {"source_row": "19", "speaker": "制作人", "text_zh": "咲季同学好像喜欢山里呢……"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季发起关于海边或山里的问卷调查。", "制作人选择了山里作为目的地。", "咲季自称是山派，并认为制作人与佑芽选择一致。", "咲季声称问卷无特殊含义，仅因与佑芽聊天时想到。"], "relationship_facts": ["咲季与佑芽关系亲密，常提及对方。", "咲季与制作人关系轻松，能开玩笑。", "制作人与佑芽在问卷选择上保持一致。"], "worldbuilding_facts": ["咲季性格活泼，喜欢开玩笑。", "咲季对山里环境表现出偏好。", "问卷选项包含海边、山里及与咲季同行。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00317", "scene_id": "scene-00317", "source_file": "CSV/pevent/hski/adv_pevent_001_hski_activity_008.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_001_hski_activity_008", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/pevent/hski/adv_pevent_001_hski_activity_008.csv:1-20"], "line_count": 20, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "team_story"], "title": "咲季决心打扫房间", "summary": "咲季因房间杂乱感到压力，决定立即打扫以免耽误活动。制作人建议趁现在行动，咲季虽嘴上抱怨但态度坚决，表示回去后绝对要清理干净，展现了她重视活动与自我管理的决心。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "姐姐"], "worldbuilding_signals": [], "dialogue_style_signals": ["当然", "制作人", "啦"], "key_evidence": [{"source_row": "3", "speaker": "咲季", "text_zh": "房间乱糟糟的不是会积累压力吗？"}, {"source_row": "8", "speaker": "咲季", "text_zh": "就是啊，这样不行！会影响活动的！"}, {"source_row": "16", "speaker": "咲季", "text_zh": "回去后绝～～～～对要打扫干净！"}, {"source_row": "19", "speaker": "制作人", "text_zh": "积攒起来会更麻烦的。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季认为房间杂乱会积累压力，影响活动表现。", "咲季决定立刻打扫房间，拒绝他人帮忙。", "咲季承诺回家后绝对要将房间打扫干净。", "制作人指出积攒杂物会让打扫变得更麻烦。"], "relationship_facts": ["咲季与制作人是共同生活的伙伴。", "咲季称呼制作人为‘制作人’。", "咲季将制作人视为需要督促的‘弟弟’角色（自称姐姐）。"], "worldbuilding_facts": ["咲季的房间目前处于非常杂乱的状态。", "咲季将保持房间整洁视为活动准备的重要部分。", "咲季在对话中表现出对‘姐姐’身份的强调。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00318", "scene_id": "scene-00318", "source_file": "CSV/pevent/hski/adv_pevent_001_hski_activity_009.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_001_hski_activity_009", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "19", "line_count": 19}], "source_refs": ["CSV/pevent/hski/adv_pevent_001_hski_activity_009.csv:1-19"], "line_count": 19, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "plot", "worldbuilding"], "title": "咲季的世界巡演梦想", "summary": "咲季向制作人展示其成为顶级偶像的宏大愿景，计划举办世界巡演。她依次提及欧洲伦敦西区、亚洲日本及美国曼哈顿作为潜在演出地，并自信表示十年内定能实现，提醒制作人提前准备护照。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人"], "worldbuilding_signals": ["偶像", "演唱会"], "dialogue_style_signals": ["呵呵", "制作人", "啦"], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "我一定会成为顶级偶像的对吧？"}, {"source_row": "10", "speaker": "咲季", "text_zh": "果然还是伦敦吧！西区剧院怎么样？"}, {"source_row": "17", "speaker": "咲季", "text_zh": "要办就去曼哈顿！我要让全美国都为我着迷！"}, {"source_row": "19", "speaker": "咲季", "text_zh": "十年内一定会去的，记得先把护照办好哦♪"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季立志成为顶级偶像并举办世界巡演。", "咲季首选伦敦西区剧院作为欧洲演出地。", "咲季决定将美国曼哈顿作为巡演目的地。", "咲季计划在十年内实现世界巡演梦想。"], "relationship_facts": ["咲季与制作人讨论未来巡演计划。", "咲季视制作人为可信赖的倾听者。", "咲季希望制作人协助办理护照。"], "worldbuilding_facts": ["顶级偶像通常举办世界巡演。", "伦敦西区是音乐剧的发源地。", "曼哈顿是美国重要的演出地点。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00319", "scene_id": "scene-00319", "source_file": "CSV/pevent/hski/adv_pevent_001_hski_activity_010.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_001_hski_activity_010", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/pevent/hski/adv_pevent_001_hski_activity_010.csv:1-20"], "line_count": 20, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "worldbuilding"], "title": "无人岛生存讨论", "summary": "咲季询问制作人若去无人岛带何物，制作人提议带人、学校或小刀。咲季否决了导致分离的选项，认为带学校是作弊且太重，但认可小刀的实用性，并鼓励制作人保持务实态度。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽"], "worldbuilding_signals": ["学园", "工作"], "dialogue_style_signals": ["当然", "真是的", "哼", "制作人", "啦"], "key_evidence": [{"source_row": "4", "speaker": "咲季", "text_zh": "我嘛当然要带佑芽，你呢要带什么？"}, {"source_row": "10", "speaker": "咲季", "text_zh": "因为会让我和佑芽分开所以我不要这个选项。"}, {"source_row": "14", "speaker": "咲季", "text_zh": "而且根本带不动吧！"}, {"source_row": "20", "speaker": "咲季", "text_zh": "不过务实是好事呢！以后培育工作也要保持这样哦！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季询问制作人去无人岛只能带一件东西时该带什么。", "咲季拒绝了带人的选项，理由是会导致自己与佑芽分离。", "咲季认为带初星学园是作弊，且体积过大无法携带。", "咲季认可小刀是普通但实用的物品，并建议制作人保持务实。"], "relationship_facts": ["咲季与佑芽关系亲密，不希望被分开。", "咲季称呼对方为制作人，双方处于培育者与被培育者的关系。", "咲季对制作人的选择持调侃与指导态度。"], "worldbuilding_facts": ["初星学园是一个可以被提及但无法物理携带的庞大实体。", "在无人岛生存情境下，物品携带受到尺寸限制。", "培育工作被咲季视为需要保持务实态度的任务。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00320", "scene_id": "scene-00320", "source_file": "CSV/pevent/hski/adv_pevent_001_hski_activity_011.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_001_hski_activity_011", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/pevent/hski/adv_pevent_001_hski_activity_011.csv:1-20"], "line_count": 20, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "team_story", "worldbuilding"], "title": "咲季被质疑交友情况", "summary": "制作人询问咲季与同学的相处状况，咲季对此感到突兀并反问有何用处。面对制作人关于协调性重要及咲季性格强势的选项，咲季激烈反驳，强调自己拥有朋友且是协调性化身，认为制作人多管闲事并看穿其内心想法。", "saki_role": "同学/对手：咲季在群像关系中以好胜、直率和带头推进对话的姿态出现。", "relationship_signals": ["制作人", "朋友"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["当然", "真是的", "制作人", "啦"], "key_evidence": [{"source_row": "8", "speaker": "咲季", "text_zh": "问这种问题不就等于在说你没有朋友吗！"}, {"source_row": "14", "speaker": "咲季", "text_zh": "简直就是协调性的化身对吧！"}, {"source_row": "18", "speaker": "制作人", "text_zh": "（果然很强势呢）"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季认为询问交友情况等同于质疑她没有朋友。", "咲季坚称自己是协调性的化身，并会珍惜朋友。", "咲季敏锐地察觉并指出了制作人内心的想法。"], "relationship_facts": ["制作人与咲季是同学关系。", "制作人对咲季的交友情况表现出关心。", "咲季对制作人的关心表现出抗拒和强势态度。"], "worldbuilding_facts": ["协调性对偶像来说很重要。", "咲季性格比较强势。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00321", "scene_id": "scene-00321", "source_file": "CSV/pevent/hski/adv_pevent_001_hski_activity_012.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_001_hski_activity_012", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "19", "line_count": 19}], "source_refs": ["CSV/pevent/hski/adv_pevent_001_hski_activity_012.csv:1-19"], "line_count": 19, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "worldbuilding", "character_arc"], "title": "休息日的卡拉OK", "summary": "休息日里，咲季与制作人进行卡拉OK活动。咲季虽调侃制作人强硬作风，但表示喜欢唱歌。制作人提议降低难度，咲季则坚持喜欢之事需全力以赴，最终两人约定选歌，气氛轻松愉快。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人"], "worldbuilding_signals": ["偶像", "训练"], "dialogue_style_signals": ["呵呵", "制作人", "不是吗", "啦"], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "没想到连休息日都要唱歌呢……"}, {"source_row": "17", "speaker": "咲季", "text_zh": "喜欢的事情就该全力以赴，不是吗？"}, {"source_row": "11", "speaker": "咲季", "text_zh": "就算来玩也改不掉你这强硬的作风呢……"}, {"source_row": "19", "speaker": "咲季", "text_zh": "谢谢。该选什么歌好呢～♪"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["休息日咲季与制作人进行卡拉OK活动。", "咲季表示喜欢唱歌，认为喜欢之事应全力以赴。", "制作人提议降低难度，咲季坚持认真态度。", "咲季调侃制作人强硬作风，但期待活动。"], "relationship_facts": ["咲季与制作人是搭档关系。", "咲季对制作人既调侃又信任。", "制作人对咲季有指导与包容态度。"], "worldbuilding_facts": ["咲季是偶像，将唱歌视为本分。", "休息日仍有训练或活动安排。", "卡拉OK是角色间放松的互动方式。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00322", "scene_id": "scene-00322", "source_file": "CSV/pevent/hski/adv_pevent_001_hski_activity_013.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_001_hski_activity_013", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/pevent/hski/adv_pevent_001_hski_activity_013.csv:1-20"], "line_count": 20, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "worldbuilding"], "title": "咲季的沙拉自助", "summary": "咲季因饥饿选择沙拉自助，理由是甜食少且咖喱脂肪高。制作人虽担心其蔬菜摄入不足，但咲季坚持营养均衡饮食，并享受自助餐的随意性。咲季展现出偶像苗子般开朗直率的性格，对美食充满热情。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["制作人"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["制作人", "不是吗", "啦"], "key_evidence": [{"source_row": "3", "speaker": "咲季", "text_zh": "沙拉自助吧！"}, {"source_row": "5", "speaker": "咲季", "text_zh": "因为甜食不是很多吗？咖喱的脂肪含量也很高。"}, {"source_row": "19", "speaker": "咲季", "text_zh": "我喜欢营养均衡的饮食搭配！"}, {"source_row": "20", "speaker": "制作人", "text_zh": "真是不得了的女高中生啊……不对，是偶像的苗子才对"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季因饥饿选择沙拉自助，认为甜食少且咖喱脂肪高。", "咲季坚持营养均衡的饮食搭配，享受自助餐的随意性。", "咲季展现出偶像苗子般开朗直率、对美食充满热情的性格。"], "relationship_facts": ["咲季与制作人正在共进午餐。", "制作人对咲季的饮食习惯表示关心。", "咲季将制作人视为可以坦诚交流的朋友。"], "worldbuilding_facts": ["咲季是偶像的苗子。", "咲季平时蔬菜吃得比较少。", "咲季喜欢营养均衡的饮食搭配。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00323", "scene_id": "scene-00323", "source_file": "CSV/pevent/hski/adv_pevent_001_hski_activity_014.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_001_hski_activity_014", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "18", "line_count": 18}], "source_refs": ["CSV/pevent/hski/adv_pevent_001_hski_activity_014.csv:1-18"], "line_count": 18, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "worldbuilding"], "title": "咲季选购工作私服", "summary": "咲季向制作人咨询购买工作用私服的意见。在制作人表示信任其品味后，咲季决定购买自己喜欢的款式，并考虑与佑芽购买同款。两人随后讨论具体款式，咲季对鲜艳风格犹豫不决，最终对制作人推荐的配色表示满意。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽"], "worldbuilding_signals": ["工作"], "dialogue_style_signals": ["哼", "制作人", "啦"], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "呐，制作人。我想买件工作用的新私服呢。"}, {"source_row": "9", "speaker": "咲季", "text_zh": "既然都无所谓的话，我就买自己喜欢的咯？"}, {"source_row": "11", "speaker": "咲季", "text_zh": "那我要不要和佑芽买同款呢～。"}, {"source_row": "18", "speaker": "咲季", "text_zh": "咦？……还挺不错的嘛。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季想购买一件工作用的私服。", "咲季决定购买自己喜欢的款式。", "咲季考虑与佑芽购买同款衣服。", "咲季对鲜艳风格感到犹豫，但认可了推荐配色。"], "relationship_facts": ["咲季与制作人讨论服装选择。", "咲季与佑芽关系亲密，考虑买同款。", "制作人对咲季的品味表示信任。"], "worldbuilding_facts": ["咲季有工作用的私服需求。", "服装选择涉及形象战略考量。", "存在不同风格的服装款式（鲜艳、忧郁）。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00324", "scene_id": "scene-00324", "source_file": "CSV/pevent/hski/adv_pevent_001_hski_activity_015.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_001_hski_activity_015", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "18", "line_count": 18}], "source_refs": ["CSV/pevent/hski/adv_pevent_001_hski_activity_015.csv:1-18"], "line_count": 18, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships"], "title": "女仆咖啡厅的称呼", "summary": "咲季在女仆咖啡厅欢迎制作人归来，并调侃其被称呼为“主人大人”时的反应。面对制作人的回应，咲季顺势点餐并强调享受氛围才是礼仪。随后咲季试探制作人是否喜欢该称呼，在制作人请求后，咲季害羞地改口并索要小费，展现了两人间轻松且略带暧昧的互动。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人"], "worldbuilding_signals": [], "dialogue_style_signals": ["制作人", "啦"], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "欢迎回来了呢！"}, {"source_row": "4", "speaker": "咲季", "text_zh": "被叫主人大人也会开心的对吧？"}, {"source_row": "17", "speaker": "咲季", "text_zh": "呜……欢、欢迎回来，主人大人……"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季在女仆咖啡厅欢迎制作人归来。", "咲季认为被叫主人大人会让制作人开心。", "咲季在制作人请求后改口并索要小费。"], "relationship_facts": ["咲季与制作人是女仆与客人的关系。", "咲季对制作人表现出亲近与调侃。", "制作人接受咲季的称呼并请求她改口。"], "worldbuilding_facts": ["场景设定在女仆咖啡厅。", "女仆咖啡厅中客人可被称呼为主人。", "咲季作为女仆有向客人点餐的职责。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00325", "scene_id": "scene-00325", "source_file": "CSV/pevent/hski/adv_pevent_001_hski_activity_016.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_001_hski_activity_016", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "19", "line_count": 19}], "source_refs": ["CSV/pevent/hski/adv_pevent_001_hski_activity_016.csv:1-19"], "line_count": 19, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships"], "title": "咲季练习签名", "summary": "休息期间，咲季坚持练习自己的签名，认为当前版本已具特色。制作人给予肯定，并提议画小动物或尝试反差萌风格。咲季虽犹豫但最终决定继续练习现有签名，展现了自信与对细节的执着。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["制作人"], "worldbuilding_signals": [], "dialogue_style_signals": ["当然", "才不是", "真是的", "哼", "制作人", "啦"], "key_evidence": [{"source_row": "2", "speaker": "咲季", "text_zh": "这种时候不练的话就没时间了啦。"}, {"source_row": "9", "speaker": "制作人", "text_zh": "我觉得非常有咲季同学的特色哦。"}, {"source_row": "13", "speaker": "制作人", "text_zh": "我觉得反差萌也不错。"}, {"source_row": "19", "speaker": "咲季", "text_zh": "总之现在的就是最好的对吧。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季在休息时间坚持练习签名。", "制作人认为咲季的签名很有特色。", "制作人提议画小动物或反差萌风格。", "咲季决定继续练习当前的签名。"], "relationship_facts": ["制作人与咲季是同事或上下级关系。", "制作人关心咲季的风格发展。", "咲季对制作人的提议持开放但谨慎态度。"], "worldbuilding_facts": ["角色有个人签名作为标识。", "角色之间存在风格讨论与提案。", "休息时间是进行练习的时段。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00326", "scene_id": "scene-00326", "source_file": "CSV/pevent/hski/adv_pevent_001_hski_activity_017-01.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_001_hski_activity_017-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "12", "line_count": 12}], "source_refs": ["CSV/pevent/hski/adv_pevent_001_hski_activity_017-01.csv:1-12"], "line_count": 12, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "team_story"], "title": "咲季提议去抽奖", "summary": "咲季在店里获得抽奖辅助券后，提议制作人立刻前往参加活动。她认为两人身上带有能吸引好运的运气，并鼓励制作人尝试。面对制作人认为今天时运不佳的回应，咲季询问是否意味着无法中奖，最终决定改天再来，并承诺活动期间会再次光临。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["制作人"], "worldbuilding_signals": [], "dialogue_style_signals": ["制作人"], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "呐，刚才在店里拿到了什么呀？"}, {"source_row": "2", "speaker": "制作人", "text_zh": "是抽奖的辅助券呢。"}, {"source_row": "6", "speaker": "咲季", "text_zh": "对呀！能把想要的东西吸引过来的运气！"}, {"source_row": "12", "speaker": "咲季", "text_zh": "那就改天吧。活动期间内我一定会再来的！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季在店里获得了抽奖的辅助券。", "咲季提议两人立刻前往正在举办的活动。", "制作人认为今天的时运不佳，无法中奖。", "咲季决定改天再来参加活动。"], "relationship_facts": ["咲季与制作人关系亲密，咲季会主动关心制作人的状态。", "咲季对制作人抱有期待，希望两人能一起获得好运。", "咲季对制作人展现出依赖与信任，承诺活动期间会再次来访。"], "worldbuilding_facts": ["存在一种能吸引想要之物的“运气”概念。", "抽奖活动需要特定的辅助券才能参与。", "抽奖结果被认为与当天的时运有关。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00327", "scene_id": "scene-00327", "source_file": "CSV/pevent/hski/adv_pevent_001_hski_activity_017-02.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_001_hski_activity_017-02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "17", "line_count": 17}], "source_refs": ["CSV/pevent/hski/adv_pevent_001_hski_activity_017-02.csv:1-17"], "line_count": 17, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "character_arc", "team_story"], "title": "咲季抽奖未中一等奖", "summary": "咲季连续抽中二等奖后，制作人告知无券可抽。咲季从自信认为理所当然，到得知无法再抽后感到不甘与失落。制作人解释现实中连续中奖概率极低，咲季最终无奈接受现实，展现了角色对运气的执着与反差萌。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["制作人"], "worldbuilding_signals": [], "dialogue_style_signals": ["当然", "哼", "制作人", "啦"], "key_evidence": [{"source_row": "2", "speaker": "咲季", "text_zh": "这种程度理所当然啦！"}, {"source_row": "11", "speaker": "咲季", "text_zh": "六……六等奖～～～～！"}, {"source_row": "13", "speaker": "制作人", "text_zh": "已经没有抽奖券了。"}, {"source_row": "16", "speaker": "制作人", "text_zh": "连续抽中二等奖以上的概率在现实中是不可能的。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季连续两次抽中了二等奖。", "抽奖券已用完，无法继续抽取。", "咲季因未能抽中一等奖而非常不甘心。", "制作人在现实中无法连续抽中二等奖以上。"], "relationship_facts": ["制作人与咲季是同事或朋友关系。", "咲季对制作人抱有信任与依赖。", "制作人是咲季抽奖活动的引导者。"], "worldbuilding_facts": ["抽奖活动存在一等奖、二等奖、六等奖等等级。", "连续抽中二等奖以上的概率在现实中几乎为零。", "抽奖券数量有限，抽完即止。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00328", "scene_id": "scene-00328", "source_file": "CSV/pevent/hski/adv_pevent_001_hski_activity_018-01.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_001_hski_activity_018-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "10", "line_count": 10}], "source_refs": ["CSV/pevent/hski/adv_pevent_001_hski_activity_018-01.csv:1-10"], "line_count": 10, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "character_arc"], "title": "初次造访游戏中心", "summary": "咲季首次造访游戏中心，对猜拳机等设施感到新奇。制作人解释规则并鼓励她尝试，咲季表现出乐观态度，认为输了不甘心是游戏乐趣的一部分，随后提议先观察其他项目。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["制作人"], "worldbuilding_signals": [], "dialogue_style_signals": ["制作人"], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "我可能是第一次来呢……"}, {"source_row": "3", "speaker": "制作人", "text_zh": "是猜拳机哦。赢了的话可以获得奖品。"}, {"source_row": "9", "speaker": "咲季", "text_zh": "游戏不就是这样子的吗？"}, {"source_row": "10", "speaker": "咲季", "text_zh": "嘛，先看看其他的也不迟呢。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季第一次来到游戏中心。", "咲季对猜拳机感到好奇并提议尝试。", "咲季认为输了不甘心是游戏的常态。", "咲季决定先观察其他游戏设施。"], "relationship_facts": ["咲季与制作人是同行关系。", "制作人负责向咲季解释游戏设施。", "咲季听从制作人的建议进行互动。"], "worldbuilding_facts": ["游戏中心设有猜拳机。", "猜拳机获胜可获得奖品。", "游戏中心内存在多种可供游玩的设施。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00329", "scene_id": "scene-00329", "source_file": "CSV/pevent/hski/adv_pevent_001_hski_activity_018-02.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_001_hski_activity_018-02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "18", "line_count": 18}], "source_refs": ["CSV/pevent/hski/adv_pevent_001_hski_activity_018-02.csv:1-18"], "line_count": 18, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "character_arc", "plot"], "title": "咲季挑战游戏胜负", "summary": "咲季在制作人面前挑战游戏，起初连胜并领取奖品，随后遭遇连败。咲季拒绝认输，认为只要再赢一次即可，但制作人指出这种执念会陷入死胡同，劝其带着胜利的喜悦离开。咲季虽不甘心，最终仍被劝止。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["制作人"], "worldbuilding_signals": [], "dialogue_style_signals": ["当然", "哼", "制作人", "啦"], "key_evidence": [{"source_row": "10", "speaker": "咲季", "text_zh": "还拿到了奖品，真是满足呢。"}, {"source_row": "12", "speaker": "咲季", "text_zh": "唔，输了……再来一次……"}, {"source_row": "14", "speaker": "制作人", "text_zh": "不行。这种想法只会让你陷入死胡同。"}, {"source_row": "18", "speaker": "咲季", "text_zh": "呜～。完全不能接受！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季在游戏初期连续获胜并获得了奖品。", "咲季在连续输掉后拒绝认输，坚持要再赢一次。", "制作人认为咲季执着于再赢一次的想法是错误的。", "咲季最终接受了制作人的劝告，情绪低落。"], "relationship_facts": ["咲季与制作人之间存在游戏挑战关系。", "制作人是咲季的挑战对象或对手。", "制作人对咲季的游戏执念持劝阻态度。"], "worldbuilding_facts": ["游戏存在奖品机制。", "游戏结果受运气因素影响。", "连续失败可能导致玩家陷入死胡同心态。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00330", "scene_id": "scene-00330", "source_file": "CSV/pevent/hski/adv_pevent_001_hski_activity_019.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_001_hski_activity_019", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "16", "line_count": 16}], "source_refs": ["CSV/pevent/hski/adv_pevent_001_hski_activity_019.csv:1-16"], "line_count": 16, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "character_arc"], "title": "咲季挑战佑芽", "summary": "咲季在竞争中再次战胜佑芽，兴奋地寻求制作人的夸奖。她虽承认两人关系良好，但强调当前是竞争状态，希望听到关于对方努力的肯定，以此激励自己下周继续拉开差距，展现不服输的劲头。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽"], "worldbuilding_signals": [], "dialogue_style_signals": ["当然", "哼", "呵呵", "制作人", "啦"], "key_evidence": [{"source_row": "2", "speaker": "咲季", "text_zh": "又赢过佑芽了！"}, {"source_row": "14", "speaker": "咲季", "text_zh": "虽然关系好，但现在不一样吧！"}, {"source_row": "16", "speaker": "咲季", "text_zh": "我想听那种话啦！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季在今天的活动中再次战胜了佑芽。", "咲季希望制作人夸奖她或肯定佑芽的努力。", "咲季计划下周继续训练以扩大与佑芽的差距。", "咲季认为虽然两人关系好，但现在的关系已发生变化。"], "relationship_facts": ["咲季与佑芽是竞争对手。", "咲季与佑芽关系良好。", "咲季与制作人关系亲密。"], "worldbuilding_facts": ["咲季和佑芽正在进行某种技能或游戏相关的活动。", "咲季非常在意自己的排名或表现。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00331", "scene_id": "scene-00331", "source_file": "CSV/pevent/hski/adv_pevent_001_hski_activity_020.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_001_hski_activity_020", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "17", "line_count": 17}], "source_refs": ["CSV/pevent/hski/adv_pevent_001_hski_activity_020.csv:1-17"], "line_count": 17, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "team_story", "character_arc"], "title": "咲季选购运动毛巾", "summary": "咲季提议前往运动用品店购买新毛巾，强调需吸水性强的超细纤维混棉材质。她自信地展示专业知识，并调侃制作人下次买哑铃时也要帮忙挑选。制作人表示愿意努力，咲季随即开玩笑说时机正好，决定一次性多买几条以延长使用时间。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人"], "worldbuilding_signals": [], "dialogue_style_signals": ["哼", "制作人", "啦"], "key_evidence": [{"source_row": "3", "speaker": "咲季", "text_zh": "那我们去运动用品店吧♪"}, {"source_row": "9", "speaker": "咲季", "text_zh": "材质不同速干性也会变化。"}, {"source_row": "12", "speaker": "咲季", "text_zh": "也是呢。那下次买哑铃的时候，就拜托你啦？"}, {"source_row": "17", "speaker": "咲季", "text_zh": "为了短时间内不用再买，我们一次性多买些吧！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季计划去运动用品店购买新毛巾。", "咲季认为超细纤维混棉材质吸水性最佳。", "咲季提议一次性多买几条毛巾。", "咲季调侃制作人下次买哑铃时也要帮忙挑选。"], "relationship_facts": ["咲季与制作人是同事或上下级关系。", "咲季对制作人的心意感到开心但保持玩笑态度。", "咲季与制作人之间存在轻松互动的日常关系。"], "worldbuilding_facts": ["运动用品店售卖毛巾和哑铃等器材。", "超细纤维混棉材质具有超强吸水性。", "购买运动器材需考虑材质与功能特性。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00332", "scene_id": "scene-00332", "source_file": "CSV/pevent/hski/adv_pevent_001_hski_school_001.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_001_hski_school_001", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "23", "line_count": 23}], "source_refs": ["CSV/pevent/hski/adv_pevent_001_hski_school_001.csv:1-23"], "line_count": 23, "speakers": ["制作人", "咲季", "浅梨老师", "选项"], "topics": ["worldbuilding", "dialogue_style", "character_arc", "plot"], "title": "咲季数学辅导风波", "summary": "浅梨老师安排咲季进行数学辅导，咲季因粗心做错递推公式题。制作人指出粗心后果，咲季请求学习未接触过的数学B内容。浅梨老师鼓励咲季，咲季抱怨被剧透答案，认为成长机会被糟蹋，最终在制作人激励下振作。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["制作人"], "worldbuilding_signals": ["学园", "偶像", "课程"], "dialogue_style_signals": ["真是的", "制作人", "不是吗", "啦"], "key_evidence": [{"source_row": "10", "speaker": "咲季", "text_zh": "什么嘛，这不是粗心大意嘛……！"}, {"source_row": "16", "speaker": "咲季", "text_zh": "还没学过不是吗。但如果很方便的话，教教我嘛。"}, {"source_row": "20", "speaker": "咲季", "text_zh": "直接把答案说出来算什么啦！"}, {"source_row": "23", "speaker": "咲季", "text_zh": "真是的，你给我振作一点啦！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季在数学辅导中因粗心做错递推公式题。", "咲季请求学习尚未接触过的数学B范围内容。", "咲季抱怨制作人直接给出答案破坏了成长机会。", "制作人指出数学中粗心大意会决定一切。"], "relationship_facts": ["浅梨老师是咲季的老师，负责监督学习。", "制作人是咲季的同伴，负责指出问题并激励咲季。", "咲季是偶像，同时也是需要学习的学生。"], "worldbuilding_facts": ["学园允许学生提前学习未接触过的课程。", "数学B是递推公式所属的学科范围。", "学生偶像需要兼顾偶像活动与学业。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00333", "scene_id": "scene-00333", "source_file": "CSV/pevent/hski/adv_pevent_001_hski_school_002.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_001_hski_school_002", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "26", "line_count": 26}], "source_refs": ["CSV/pevent/hski/adv_pevent_001_hski_school_002.csv:1-26"], "line_count": 26, "speakers": ["制作人", "咲季", "浅梨老师", "选项"], "topics": ["dialogue_style", "relationships", "worldbuilding", "character_arc"], "title": "咲季的科学特训", "summary": "咲季因肌肉酸痛无法训练，制作人提议通过思维训练转移注意力。浅梨老师支持此法，建议咲季指导他人以加深理解。咲季虽感意外但仍同意，计划结束后前往训练室，为制作人准备科学特训。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人"], "worldbuilding_signals": ["偶像", "训练"], "dialogue_style_signals": ["呵呵", "制作人", "啦"], "key_evidence": [{"source_row": "2", "speaker": "咲季", "text_zh": "肌肉酸痛一直没好没法进行训练"}, {"source_row": "17", "speaker": "制作人", "text_zh": "只要能让大脑通过思维训练获得满足感"}, {"source_row": "23", "speaker": "浅梨老师", "text_zh": "通过教导他人也能加深对训练内容的理解"}, {"source_row": "26", "speaker": "咲季", "text_zh": "我会给你来点对身体也很有效的科学特训"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季因肌肉酸痛暂时无法进行训练。", "制作人提议通过思维训练解决烦恼。", "咲季同意在结束后前往训练室进行特训。"], "relationship_facts": ["咲季与浅梨老师是师生或前辈后辈关系。", "制作人是咲季的粉丝或支持者。", "浅梨老师与制作人共同协助咲季。"], "worldbuilding_facts": ["按摩需在肌肉酸痛发生前进行才有效。", "教导他人能加深对训练内容的理解。", "将身体与头脑分开考虑会导致困扰。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00334", "scene_id": "scene-00334", "source_file": "CSV/pevent/hski/adv_pevent_001_hski_school_003.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_001_hski_school_003", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "27", "line_count": 27}], "source_refs": ["CSV/pevent/hski/adv_pevent_001_hski_school_003.csv:1-27"], "line_count": 27, "speakers": ["制作人", "咲季", "浅梨老师", "选项"], "topics": ["dialogue_style", "relationships", "worldbuilding", "character_arc"], "title": "培育羁绊的斯巴达式", "summary": "浅梨老师与咲季探讨偶像培育中牢固羁绊的重要性。咲季虽被质疑干劲不足，却展现出超越高中生的可靠，坚持相信制作人并重视实际成绩。两人达成共识，认为只要目标一致便无需动摇，展现了深厚的信任与默契。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人"], "worldbuilding_signals": ["偶像", "训练", "工作"], "dialogue_style_signals": ["当然", "才不是", "制作人", "啦"], "key_evidence": [{"source_row": "3", "speaker": "咲季", "text_zh": "亚纱里老师，您是不是干劲不足呀？"}, {"source_row": "14", "speaker": "浅梨老师", "text_zh": "花海同学，完全看不出是高中生的可靠程度呢。"}, {"source_row": "22", "speaker": "制作人", "text_zh": "我认为积累实际成绩才是最重要的。"}, {"source_row": "25", "speaker": "浅梨老师", "text_zh": "只要目标和手段一致，就没有分开的理由呢。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季展现出超越高中生的可靠程度。", "咲季与制作人意见一致，重视实际成绩。", "两人认为只要目标和手段一致就没有分开理由。"], "relationship_facts": ["咲季与制作人之间存在深厚的信任。", "咲季与浅梨老师正在探讨培育理念。", "制作人将培育工作托付给咲季。"], "worldbuilding_facts": ["偶像业界充满惊涛骇浪，生存不易。", "偶像与制作人之间需要非常牢固的羁绊。", "培育偶像需要付出辛苦努力，非轻易建立。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00335", "scene_id": "scene-00335", "source_file": "CSV/pevent/hski/adv_pevent_001_hski_school_004.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_001_hski_school_004", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "19", "line_count": 19}], "source_refs": ["CSV/pevent/hski/adv_pevent_001_hski_school_004.csv:1-19"], "line_count": 19, "speakers": ["制作人", "浅梨老师", "选项"], "topics": ["dialogue_style", "relationships", "worldbuilding", "character_arc"], "title": "咲季偶像快问快答", "summary": "浅梨老师介绍花海咲季独立且自信，但亦有敏感一面。制作人选择把握方向，被老师赞许为灯塔。随后讨论到照顾咲季需查漏补缺，制作人表示虽费神但会时刻关注，老师对此充满期待。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["制作人"], "key_evidence": [{"source_row": "2", "speaker": "浅梨老师", "text_zh": "花海同学非常独立，什么事都喜欢自己解决。"}, {"source_row": "11", "speaker": "浅梨老师", "text_zh": "请务必像灯塔一样，为花海同学照亮最闪耀的方向！"}, {"source_row": "12", "speaker": "制作人", "text_zh": "虽然她很自信，但也有细腻敏感的一面。"}, {"source_row": "19", "speaker": "浅梨老师", "text_zh": "相信你一定没问题的。我很期待哦——。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["花海咲季性格独立，凡事喜欢自己解决。", "咲季虽自信，但内心细腻敏感，偶有踌躇。", "制作人需以全局视角支持咲季，并关注细节疏漏。"], "relationship_facts": ["浅梨老师是制作人关于咲季的指导者。", "制作人是花海咲季的偶像经理。", "制作人视咲季为需要引导与支持的偶像。"], "worldbuilding_facts": ["偶像快问快答是节目环节。", "制作人需具备全局视角与灯塔般的指引作用。", "照顾偶像需要时刻关注其方方面面。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00336", "scene_id": "scene-00336", "source_file": "CSV/pevent/hski/adv_pevent_001_hski_school_005.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_001_hski_school_005", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "23", "line_count": 23}], "source_refs": ["CSV/pevent/hski/adv_pevent_001_hski_school_005.csv:1-23"], "line_count": 23, "speakers": ["咲季", "数学教師", "选项"], "topics": ["dialogue_style", "relationships", "worldbuilding", "plot"], "title": "秀吉数树与绳子的智慧", "summary": "数学教师讲述丰臣秀吉用绳子标记树木以计数，咲季联想到计算粉丝人数。教师纠正咲季关于颜料工具的误解，强调绳子可计算剩余量。咲季感叹偶像可能面临无理要求，认为保持头脑灵活很重要。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人"], "worldbuilding_signals": ["偶像", "演唱会"], "dialogue_style_signals": ["哼", "制作人"], "key_evidence": [{"source_row": "10", "speaker": "数学教師", "text_zh": "于是秀吉给每棵树都系上了绳子。"}, {"source_row": "17", "speaker": "咲季", "text_zh": "原来使用的工具是绳子啊。"}, {"source_row": "19", "speaker": "数学教師", "text_zh": "正确答案是给树木系绳子。"}, {"source_row": "21", "speaker": "数学教師", "text_zh": "偶像也会遇到无理要求吧。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["丰臣秀吉通过给树木系绳子并计算剩余量来统计总数。", "咲季误以为制作人是说用颜料做标记，后被纠正。", "数学教师指出部下不能算作工具，正确答案是绳子。", "咲季认为偶像可能会遇到像数树一样的无理要求。"], "relationship_facts": ["咲季与数学教师进行关于历史故事和数学方法的对话。", "咲季对制作人提到的工具内容存在记忆偏差。", "数学教师作为引导者向咲季解释历史典故和逻辑。"], "worldbuilding_facts": ["丰臣秀吉曾执行过数清山上树木的任务。", "用绳子系在树上可以区分已数过的树木，颜料则无法计算剩余量。", "偶像行业可能会面临各种无理要求，需要保持头脑灵活。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00337", "scene_id": "scene-00337", "source_file": "CSV/pevent/hski/adv_pevent_001_hski_school_006.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_001_hski_school_006", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "27", "line_count": 27}], "source_refs": ["CSV/pevent/hski/adv_pevent_001_hski_school_006.csv:1-27"], "line_count": 27, "speakers": ["咲季", "浅梨老师", "选项"], "topics": ["dialogue_style", "relationships", "character_arc", "plot"], "title": "咲季与金星的一等星", "summary": "浅梨老师向咲季解释学园奋斗目标“一等星”实为金星。咲季自信地回答并调侃制作人，虽因混淆水星与金星而答错，但展现了其作为姐姐的自信与对制作人的亲密互动，最后主动提出补课。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "姐姐"], "worldbuilding_signals": ["学园"], "dialogue_style_signals": ["当然", "真是的", "制作人"], "key_evidence": [{"source_row": "1", "speaker": "浅梨老师", "text_zh": "学园的孩子们所追求的当然是『一等星』。"}, {"source_row": "11", "speaker": "浅梨老师", "text_zh": "一等星别名又叫『黄昏明星』，是傍晚时分最早出现的那颗星。"}, {"source_row": "14", "speaker": "咲季", "text_zh": "不觉得和我很相配吗？"}, {"source_row": "27", "speaker": "咲季", "text_zh": "咲季姐姐这就来给你开小灶补课！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["学园孩子们追求的奋斗目标被称为“一等星”。", "一等星在傍晚时分最早出现，别名“黄昏明星”。", "咲季将金星（启明星）与自身形象相提并论。", "咲季主动提出为答错的制作人补课。"], "relationship_facts": ["咲季称呼对方为“制作人”，关系亲密。", "咲季自称为“咲季姐姐”，展现长辈姿态。", "浅梨老师负责科普天文知识并纠正错误。"], "worldbuilding_facts": ["“一等星”是学园孩子们追求的目标象征。", "一等星即金星，别名“黄昏明星”或“启明星”。", "水星和金星都位于地球靠近太阳的一侧。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00338", "scene_id": "scene-00338", "source_file": "CSV/pevent/hski/adv_pevent_001_hski_school_007.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_001_hski_school_007", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "21", "line_count": 21}], "source_refs": ["CSV/pevent/hski/adv_pevent_001_hski_school_007.csv:1-21"], "line_count": 21, "speakers": ["浅梨老师", "选项"], "topics": ["team_story"], "title": "七彩饮品的秘密", "summary": "浅梨老师向同学们介绍花海咲季调制的七彩饮品。在问答环节，老师指出该饮品在黑光灯下会因含有维生素B2而发光。她强调维生素B2是重要的发育营养素，对代谢和细胞再生不可或缺，并提醒同学们不要因饮品发光而拒绝饮用，应保证营养摄入。", "saki_role": "被提及对象：咲季未必直接发言，但场景信息与她的关系或评价有关。", "relationship_signals": [], "worldbuilding_signals": [], "dialogue_style_signals": [], "key_evidence": [{"source_row": "2", "speaker": "浅梨老师", "text_zh": "花海同学调制的七彩饮品。"}, {"source_row": "4", "speaker": "选项", "text_zh": "因为含有维生素B2"}, {"source_row": "9", "speaker": "浅梨老师", "text_zh": "其中有一种叫维生素B2的成分会在黑光灯下发亮哦。"}, {"source_row": "16", "speaker": "浅梨老师", "text_zh": "对代谢和细胞再生不可或缺。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["花海咲季调制了七彩饮品。", "该饮品在黑光灯照射下会闪闪发光。", "发光原因是饮品中含有维生素B2。", "维生素B2被称为发育维生素，对代谢和细胞再生至关重要。"], "relationship_facts": ["浅梨老师是花海咲季的同学或朋友。", "浅梨老师是同学们的老师。", "花海咲季是浅梨老师所提及的特定同学。"], "worldbuilding_facts": ["学校环境设有黑光灯设施。", "维生素B2具有在黑光灯下发光的特性。", "七彩饮品是一种含有多种营养成分的饮料。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00339", "scene_id": "scene-00339", "source_file": "CSV/pevent/hski/adv_pevent_001_hski_school_008.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_001_hski_school_008", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "24", "line_count": 24}], "source_refs": ["CSV/pevent/hski/adv_pevent_001_hski_school_008.csv:1-24"], "line_count": 24, "speakers": ["咲季", "社会教師", "选项"], "topics": ["dialogue_style", "relationships", "team_story"], "title": "北条氏纲与五条训诫", "summary": "社会教师考问咲季关于“胜而不骄”谚语的历史人物。咲季起初误记为制作人提及的北条氏纲，后在选项中混淆了武田信玄与爱因斯坦。教师纠正指出正确答案为北条氏纲，并解释其“五条训诫”及武田信玄的“风林火山”典故，咲季最终确认了历史事实并调侃制作人的错误。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "广"], "worldbuilding_signals": [], "dialogue_style_signals": ["哼", "制作人"], "key_evidence": [{"source_row": "9", "speaker": "社会教師", "text_zh": "答对了。这是他留给儿子氏康作为遗言的话语。"}, {"source_row": "10", "speaker": "社会教師", "text_zh": "顺便一提，这份遗言被称为『五条训诫』，另外还有四条。"}, {"source_row": "15", "speaker": "社会教師", "text_zh": "顺便说一下，武田信玄是『风林火山』的起源人物。"}, {"source_row": "22", "speaker": "社会教師", "text_zh": "爱因斯坦是物理学家，他做出了改变常识的发现。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["谚语“胜而不骄”出自北条氏纲留给儿子氏康的遗言，被称为“五条训诫”。", "武田信玄是“风林火山”的起源人物，该词源自《孙子兵法》。", "爱因斯坦在1905年发表重要论文，被称为“奇迹之年”。", "咲季曾误以为制作人记错了北条氏纲的相关典故。"], "relationship_facts": ["北条氏纲是北条氏康的父亲。", "咲季与制作人存在互动，制作人曾错误提及历史人物。", "社会教师负责向咲季传授历史知识并纠正错误。"], "worldbuilding_facts": ["“五条训诫”阐述了作为统治者的心术。", "“风林火山”在日本广为人知，被写在旗帜上。", "1905年被称为爱因斯坦的“奇迹之年”。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00340", "scene_id": "scene-00340", "source_file": "CSV/pevent/hski/adv_pevent_001_hski_school_009.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_001_hski_school_009", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "25", "line_count": 25}], "source_refs": ["CSV/pevent/hski/adv_pevent_001_hski_school_009.csv:1-25"], "line_count": 25, "speakers": ["咲季", "浅梨老师", "选项"], "topics": ["dialogue_style", "character_arc", "relationships", "worldbuilding"], "title": "咲季纠正老师营养知识", "summary": "浅梨老师讲解营养素热量，咲季自信作答并纠正老师关于相差倍数的口误。咲季指出老师易过量摄入脂质，并主动提出教授运动营养学。咲季表示会自行管理饮食，拒绝制作人过度干涉，展现其独立与对健康的重视。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["当然", "哼", "制作人", "啦"], "key_evidence": [{"source_row": "9", "speaker": "浅梨老师", "text_zh": "没错，脂质约9大卡。"}, {"source_row": "10", "speaker": "浅梨老师", "text_zh": "相差两倍多呢。"}, {"source_row": "19", "speaker": "咲季", "text_zh": "要不要我来教你运动营养学啊？"}, {"source_row": "25", "speaker": "咲季", "text_zh": "因为交给你来管的话……太可怕了。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["脂质每克约9大卡，热量最高。", "碳水化合物和蛋白质每克约4大卡。", "膳食纤维属于无法消化的碳水化合物。", "咲季主动提出教老师运动营养学。"], "relationship_facts": ["咲季与浅梨老师是师生。", "咲季与制作人是上下级关系。", "咲季对制作人的管理方式感到畏惧。"], "worldbuilding_facts": ["人类最重要的三大营养素是碳水、蛋白质和脂质。", "脂质过量摄取需特别注意。", "运动营养学是咲季擅长的领域。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00341", "scene_id": "scene-00341", "source_file": "CSV/pevent/hski/adv_pevent_001_hski_school_010.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_001_hski_school_010", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "21", "line_count": 21}], "source_refs": ["CSV/pevent/hski/adv_pevent_001_hski_school_010.csv:1-21"], "line_count": 21, "speakers": ["浅梨老师", "选项"], "topics": ["dialogue_style", "character_arc", "worldbuilding"], "title": "浅梨老师讲解核心肌群", "summary": "浅梨老师因花海咲季缺席，借机讲解其作为运动健将的核心肌群知识。她详细定义了核心肌群为躯干部位，强调其对舞蹈及身体稳定性的基础作用，并纠正了关于内脏可锻炼的误解，提醒学生务必牢记体能训练要点。", "saki_role": "被提及对象：咲季未必直接发言，但场景信息与她的关系或评价有关。", "relationship_signals": [], "worldbuilding_signals": ["训练"], "dialogue_style_signals": ["当然"], "key_evidence": [{"source_row": "1", "speaker": "浅梨老师", "text_zh": "今天花海同学不在"}, {"source_row": "2", "speaker": "浅梨老师", "text_zh": "作为运动健将的花海同学"}, {"source_row": "8", "speaker": "浅梨老师", "text_zh": "核心肌群是指除去头、四肢之外的躯干部位"}, {"source_row": "17", "speaker": "浅梨老师", "text_zh": "内脏可不是通过肌肉训练能锻炼的"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["花海咲季今天不在场。", "核心肌群指除去头、四肢外的躯干肌肉群。", "锻炼核心肌群能提升身体动作稳定性。", "内脏无法通过肌肉训练锻炼。"], "relationship_facts": ["浅梨老师是花海咲季的老师。", "浅梨老师关注花海咲季的体能状况。", "花海咲季是学校的运动健将。"], "worldbuilding_facts": ["核心肌群是身体动作的基础部分。", "核心肌群对舞蹈表演非常重要。", "体能训练应从核心力量开始。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00342", "scene_id": "scene-00342", "source_file": "CSV/pevent/hski/adv_pevent_001_hski_school_011.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_001_hski_school_011", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "14", "line_count": 14}], "source_refs": ["CSV/pevent/hski/adv_pevent_001_hski_school_011.csv:1-14"], "line_count": 14, "speakers": ["制作人", "咲季", "担任教師", "选项"], "topics": ["character_arc", "worldbuilding", "dialogue_style", "relationships"], "title": "咲季选择舞蹈训练", "summary": "教师宣布自习时间用于备考训练，咲季确认选择舞蹈训练。她兴奋地表示喜欢活动身体，并自信能应对任何舞步，随后提议更换场地开始训练。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人"], "worldbuilding_signals": ["训练"], "dialogue_style_signals": ["制作人", "啦"], "key_evidence": [{"source_row": "3", "speaker": "咲季", "text_zh": "原来如此。所以你才会出现在这里啊。"}, {"source_row": "9", "speaker": "咲季", "text_zh": "要锻炼歌唱能力呢。很不错啊。"}, {"source_row": "11", "speaker": "咲季", "text_zh": "太好了！我最喜欢活动身体了！"}, {"source_row": "14", "speaker": "咲季", "text_zh": "那我们换个场地吧。放马过来！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季选择歌唱训练作为重点。", "咲季表示最喜欢活动身体。", "咲季自信能应对任何舞步。", "咲季提议更换场地开始训练。"], "relationship_facts": ["咲季与教师讨论训练内容。", "咲季与制作人共同决定训练项目。", "咲季与担任教师存在师生或指导关系。"], "worldbuilding_facts": ["近期有定期考试。", "自习时间可用于训练。", "训练内容包含歌唱、舞蹈及表现能力。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00343", "scene_id": "scene-00343", "source_file": "CSV/pevent/hski/adv_pevent_002_hski_sales_1-001-01.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_002_hski_sales_1-001-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "11", "line_count": 11}], "source_refs": ["CSV/pevent/hski/adv_pevent_002_hski_sales_1-001-01.csv:1-11"], "line_count": 11, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "team_story"], "title": "咲季推销新饮品", "summary": "咲季向制作人推销新饮品，强调自己精心设计的递送方式。制作人表示无需担心，建议她去做更有意义的事。咲季对此感到惊讶并试图辩解，展现了活泼自信的性格。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人"], "worldbuilding_signals": [], "dialogue_style_signals": ["当然", "哼", "制作人", "啦"], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "新推出的饮品，请多多关照啦～！"}, {"source_row": "10", "speaker": "咲季", "text_zh": "我可是专门研究了让人忍不住接过来的递送方式哦！"}, {"source_row": "7", "speaker": "制作人", "text_zh": "完全不需要担心。再去找些更能帮上忙的事吧。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季正在推销新推出的饮品。", "咲季特意研究了让人容易接过的递送方式。", "制作人认为咲季无需担心，建议她做更有价值的事。", "咲季对制作人的回应感到意外并试图掩饰。"], "relationship_facts": ["咲季与制作人关系亲密，咲季会直接称呼制作人为‘制作人’。", "制作人对咲季的行为持包容态度，给予指导。", "咲季对制作人抱有期待，希望得到认可。"], "worldbuilding_facts": ["咲季是花海咲季，性格活泼自信。", "咲季擅长推销，注重细节。", "咲季对递送方式有深入研究。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00344", "scene_id": "scene-00344", "source_file": "CSV/pevent/hski/adv_pevent_002_hski_sales_1-001-02.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_002_hski_sales_1-001-02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "11", "line_count": 11}], "source_refs": ["CSV/pevent/hski/adv_pevent_002_hski_sales_1-001-02.csv:1-11"], "line_count": 11, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "character_arc", "plot"], "title": "咲季推销新饮品", "summary": "咲季向制作人推销新饮品，自信展示其精心设计的递送方式。制作人对此表示认可，并设定了更高的目标。咲季虽对突然被提及目标感到惊讶，但随即自豪地强调自己研究过的递送技巧，展现了其活泼且略带傲娇的性格。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人"], "worldbuilding_signals": [], "dialogue_style_signals": ["当然", "哼", "制作人", "啦"], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "新推出的饮品，请多多关照啦～！"}, {"source_row": "6", "speaker": "咲季", "text_zh": "那当然！我可是花海咲季！"}, {"source_row": "10", "speaker": "咲季", "text_zh": "我可是研究了让人忍不住就会接过来的递送方式哦！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季正在推销新推出的饮品。", "咲季展示了精心设计的递送方式。", "制作人对咲季的表现表示认可并设定了更高目标。"], "relationship_facts": ["咲季与制作人之间存在工作互动关系。", "制作人对咲季的能力持肯定态度。"], "worldbuilding_facts": ["咲季是花海咲季。", "咲季擅长设计引人注目的递送方式。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00345", "scene_id": "scene-00345", "source_file": "CSV/pevent/hski/adv_pevent_002_hski_sales_1-002-01.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_002_hski_sales_1-002-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "11", "line_count": 11}], "source_refs": ["CSV/pevent/hski/adv_pevent_002_hski_sales_1-002-01.csv:1-11"], "line_count": 11, "speakers": ["制作人", "咲季", "选项"], "topics": ["relationships", "dialogue_style", "team_story", "character_arc"], "title": "花海咲季宣传联名饮品", "summary": "咲季在N.I.A联名咖啡厅宣传饮品，提及队友佑芽和手毬的联名款。面对选项，咲季对红色饮品表示兴奋，并称赞佑芽可爱。她感叹作为偶像的手毬感觉不同。制作人多次确认咲季干劲提升，认为来对了地方。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "手毬"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["哼", "呵呵", "制作人"], "key_evidence": [{"source_row": "2", "speaker": "咲季", "text_zh": "佑芽和手毬的也有呢。"}, {"source_row": "6", "speaker": "咲季", "text_zh": "呵呵呵……胜利的红色呢！"}, {"source_row": "8", "speaker": "咲季", "text_zh": "佑芽也好可爱呀～～～♪"}, {"source_row": "10", "speaker": "咲季", "text_zh": "作为偶像的手毬，原来是这种感觉啊……"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季在N.I.A联名咖啡厅进行饮品宣传。", "咲季对红色饮品表现出兴奋情绪。", "咲季称赞队友佑芽非常可爱。", "咲季感叹手毬作为偶像的感觉。"], "relationship_facts": ["咲季与佑芽、手毬是队友关系。", "咲季与制作人存在互动关系。", "咲季对队友持有喜爱态度。"], "worldbuilding_facts": ["N.I.A拥有联名咖啡厅。", "咖啡厅内提供多位角色的联名饮品。", "角色拥有代表色（如咲季的红色）。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00346", "scene_id": "scene-00346", "source_file": "CSV/pevent/hski/adv_pevent_002_hski_sales_1-002-02.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_002_hski_sales_1-002-02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "11", "line_count": 11}], "source_refs": ["CSV/pevent/hski/adv_pevent_002_hski_sales_1-002-02.csv:1-11"], "line_count": 11, "speakers": ["制作人", "咲季", "选项"], "topics": ["relationships", "dialogue_style", "team_story", "character_arc"], "title": "咲季挑战对手饮品", "summary": "咲季在N.I.A联名咖啡厅看到佑芽和手毬的饮品后，感叹对手可爱并燃起斗志。她认为胜利之红是她的风格，并对偶像手毬的饮品造型表示好奇，准备与制作人一同品尝或挑战这些联名饮品。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "手毬", "对手"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["哼", "呵呵", "制作人"], "key_evidence": [{"source_row": "1", "speaker": "制作人", "text_zh": "这里就是『N.I.A』的联名咖啡厅。"}, {"source_row": "2", "speaker": "咲季", "text_zh": "……佑芽和手毬的也有呢。"}, {"source_row": "6", "speaker": "咲季", "text_zh": "呵呵呵……胜利之红啊！"}, {"source_row": "10", "speaker": "咲季", "text_zh": "嗯哼，作为偶像的手毬原来会变成这样啊……"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季在N.I.A联名咖啡厅看到其他角色的饮品。", "咲季认为对手饮品可爱，并以此激发斗志。", "咲季对偶像手毬的饮品造型感到惊讶。", "咲季准备尝试或挑战这些联名饮品。"], "relationship_facts": ["咲季与制作人一同在咖啡厅。", "咲季与佑芽、手毬存在竞争或比较关系。", "咲季与佑芽、手毬同为偶像团体成员。"], "worldbuilding_facts": ["N.I.A拥有联名咖啡厅。", "咖啡厅内提供角色联名饮品。", "咲季有‘胜利之红’的战斗风格。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00347", "scene_id": "scene-00347", "source_file": "CSV/pevent/hski/adv_pevent_002_hski_sales_1-003-01.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_002_hski_sales_1-003-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "11", "line_count": 11}], "source_refs": ["CSV/pevent/hski/adv_pevent_002_hski_sales_1-003-01.csv:1-11"], "line_count": 11, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "worldbuilding"], "title": "咲季推荐清爽果汁", "summary": "制作人与咲季进行新商品采访，咲季品尝高糖果汁后评价其甜度适中、清爽，适合运动出汗时饮用。咲季主动询问饮用场景并推荐搭配魔芋，展现了她作为工作人员认真靠谱的一面，将普通采访转化为实用的产品建议。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["制作人"], "worldbuilding_signals": ["工作"], "dialogue_style_signals": ["当然", "制作人"], "key_evidence": [{"source_row": "2", "speaker": "咲季", "text_zh": "工作需要当然要喝啊"}, {"source_row": "6", "speaker": "咲季", "text_zh": "甜度适中，喝起来很清爽"}, {"source_row": "10", "speaker": "咲季", "text_zh": "选魔芋怎么样！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季评价新商品果汁甜度适中且清爽。", "咲季认为该果汁适合在出汗时饮用。", "咲季建议搭配魔芋食用。", "制作人对咲季认真工作的态度表示认可。"], "relationship_facts": ["制作人与咲季正在进行商品采访工作。", "咲季是负责新商品介绍的可靠工作人员。", "制作人与咲季之间存在工作协作关系。"], "worldbuilding_facts": ["咲季正在参与新商品的采访工作。", "该商品果汁的糖分含量较高。", "魔芋被推荐作为果汁的搭配食品。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00348", "scene_id": "scene-00348", "source_file": "CSV/pevent/hski/adv_pevent_002_hski_sales_1-003-02.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_002_hski_sales_1-003-02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "11", "line_count": 11}], "source_refs": ["CSV/pevent/hski/adv_pevent_002_hski_sales_1-003-02.csv:1-11"], "line_count": 11, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "worldbuilding"], "title": "咲季试喝新商品", "summary": "制作人与咲季进行新商品采访，咲季试喝后评价甜度适中、清爽，适合运动出汗时饮用。现场讲解营养知识颇受欢迎，围观群众众多。咲季进一步询问果汁饮用场景，并推荐魔芋作为搭配，展现了积极的工作状态。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["制作人"], "worldbuilding_signals": ["工作"], "dialogue_style_signals": ["当然", "制作人"], "key_evidence": [{"source_row": "1", "speaker": "制作人", "text_zh": "这是新商品的采访工作。"}, {"source_row": "6", "speaker": "咲季", "text_zh": "甜度适中，喝起来很清爽呢。"}, {"source_row": "7", "speaker": "制作人", "text_zh": "营养知识的讲解似乎很受欢迎。"}, {"source_row": "10", "speaker": "咲季", "text_zh": "魔芋怎么样！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季试喝了糖分较多的新商品果汁。", "咲季评价该果汁甜度适中，口感清爽。", "咲季认为该果汁适合在出汗时饮用。", "咲季推荐魔芋作为搭配食用。"], "relationship_facts": ["制作人与咲季正在进行商品采访工作。", "咲季向制作人询问果汁的饮用场景。", "咲季与围观群众之间存在互动（讲解受欢迎）。"], "worldbuilding_facts": ["咲季正在参与新商品的采访宣传工作。", "现场有关于营养知识的讲解活动。", "魔芋被提及作为一种可搭配食用的食品。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00349", "scene_id": "scene-00349", "source_file": "CSV/pevent/hski/adv_pevent_002_hski_sales_1-004-01.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_002_hski_sales_1-004-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "11", "line_count": 11}], "source_refs": ["CSV/pevent/hski/adv_pevent_002_hski_sales_1-004-01.csv:1-11"], "line_count": 11, "speakers": ["制作人", "咲季", "选项"], "topics": ["relationships", "dialogue_style", "worldbuilding", "plot"], "title": "咲季应援练习", "summary": "咲季带领制作人进行应援练习，虽感疲惫但坚持全力以赴。她以照顾佑芽的经验应对孩子，强调作为姐姐的身份是理所当然的，展现了成熟与责任感。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "姐姐"], "worldbuilding_signals": ["演唱会", "工作"], "dialogue_style_signals": ["当然", "制作人", "啦"], "key_evidence": [{"source_row": "2", "speaker": "咲季", "text_zh": "呼……陪小孩子玩，可能比演唱会还累人呢。"}, {"source_row": "6", "speaker": "咲季", "text_zh": "嘛，就像照顾小时候的佑芽一样，我知道该怎么做的。"}, {"source_row": "10", "speaker": "咲季", "text_zh": "因为我是姐姐呀！这不是理所当然的吗！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季认为陪孩子玩比演唱会更累。", "咲季将照顾孩子比作照顾小时候的佑芽。", "咲季因是姐姐而坚持正面承受活力。"], "relationship_facts": ["咲季与佑芽存在过去的照顾关系。", "咲季与制作人进行应援练习互动。", "咲季视制作人为需要引导的对象。"], "worldbuilding_facts": ["咲季有照顾后辈（佑芽）的经验。", "应援练习被视为高强度活动。", "姐姐身份被咲季视为核心特质。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00350", "scene_id": "scene-00350", "source_file": "CSV/pevent/hski/adv_pevent_002_hski_sales_1-004-02.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_002_hski_sales_1-004-02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "11", "line_count": 11}], "source_refs": ["CSV/pevent/hski/adv_pevent_002_hski_sales_1-004-02.csv:1-11"], "line_count": 11, "speakers": ["制作人", "咲季", "选项"], "topics": ["relationships", "dialogue_style", "worldbuilding", "plot"], "title": "咲季与孩子们的练习", "summary": "咲季带领孩子们进行应援练习，虽感疲惫但充满热情。制作人称赞她在孩子中人气极高，咲季自信回应这是身为姐姐的理所当然。她决心全力以赴，展现了作为姐姐的担当与活力。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "姐姐"], "worldbuilding_signals": ["演唱会", "工作"], "dialogue_style_signals": ["当然", "制作人", "啦"], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "来，练习应援吧！预备——！加油——！"}, {"source_row": "2", "speaker": "咲季", "text_zh": "呼……陪孩子们玩，可能比演唱会还累人呢。"}, {"source_row": "7", "speaker": "制作人", "text_zh": "存在感完全不输给英雄角色。在孩子们中人气超高。"}, {"source_row": "10", "speaker": "咲季", "text_zh": "因为我是姐姐呀！这不是理所当然的嘛！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季正在带领孩子们进行应援练习。", "咲季认为陪孩子玩比演唱会更累。", "咲季在孩子们中人气超高，存在感不输英雄角色。", "咲季将照顾孩子视为身为姐姐的理所当然。"], "relationship_facts": ["咲季是孩子们的姐姐。", "制作人是咲季的对话者。", "咲季与制作人之间存在工作互动关系。"], "worldbuilding_facts": ["咲季小时候与名为佑芽的角色相似。", "咲季的形象符合姐姐这一角色设定。", "咲季的人气甚至超过了游戏中的英雄角色。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00351", "scene_id": "scene-00351", "source_file": "CSV/pevent/hski/adv_pevent_002_hski_sales_1-005-01.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_002_hski_sales_1-005-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "11", "line_count": 11}], "source_refs": ["CSV/pevent/hski/adv_pevent_002_hski_sales_1-005-01.csv:1-11"], "line_count": 11, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships"], "title": "咲季推销话术排练", "summary": "咲季在制作人指导下进行商品推销排练。她运用课堂所学话术，强调适度宣传与激发购买欲。尽管制作人因销量大增而自夸有经商才能，咲季却自信地表示已熟读注意事项，并成功促成购买，展现了其作为销售角色的成长与自信。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["制作人"], "worldbuilding_signals": [], "dialogue_style_signals": ["哼", "制作人", "啦"], "key_evidence": [{"source_row": "6", "speaker": "咲季", "text_zh": "连这些都教啊……那个，我要用。告诉我吧。"}, {"source_row": "8", "speaker": "咲季", "text_zh": "哼哼哼。那些注意事项我可是全都读过啦♪"}, {"source_row": "10", "speaker": "咲季", "text_zh": "只要让对方想买就行了吧？看我的！"}, {"source_row": "7", "speaker": "制作人", "text_zh": "卖得超好……莫非我有经商才能？"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季正在接受关于商品推销的排练指导。", "咲季运用推销话术成功促成了购买。", "咲季表示已熟读关于推销的注意事项。", "制作人对销量猛增感到惊讶并自夸有经商才能。"], "relationship_facts": ["咲季与制作人存在师徒或指导关系。", "咲季是推销话术的学习者与执行者。", "制作人是咲季推销活动的观察者与受益者。"], "worldbuilding_facts": ["存在关于商品推销的课堂教学内容。", "推销活动需要注意避免过度宣传。", "成功推销能带来销量猛增的商业效果。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00352", "scene_id": "scene-00352", "source_file": "CSV/pevent/hski/adv_pevent_002_hski_sales_1-005-02.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_002_hski_sales_1-005-02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "11", "line_count": 11}], "source_refs": ["CSV/pevent/hski/adv_pevent_002_hski_sales_1-005-02.csv:1-11"], "line_count": 11, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "worldbuilding"], "title": "咲季推销话术彩排", "summary": "咲季在制作人指导下进行商品推销话术彩排。她自信地运用课程所学技巧，试图通过提升销量来证明能力。制作人对其话语中蕴含的不可思议说服力表示惊讶，咲季则坚持只要对方想买即可，展现出强烈的行动欲。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["制作人"], "worldbuilding_signals": ["课程"], "dialogue_style_signals": ["哼", "制作人", "啦"], "key_evidence": [{"source_row": "6", "speaker": "咲季", "text_zh": "连这些都教啊……那个，我要用。告诉我。"}, {"source_row": "7", "speaker": "制作人", "text_zh": "咲季同学的话语有种不可思议的说服力呢……"}, {"source_row": "8", "speaker": "咲季", "text_zh": "哼哼哼。那些注意事项我可是全都读过啦♪"}, {"source_row": "10", "speaker": "咲季", "text_zh": "只要让对方想买你就行了吧？看我的厉害！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季正在接受推销话术的教导与彩排。", "咲季自信地表示已阅读所有注意事项。", "咲季的目标是促成购买并提升销量。", "制作人对咲季的说服力感到意外。"], "relationship_facts": ["咲季与制作人存在指导与被指导关系。", "咲季视制作人为学习对象。", "两人正在进行关于销售策略的互动。"], "worldbuilding_facts": ["存在包含推销话术的课程。", "过度宣传是被禁止的推销行为。", "彩排是正式推销前的必要环节。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00353", "scene_id": "scene-00353", "source_file": "CSV/pevent/hski/adv_pevent_002_hski_sales_1-006-01.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_002_hski_sales_1-006-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "11", "line_count": 11}], "source_refs": ["CSV/pevent/hski/adv_pevent_002_hski_sales_1-006-01.csv:1-11"], "line_count": 11, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "character_arc", "plot"], "title": "咲季自信应对密室逃脱", "summary": "咲季虽未玩过密室逃脱，但凭借提前查资料自信应对。制作人称赞其配合默契，视频效果佳。咲季强调自己温柔体贴，决心识破所有陷阱，展现好姐姐风范。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "姐姐"], "worldbuilding_signals": [], "dialogue_style_signals": ["当然", "制作人", "啦"], "key_evidence": [{"source_row": "2", "speaker": "咲季", "text_zh": "虽然没玩过，但我提前查过资料所以没问题！"}, {"source_row": "7", "speaker": "制作人", "text_zh": "没想到她们配合得这么默契。宣传视频拍出来效果应该不错。"}, {"source_row": "10", "speaker": "咲季", "text_zh": "那当然啦。我可是温柔体贴的好姐姐呢！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季提前查过密室逃脱资料。", "咲季自信能识破所有陷阱。", "咲季自称是温柔体贴的好姐姐。", "制作人对咲季的表现感到满意。"], "relationship_facts": ["咲季与制作人是同事或上下级关系。", "咲季在团队中扮演好姐姐角色。", "咲季与其他参赛者配合默契。"], "worldbuilding_facts": ["咲季是『N.I.A』的参赛者。", "团队正在拍摄宣传视频。", "密室逃脱场景包含陷阱。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00354", "scene_id": "scene-00354", "source_file": "CSV/pevent/hski/adv_pevent_002_hski_sales_1-006-02.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_002_hski_sales_1-006-02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "11", "line_count": 11}], "source_refs": ["CSV/pevent/hski/adv_pevent_002_hski_sales_1-006-02.csv:1-11"], "line_count": 11, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "character_arc", "plot"], "title": "咲季密室逃脱全攻略", "summary": "咲季虽未玩过密室逃脱，但凭借事前功课自信应对。她在游戏中展现活跃表现，成为其他成员的依靠。咲季自称是温柔的姐姐，并自信能识破所有陷阱，以完全通关为目标推进剧情。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "姐姐"], "worldbuilding_signals": [], "dialogue_style_signals": ["当然", "制作人", "啦"], "key_evidence": [{"source_row": "2", "speaker": "咲季", "text_zh": "虽然没玩过，但我事先做过功课所以没问题哦！"}, {"source_row": "7", "speaker": "制作人", "text_zh": "展现了八面玲珑的活跃表现。其他成员也都依靠着她呢。"}, {"source_row": "8", "speaker": "咲季", "text_zh": "肯定有很多陷阱对吧？看我把它们全部识破！"}, {"source_row": "10", "speaker": "咲季", "text_zh": "那当然啦。我可是温柔的姐姐呢！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季事先做过功课，自信能应对密室逃脱。", "咲季在游戏中展现了八面玲珑的活跃表现。", "其他成员都依靠着咲季。", "咲季自称是温柔的姐姐。"], "relationship_facts": ["咲季与其他『N.I.A』参赛者一同参与密室逃脱。", "其他成员依靠咲季。", "制作人与咲季互动。"], "worldbuilding_facts": ["存在名为『N.I.A』的参赛者群体。", "场景为密室逃脱游戏。", "游戏中存在陷阱。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00355", "scene_id": "scene-00355", "source_file": "CSV/pevent/hski/adv_pevent_002_hski_sales_2-001-01.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_002_hski_sales_2-001-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "11", "line_count": 11}], "source_refs": ["CSV/pevent/hski/adv_pevent_002_hski_sales_2-001-01.csv:1-11"], "line_count": 11, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "team_story", "relationships"], "title": "咲季志愿活动", "summary": "咲季在自家街道的垃圾清理志愿活动中展现干劲，主动招呼大家并提议与制作人比赛。制作人称赞其可靠且具宣传效果，咲季则回应对方更有干劲，双方约定一决胜负，共同维护街道环境。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["制作人"], "worldbuilding_signals": [], "dialogue_style_signals": ["当然", "制作人", "啦"], "key_evidence": [{"source_row": "2", "speaker": "咲季", "text_zh": "这可是我们自己生活的街道"}, {"source_row": "6", "speaker": "咲季", "text_zh": "你也要参加吗？那我们来一决胜负吧"}, {"source_row": "7", "speaker": "制作人", "text_zh": "主动招呼大家的花海同学真可靠"}, {"source_row": "10", "speaker": "咲季", "text_zh": "你看起来比我更有干劲呢"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季在自家街道的垃圾清理志愿活动中表现积极。", "咲季主动招呼大家参与，并提议与制作人进行比赛。", "制作人称赞咲季主动招呼大家的行为可靠且具宣传效果。", "咲季回应制作人更有干劲，双方约定进行比赛。"], "relationship_facts": ["咲季与制作人是朋友或同事关系。", "咲季对街道有归属感，视其为自家街道。", "咲季与制作人之间存在竞争或比较关系。"], "worldbuilding_facts": ["当前场景是垃圾清理的志愿活动。", "咲季所在的街道是她们生活的地方。", "咲季的行为对街道宣传有积极影响。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00356", "scene_id": "scene-00356", "source_file": "CSV/pevent/hski/adv_pevent_002_hski_sales_2-001-02.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_002_hski_sales_2-001-02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "11", "line_count": 11}], "source_refs": ["CSV/pevent/hski/adv_pevent_002_hski_sales_2-001-02.csv:1-11"], "line_count": 11, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "team_story"], "title": "街道清扫对决", "summary": "咲季与制作人参加街道垃圾清理志愿活动。咲季视街道为自家生活区域，干劲十足，并邀请制作人进行清扫速度对决。活动结束时，制作人感叹难以跟上咲季的节奏，咲季则称赞制作人更有干劲，双方约定一起加油。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["制作人"], "worldbuilding_signals": [], "dialogue_style_signals": ["当然", "制作人"], "key_evidence": [{"source_row": "2", "speaker": "咲季", "text_zh": "这可是我们自己生活的街道"}, {"source_row": "6", "speaker": "咲季", "text_zh": "那我们来一决胜负吧"}, {"source_row": "7", "speaker": "制作人", "text_zh": "要跟上咲季同学的节奏可真不容易"}, {"source_row": "10", "speaker": "咲季", "text_zh": "你看起来比我更有干劲呢"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季将街道视为自己生活的区域，因此对清扫活动充满干劲。", "咲季邀请制作人在清扫活动中进行一决胜负。", "活动结束时，制作人感叹难以跟上咲季的清扫节奏。", "咲季认为制作人看起来比她更有干劲。"], "relationship_facts": ["咲季与制作人是共同参与志愿活动的同伴。", "咲季与制作人之间存在清扫速度的竞争关系。", "咲季对制作人持有鼓励与认可的态度。"], "worldbuilding_facts": ["当前场景设定为街道垃圾清理的志愿活动。", "咲季与制作人居住在或经常活动于该街道。", "咲季的性格表现为充满活力且富有竞争意识。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00357", "scene_id": "scene-00357", "source_file": "CSV/pevent/hski/adv_pevent_002_hski_sales_2-002-01.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_002_hski_sales_2-002-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "11", "line_count": 11}], "source_refs": ["CSV/pevent/hski/adv_pevent_002_hski_sales_2-002-01.csv:1-11"], "line_count": 11, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "character_arc", "worldbuilding"], "title": "咲季筹备祭典店铺", "summary": "为配合N.I.A祭典，咲季在商店街协助工作。她不仅提前调查了店铺详情，还熟记了各位店员的名字。面对制作人的夸奖，咲季自信地表示已做好充分准备，并主动提出带路，展现了其认真努力且充满活力的性格。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["制作人"], "worldbuilding_signals": ["工作"], "dialogue_style_signals": ["制作人", "啦"], "key_evidence": [{"source_row": "2", "speaker": "制作人", "text_zh": "现在是为了配合『N.I.A』举办的祭典期间。"}, {"source_row": "6", "speaker": "咲季", "text_zh": "什么嘛，包在我身上！我可是做好充分调查的！"}, {"source_row": "10", "speaker": "咲季", "text_zh": "明白啦！商店街各位的名字我都记在脑子里了！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季为配合N.I.A祭典在商店街工作。", "咲季提前调查了所有店铺详情。", "咲季熟记了商店街各位店员的名字。", "咲季主动提出带路并自信完成任务。"], "relationship_facts": ["咲季与制作人存在上下级或指导关系。", "咲季与商店街店员们相互认识。", "咲季与N.I.A组织有工作关联。"], "worldbuilding_facts": ["当前场景处于N.I.A举办的祭典期间。", "商店街是祭典活动的重要场所。", "咲季的工作内容涉及店铺介绍与引导。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00358", "scene_id": "scene-00358", "source_file": "CSV/pevent/hski/adv_pevent_002_hski_sales_2-002-02.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_002_hski_sales_2-002-02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "11", "line_count": 11}], "source_refs": ["CSV/pevent/hski/adv_pevent_002_hski_sales_2-002-02.csv:1-11"], "line_count": 11, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "worldbuilding"], "title": "庆典期间咲季大显身手", "summary": "庆典期间，咲季在制作人指导下负责店铺相关工作。她自信表示已做好调研，并在引导、问候、打气方面表现优异。咲季熟记商店街各位名字，展现出极高的热情与能力，令制作人赞叹不已。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["制作人"], "worldbuilding_signals": ["工作"], "dialogue_style_signals": ["制作人", "啦"], "key_evidence": [{"source_row": "2", "speaker": "制作人", "text_zh": "现在是配合『N.I.A』举办的庆典期间。"}, {"source_row": "6", "speaker": "咲季", "text_zh": "什么嘛，包在我身上！我可是做好充分调研的！"}, {"source_row": "7", "speaker": "制作人", "text_zh": "结果她在引导、问候、打气方面都大显身手"}, {"source_row": "10", "speaker": "咲季", "text_zh": "明白啦！商店街各位的名字我都记在脑子里了！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季在庆典期间负责店铺相关工作。", "咲季熟记商店街各位工作人员的名字。", "咲季在引导、问候、打气方面表现优异。", "咲季自信表示已做好充分调研。"], "relationship_facts": ["咲季与制作人存在工作指导关系。", "咲季与商店街各位工作人员存在互动关系。", "制作人与咲季共同配合举办庆典。"], "worldbuilding_facts": ["当前场景为配合『N.I.A』举办的庆典期间。", "咲季的工作地点位于商店街。", "庆典期间商店街人气很高。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00359", "scene_id": "scene-00359", "source_file": "CSV/pevent/hski/adv_pevent_002_hski_sales_2-003-01.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_002_hski_sales_2-003-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "11", "line_count": 11}], "source_refs": ["CSV/pevent/hski/adv_pevent_002_hski_sales_2-003-01.csv:1-11"], "line_count": 11, "speakers": ["制作人", "咲季", "选项"], "topics": ["relationships", "dialogue_style", "worldbuilding"], "title": "咲季初星学园宣传", "summary": "咲季作为天川市观光大使，与制作人讨论宣传视频选址。面对制作人希望游客涌向初星学园的要求，咲季感到惊讶并怀疑是制作人个人喜好。她提及了佑芽曾去过的精品店和咖啡厅作为对比选项，最终确认了初星学园作为宣传地点的设定。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽"], "worldbuilding_signals": ["学园", "工作"], "dialogue_style_signals": ["制作人"], "key_evidence": [{"source_row": "1", "speaker": "制作人", "text_zh": "这是天川市观光大使的工作。"}, {"source_row": "8", "speaker": "咲季", "text_zh": "要、要把游客叫来初星学园？"}, {"source_row": "10", "speaker": "咲季", "text_zh": "该不会是你的个人喜好吧？"}, {"source_row": "6", "speaker": "咲季", "text_zh": "是和佑芽一起去过的精品店吧。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季担任天川市观光大使，负责吸引游客。", "制作人希望宣传视频将游客引导至初星学园。", "咲季对制作人精准指定初星学园表示怀疑，认为可能是其个人喜好。", "咲季曾与佑芽一同去过精品店和女仆咖啡厅。"], "relationship_facts": ["咲季与佑芽是共同行动的朋友。", "咲季与制作人是工作搭档关系。", "初星学园是咲季与佑芽的母校或关联场所。"], "worldbuilding_facts": ["天川市正在通过早间节目播放宣传视频以吸引游客。", "初星学园是当地重要的旅游景点之一。", "女仆咖啡厅和精品店也是天川市的知名景点。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00360", "scene_id": "scene-00360", "source_file": "CSV/pevent/hski/adv_pevent_002_hski_sales_2-003-02.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_002_hski_sales_2-003-02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "11", "line_count": 11}], "source_refs": ["CSV/pevent/hski/adv_pevent_002_hski_sales_2-003-02.csv:1-11"], "line_count": 11, "speakers": ["制作人", "咲季", "选项"], "topics": ["relationships", "dialogue_style", "worldbuilding"], "title": "咲季推销观光景点", "summary": "制作人感谢咲季作为天川市观光大使的功劳，游客数量增加。咲季对推荐初星学园作为景点表示惊讶，并怀疑制作人是否因个人喜好而精准推荐了特定地点，如和佑芽常去的精品店或咖啡厅。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽"], "worldbuilding_signals": ["学园", "工作"], "dialogue_style_signals": ["制作人"], "key_evidence": [{"source_row": "1", "speaker": "制作人", "text_zh": "是天川市观光大使的工作呢。"}, {"source_row": "8", "speaker": "咲季", "text_zh": "要吸引游客来初星学园？"}, {"source_row": "10", "speaker": "咲季", "text_zh": "这么精准的推荐啊……"}, {"source_row": "7", "speaker": "制作人", "text_zh": "这都是咲季同学的功劳……！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季担任天川市观光大使，负责吸引游客。", "游客数量增加，制作人将功劳归于咲季。", "咲季对推荐初星学园感到惊讶并询问是否可行。", "咲季怀疑制作人的推荐是基于个人喜好。"], "relationship_facts": ["咲季与佑芽关系亲密，常一同外出。", "制作人与咲季关系良好，经常互动。", "咲季与制作人之间存在关于景点推荐的互动。"], "worldbuilding_facts": ["天川市设有观光大使职位。", "初星学园是一个可以吸引游客的景点。", "存在和佑芽常去的精品店及咖啡厅。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00361", "scene_id": "scene-00361", "source_file": "CSV/pevent/hski/adv_pevent_002_hski_sales_2-004-01.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_002_hski_sales_2-004-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "12", "line_count": 12}], "source_refs": ["CSV/pevent/hski/adv_pevent_002_hski_sales_2-004-01.csv:1-12"], "line_count": 12, "speakers": ["制作人", "咲季", "选项"], "topics": ["relationships", "dialogue_style", "team_story"], "title": "广播人生辅导录制", "summary": "咲季确认广播人生辅导录制问题，面对“害怕输给对手”的咨询，她选择逻辑性地给予希望。制作人称赞其话语具有说服力，能成为支撑力量。咲季表示在责任范围内会给出积极向上的回答，展现其理性与关怀并存的特质。", "saki_role": "同学/对手：咲季在群像关系中以好胜、直率和带头推进对话的姿态出现。", "relationship_signals": ["制作人", "广", "对手"], "worldbuilding_signals": [], "dialogue_style_signals": ["制作人"], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "广播人生辅导的公开录制呢……"}, {"source_row": "2", "speaker": "咲季", "text_zh": "『害怕输给竞争对手所以不敢挑战』"}, {"source_row": "9", "speaker": "咲季", "text_zh": "要是能逻辑性地行动就不会烦恼了。"}, {"source_row": "11", "speaker": "咲季", "text_zh": "我会给出能让人积极向上的回答。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季正在主持广播人生辅导的公开录制节目。", "咲季决定以逻辑性行动给予对方希望。", "咲季承诺在责任范围内给出积极向上的回答。"], "relationship_facts": ["咲季与制作人存在工作合作关系。", "咲季作为辅导者倾听并回应听众问题。", "制作人对咲季的辅导能力表示认可。"], "worldbuilding_facts": ["存在名为“广播人生辅导”的公开录制节目。", "节目内容涉及对听众心理问题的辅导与建议。", "咲季在节目中扮演人生辅导者的角色。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00362", "scene_id": "scene-00362", "source_file": "CSV/pevent/hski/adv_pevent_002_hski_sales_2-004-02.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_002_hski_sales_2-004-02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "12", "line_count": 12}], "source_refs": ["CSV/pevent/hski/adv_pevent_002_hski_sales_2-004-02.csv:1-12"], "line_count": 12, "speakers": ["制作人", "咲季", "选项"], "topics": ["relationships", "dialogue_style", "team_story"], "title": "广播人生辅导录制", "summary": "咲季参与广播人生辅导公开录制，面对关于害怕输给竞争对手不敢挑战的问题，她选择给出能给予希望的积极回答。制作人称赞其回答打动人心，咲季表示在责任范围内会积极回应，认为逻辑性行动能减少烦恼。", "saki_role": "同学/对手：咲季在群像关系中以好胜、直率和带头推进对话的姿态出现。", "relationship_signals": ["制作人", "广", "对手"], "worldbuilding_signals": [], "dialogue_style_signals": ["制作人"], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "广播人生辅导的公开录制呢……"}, {"source_row": "2", "speaker": "咲季", "text_zh": "『因为害怕输给竞争对手所以不敢挑战』"}, {"source_row": "6", "speaker": "选项", "text_zh": "要能给予希望"}, {"source_row": "11", "speaker": "咲季", "text_zh": "在不失责任的范围内，我会给出积极向上的回答。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季正在参与广播人生辅导的公开录制节目。", "咲季决定给出能给予希望的积极回答。", "咲季认为逻辑性地行动就不会感到烦恼。", "制作人对咲季的回答表示被打动人心。"], "relationship_facts": ["咲季与制作人共同进行广播录制。", "咲季面对选项做出选择。", "咲季与竞争对手存在潜在的竞争关系。"], "worldbuilding_facts": ["存在名为“广播人生辅导”的公开录制节目。", "节目内容涉及对人生问题的辅导与建议。", "咲季作为广播人生辅导的参与者或主持人。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00363", "scene_id": "scene-00363", "source_file": "CSV/pevent/hski/adv_pevent_002_hski_sales_2-005-01.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_002_hski_sales_2-005-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "11", "line_count": 11}], "source_refs": ["CSV/pevent/hski/adv_pevent_002_hski_sales_2-005-01.csv:1-11"], "line_count": 11, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "team_story", "worldbuilding"], "title": "咲季体操课与食谱秘密", "summary": "咲季在体操课上展现亲和力，制作人称赞其擅长应付孩子。咲季否认这是理所当然，并透露食谱是秘密，不愿轻易透露。面对选项，咲季对时间结束表示无奈，强调体质差异。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽"], "worldbuilding_signals": ["工作"], "dialogue_style_signals": ["当然", "制作人", "啦"], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "给孩子们上体操课什么的"}, {"source_row": "8", "speaker": "咲季", "text_zh": "食谱是秘密呢"}, {"source_row": "7", "speaker": "制作人", "text_zh": "很擅长应付小孩子呢"}, {"source_row": "6", "speaker": "咲季", "text_zh": "每个人的体质都不一样啊"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季正在给孩子们上体操课。", "咲季表示食谱是秘密，不想被缠着要。", "制作人多次称赞咲季擅长应付小孩子。", "咲季认为体质不同，不能一概而论。"], "relationship_facts": ["咲季与制作人存在上下级或指导关系。", "咲季与孩子们有直接的互动教学关系。", "咲季与选项中的角色（佑芽、SSD）存在间接关联。"], "worldbuilding_facts": ["咲季的工作涉及给孩子们上体操课。", "咲季拥有不为人知的秘密食谱。", "每个人的体质存在差异。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00364", "scene_id": "scene-00364", "source_file": "CSV/pevent/hski/adv_pevent_002_hski_sales_2-005-02.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_002_hski_sales_2-005-02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "11", "line_count": 11}], "source_refs": ["CSV/pevent/hski/adv_pevent_002_hski_sales_2-005-02.csv:1-11"], "line_count": 11, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "worldbuilding"], "title": "体操课食谱的秘密", "summary": "咲季认为给孩子们上体操课非常适合自己，但制作人指出体操爱好者增多，暗示食谱可能外泄。咲季否认并强调食谱是秘密，面对制作人的反复追问，她坚持锻炼方式因人而异，不愿透露具体食谱内容。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽"], "worldbuilding_signals": ["工作"], "dialogue_style_signals": ["当然", "制作人", "啦"], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "给孩子们上体操课这种工作，不是正适合我吗！"}, {"source_row": "7", "speaker": "制作人", "text_zh": "网上都在讨论喜欢体操的孩子变多了。"}, {"source_row": "8", "speaker": "咲季", "text_zh": "是啊……食谱可是秘密呢，就算被人缠着要也很困扰哦。"}, {"source_row": "10", "speaker": "咲季", "text_zh": "别说得这么理所当然啦！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季认为给孩子们上体操课非常适合自己。", "网络上讨论喜欢体操的孩子变多了。", "咲季的食谱是秘密，不希望被人缠着索要。", "咲季认为身体锻炼方式因人而异。"], "relationship_facts": ["咲季与制作人是同事关系。", "咲季与孩子们是体操教练与学员的关系。", "咲季与佑芽同学存在某种关联（选项提及）。"], "worldbuilding_facts": ["咲季正在给孩子们上体操课。", "网络上有关于体操爱好者的讨论。", "咲季的食谱被视为需要保密的内容。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00365", "scene_id": "scene-00365", "source_file": "CSV/pevent/hski/adv_pevent_002_hski_sales_2-006-01.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_002_hski_sales_2-006-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "11", "line_count": 11}], "source_refs": ["CSV/pevent/hski/adv_pevent_002_hski_sales_2-006-01.csv:1-11"], "line_count": 11, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "team_story", "worldbuilding"], "title": "徒步赛中的咲季", "summary": "在徒步拉力赛现场，咲季负责巡视并提醒参与者补充水分，确保孩子们安全。赛事平安结束后，制作人称赞咲季表现优异。咲季表示这是为了防止孩子乱跑而进行的必要工作，且提醒工作与时节无关。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["制作人"], "worldbuilding_signals": ["工作"], "dialogue_style_signals": ["当然", "制作人"], "key_evidence": [{"source_row": "2", "speaker": "咲季", "text_zh": "在街上没问题的。"}, {"source_row": "6", "speaker": "咲季", "text_zh": "必须让大家好好享受才行。"}, {"source_row": "8", "speaker": "咲季", "text_zh": "这也是为了防止孩子们乱跑"}, {"source_row": "10", "speaker": "咲季", "text_zh": "我也会提醒参与者及时补充水分。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季在徒步拉力赛现场负责巡视和提供建议。", "咲季提醒参与者及时补充水分。", "徒步拉力赛最终平安结束。", "制作人称赞咲季很好地展现了自己。"], "relationship_facts": ["咲季是徒步拉力赛的巡视人员。", "制作人是赛事的观察者或负责人。", "咲季关注参与者的安全，特别是小孩子。"], "worldbuilding_facts": ["徒步拉力赛设有休息处。", "赛事期间存在迷路、车辆、中暑等潜在风险。", "咲季的工作职责与季节无关。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00366", "scene_id": "scene-00366", "source_file": "CSV/pevent/hski/adv_pevent_002_hski_sales_2-006-02.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_002_hski_sales_2-006-02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "11", "line_count": 11}], "source_refs": ["CSV/pevent/hski/adv_pevent_002_hski_sales_2-006-02.csv:1-11"], "line_count": 11, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "team_story", "worldbuilding"], "title": "徒步赛全员完赛", "summary": "咲季在市区徒步拉力赛中负责巡视与补给，确保儿童安全及防止中暑。尽管工作繁忙，她仍坚持鼓励所有参赛者，最终实现全员完赛无人退出的佳绩，展现了其细致入微的关怀与责任感。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["制作人"], "worldbuilding_signals": ["工作"], "dialogue_style_signals": ["当然", "制作人"], "key_evidence": [{"source_row": "2", "speaker": "咲季", "text_zh": "在市区里没问题的。"}, {"source_row": "6", "speaker": "咲季", "text_zh": "必须让大家玩得尽兴才行。"}, {"source_row": "10", "speaker": "咲季", "text_zh": "我也会提醒参赛者及时补充水分。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季在市区徒步拉力赛中负责巡视工作。", "咲季提醒参赛者及时补充水分以防中暑。", "徒步拉力赛最终实现全员完赛无人退出。", "咲季鼓励了所有参赛者完成比赛。"], "relationship_facts": ["咲季是徒步拉力赛的志愿者或工作人员。", "咲季负责照顾比赛中的儿童参与者。", "制作人对咲季的工作成果表示赞赏。"], "worldbuilding_facts": ["徒步拉力赛设有休息区供参与者使用。", "比赛地点位于市区范围内。", "比赛期间存在中暑和迷路等潜在风险。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00367", "scene_id": "scene-00367", "source_file": "CSV/pevent/hski/adv_pevent_002_hski_sales_3-001-01.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_002_hski_sales_3-001-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "11", "line_count": 11}], "source_refs": ["CSV/pevent/hski/adv_pevent_002_hski_sales_3-001-01.csv:1-11"], "line_count": 11, "speakers": ["制作人", "咲季", "选项"], "topics": ["relationships", "dialogue_style", "worldbuilding"], "title": "森林浴拍摄与咲季", "summary": "咲季在森林浴景点进行拍摄，虽无丰富经验但保持健康形象。她提醒制作人注意防暑，并强调先工作后享受。制作人称赞咲季与工作的绝配，并提及佑芽容易睡着的对比。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽"], "worldbuilding_signals": ["工作"], "dialogue_style_signals": ["制作人"], "key_evidence": [{"source_row": "1", "speaker": "制作人", "text_zh": "这是在森林浴景点的拍摄呢。"}, {"source_row": "6", "speaker": "咲季", "text_zh": "夏天也很凉快呢。要注意别感冒了。"}, {"source_row": "10", "speaker": "咲季", "text_zh": "先把工作完成！享受要留到之后哦！"}, {"source_row": "7", "speaker": "制作人", "text_zh": "和充满健康形象的咲季同学简直是绝配的工作呢。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季在森林浴景点进行拍摄工作。", "咲季表示夏天森林浴很凉快，提醒别感冒。", "咲季认为应先完成工作，享受留到之后。", "制作人认为咲季的健康形象适合此工作。"], "relationship_facts": ["咲季与制作人正在合作拍摄。", "咲季与佑芽存在性格或状态对比（佑芽易睡着）。", "制作人与咲季互相认可对方的状态。"], "worldbuilding_facts": ["场景位于森林浴景点。", "森林浴在夏天环境凉快。", "咲季拥有健康形象。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00368", "scene_id": "scene-00368", "source_file": "CSV/pevent/hski/adv_pevent_002_hski_sales_3-001-02.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_002_hski_sales_3-001-02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "11", "line_count": 11}], "source_refs": ["CSV/pevent/hski/adv_pevent_002_hski_sales_3-001-02.csv:1-11"], "line_count": 11, "speakers": ["制作人", "咲季", "选项"], "topics": ["relationships", "dialogue_style", "worldbuilding"], "title": "森林浴拍摄与粉丝活动", "summary": "咲季在森林浴景点参与拍摄，自嘲仅会跑步。她提醒制作人注意夏日温差防感冒，并强调工作优先。咲季评价队友佑芽容易睡着，对粉丝户外活动增加表示赞同，展现其敬业与亲和力。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽"], "worldbuilding_signals": ["工作"], "dialogue_style_signals": ["制作人"], "key_evidence": [{"source_row": "1", "speaker": "制作人", "text_zh": "这是在森林浴景点的拍摄。"}, {"source_row": "2", "speaker": "咲季", "text_zh": "森林浴的经验？顶多就是跑步顺带一下吧。"}, {"source_row": "6", "speaker": "咲季", "text_zh": "夏天也很凉快呢。要注意别感冒了。"}, {"source_row": "8", "speaker": "咲季", "text_zh": "佑芽可是会直接睡着的呢。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季在森林浴景点进行拍摄工作。", "咲季表示自己在森林浴方面经验不多，仅会跑步。", "咲季提醒制作人夏天在户外要注意防感冒。", "咲季认为工作优先，享受活动要等之后。"], "relationship_facts": ["咲季与制作人是同事关系。", "咲季与佑芽是队友关系。", "咲季对粉丝群体持友好态度。"], "worldbuilding_facts": ["当前场景位于森林浴景点。", "当前季节为夏天，气温凉快。", "粉丝们的户外活动数量有所增加。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00369", "scene_id": "scene-00369", "source_file": "CSV/pevent/hski/adv_pevent_002_hski_sales_3-002-01.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_002_hski_sales_3-002-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "11", "line_count": 11}], "source_refs": ["CSV/pevent/hski/adv_pevent_002_hski_sales_3-002-01.csv:1-11"], "line_count": 11, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships"], "title": "温泉宣传与美食体验", "summary": "咲季因无法与佑芽同行而遗憾，随后协助制作人策划温泉宣传。她提议结合运动项目、强调放松效果并推荐美食，认为运动后泡澡按摩是完美体验。制作人反馈宣传反响不错，咲季还邀请制作人亲自体验，并称赞宿舍休息与食物安排周到。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽"], "worldbuilding_signals": [], "dialogue_style_signals": ["真是的", "制作人"], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "好想和佑芽一起来啊～～～！"}, {"source_row": "6", "speaker": "咲季", "text_zh": "运动完可以泡完澡再做按摩！"}, {"source_row": "10", "speaker": "咲季", "text_zh": "还有鸡胸肉和沙拉呢。"}, {"source_row": "7", "speaker": "制作人", "text_zh": "但似乎反响不错。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季因无法和佑芽同行而感到遗憾。", "咲季提议将温泉宣传与运动项目结合。", "咲季认为运动后泡澡和按摩是完美体验。", "咲季称赞宿舍的食物安排非常周到。"], "relationship_facts": ["咲季与佑芽关系亲密，希望同行。", "咲季与制作人合作进行温泉宣传。", "咲季邀请制作人体验温泉设施。"], "worldbuilding_facts": ["温泉设施提供运动项目结合的宣传。", "温泉体验包含泡澡和按摩服务。", "宿舍提供鸡胸肉和沙拉等健康食物。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00370", "scene_id": "scene-00370", "source_file": "CSV/pevent/hski/adv_pevent_002_hski_sales_3-002-02.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_002_hski_sales_3-002-02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "11", "line_count": 11}], "source_refs": ["CSV/pevent/hski/adv_pevent_002_hski_sales_3-002-02.csv:1-11"], "line_count": 11, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships"], "title": "温泉宣传与运动搭配", "summary": "咲季因无法与佑芽同行而遗憾，随后向制作人提议将温泉宣传与运动结合。她推荐运动后泡澡加按摩的完美流程，并提及鸡胸肉沙拉等健康美食。制作人对此表示赞赏，认为咲季的名气正随其创意日益增长。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽"], "worldbuilding_signals": [], "dialogue_style_signals": ["真是的", "制作人"], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "好想和小佑芽一起来啊～"}, {"source_row": "6", "speaker": "咲季", "text_zh": "运动后泡完澡再来按摩！"}, {"source_row": "10", "speaker": "咲季", "text_zh": "还有鸡胸肉和沙拉呢。"}, {"source_row": "7", "speaker": "制作人", "text_zh": "咲季同学的名气也越来越大了呢。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季希望与佑芽一同前往温泉。", "咲季提议将运动与温泉宣传结合。", "咲季推荐运动后泡澡并配合按摩。", "咲季提到温泉提供鸡胸肉和沙拉。"], "relationship_facts": ["咲季与佑芽是好友。", "咲季与制作人是工作伙伴。", "咲季在制作人心目中名气渐增。"], "worldbuilding_facts": ["温泉宣传可结合运动项目。", "温泉设施提供按摩服务。", "温泉餐厅提供健康饮食如鸡胸肉。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00371", "scene_id": "scene-00371", "source_file": "CSV/pevent/hski/adv_pevent_002_hski_sales_3-003-01.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_002_hski_sales_3-003-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "11", "line_count": 11}], "source_refs": ["CSV/pevent/hski/adv_pevent_002_hski_sales_3-003-01.csv:1-11"], "line_count": 11, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "worldbuilding", "team_story"], "title": "咲季录制海洋生物语音", "summary": "制作人询问咲季对海洋生物的了解程度，咲季表示食用鱼类知识丰富。录制完成后，咲季自信地表示可解答所有食用海洋生物问题，并透露喜欢秋刀鱼，常将其作为鸡胸肉的替代品。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["制作人"], "worldbuilding_signals": ["工作"], "dialogue_style_signals": ["制作人"], "key_evidence": [{"source_row": "2", "speaker": "咲季", "text_zh": "如果是食用鱼类的话我倒很清楚。"}, {"source_row": "6", "speaker": "咲季", "text_zh": "我会把需要的知识都记下来的！"}, {"source_row": "8", "speaker": "咲季", "text_zh": "只要是能吃的海洋生物，什么问题都可以问我哦♪"}, {"source_row": "10", "speaker": "咲季", "text_zh": "大概是秋刀鱼吧。当季的时候我会用它代替鸡胸肉。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季对食用鱼类知识丰富", "录制导航语音工作顺利完成", "咲季喜欢秋刀鱼", "咲季用秋刀鱼代替鸡胸肉"], "relationship_facts": ["咲季与制作人进行对话", "制作人对咲季的工作表示安心", "咲季向制作人展示专业知识"], "worldbuilding_facts": ["游戏包含海洋生物导航语音", "秋刀鱼是当季食材", "鸡胸肉是常见肉类替代品"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00372", "scene_id": "scene-00372", "source_file": "CSV/pevent/hski/adv_pevent_002_hski_sales_3-003-02.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_002_hski_sales_3-003-02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "11", "line_count": 11}], "source_refs": ["CSV/pevent/hski/adv_pevent_002_hski_sales_3-003-02.csv:1-11"], "line_count": 11, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "team_story", "worldbuilding"], "title": "咲季录制海洋生物语音", "summary": "咲季为制作导航语音录制工作，自信表示会掌握所有海洋生物知识。她以食材角度了解生物，并推荐秋刀鱼作为当季替代鸡胸肉的食材。制作人称赞其认真态度让旁白更具说服力，咲季则幽默表示可询问任何可食用生物。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["制作人"], "worldbuilding_signals": ["工作"], "dialogue_style_signals": ["制作人"], "key_evidence": [{"source_row": "2", "speaker": "咲季", "text_zh": "如果是作为食材的话倒是很清楚。"}, {"source_row": "6", "speaker": "咲季", "text_zh": "我会把所有需要的知识都装进去的！"}, {"source_row": "7", "speaker": "制作人", "text_zh": "让旁白更有说服力了呢！"}, {"source_row": "10", "speaker": "咲季", "text_zh": "大概是秋刀鱼吧。当季的时候"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季表示对海洋生物的了解程度取决于是否作为食材。", "咲季计划将制作导航所需的所有海洋生物知识都装进语音中。", "制作人认为咲季的认真学习让旁白更有说服力。", "咲季推荐秋刀鱼作为当季可替代鸡胸肉的食材。"], "relationship_facts": ["咲季与制作人共同进行导航语音的录制工作。", "制作人对咲季的学习态度表示认可和赞赏。", "咲季向制作人展示其关于海洋生物的知识储备。"], "worldbuilding_facts": ["咲季将海洋生物知识用于制作导航语音。", "秋刀鱼在当季可作为鸡胸肉的替代品。", "咲季对可食用的海洋生物有详细的了解。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00373", "scene_id": "scene-00373", "source_file": "CSV/pevent/hski/adv_pevent_002_hski_sales_3-004-01.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_002_hski_sales_3-004-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "11", "line_count": 11}], "source_refs": ["CSV/pevent/hski/adv_pevent_002_hski_sales_3-004-01.csv:1-11"], "line_count": 11, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships"], "title": "咲季展示柔软体操秘诀", "summary": "制作人与咲季体验瑜伽，咲季展示惊人柔韧性并分享秘诀。制作人提议增加运动环节，咲季表示开心并强调每日坚持体操的重要性。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["制作人"], "worldbuilding_signals": [], "dialogue_style_signals": ["真是的", "呵呵", "制作人", "啦"], "key_evidence": [{"source_row": "2", "speaker": "咲季", "text_zh": "初学者级别的姿势对我来说太简单啦。"}, {"source_row": "6", "speaker": "咲季", "text_zh": "我会听从教练指导的。不过，告诉你也没关系哦。"}, {"source_row": "10", "speaker": "咲季", "text_zh": "每天坚持做柔软体操！这才是最重要的！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季作为瑜伽初学者，其身体柔软度令人惊讶。", "咲季表示每日坚持做柔软体操是最重要的。", "制作人认为咲季运动时很开心，建议增加运动环节。"], "relationship_facts": ["制作人与咲季是同学关系。", "制作人与咲季正在共同体验瑜伽课程。"], "worldbuilding_facts": ["咲季目前处于瑜伽初学者阶段。", "咲季认为每日坚持体操是保持柔软的关键。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00374", "scene_id": "scene-00374", "source_file": "CSV/pevent/hski/adv_pevent_002_hski_sales_3-004-02.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_002_hski_sales_3-004-02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "11", "line_count": 11}], "source_refs": ["CSV/pevent/hski/adv_pevent_002_hski_sales_3-004-02.csv:1-11"], "line_count": 11, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships"], "title": "咲季展示瑜伽柔韧性", "summary": "制作人在体验瑜伽时惊叹于咲季的柔软度。咲季自信表示初学者姿势很简单，并透露秘诀是坚持拉伸运动。制作人称赞其高难度姿势保持能力，认为咲季很有潜力，咲季对此表示认同并强调日常锻炼的重要性。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["制作人"], "worldbuilding_signals": [], "dialogue_style_signals": ["真是的", "呵呵", "制作人", "啦"], "key_evidence": [{"source_row": "2", "speaker": "咲季", "text_zh": "初学者级别的姿势对我来说很简单啦。"}, {"source_row": "10", "speaker": "咲季", "text_zh": "每天坚持做拉伸运动！这才是最重要的！"}, {"source_row": "7", "speaker": "制作人", "text_zh": "居然能保持这么高难度的姿势…很有潜力啊！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季认为初学者级别的瑜伽姿势对她来说很简单。", "咲季表示保持高难度姿势的秘诀是每天坚持做拉伸运动。", "制作人认为咲季能保持高难度姿势，证明其很有潜力。"], "relationship_facts": ["制作人与咲季正在一起体验瑜伽。", "制作人对咲季的柔韧性表示惊讶和赞赏。", "咲季愿意向制作人分享保持柔韧性的秘诀。"], "worldbuilding_facts": ["咲季具备超出初学者水平的瑜伽柔韧性。", "瑜伽练习中区分了初学者级别和高难度动作。", "坚持拉伸运动是提升柔韧性的关键方法。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00375", "scene_id": "scene-00375", "source_file": "CSV/pevent/hski/adv_pevent_002_hski_sales_3-005-01.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_002_hski_sales_3-005-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "11", "line_count": 11}], "source_refs": ["CSV/pevent/hski/adv_pevent_002_hski_sales_3-005-01.csv:1-11"], "line_count": 11, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "worldbuilding"], "title": "温泉店一日老板娘体验", "summary": "咲季参观温泉后干劲十足，决定体验一日老板娘工作。制作人安排采访、拍摄等任务，咲季自信能应对团体客人。工作之余，咲季提议去特产店为佑芽购物，展现了轻松愉快的氛围。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽"], "worldbuilding_signals": ["工作"], "dialogue_style_signals": ["制作人", "啦"], "key_evidence": [{"source_row": "6", "speaker": "咲季", "text_zh": "工作流程我已经完全记住啦！"}, {"source_row": "8", "speaker": "咲季", "text_zh": "那在开始前先体验一下吧！"}, {"source_row": "10", "speaker": "咲季", "text_zh": "我要去特产店吗？"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季参观温泉后感到干劲十足。", "咲季决定在开始前先体验温泉设施。", "咲季提议去特产店为佑芽购买物品。", "制作人安排了采访和拍摄视频的工作。"], "relationship_facts": ["咲季与制作人存在工作上下级关系。", "咲季与佑芽是朋友或熟人关系。", "咲季与制作人共同进行温泉店的工作。"], "worldbuilding_facts": ["温泉设施相当气派。", "温泉店有特产店可供购物。", "温泉店接待团体客人。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00376", "scene_id": "scene-00376", "source_file": "CSV/pevent/hski/adv_pevent_002_hski_sales_3-005-02.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_002_hski_sales_3-005-02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "11", "line_count": 11}], "source_refs": ["CSV/pevent/hski/adv_pevent_002_hski_sales_3-005-02.csv:1-11"], "line_count": 11, "speakers": ["制作人", "咲季", "选项"], "topics": ["worldbuilding", "relationships", "dialogue_style"], "title": "温泉店掌柜与特产采购", "summary": "咲季对温泉设施赞不绝口，干劲十足。制作人安排其体验工作并负责土特产店，咲季计划为佑芽购买特产。工作结束后将泡温泉，预计引发话题反响。咲季自信能应对团体客人，并愿先体验流程再做精准介绍。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽"], "worldbuilding_signals": ["工作"], "dialogue_style_signals": ["制作人"], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "实际一看，真是非常气派的温泉呢。"}, {"source_row": "3", "speaker": "选项", "text_zh": "担任一日女掌柜"}, {"source_row": "10", "speaker": "咲季", "text_zh": "我负责土特产店？给佑芽也买些吧。"}, {"source_row": "7", "speaker": "制作人", "text_zh": "工作结束后泡了温泉，引发话题反响。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季对温泉设施评价很高，工作干劲十足。", "咲季被安排负责土特产店，并计划为佑芽购买特产。", "工作结束后将安排泡温泉，预计引发话题反响。", "咲季自信能应对团体客人，并愿先体验流程。"], "relationship_facts": ["咲季与制作人存在工作上下级关系。", "咲季与佑芽存在朋友或熟人关系，咲季愿为其购买特产。", "制作人与佑芽存在关联，通过咲季的工作安排间接联系。"], "worldbuilding_facts": ["温泉设施气派，适合引发话题反响。", "存在土特产店，可作为工作场所。", "团体客人是温泉店可能接待的顾客类型。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00377", "scene_id": "scene-00377", "source_file": "CSV/pevent/hski/adv_pevent_002_hski_sales_3-006-01.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_002_hski_sales_3-006-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "11", "line_count": 11}], "source_refs": ["CSV/pevent/hski/adv_pevent_002_hski_sales_3-006-01.csv:1-11"], "line_count": 11, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships"], "title": "咲季宣传露营特色项目", "summary": "制作人邀请咲季宣传露营场特色项目，咲季热情回应并列举钟乳洞、徒步及激流泛舟等项目。制作人称赞咲季与户外活动合拍，咲季表示对此地早有向往，双方约定未来有机会再一同尝试这些户外活动。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["制作人"], "worldbuilding_signals": [], "dialogue_style_signals": ["制作人", "不是吗"], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "今天要在这里野外求生一整天哦！"}, {"source_row": "3", "speaker": "选项", "text_zh": "是钟乳洞"}, {"source_row": "7", "speaker": "制作人", "text_zh": "咲季同学和户外活动很合拍呢。"}, {"source_row": "10", "speaker": "咲季", "text_zh": "很不错啊！自从知道这个地方就一直想试试呢！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季主动提议在野外求生一整天。", "露营场提供钟乳洞、徒步路线及激流泛舟等特色项目。", "咲季表示自从知道该地就一直想尝试这些项目。", "制作人认为咲季与户外活动非常合拍。"], "relationship_facts": ["制作人与咲季关系融洽，制作人主动邀请咲季宣传项目。", "制作人欣赏咲季对户外活动的热情与合拍度。", "咲季对制作人提出的露营场项目表现出浓厚兴趣。"], "worldbuilding_facts": ["露营场设有钟乳洞、徒步路线和激流泛舟等户外设施。", "该露营场适合进行一整天的野外活动。", "制作人与咲季之间存在共同参与户外活动的潜在机会。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00378", "scene_id": "scene-00378", "source_file": "CSV/pevent/hski/adv_pevent_002_hski_sales_3-006-02.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_002_hski_sales_3-006-02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "11", "line_count": 11}], "source_refs": ["CSV/pevent/hski/adv_pevent_002_hski_sales_3-006-02.csv:1-11"], "line_count": 11, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "worldbuilding"], "title": "咲季挑战露营活动", "summary": "咲季误以为今日是生存挑战，后得知实为露营场宣传。面对钟乳洞、徒步及激流泛舟等选项，咲季对激流泛舟表现出浓厚兴趣。制作人惊叹其惊人体力，咲季自信准备充分，渴望尝试该活动。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["制作人"], "worldbuilding_signals": ["工作"], "dialogue_style_signals": ["制作人", "不是吗"], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "今天要在这里进行一整天的生存挑战呢！"}, {"source_row": "3", "speaker": "选项", "text_zh": "是钟乳洞"}, {"source_row": "5", "speaker": "选项", "text_zh": "激流泛舟"}, {"source_row": "7", "speaker": "制作人", "text_zh": "体力真惊人。这种类型的活动简直无人能敌啊……！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季误以为当天是生存挑战。", "活动实为露营场特色宣传。", "咲季对激流泛舟选项表现出兴趣。", "制作人称赞咲季体力惊人。"], "relationship_facts": ["咲季与制作人进行对话互动。", "制作人对咲季的体力表示惊讶。", "咲季视制作人为活动引导者。"], "worldbuilding_facts": ["活动包含钟乳洞、徒步路线及激流泛舟。", "激流泛舟被描述为适合体力的活动。", "露营场具有多种特色项目供体验。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00379", "scene_id": "scene-00379", "source_file": "CSV/pevent/hski/adv_pevent_002_hski_sales_4-001-01.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_002_hski_sales_4-001-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "11", "line_count": 11}], "source_refs": ["CSV/pevent/hski/adv_pevent_002_hski_sales_4-001-01.csv:1-11"], "line_count": 11, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "plot", "worldbuilding"], "title": "咲季演唱会登场", "summary": "演唱会即将开始，咲季作为首位登场者已做好万全准备。面对制作人对其精湛表演的赞叹，咲季表示今日也要全力以赴获胜。她虽认可表演的温柔，但更偏爱胜利的感觉，展现出对舞台的执着与自信。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["制作人"], "worldbuilding_signals": ["演唱会"], "dialogue_style_signals": ["当然", "制作人"], "key_evidence": [{"source_row": "1", "speaker": "制作人", "text_zh": "咲季同学是第一个登场呢。"}, {"source_row": "2", "speaker": "咲季", "text_zh": "我已经准备好了。"}, {"source_row": "6", "speaker": "咲季", "text_zh": "那么，今天也要赢下来呢。"}, {"source_row": "10", "speaker": "咲季", "text_zh": "不过我更喜欢赢的感觉。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季是本次演唱会的第一个登场角色。", "咲季表示今天也要像往常一样赢下来。", "制作人对咲季日益精湛的表演表示赞叹。", "咲季更喜欢赢的感觉胜过表演的温柔。"], "relationship_facts": ["咲季与制作人共同筹备演唱会。", "制作人是咲季表演的见证者与评价者。", "咲季视制作人为可信赖的对话对象。"], "worldbuilding_facts": ["咲季正在进行一场重要的演唱会演出。", "咲季对舞台表演有着极高的自我要求。", "咲季保持着每天练习或准备的状态。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00380", "scene_id": "scene-00380", "source_file": "CSV/pevent/hski/adv_pevent_002_hski_sales_4-001-02.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_002_hski_sales_4-001-02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "11", "line_count": 11}], "source_refs": ["CSV/pevent/hski/adv_pevent_002_hski_sales_4-001-02.csv:1-11"], "line_count": 11, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships"], "title": "咲季舞台首秀", "summary": "制作人宣布演出开始，咲季作为首位登场者准备就绪。面对选项，咲季表示今日也要赢回胜利，并感谢制作人的温柔。观众被其震撼，咲季自信地表示一天都没忘记，今天同样全力以赴，展现了她渴望胜利与温柔的一面。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["制作人"], "worldbuilding_signals": [], "dialogue_style_signals": ["当然", "制作人"], "key_evidence": [{"source_row": "1", "speaker": "制作人", "text_zh": "咲季同学是第一个上场呢。"}, {"source_row": "6", "speaker": "咲季", "text_zh": "那么，今天也要赢回来哦。"}, {"source_row": "10", "speaker": "咲季", "text_zh": "我可是很喜欢赢的。"}, {"source_row": "11", "speaker": "制作人", "text_zh": "这就是咲季同学的表演。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季是本次演出的第一位上场者。", "咲季表示今天也要赢回来。", "咲季很喜欢赢的感觉。", "制作人对咲季的态度很温柔。"], "relationship_facts": ["咲季与制作人关系良好。", "咲季对制作人表现出信任。", "咲季将制作人视为重要伙伴。"], "worldbuilding_facts": ["演出是重要事件。", "咲季有过去的失败经历。", "咲季通过表演赢得观众震撼。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00381", "scene_id": "scene-00381", "source_file": "CSV/pevent/hski/adv_pevent_002_hski_sales_4-002-01.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_002_hski_sales_4-002-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "11", "line_count": 11}], "source_refs": ["CSV/pevent/hski/adv_pevent_002_hski_sales_4-002-01.csv:1-11"], "line_count": 11, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "character_arc", "team_story"], "title": "咲季自信应对冷门运动", "summary": "谈话活动中，咲季确认已阅读资料并调查完毕，对冷门运动话题充满自信。制作人称赞其专长，咲季解释自信源于充分准备，随后提议离开。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["制作人"], "worldbuilding_signals": [], "dialogue_style_signals": ["当然", "嘿嘿", "制作人"], "key_evidence": [{"source_row": "2", "speaker": "咲季", "text_zh": "当然读过了。其他方面也做了各种调查"}, {"source_row": "7", "speaker": "制作人", "text_zh": "聊起冷门运动话题就特别起劲。"}, {"source_row": "8", "speaker": "咲季", "text_zh": "嘛，这可是我的专长领域呢。"}, {"source_row": "10", "speaker": "咲季", "text_zh": "只是准备到能让自己有信心而已。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季已阅读并调查了谈话活动所需资料。", "咲季对冷门运动话题表现出特别的兴趣与自信。", "咲季认为自信源于将准备做到让自己确信的程度。", "咲季在对话结束后提议与制作人离开。"], "relationship_facts": ["制作人与咲季正在进行谈话活动。", "制作人对咲季在冷门运动领域的知识表示赞赏。", "咲季视冷门运动知识为自己的专长领域。"], "worldbuilding_facts": ["当前场景为谈话活动。", "咲季擅长冷门运动话题。", "咲季对冷门运动知识有深入的了解。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00382", "scene_id": "scene-00382", "source_file": "CSV/pevent/hski/adv_pevent_002_hski_sales_4-002-02.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_002_hski_sales_4-002-02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "11", "line_count": 11}], "source_refs": ["CSV/pevent/hski/adv_pevent_002_hski_sales_4-002-02.csv:1-11"], "line_count": 11, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "team_story"], "title": "咲季自信应对谈话活动", "summary": "咲季在谈话活动中自信表示已充分研读资料并调查其他信息，对制作人提及的身体塑造话题也了如指掌。她认为之前的热情演说很受欢迎，但强调自己只是做好充分准备以建立信心，随后提议结束话题并准备离开现场。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["制作人"], "worldbuilding_signals": [], "dialogue_style_signals": ["当然", "嘿嘿", "制作人"], "key_evidence": [{"source_row": "2", "speaker": "咲季", "text_zh": "当然读过了。还调查了很多其他资料"}, {"source_row": "8", "speaker": "咲季", "text_zh": "嘛，这可是我的专长领域。"}, {"source_row": "10", "speaker": "咲季", "text_zh": "只是准备到能让自己充满信心而已。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季已阅读并调查了谈话活动的相关资料。", "咲季擅长运动细节及身体塑造方面的话题。", "咲季认为之前的热情演说很受欢迎。", "咲季表示只是做好充分准备以建立信心。"], "relationship_facts": ["咲季与制作人共同参与谈话活动。", "咲季对制作人的话题延伸表现出自信回应。", "咲季与制作人之间存在关于演说受欢迎程度的共识。"], "worldbuilding_facts": ["谈话活动是剧情中的重要环节。", "咲季具备运动及身体塑造方面的专长。", "咲季通过充分准备来建立自信。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00383", "scene_id": "scene-00383", "source_file": "CSV/pevent/hski/adv_pevent_002_hski_sales_4-003-01.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_002_hski_sales_4-003-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "11", "line_count": 11}], "source_refs": ["CSV/pevent/hski/adv_pevent_002_hski_sales_4-003-01.csv:1-11"], "line_count": 11, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "worldbuilding"], "title": "咲季初体验握手会", "summary": "咲季在握手会上面对众多粉丝感到惊讶，决心展现不输他人的偶像魅力。制作人评价其应对中规中矩，咲季对此表示不满，认为自己被低估，并准备全力以赴让粉丝体验难忘的互动。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["真是的", "制作人"], "key_evidence": [{"source_row": "2", "speaker": "咲季", "text_zh": "亲眼看到才发现数量惊人呢……"}, {"source_row": "8", "speaker": "咲季", "text_zh": "不输给佑芽的偶像魅力……"}, {"source_row": "7", "speaker": "制作人", "text_zh": "应对得中规中矩。"}, {"source_row": "10", "speaker": "咲季", "text_zh": "真是的，你们把我看成什么人了啊！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季亲眼看到粉丝数量感到惊讶。", "咲季决心展现不输佑芽的偶像魅力。", "制作人认为咲季的应对中规中矩。", "咲季对制作人的评价表示不满。"], "relationship_facts": ["咲季与佑芽存在偶像魅力对比。", "制作人与咲季是上下级或指导关系。", "咲季与粉丝是偶像与受众关系。"], "worldbuilding_facts": ["存在名为佑芽的知名偶像作为参照。", "场景设定为握手会活动。", "咲季是偶像团体成员。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00384", "scene_id": "scene-00384", "source_file": "CSV/pevent/hski/adv_pevent_002_hski_sales_4-003-02.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_002_hski_sales_4-003-02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "11", "line_count": 11}], "source_refs": ["CSV/pevent/hski/adv_pevent_002_hski_sales_4-003-02.csv:1-11"], "line_count": 11, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "worldbuilding"], "title": "咲季握手会决心", "summary": "面对众多粉丝，咲季感叹人数惊人并决心展现偶像魅力。她立志不输给佑芽，要让握手会成为难忘回忆。尽管制作人称赞其有力握手，咲季却害羞否认，展现出偶像的娇羞与成长。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["真是的", "制作人"], "key_evidence": [{"source_row": "2", "speaker": "咲季", "text_zh": "亲眼看到才知道数量这么惊人……"}, {"source_row": "8", "speaker": "咲季", "text_zh": "不能输给佑芽，要展现偶像的魅力"}, {"source_row": "10", "speaker": "咲季", "text_zh": "真是的，你们把我想成什么人了啊！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["握手会聚集了大量咲季的粉丝。", "咲季决心展现偶像魅力，不输给佑芽。", "制作人称赞咲季有力的握手能印在粉丝心中。", "咲季害羞否认制作人对其握力的评价。"], "relationship_facts": ["咲季与佑芽存在竞争关系。", "制作人与咲季是上下级或指导关系。", "咲季拥有大量粉丝。"], "worldbuilding_facts": ["存在名为“握手会”的偶像活动。", "咲季是偶像团体成员。", "佑芽是咲季的竞争对手或队友。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00385", "scene_id": "scene-00385", "source_file": "CSV/pevent/hski/adv_pevent_002_hski_sales_4-004-01.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_002_hski_sales_4-004-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "11", "line_count": 11}], "source_refs": ["CSV/pevent/hski/adv_pevent_002_hski_sales_4-004-01.csv:1-11"], "line_count": 11, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "team_story", "character_arc"], "title": "试映会后的姐妹情", "summary": "电影宣传活动试映会结束后，咲季感叹姐妹情深并自信表示胜过对手。制作人询问对动作场景的看法，咲季称赞专业演员的严格训练。尽管对话中制作人重复提及粉丝会因咲季推荐而观影，咲季仍强调大家本质善良，展现了积极乐观的互动氛围。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["制作人"], "worldbuilding_signals": ["训练"], "dialogue_style_signals": ["制作人", "啦"], "key_evidence": [{"source_row": "2", "speaker": "咲季", "text_zh": "真是美好的姐妹情呢……"}, {"source_row": "8", "speaker": "咲季", "text_zh": "那些都是经过严格训练的动作呢……"}, {"source_row": "10", "speaker": "咲季", "text_zh": "说到底大家都是好人这点最棒了呢。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["今天是电影宣传活动的试映会。", "咲季认为试映会展现了美好的姐妹情。", "咲季称赞专业演员的动作是经过严格训练的。", "咲季认为大家本质上都是好人。"], "relationship_facts": ["咲季与制作人讨论宣传活动。", "咲季与对手（姐妹）存在竞争关系。", "咲季与粉丝之间存在推荐与被推荐的关系。"], "worldbuilding_facts": ["当前场景为电影宣传活动的试映会。", "咲季是能够影响粉丝观影意愿的推荐人。", "咲季具备专业演员般的严格训练背景。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00386", "scene_id": "scene-00386", "source_file": "CSV/pevent/hski/adv_pevent_002_hski_sales_4-004-02.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_002_hski_sales_4-004-02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "11", "line_count": 11}], "source_refs": ["CSV/pevent/hski/adv_pevent_002_hski_sales_4-004-02.csv:1-11"], "line_count": 11, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "team_story", "character_arc"], "title": "试映会后的感想", "summary": "试映会结束后，咲季感叹姐妹情深，并自信表示在动作戏上胜过对方。制作人称赞宣传巧妙，咲季则强调演员的专业训练。最后咲季认为大家本质都是好人，对宣传活动给予肯定。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["制作人"], "worldbuilding_signals": ["训练"], "dialogue_style_signals": ["制作人"], "key_evidence": [{"source_row": "2", "speaker": "咲季", "text_zh": "真是感人的姐妹情呢……"}, {"source_row": "8", "speaker": "咲季", "text_zh": "那些动作都是经过严格训练的……"}, {"source_row": "10", "speaker": "咲季", "text_zh": "说到底大家其实都是好人"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["试映会展现了感人的姐妹情。", "咲季在动作戏方面胜过对方。", "咲季认为演员都是经过严格训练的专业人士。", "咲季认为大家本质上都是好人。"], "relationship_facts": ["咲季与花海同学是姐妹关系。", "咲季与制作人讨论宣传活动。", "咲季与花海同学是演员搭档。"], "worldbuilding_facts": ["当前场景为电影宣传活动。", "咲季具备专业的动作表演能力。", "宣传活动旨在结合角色关系进行推广。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00387", "scene_id": "scene-00387", "source_file": "CSV/pevent/hski/adv_pevent_002_hski_sales_4-005-01.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_002_hski_sales_4-005-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "11", "line_count": 11}], "source_refs": ["CSV/pevent/hski/adv_pevent_002_hski_sales_4-005-01.csv:1-11"], "line_count": 11, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships"], "title": "制作人拍摄咲季游戏", "summary": "制作人在未做调查的情况下，安排咲季参与游戏节目得分挑战。咲季选择空气曲棍球后，因抓娃娃失败和遭遇多人碰撞而狼狈不堪。制作人全程拍摄，认为这些滑稽画面正如他所料，成功捕捉到了咲季窘迫又搞笑的瞬间。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["制作人"], "worldbuilding_signals": [], "dialogue_style_signals": ["制作人"], "key_evidence": [{"source_row": "2", "speaker": "制作人", "text_zh": "这次特意没做任何调查就来了。"}, {"source_row": "1", "speaker": "咲季", "text_zh": "我要选空气曲棍球！"}, {"source_row": "6", "speaker": "咲季", "text_zh": "根本抓不到好不好！"}, {"source_row": "11", "speaker": "制作人", "text_zh": "很好，拍到了滑稽的画面。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["制作人特意未做调查就安排咲季参与游戏节目。", "咲季选择了空气曲棍球项目。", "咲季在抓娃娃环节完全失败。", "咲季在游戏中遭遇了多人碰撞。"], "relationship_facts": ["制作人是活动的策划者和拍摄者。", "咲季是游戏节目的参与者。", "制作人对咲季的失败表现感到满意。"], "worldbuilding_facts": ["场景设定为游戏节目的得分挑战环节。", "游戏项目包含抓娃娃、射击和赛车等类型。", "节目允许玩家与多名敌人进行互动。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00388", "scene_id": "scene-00388", "source_file": "CSV/pevent/hski/adv_pevent_002_hski_sales_4-005-02.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_002_hski_sales_4-005-02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "11", "line_count": 11}], "source_refs": ["CSV/pevent/hski/adv_pevent_002_hski_sales_4-005-02.csv:1-11"], "line_count": 11, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships"], "title": "咲季挑战游戏节目", "summary": "咲季参加制作人安排的游戏节目，选择空气曲棍球却因操作困难连连失败。面对抓娃娃、射击等选项，她因无法应对敌人数量和冲撞攻击而崩溃。制作人认为这种狼狈表现极具节目效果，或许能助她在该领域走红。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["制作人"], "worldbuilding_signals": [], "dialogue_style_signals": ["制作人"], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "我选空气曲棍球！"}, {"source_row": "6", "speaker": "咲季", "text_zh": "根本抓不到啊！"}, {"source_row": "8", "speaker": "咲季", "text_zh": "敌人也太多了吧"}, {"source_row": "11", "speaker": "制作人", "text_zh": "更有节目效果呢"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季选择了空气曲棍球作为挑战项目。", "咲季在抓娃娃环节表示根本抓不到。", "咲季抱怨敌人数量太多且遭遇冲撞攻击。", "制作人认为咲季的失败表现具有节目效果。"], "relationship_facts": ["制作人是游戏节目的安排者。", "咲季是游戏节目的参与者。", "制作人与咲季存在节目效果上的互动。"], "worldbuilding_facts": ["节目包含空气曲棍球、抓娃娃、射击、赛车等项目。", "游戏节目中存在冲撞攻击机制。", "节目效果可能成为走红的关键因素。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00389", "scene_id": "scene-00389", "source_file": "CSV/pevent/hski/adv_pevent_002_hski_sales_4-006-01.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_002_hski_sales_4-006-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "11", "line_count": 11}], "source_refs": ["CSV/pevent/hski/adv_pevent_002_hski_sales_4-006-01.csv:1-11"], "line_count": 11, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "team_story"], "title": "咲季签名会准备", "summary": "签名会即将开始，咲季自信地表示会为所有排队的人签名，并期待粉丝数量增加。制作人指出粉丝会因开心接过签名而增长，咲季为此已做好充分锻炼准备，展现出对活动的热情与期待。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["制作人"], "worldbuilding_signals": [], "dialogue_style_signals": ["哼", "制作人", "啦"], "key_evidence": [{"source_row": "1", "speaker": "制作人", "text_zh": "来吧，签名会开始了。"}, {"source_row": "2", "speaker": "咲季", "text_zh": "这队伍里的所有人，都是想要我的签名对吧。"}, {"source_row": "6", "speaker": "咲季", "text_zh": "不管来多少人，我都会给所有人签名的！"}, {"source_row": "8", "speaker": "咲季", "text_zh": "真期待签名会结束后，粉丝会增加多少呢♪"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["签名会即将开始，现场已有排队粉丝。", "咲季自信表示会为所有人签名。", "咲季期待签名会后粉丝数量增加。", "咲季为活动进行了充分锻炼准备。"], "relationship_facts": ["咲季与粉丝存在互动关系。", "制作人与咲季共同筹备活动。", "选项代表玩家视角参与对话。"], "worldbuilding_facts": ["签名会是提升粉丝数量的活动。", "咲季具备为大量粉丝签名的能力。", "活动成功可带来粉丝增长。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00390", "scene_id": "scene-00390", "source_file": "CSV/pevent/hski/adv_pevent_002_hski_sales_4-006-02.csv", "source_kind": "pevent", "chapter": "pevent/hski", "scene": "adv_pevent_002_hski_sales_4-006-02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "11", "line_count": 11}], "source_refs": ["CSV/pevent/hski/adv_pevent_002_hski_sales_4-006-02.csv:1-11"], "line_count": 11, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "team_story"], "title": "咲季签名会圆满举行", "summary": "签名会现场粉丝排成长队，咲季以惊人的速度为所有人签名并维持高满意度。她自信表示为此锻炼过，期待粉丝数量增长。制作人称赞其表现，咲季展现出对工作的热情与活力。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["制作人"], "worldbuilding_signals": [], "dialogue_style_signals": ["呵呵", "制作人", "啦"], "key_evidence": [{"source_row": "1", "speaker": "制作人", "text_zh": "来吧，签名会开始了。"}, {"source_row": "2", "speaker": "咲季", "text_zh": "呵呵呵……这一整列的人，"}, {"source_row": "6", "speaker": "咲季", "text_zh": "我都会给所有人签名的！"}, {"source_row": "7", "speaker": "制作人", "text_zh": "以惊人的速度处理着……"}, {"source_row": "10", "speaker": "咲季", "text_zh": "我可是好好锻炼过了！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["签名会现场粉丝排成长队等待签名。", "咲季以惊人速度处理签名并维持满意度。", "咲季表示为了这一天好好锻炼过。", "咲季期待签名会后粉丝数量增加。"], "relationship_facts": ["咲季是制作人的艺人。", "咲季面对粉丝热情回应。", "制作人负责监督活动流程。"], "worldbuilding_facts": ["活动包含签名会环节。", "粉丝对咲季有高度期待。", "艺人需锻炼以应对大量签名。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00391", "scene_id": "scene-00391", "source_file": "CSV/pevent/hume/adv_pevent_002_hume_sales_1-002-01.csv", "source_kind": "pevent", "chapter": "pevent/hume", "scene": "adv_pevent_002_hume_sales_1-002-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "12", "line_count": 12}], "source_refs": ["CSV/pevent/hume/adv_pevent_002_hume_sales_1-002-01.csv:1-12"], "line_count": 12, "speakers": ["佑芽", "制作人", "选项"], "topics": ["relationships", "dialogue_style", "team_story", "worldbuilding"], "title": "花海咲季饮品宣传", "summary": "佑芽与制作人来到N.I.A联名咖啡厅，品尝并宣传三款角色特调饮品。佑芽先品尝自己的饮品，随后称赞筱泽广的饮品造型神奇且风格独特，认为喝下会变聪明。咲季虽未直接出场，但作为联名角色之一，其特调饮品被重点提及并受到好评。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "广", "姐姐"], "worldbuilding_signals": ["工作"], "dialogue_style_signals": ["制作人"], "key_evidence": [{"source_row": "5", "speaker": "选项", "text_zh": "选项：花海咲季的联名饮品"}, {"source_row": "9", "speaker": "佑芽", "text_zh": "虽然比不上姐姐亲手调制的饮品"}, {"source_row": "11", "speaker": "佑芽", "text_zh": "造型好神奇，很有小广的风格！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["佑芽与制作人正在N.I.A联名咖啡厅进行饮品品尝宣传工作。", "佑芽品尝了自己的特调饮品，表示超级好喝。", "筱泽广的联名饮品造型神奇，具有其个人风格。", "咲季的联名饮品是本次宣传活动的选项之一。"], "relationship_facts": ["佑芽称呼咲季为姐姐。", "佑芽与制作人是同事关系。", "佑芽、制作人、筱泽广均为N.I.A相关角色。"], "worldbuilding_facts": ["N.I.A与咖啡厅进行了联名活动。", "活动包含花海佑芽、花海咲季、筱泽广三位角色的特调饮品。", "筱泽广的饮品设定具有让人变聪明的效果。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00392", "scene_id": "scene-00392", "source_file": "CSV/pevent/hume/adv_pevent_002_hume_sales_1-002-02.csv", "source_kind": "pevent", "chapter": "pevent/hume", "scene": "adv_pevent_002_hume_sales_1-002-02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "12", "line_count": 12}], "source_refs": ["CSV/pevent/hume/adv_pevent_002_hume_sales_1-002-02.csv:1-12"], "line_count": 12, "speakers": ["佑芽", "制作人", "选项"], "topics": ["relationships", "dialogue_style", "team_story", "worldbuilding"], "title": "花海咲季联名饮品", "summary": "佑芽在N.I.A联名咖啡厅进行饮品宣传，制作人确认宣传效果良好。佑芽将咲季的特饮形容为造型神奇且充满小广风格，并好奇饮用后是否变聪明，侧面提及咲季未直接出场。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "广", "姐姐"], "worldbuilding_signals": ["工作"], "dialogue_style_signals": ["制作人"], "key_evidence": [{"source_row": "1", "speaker": "佑芽", "text_zh": "这里就是『N.I.A』联名咖啡厅……"}, {"source_row": "5", "speaker": "选项", "text_zh": "选项：花海咲季的联名饮品"}, {"source_row": "11", "speaker": "佑芽", "text_zh": "造型好神奇，很有小广的风格！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["佑芽在N.I.A联名咖啡厅进行饮品宣传。", "制作人确认佑芽的宣传效果不错。", "咲季的联名饮品造型神奇，具有筱泽广的风格。", "佑芽好奇饮用咲季特饮后是否会变聪明。"], "relationship_facts": ["佑芽与咲季是姐妹关系。", "佑芽与筱泽广是同事或朋友关系。", "制作人是佑芽的上级或指导者。"], "worldbuilding_facts": ["存在N.I.A联名咖啡厅。", "咖啡厅提供花海咲季、花海佑芽、筱泽广的联名特饮。", "筱泽广的饮品风格独特，能让人联想到其本人。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00393", "scene_id": "scene-00393", "source_file": "CSV/pevent/ssmk/adv_pevent_001_ssmk_activity_010.csv", "source_kind": "pevent", "chapter": "pevent/ssmk", "scene": "adv_pevent_001_ssmk_activity_010", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "20", "line_count": 20}], "source_refs": ["CSV/pevent/ssmk/adv_pevent_001_ssmk_activity_010.csv:1-20"], "line_count": 20, "speakers": ["制作人", "清夏", "选项"], "topics": ["team_story", "dialogue_style", "relationships"], "title": "清夏想养宠物被拒", "summary": "清夏受电视剧影响想养宠物，先提议大型犬但因室内限制放弃，转而考虑会说话的鹦鹉并取名小P亲。制作人虽认同其想法，但告知宿舍禁止养宠物，令清夏失落。咲季全程未直接出场，仅作为清夏的自称对象被提及。", "saki_role": "被提及对象：咲季未必直接发言，但场景信息与她的关系或评价有关。", "relationship_signals": ["制作人", "清夏"], "worldbuilding_signals": [], "dialogue_style_signals": ["制作人"], "key_evidence": [{"source_row": "1", "speaker": "清夏", "text_zh": "我想养宠物诶～"}, {"source_row": "11", "speaker": "清夏", "text_zh": "我想养大型犬，但在室内没法养吧？"}, {"source_row": "14", "speaker": "清夏", "text_zh": "鹦鹉就是那个对吧！会学人说话的对吧？"}, {"source_row": "18", "speaker": "制作人", "text_zh": "宿舍是禁止养宠物的哦。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["清夏想养宠物，最初倾向于大型犬。", "清夏因室内限制放弃养大型犬，转而考虑鹦鹉。", "制作人告知宿舍禁止养宠物。", "清夏因无法养宠物而感到失落。"], "relationship_facts": ["清夏与制作人是同事或上下级关系。", "清夏称呼制作人为P亲。", "清夏希望未来的宠物鹦鹉称呼自己为小咲季。"], "worldbuilding_facts": ["宿舍内禁止饲养宠物。", "大型犬不适合在室内饲养。", "鹦鹉具有模仿人类说话的能力。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00394", "scene_id": "scene-00394", "source_file": "CSV/pgrowth/hski/adv_pgrowth_001_hski_01.csv", "source_kind": "pgrowth", "chapter": "pgrowth/hski", "scene": "adv_pgrowth_001_hski_01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "4", "line_count": 4}], "source_refs": ["CSV/pgrowth/hski/adv_pgrowth_001_hski_01.csv:1-4"], "line_count": 4, "speakers": ["咲季", "舞蹈训练师"], "topics": ["character_arc", "worldbuilding", "plot", "relationships"], "title": "咲季誓要战胜对手", "summary": "舞蹈训练师称赞花海咲季成长迅速，肯定其首席地位，同时提醒她人外有人，需戒骄戒躁。咲季虚心接受并表态将继续努力，因为她心中有一个必须战胜的对手。这段对话展现了咲季谦逊进取的态度以及她明确的奋斗目标。", "saki_role": "同学/对手：咲季在群像关系中以好胜、直率和带头推进对话的姿态出现。", "relationship_signals": ["对手"], "worldbuilding_signals": ["训练"], "dialogue_style_signals": [], "key_evidence": [{"source_row": "2", "speaker": "舞蹈训练师", "text_zh": "不愧是首席呢。"}, {"source_row": "3", "speaker": "舞蹈训练师", "text_zh": "希望你能戒骄戒躁继续努力。"}, {"source_row": "4", "speaker": "咲季", "text_zh": "因为有个一定要战胜的对手在！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["舞蹈训练师认为咲季成长速度很快。", "咲季被舞蹈训练师称为首席。", "咲季表示有一个必须战胜的对手。", "咲季决心戒骄戒躁继续努力。"], "relationship_facts": ["咲季是舞蹈训练师的学姐。", "咲季是首席舞者。", "咲季与某位未具名的对手存在竞争关系。"], "worldbuilding_facts": ["咲季拥有首席头衔。", "舞蹈界存在人外有人、需不断精进的环境。", "咲季将战胜特定对手视为重要动力。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00395", "scene_id": "scene-00395", "source_file": "CSV/pgrowth/hski/adv_pgrowth_001_hski_02.csv", "source_kind": "pgrowth", "chapter": "pgrowth/hski", "scene": "adv_pgrowth_001_hski_02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "4", "line_count": 4}], "source_refs": ["CSV/pgrowth/hski/adv_pgrowth_001_hski_02.csv:1-4"], "line_count": 4, "speakers": ["ボイストレーナー", "咲季"], "topics": ["plot"], "title": "咲季对进步感到不安", "summary": "声优教练称赞咲季表现力突飞猛进，咲季对此表示感谢。然而咲季随即表示目前的程度远远不够，她对自己要求极高，认为这种水平根本不够看，流露出对现状的极度不满足与焦虑。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": [], "worldbuilding_signals": [], "dialogue_style_signals": [], "key_evidence": [{"source_row": "2", "speaker": "ボイストレーナー", "text_zh": "表现力更是突飞猛进呢。"}, {"source_row": "4", "speaker": "咲季", "text_zh": "还远远不够……这种程度根本不够看……！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季的声优表现力得到了教练的高度评价。", "咲季认为目前的水平距离目标还有很大差距。", "咲季对自己有着极高的自我要求。"], "relationship_facts": ["声优教练是咲季的指导者。", "教练对咲季的进步感到惊喜。", "咲季视教练的鼓励为重要动力。"], "worldbuilding_facts": ["声优行业对表现力有明确的高标准要求。", "咲季处于声优成长的进阶阶段。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00396", "scene_id": "scene-00396", "source_file": "CSV/pgrowth/hski/adv_pgrowth_001_hski_03.csv", "source_kind": "pgrowth", "chapter": "pgrowth/hski", "scene": "adv_pgrowth_001_hski_03", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "4", "line_count": 4}], "source_refs": ["CSV/pgrowth/hski/adv_pgrowth_001_hski_03.csv:1-4"], "line_count": 4, "speakers": ["咲季", "形象训练师"], "topics": ["worldbuilding", "character_arc", "relationships"], "title": "咲季获准立刻出道", "summary": "形象训练师高度赞扬咲季的偶像实力，认为其连专业偶像都需甘拜下风，确认其具备立刻出道的条件。咲季对此表示衷心感谢，并立下誓言绝不输给佑芽，展现出强烈的进取心与决心。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽"], "worldbuilding_signals": ["偶像", "训练"], "dialogue_style_signals": [], "key_evidence": [{"source_row": "2", "speaker": "形象训练师", "text_zh": "连专业偶像都要甘拜下风呢♪"}, {"source_row": "3", "speaker": "咲季", "text_zh": "是！非常感谢！"}, {"source_row": "4", "speaker": "咲季", "text_zh": "……等着瞧吧，佑芽。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季的偶像实力获得形象训练师的高度认可。", "咲季被确认具备立刻出道的资格。", "咲季向形象训练师表达了诚挚的感谢。", "咲季立誓绝不输给佑芽。"], "relationship_facts": ["咲季与形象训练师存在指导与被指导关系。", "咲季与佑芽存在竞争关系。", "形象训练师对咲季持有欣赏与鼓励的态度。"], "worldbuilding_facts": ["咲季的目标是成为偶像。", "存在名为佑芽的竞争者。", "咲季拥有被评价为连专业偶像都甘拜下风的实力。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00397", "scene_id": "scene-00397", "source_file": "CSV/pstory/hski/adv_pstory_001_hski_after-audition-final-failure-01.csv", "source_kind": "pstory", "chapter": "pstory/hski", "scene": "adv_pstory_001_hski_after-audition-final-failure-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "31", "line_count": 31}], "source_refs": ["CSV/pstory/hski/adv_pstory_001_hski_after-audition-final-failure-01.csv:1-31"], "line_count": 31, "speakers": ["制作人", "咲季", "选项"], "topics": ["relationships", "dialogue_style", "character_arc", "plot"], "title": "咲季落选后的崩溃与振作", "summary": "咲季在试镜中落选，得知结果后情绪崩溃，对着制作人哭诉不甘。制作人鼓励她仍有成长空间，咲季短暂振作后，因担心在妹妹面前丢脸而迅速调整心态，自称无敌姐姐，决心结束丧气话。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "妹妹", "姐姐"], "worldbuilding_signals": [], "dialogue_style_signals": ["哼", "制作人"], "key_evidence": [{"source_row": "2", "speaker": "制作人", "text_zh": "不合格。"}, {"source_row": "5", "speaker": "咲季", "text_zh": "居、居然是我……"}, {"source_row": "29", "speaker": "咲季", "text_zh": "在妹妹面前输掉的事？"}, {"source_row": "31", "speaker": "咲季", "text_zh": "现在的我可是无敌的姐姐大人！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季在试镜中未能合格。", "咲季因落选而情绪激动，大声哭喊。", "咲季担心在妹妹面前输掉会显得无能。", "咲季迅速从崩溃中恢复，自称无敌姐姐。"], "relationship_facts": ["咲季与制作人存在上下级或指导关系。", "咲季有一位妹妹，且非常在意妹妹的看法。", "咲季自视为姐姐，对妹妹有照顾或保护的责任感。"], "worldbuilding_facts": ["存在名为“试镜”的选拔活动。", "咲季有“姐姐”和“妹妹”的家庭身份设定。", "咲季拥有“花海咲季”的全名。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00398", "scene_id": "scene-00398", "source_file": "CSV/pstory/hski/adv_pstory_001_hski_after-audition-final-normal-01.csv", "source_kind": "pstory", "chapter": "pstory/hski", "scene": "adv_pstory_001_hski_after-audition-final-normal-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "32", "line_count": 32}], "source_refs": ["CSV/pstory/hski/adv_pstory_001_hski_after-audition-final-normal-01.csv:1-32"], "line_count": 32, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "plot", "relationships", "character_arc"], "title": "咲季突破墙壁的决心", "summary": "咲季在试镜合格后，面对制作人关于仍有进步空间的直言，她虽短暂抱怨但随即展现出顶级偶像的野心。咲季将困难视为乐趣，誓言要在正式演出中突破更高墙壁，以世界第一为目标，坚信自己必将大获成功。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["当然", "哼", "呵呵", "制作人", "让你见识", "啦"], "key_evidence": [{"source_row": "2", "speaker": "制作人", "text_zh": "合格了。这是最好的结果呢。"}, {"source_row": "12", "speaker": "咲季", "text_zh": "毕竟我可是要成为顶级偶像的人！"}, {"source_row": "19", "speaker": "咲季", "text_zh": "制作人，我一定会突破这道墙壁给你看。"}, {"source_row": "32", "speaker": "咲季", "text_zh": "正式演出也绝对会大获成功呢！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季在试镜中合格。", "咲季认为面对更高墙壁是成长的乐趣。", "咲季誓言要在正式演出中突破极限。", "咲季的目标是成为世界第一的偶像。"], "relationship_facts": ["咲季与制作人存在师徒或指导关系。", "制作人对咲季抱有高期望并指出其不足。", "咲季视制作人为见证自己成长的对象。"], "worldbuilding_facts": ["咲季立志成为顶级偶像。", "咲季追求世界第一的偶像地位。", "咲季将成长过程比喻为不断突破墙壁。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00399", "scene_id": "scene-00399", "source_file": "CSV/pstory/hski/adv_pstory_001_hski_after-audition-final-normal-02.csv", "source_kind": "pstory", "chapter": "pstory/hski", "scene": "adv_pstory_001_hski_after-audition-final-normal-02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "29", "line_count": 29}], "source_refs": ["CSV/pstory/hski/adv_pstory_001_hski_after-audition-final-normal-02.csv:1-29"], "line_count": 29, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "worldbuilding", "plot"], "title": "咲季合格后的烦恼", "summary": "咲季在试镜合格后，面对排名感到纠结与不甘。她虽承认成绩不错，但坚持认为非第一即输家，这不符合她成为世界第一偶像的志向。咲季随即决定将烦恼搁置，全力准备演唱会，并自信地宣告要让制作人重新认识她作为顶级偶像的实力。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人"], "worldbuilding_signals": ["偶像", "演唱会"], "dialogue_style_signals": ["当然", "哼", "制作人"], "key_evidence": [{"source_row": "2", "speaker": "制作人", "text_zh": "合格了。真是很棒的成绩呢。"}, {"source_row": "18", "speaker": "咲季", "text_zh": "不是第一名就是输家！"}, {"source_row": "27", "speaker": "咲季", "text_zh": "未来的顶级偶像，花海咲季哦！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季在试镜中获得了合格的成绩。", "咲季对目前的排名感到纠结，认为非第一即输家。", "咲季决定暂时搁置烦恼，集中精力准备演唱会。", "咲季自信地宣称自己是未来的顶级偶像。"], "relationship_facts": ["咲季与制作人之间存在偶像与制作人的工作关系。", "咲季视制作人为能理解其烦恼的人。", "咲季向制作人承诺会在演唱会上证明自己的实力。"], "worldbuilding_facts": ["咲季的目标是成为世界第一的偶像。", "咲季认为在偶像竞技中，不是第一名就是输家。", "咲季拥有强烈的自信，自称未来的顶级偶像。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00400", "scene_id": "scene-00400", "source_file": "CSV/pstory/hski/adv_pstory_001_hski_after-audition-final-normal-03.csv", "source_kind": "pstory", "chapter": "pstory/hski", "scene": "adv_pstory_001_hski_after-audition-final-normal-03", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "27", "line_count": 27}], "source_refs": ["CSV/pstory/hski/adv_pstory_001_hski_after-audition-final-normal-03.csv:1-27"], "line_count": 27, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "plot", "worldbuilding"], "title": "咲季对高完成度的纠结", "summary": "制作人告知咲季试镜合格，咲季询问表现后得知评价为完成度高。咲季虽因成长空间小而讨厌此评价，但认为这是优点。她决定将反省会留待下次，并决心在演唱会上展示超高完成度的现场，期待制作人的反馈。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人"], "worldbuilding_signals": ["演唱会"], "dialogue_style_signals": ["当然", "真是的", "哼", "嘿嘿", "制作人", "啦"], "key_evidence": [{"source_row": "2", "speaker": "制作人", "text_zh": "合格了。算是相当不错的结果呢。"}, {"source_row": "9", "speaker": "选项", "text_zh": "完成度很高"}, {"source_row": "22", "speaker": "咲季", "text_zh": "所谓完成度高……就是说成长空间小了吧。"}, {"source_row": "27", "speaker": "咲季", "text_zh": "我会让大家好好见识的。所谓完成度超高的live呢。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季通过了试镜，获得了合格的结果。", "咲季对‘完成度高’的评价感到矛盾，既讨厌又承认是优点。", "咲季决定将详细的反省会留到下次演唱会后。", "咲季决心在演唱会上展示超高完成度的现场表演。"], "relationship_facts": ["制作人与咲季是同事或上下级关系，制作人负责评价咲季。", "制作人与咲季关系亲密，咲季会直接询问制作人对自己的看法。", "制作人对咲季抱有期待，认为咲季的高完成度是优点。"], "worldbuilding_facts": ["咲季即将参加一场重要的演唱会。", "咲季非常在意他人对自己表演的评价，尤其是关于成长空间的看法。", "咲季将试镜后的反省会作为演唱会的余兴节目。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00401", "scene_id": "scene-00401", "source_file": "CSV/pstory/hski/adv_pstory_001_hski_after-audition-final-normal-04.csv", "source_kind": "pstory", "chapter": "pstory/hski", "scene": "adv_pstory_001_hski_after-audition-final-normal-04", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "30", "line_count": 30}], "source_refs": ["CSV/pstory/hski/adv_pstory_001_hski_after-audition-final-normal-04.csv:1-30"], "line_count": 30, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "plot", "worldbuilding"], "title": "咲季全力备战演唱会", "summary": "咲季虽勉强通过选拔且排名靠后，但拒绝切换至下一场，坚持在演唱会前修正失误。她视制作人的高要求为信任证明，决心心无旁骛地练习，展现出不因挫折动摇的偶像精神。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "姐姐"], "worldbuilding_signals": ["偶像", "演唱会"], "dialogue_style_signals": ["才不是", "哼", "制作人", "啦"], "key_evidence": [{"source_row": "4", "speaker": "咲季", "text_zh": "虽然合格了，但名次很低。"}, {"source_row": "15", "speaker": "咲季", "text_zh": "你是要我把刚才出错的地方在演唱会前全部修正？"}, {"source_row": "28", "speaker": "咲季", "text_zh": "我就当这是信任的证明了。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季在选拔中勉强合格，名次较低。", "咲季决定在演唱会前修正所有失误。", "咲季认为制作人的要求是信任的证明。"], "relationship_facts": ["咲季与制作人存在上下级及指导关系。", "制作人认可咲季的抗压能力。", "咲季将制作人视为可信赖的伙伴。"], "worldbuilding_facts": ["选拔结果直接影响后续演唱会表现。", "偶像需具备在压力下修正失误的能力。", "当前剧情处于选拔结束后的准备阶段。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00402", "scene_id": "scene-00402", "source_file": "CSV/pstory/hski/adv_pstory_001_hski_after-audition-mid-failure-01.csv", "source_kind": "pstory", "chapter": "pstory/hski", "scene": "adv_pstory_001_hski_after-audition-mid-failure-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "29", "line_count": 29}], "source_refs": ["CSV/pstory/hski/adv_pstory_001_hski_after-audition-mid-failure-01.csv:1-29"], "line_count": 29, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "character_arc", "plot"], "title": "咲季落选后的反省与复仇", "summary": "咲季在试镜中落选，情绪崩溃后迅速冷静下来。她拒绝被安慰，坚持要分析失败原因并立即改进。制作人肯定了她行动力，咲季则立下誓言，要在下次获胜前保持对失败的愤怒，以此作为复仇的动力。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人"], "worldbuilding_signals": [], "dialogue_style_signals": ["当然", "真是的", "哼", "制作人", "啦"], "key_evidence": [{"source_row": "2", "speaker": "制作人", "text_zh": "……不合格。"}, {"source_row": "13", "speaker": "咲季", "text_zh": "抽泣……等回去再哭。"}, {"source_row": "22", "speaker": "咲季", "text_zh": "我要以最快速度复仇哦！"}, {"source_row": "29", "speaker": "咲季", "text_zh": "所以，等我赢了再夸我吧。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季在试镜中未能通过，被判定为不合格。", "咲季在极度不甘心的情绪后迅速冷静，决定先处理工作。", "咲季主动要求分析失败原因，并誓言要快速改进以复仇。", "咲季表示在获胜之前，对失败的愤怒不会消失。"], "relationship_facts": ["制作人与咲季是上下级或指导与被指导的关系。", "制作人关心咲季，在咲季冷静后感到安心。", "咲季对制作人抱有期待，希望获胜后得到夸奖。"], "worldbuilding_facts": ["该场景发生在试镜结束后的工作场所。", "咲季作为演员或表演者，面临严格的考核标准。", "咲季将失败视为需要克服的障碍，而非终点。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00403", "scene_id": "scene-00403", "source_file": "CSV/pstory/hski/adv_pstory_001_hski_after-audition-mid-normal-01.csv", "source_kind": "pstory", "chapter": "pstory/hski", "scene": "adv_pstory_001_hski_after-audition-mid-normal-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "26", "line_count": 26}], "source_refs": ["CSV/pstory/hski/adv_pstory_001_hski_after-audition-mid-normal-01.csv:1-26"], "line_count": 26, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "plot"], "title": "咲季通过初选后的得意", "summary": "咲季顺利通过选拔初关，对制作人的夸奖感到得意忘形，认为这只是起步。她自信魅力无穷，拒绝过早向妹妹炫耀，决心继续挑战更高关卡，期待未来能更骄傲地展示成果。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "妹妹"], "worldbuilding_signals": [], "dialogue_style_signals": ["当然", "哼", "嘿嘿", "制作人", "啦"], "key_evidence": [{"source_row": "2", "speaker": "制作人", "text_zh": "合格了。真是最棒的结果呢。"}, {"source_row": "11", "speaker": "咲季", "text_zh": "但要在那孩子面前炫耀还太早了！"}, {"source_row": "22", "speaker": "制作人", "text_zh": "但这只是突破了第一道关卡而已。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季成功通过了选拔的第一道关卡。", "咲季认为目前的合格成绩还不足以向妹妹炫耀。", "咲季对自己的魅力和未来的表现充满自信。"], "relationship_facts": ["咲季与制作人关系亲密，互相调侃。", "咲季计划向妹妹炫耀成绩。", "制作人对咲季抱有更高的期望。"], "worldbuilding_facts": ["选拔过程分为多个关卡，当前仅通过第一关。", "咲季作为偶像或表演者，拥有极高的自信。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00404", "scene_id": "scene-00404", "source_file": "CSV/pstory/hski/adv_pstory_001_hski_after-audition-mid-normal-02.csv", "source_kind": "pstory", "chapter": "pstory/hski", "scene": "adv_pstory_001_hski_after-audition-mid-normal-02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "26", "line_count": 26}], "source_refs": ["CSV/pstory/hski/adv_pstory_001_hski_after-audition-mid-normal-02.csv:1-26"], "line_count": 26, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "plot", "character_arc"], "title": "咲季突破初关后的复杂心情", "summary": "咲季在选拔中合格，虽突破第一道关卡却因未获第一而心情复杂。她坦言过去比赛多靠有利条件，担心无法成为顶级偶像或赢过妹妹，因此难以单纯开心。制作人鼓励她正视高目标，咲季最终宣泄情绪，表示说出口后感到轻松。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "妹妹"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["制作人", "啦"], "key_evidence": [{"source_row": "12", "speaker": "咲季", "text_zh": "第一道关卡突破啦！"}, {"source_row": "19", "speaker": "咲季", "text_zh": "凭什么本小姐不是第一名啊"}, {"source_row": "24", "speaker": "咲季", "text_zh": "也赢不了妹妹。"}, {"source_row": "26", "speaker": "咲季", "text_zh": "说出口之后，稍微轻松了些呢。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季在选拔中合格，成功突破通往顶级偶像的第一道关卡。", "咲季因未获得第一名而感到不满，认为自己过去的成绩多依赖有利条件。", "咲季担心若不能凭实力获胜，将无法成为顶级偶像或赢过妹妹。", "咲季向制作人坦露心声后，表示心情稍微轻松了一些。"], "relationship_facts": ["咲季与妹妹存在竞争关系，咲季希望赢过妹妹。", "制作人与咲季是指导与被指导的关系，制作人负责鼓励咲季。", "咲季将制作人视为可以倾诉复杂心情的对象。"], "worldbuilding_facts": ["成为顶级偶像需要不断突破关卡，合格只是第一步。", "咲季认为仅靠有利条件获得的名次不足以支撑其成为顶级偶像的目标。", "咲季的目标是成为顶级偶像，并在此过程中超越妹妹。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00405", "scene_id": "scene-00405", "source_file": "CSV/pstory/hski/adv_pstory_001_hski_after-audition-mid-normal-03.csv", "source_kind": "pstory", "chapter": "pstory/hski", "scene": "adv_pstory_001_hski_after-audition-mid-normal-03", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "26", "line_count": 26}], "source_refs": ["CSV/pstory/hski/adv_pstory_001_hski_after-audition-mid-normal-03.csv:1-26"], "line_count": 26, "speakers": ["制作人", "咲季", "选项"], "topics": ["relationships", "dialogue_style", "character_arc", "plot"], "title": "咲季立志成为偶像", "summary": "制作人告知咲季试镜合格，咲季虽感意外但随即振作，认为这是真正起点。她坦言想超越自我，并流露出对妹妹的思念，强调自己并非妹控，而是作为姐姐的骄傲，决心在此作为偶像大放异彩。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "妹妹", "姐姐"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["才不是", "制作人"], "key_evidence": [{"source_row": "11", "speaker": "咲季", "text_zh": "照这个势头继续努力的话，应该还能更进一步"}, {"source_row": "19", "speaker": "咲季", "text_zh": "所以，现在才是起点。这里才是我的真正起点。"}, {"source_row": "22", "speaker": "制作人", "text_zh": "咲季同学怎么可能会有不想念妹妹的瞬间呢。"}, {"source_row": "26", "speaker": "咲季", "text_zh": "我才不是什么妹控呢！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季在试镜中获得了合格的成绩。", "咲季认为当前名次是起点，决心作为偶像大放异彩。", "咲季在思考时短暂走神，被制作人点破其思念妹妹。", "咲季否认自己是妹控，仅表示作为姐姐的骄傲。"], "relationship_facts": ["咲季是妹妹的姐姐。", "制作人是咲季的上级或指导者。", "咲季与制作人之间存在信任关系。"], "worldbuilding_facts": ["咲季参加了偶像相关的竞赛或试镜。", "咲季对偶像事业有明确的追求和野心。", "咲季的家庭背景中包含一位妹妹。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00406", "scene_id": "scene-00406", "source_file": "CSV/pstory/hski/adv_pstory_001_hski_after-audition-mid-normal-04.csv", "source_kind": "pstory", "chapter": "pstory/hski", "scene": "adv_pstory_001_hski_after-audition-mid-normal-04", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "27", "line_count": 27}], "source_refs": ["CSV/pstory/hski/adv_pstory_001_hski_after-audition-mid-normal-04.csv:1-27"], "line_count": 27, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "character_arc", "plot"], "title": "咲季不甘心的复仇宣言", "summary": "咲季勉强通过选拔，虽表面冷静实则内心不甘。她迅速调整心态，立下复仇誓言，决心改进失误冲击第一。制作人指出其并非软弱，咲季则回应未来可能遭遇更惨痛的败北，展现出坚韧与对胜利的执着。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人"], "worldbuilding_signals": [], "dialogue_style_signals": ["制作人", "啦"], "key_evidence": [{"source_row": "2", "speaker": "制作人", "text_zh": "合格了。真是勉强及格的结果呢。"}, {"source_row": "13", "speaker": "咲季", "text_zh": "如果全部改进的话，说不定能冲击第一名？"}, {"source_row": "21", "speaker": "咲季", "text_zh": "给我好好看着吧！绝～对！！我要复仇了！！"}, {"source_row": "27", "speaker": "咲季", "text_zh": "说不定也会遇到让人一蹶不振的败北呢。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季在选拔中勉强合格，但内心非常不甘心。", "咲季决定改进失误，目标是冲击第一名。", "咲季立下誓言，为了下次胜利要复仇。", "咲季认为未来可能会遇到让人一蹶不振的败北。"], "relationship_facts": ["制作人与咲季是上下级或指导关系。", "制作人认为咲季的表现并非软弱。", "咲季对制作人表示感谢并请求指导。"], "worldbuilding_facts": ["选拔存在落选者，对落选者需保持礼貌。", "咲季准备了失败时的固定流程。", "选拔第一名是咲季的目标。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00407", "scene_id": "scene-00407", "source_file": "CSV/pstory/hski/adv_pstory_001_hski_after-step-1-normal-01.csv", "source_kind": "pstory", "chapter": "pstory/hski", "scene": "adv_pstory_001_hski_after-step-1-normal-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "29", "line_count": 29}], "source_refs": ["CSV/pstory/hski/adv_pstory_001_hski_after-step-1-normal-01.csv:1-29"], "line_count": 29, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "character_arc", "plot"], "title": "咲季的焦虑与自信", "summary": "咲季向制作人展示自己万全的状态，坦言因成长放缓而焦虑，害怕被竞争对手超越。制作人安慰她注定成为顶级偶像，并列举其优秀特质。咲季虽害羞但随即自信地接受赞美，展现偶像的活力。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人", "对手"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["哼", "呵呵", "嘿嘿", "制作人", "啦"], "key_evidence": [{"source_row": "7", "speaker": "咲季", "text_zh": "为了能保持这样，我可是付出了很多努力啊！"}, {"source_row": "14", "speaker": "咲季", "text_zh": "因为后面有紧追不舍的竞争对手在追赶啊。"}, {"source_row": "25", "speaker": "制作人", "text_zh": "既可爱又美丽，健康又专注，聪慧又勤奋……"}, {"source_row": "29", "speaker": "咲季", "text_zh": "诶嘿嘿……♡ 就是说嘛！我早就知道！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季认为自己已付出努力保持绝佳状态，但成长速度将放缓。", "咲季因有竞争对手追赶而感到焦虑，担心自己成长空间有限。", "制作人肯定咲季注定成为无敌的顶级偶像。", "咲季在听到赞美后害羞地接受了，并自信地表示自己是超厉害的。"], "relationship_facts": ["制作人与咲季是指导与被指导的关系。", "咲季将制作人视为可以倾诉内心焦虑的对象。", "咲季视竞争对手为紧追不舍的追赶者。"], "worldbuilding_facts": ["咲季作为偶像，其成长速度会逐渐放缓。", "咲季面临来自竞争对手的压力。", "成为顶级偶像需要兼具可爱、美丽、健康、专注、聪慧、勤奋、温柔、可靠等特质。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00408", "scene_id": "scene-00408", "source_file": "CSV/pstory/hski/adv_pstory_001_hski_after-step-1-normal-02.csv", "source_kind": "pstory", "chapter": "pstory/hski", "scene": "adv_pstory_001_hski_after-step-1-normal-02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "28", "line_count": 28}], "source_refs": ["CSV/pstory/hski/adv_pstory_001_hski_after-step-1-normal-02.csv:1-28"], "line_count": 28, "speakers": ["制作人", "咲季", "选项"], "topics": ["relationships", "dialogue_style", "worldbuilding", "team_story"], "title": "咲季偶像成长烦恼", "summary": "咲季向制作人请教偶像课题，确认需改善身体状态、积累知识并拓展人脉。她因前运动员经历担心身材，对缺乏朋友感到焦虑，害怕被嘲笑，决心在学园中努力成长。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人", "广", "朋友"], "worldbuilding_signals": ["学园", "偶像"], "dialogue_style_signals": ["当然", "呵呵", "制作人"], "key_evidence": [{"source_row": "9", "speaker": "咲季", "text_zh": "因为我以前是运动员"}, {"source_row": "11", "speaker": "咲季", "text_zh": "稍微增加一点体重"}, {"source_row": "24", "speaker": "咲季", "text_zh": "我的朋友特别少呢"}, {"source_row": "26", "speaker": "咲季", "text_zh": "会嘲笑我把我当傻瓜"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季曾是运动员，一直在进行身体锻炼。", "咲季认为增加体重会让身体显得更柔和。", "咲季在学校里朋友特别少，担心被嘲笑。", "咲季认为掌握广泛知识能成为顶级偶像的力量。"], "relationship_facts": ["咲季与制作人是咨询与被咨询的关系。", "咲季与学园里的其他同学关系疏远。", "咲季与制作人之间存在信任关系。"], "worldbuilding_facts": ["咲季有前运动员的背景。", "学园是咲季学习和社交的主要场所。", "成为顶级偶像需要身体、知识和人脉。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00409", "scene_id": "scene-00409", "source_file": "CSV/pstory/hski/adv_pstory_001_hski_after-step-1-normal-03.csv", "source_kind": "pstory", "chapter": "pstory/hski", "scene": "adv_pstory_001_hski_after-step-1-normal-03", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "31", "line_count": 31}], "source_refs": ["CSV/pstory/hski/adv_pstory_001_hski_after-step-1-normal-03.csv:1-31"], "line_count": 31, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "worldbuilding", "character_arc"], "title": "咲季嗓子受伤静养", "summary": "咲季因声乐训练过度导致嗓子受伤，被迫暂停训练并静养。她虽不甘心但承认自己心急了，制作人对此表示担忧并决定带她离开。咲季对制作人的过度保护感到无奈，最终道谢。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人"], "worldbuilding_signals": ["偶像", "训练"], "dialogue_style_signals": ["当然", "制作人"], "key_evidence": [{"source_row": "7", "speaker": "咲季", "text_zh": "因为嗓子受伤了，所以在保持安静。"}, {"source_row": "14", "speaker": "咲季", "text_zh": "歌唱能力的提升对我来说是优先级很高的课题"}, {"source_row": "22", "speaker": "咲季", "text_zh": "为了克服课题，进行了超出方案强度的训练"}, {"source_row": "27", "speaker": "制作人", "text_zh": "负责的偶像嗓子受伤的话，担心也是理所当然的"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季因声乐训练强度过大导致嗓子受伤。", "咲季决定暂停声乐训练一段时间进行静养。", "咲季承认自己过于心急，导致情况恶化。", "制作人因担心咲季而表现出过度保护的态度。"], "relationship_facts": ["制作人与咲季是偶像与负责人的关系。", "制作人非常关心咲季的健康状况。", "咲季对制作人的关心感到些许无奈但接受。"], "worldbuilding_facts": ["咲季作为偶像，歌唱能力是她的核心课题。", "声乐训练若过度会导致喉咙受伤。", "偶像的嗓子受伤属于需要紧急处理的状况。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00410", "scene_id": "scene-00410", "source_file": "CSV/pstory/hski/adv_pstory_001_hski_after-step-2-normal-01.csv", "source_kind": "pstory", "chapter": "pstory/hski", "scene": "adv_pstory_001_hski_after-step-2-normal-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "28", "line_count": 28}], "source_refs": ["CSV/pstory/hski/adv_pstory_001_hski_after-step-2-normal-01.csv:1-28"], "line_count": 28, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "character_arc", "plot"], "title": "咲季训练与成长约定", "summary": "咲季结束训练后，制作人称赞其表现。咲季承认无敌状态终将结束，成长速度变缓，决定依靠制作人进一步培育。双方约定由制作人负责后续训练，咲季做好觉悟接受挑战，期待在不久的将来突破极限。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人"], "worldbuilding_signals": ["训练"], "dialogue_style_signals": ["当然", "哼", "嘿嘿", "制作人", "啦"], "key_evidence": [{"source_row": "16", "speaker": "咲季", "text_zh": "虽然正在顺利成长，但成长速度也逐渐变得迟缓了呢。"}, {"source_row": "23", "speaker": "咲季", "text_zh": "面对史无前例状态绝佳，近乎无敌的我。"}, {"source_row": "26", "speaker": "咲季", "text_zh": "我的无敌状态，从来都只能维持到这个程度而已。"}, {"source_row": "20", "speaker": "制作人", "text_zh": "我会用培育让你更进一步成长的。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季的训练状态极佳，但成长速度逐渐变缓。", "咲季承认自己的无敌状态只能维持有限时间。", "咲季决定依靠制作人进行进一步的培育。", "制作人承诺将用培育让咲季更进一步成长。"], "relationship_facts": ["制作人与咲季是训练者与学员的关系。", "咲季对制作人抱有信任与依赖。", "咲季视制作人为能让自己突破极限的关键。"], "worldbuilding_facts": ["咲季拥有史无前例的状态绝佳、近乎无敌的能力。", "咲季的无敌状态存在时间限制，无法永久维持。", "咲季的成长速度会随着时间推移而逐渐迟缓。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00411", "scene_id": "scene-00411", "source_file": "CSV/pstory/hski/adv_pstory_001_hski_after-step-2-normal-02.csv", "source_kind": "pstory", "chapter": "pstory/hski", "scene": "adv_pstory_001_hski_after-step-2-normal-02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "30", "line_count": 30}], "source_refs": ["CSV/pstory/hski/adv_pstory_001_hski_after-step-2-normal-02.csv:1-30"], "line_count": 30, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "character_arc", "worldbuilding"], "title": "咲季烦恼饮品难喝", "summary": "咲季因特制饮品被评价难喝而烦恼，认为训练饮品味道无所谓。制作人指出难喝可能带来压力，建议接纳不同意见。咲季最终理解并决定重新考虑饮品问题，感谢制作人的开导。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人"], "worldbuilding_signals": ["训练"], "dialogue_style_signals": ["真是的", "制作人", "啦"], "key_evidence": [{"source_row": "5", "speaker": "咲季", "text_zh": "我特制的饮品很难喝"}, {"source_row": "13", "speaker": "咲季", "text_zh": "作为训练的一环要喝的东西"}, {"source_row": "27", "speaker": "制作人", "text_zh": "可能会造成压力，反而产生负面影响"}, {"source_row": "30", "speaker": "咲季", "text_zh": "我会好好考虑的。谢谢你，制作人。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季特制的饮品被评价为很难喝。", "咲季认为作为训练环节的饮品，味道根本无所谓。", "制作人指出难喝的味道可能造成压力，产生负面影响。", "咲季在理解后决定好好考虑饮品的味道问题。"], "relationship_facts": ["咲季与制作人之间存在指导与被指导的关系。", "咲季愿意向制作人倾诉自己的烦恼。", "制作人对咲季的想法表示理解并给予建议。"], "worldbuilding_facts": ["咲季需要饮用特制的饮品作为训练的一环。", "饮品的味道对咲季的训练状态有潜在影响。", "接受不同意见是处理烦恼的重要方式。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00412", "scene_id": "scene-00412", "source_file": "CSV/pstory/hski/adv_pstory_001_hski_after-step-2-normal-03.csv", "source_kind": "pstory", "chapter": "pstory/hski", "scene": "adv_pstory_001_hski_after-step-2-normal-03", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "31", "line_count": 31}], "source_refs": ["CSV/pstory/hski/adv_pstory_001_hski_after-step-2-normal-03.csv:1-31"], "line_count": 31, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "worldbuilding", "character_arc"], "title": "咲季偶像形体塑造", "summary": "训练结束后，咲季向制作人汇报状态。她因体重增加导致动作变迟钝，正努力适应新的偶像身体。制作人指出方案调整为减少肌肉量，整体印象更柔和。咲季干劲满满，目标是找回身体灵活性，认为偶像工作了不起。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人"], "worldbuilding_signals": ["偶像", "训练"], "dialogue_style_signals": ["嘿嘿", "制作人", "啦"], "key_evidence": [{"source_row": "11", "speaker": "咲季", "text_zh": "动作变得迟钝是因为……体重增加的缘故吧。"}, {"source_row": "20", "speaker": "制作人", "text_zh": "这次采用的是稍微减少肌肉量的方案呢。"}, {"source_row": "29", "speaker": "咲季", "text_zh": "只要找回身体的灵活性就行啦！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季因体重增加导致动作变迟钝。", "制作人指出本次方案为减少肌肉量。", "咲季的目标是找回身体的灵活性。", "咲季认为偶像工作非常了不起。"], "relationship_facts": ["咲季与制作人是同事关系。", "制作人负责指导咲季的形体塑造。", "咲季依赖制作人的反馈确认状态。"], "worldbuilding_facts": ["偶像需要维持特定的形体塑造。", "偶像的身体需要兼顾体重与灵活性。", "形体塑造方案包含减少肌肉量。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00413", "scene_id": "scene-00413", "source_file": "CSV/pstory/hski/adv_pstory_001_hski_before-audition-final-normal-01.csv", "source_kind": "pstory", "chapter": "pstory/hski", "scene": "adv_pstory_001_hski_before-audition-final-normal-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "36", "line_count": 36}], "source_refs": ["CSV/pstory/hski/adv_pstory_001_hski_before-audition-final-normal-01.csv:1-36"], "line_count": 36, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "worldbuilding"], "title": "咲季赛前挑战宣言", "summary": "咲季在制作人面前进行赛前准备，坦言因经验不足而感到紧张与兴奋交织。她强调自己已做到极致，处于最佳状态，决心向其他偶像发起挑战。咲季以不容疏忽的严谨态度迎接这场激烈的比试，展现出对胜利的渴望与自信。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["当然", "真是的", "哼", "呵呵", "制作人", "啦"], "key_evidence": [{"source_row": "10", "speaker": "咲季", "text_zh": "现在的我作为偶像到底能走多远……"}, {"source_row": "18", "speaker": "咲季", "text_zh": "我要向偶像们发起挑战！"}, {"source_row": "22", "speaker": "咲季", "text_zh": "不安与兴奋在此刻交织在一起。"}, {"source_row": "33", "speaker": "咲季", "text_zh": "这是我的基本原则。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季因经验不足而感到紧张与兴奋交织。", "咲季认为已将所有能做的事做到极致。", "咲季决心向其他偶像发起挑战。", "咲季以不容疏忽的态度迎接比试。"], "relationship_facts": ["咲季与制作人关系亲密，制作人作为观众见证咲季。", "咲季视其他偶像为挑战对象。"], "worldbuilding_facts": ["咲季作为偶像，面临实力与经验的挑战。", "比赛结果对咲季而言至关重要。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00414", "scene_id": "scene-00414", "source_file": "CSV/pstory/hski/adv_pstory_001_hski_before-audition-mid-normal-01.csv", "source_kind": "pstory", "chapter": "pstory/hski", "scene": "adv_pstory_001_hski_before-audition-mid-normal-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "34", "line_count": 34}], "source_refs": ["CSV/pstory/hski/adv_pstory_001_hski_before-audition-mid-normal-01.csv:1-34"], "line_count": 34, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "character_arc", "plot"], "title": "咲季赛前自信宣言", "summary": "咲季在休息室完成热身，面对制作人展现出高涨的赛前情绪。她坦言虽身经百战，但面对当前实力差距仍感紧张，不过决心全力以赴挑战第一名。咲季将制作人视为同类，并承诺演出将震撼全场，以此作为给制作人的礼物。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "妹妹"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["当然", "哼", "呵呵", "制作人", "啦"], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "准备体操结束啦！"}, {"source_row": "15", "speaker": "咲季", "text_zh": "胜算不大吧？"}, {"source_row": "26", "speaker": "咲季", "text_zh": "我的目标永远只有第一名。"}, {"source_row": "34", "speaker": "咲季", "text_zh": "你培养的偶像即将震撼全场！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季赛前进行热身运动，情绪高涨。", "咲季承认面对当前实力差距感到紧张。", "咲季的目标永远是夺得第一名。", "咲季将演出作为给制作人的礼物。"], "relationship_facts": ["咲季与制作人关系亲密，互称同类。", "咲季将制作人视为重要的支持者。", "咲季在妹妹面前会表现得更加积极。"], "worldbuilding_facts": ["咲季是身经百战的偶像，经历过多次比赛。", "咲季清楚当前比赛胜算不大，但仍想挑战。", "制作人是负责培养并送咲季出场的负责人。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00415", "scene_id": "scene-00415", "source_file": "CSV/pstory/hski/adv_pstory_001_hski_ending-normal-01.csv", "source_kind": "pstory", "chapter": "pstory/hski", "scene": "adv_pstory_001_hski_ending-normal-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "24", "line_count": 24}], "source_refs": ["CSV/pstory/hski/adv_pstory_001_hski_ending-normal-01.csv:1-24"], "line_count": 24, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "worldbuilding"], "title": "咲季的完全休息日", "summary": "制作人偶遇在长椅上休息的咲季。咲季表示今天是偶像活动的完全休息日，她正享受阳光放松身心。她感谢制作人带来的顺利日常，让她能安心休息，并约定明天全力重新开始。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人"], "worldbuilding_signals": ["偶像", "工作"], "dialogue_style_signals": ["制作人"], "key_evidence": [{"source_row": "13", "speaker": "咲季", "text_zh": "今天啊……偶像活动……要完全休息的日子……"}, {"source_row": "16", "speaker": "咲季", "text_zh": "都是托你的福哦，制作人。"}, {"source_row": "24", "speaker": "咲季", "text_zh": "全力冲刺，重新开始哦！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["今天是咲季的偶像活动完全休息日。", "咲季在长椅上晒太阳并放松身心。", "咲季感谢制作人让她能安心休息。", "咲季约定明天开始全力冲刺工作。"], "relationship_facts": ["咲季称呼制作人为制作人。", "咲季视制作人为带来顺利日常的恩人。", "咲季与制作人约定明天重新开始工作。"], "worldbuilding_facts": ["咲季是偶像。", "存在偶像活动的休息日制度。", "咲季因工作顺利而能安心休息。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00416", "scene_id": "scene-00416", "source_file": "CSV/pstory/hski/adv_pstory_001_hski_ending-normal-02.csv", "source_kind": "pstory", "chapter": "pstory/hski", "scene": "adv_pstory_001_hski_ending-normal-02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "26", "line_count": 26}], "source_refs": ["CSV/pstory/hski/adv_pstory_001_hski_ending-normal-02.csv:1-26"], "line_count": 26, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "character_arc", "plot"], "title": "咲季的成长瓶颈", "summary": "咲季向制作人求助，坦言自己因过度反省已无成长空间，技术层面遭遇瓶颈。她自嘲可爱特质导致成长空间为零，实则渴望突破。制作人鼓励她相信能打破那道墙壁，咲季最终决定继续前进。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人"], "worldbuilding_signals": [], "dialogue_style_signals": ["才不是", "制作人", "啦"], "key_evidence": [{"source_row": "11", "speaker": "咲季", "text_zh": "能反省的地方已经所剩无几了！"}, {"source_row": "14", "speaker": "咲季", "text_zh": "我的歌和舞蹈能力都快要遇到瓶颈了！"}, {"source_row": "18", "speaker": "咲季", "text_zh": "因为天生就这么可爱……！"}, {"source_row": "25", "speaker": "制作人", "text_zh": "那道墙壁，一定能打破的。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季认为自己已无反省空间，技术成长遇到瓶颈。", "咲季将自身可爱特质视为无法再成长的原因。", "制作人鼓励咲季相信能打破眼前的困难。", "咲季接受鼓励，决定继续前进。"], "relationship_facts": ["咲季与制作人存在师徒或指导关系。", "咲季依赖制作人的意见解决困惑。", "制作人给予咲季鼓励与肯定。"], "worldbuilding_facts": ["咲季拥有唱歌和跳舞的能力。", "咲季具备自我反省和改进的习惯。", "咲季对自己的可爱程度有高度自信。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00417", "scene_id": "scene-00417", "source_file": "CSV/pstory/hski/adv_pstory_001_hski_ending-normal-03.csv", "source_kind": "pstory", "chapter": "pstory/hski", "scene": "adv_pstory_001_hski_ending-normal-03", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "23", "line_count": 23}], "source_refs": ["CSV/pstory/hski/adv_pstory_001_hski_ending-normal-03.csv:1-23"], "line_count": 23, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "character_arc", "worldbuilding"], "title": "咲季总结活动与感谢", "summary": "咲季结束近期活动总结，提议改变训练方案并选择休养。她感谢制作人，表示对方让自己变得积极向上，并承诺今后多多关照，同时提议为忙碌的制作人按摩。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人"], "worldbuilding_signals": ["训练"], "dialogue_style_signals": ["当然", "制作人", "啦"], "key_evidence": [{"source_row": "8", "speaker": "咲季", "text_zh": "根据这次的总结要改变方案呢。"}, {"source_row": "14", "speaker": "咲季", "text_zh": "我知道啦。会好好休息的。"}, {"source_row": "21", "speaker": "咲季", "text_zh": "多亏了你……让我变得积极向上了呢。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季结束近期活动总结并提议改变方案。", "咲季选择休养而非立即行动。", "咲季感谢制作人让自己变得积极向上。"], "relationship_facts": ["咲季与制作人关系亲密且互相感激。", "咲季主动提出为制作人按摩。", "咲季视制作人为重要的支持者。"], "worldbuilding_facts": ["近期有特定的活动需要总结。", "咲季正在进行训练。", "制作人与训练师共同商讨调整方案。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00418", "scene_id": "scene-00418", "source_file": "CSV/pstory/hski/adv_pstory_001_hski_ending-normal-04.csv", "source_kind": "pstory", "chapter": "pstory/hski", "scene": "adv_pstory_001_hski_ending-normal-04", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "23", "line_count": 23}], "source_refs": ["CSV/pstory/hski/adv_pstory_001_hski_ending-normal-04.csv:1-23"], "line_count": 23, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "worldbuilding", "character_arc"], "title": "咲季立志攀登顶峰", "summary": "培育工作告一段落，咲季虽认可成绩，但拒绝满足现状。制作人指出其作为新生已接近顶尖，咲季却认为这不足以支撑向上攀登。咲季整理反省点并请求辅导，两人虽对“快乐”定义不同，但咲季决心在接下来不断勇往直前，追求更高的偶像之路。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人"], "worldbuilding_signals": ["偶像", "工作"], "dialogue_style_signals": ["真是的", "呵呵", "制作人", "啦"], "key_evidence": [{"source_row": "1", "speaker": "制作人", "text_zh": "培育工作告一段落，我想对目前为止的情况做个总结。"}, {"source_row": "10", "speaker": "咲季", "text_zh": "如果在这种程度就满足的话，是无法继续向上的。"}, {"source_row": "15", "speaker": "咲季", "text_zh": "制作人，能给我一些辅导吗？"}, {"source_row": "23", "speaker": "咲季", "text_zh": "是接下来不断勇往直前、不断攀登的时光啊！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["培育工作已告一段落，咲季对结果不满意。", "咲季认为作为新生接近顶尖的成绩仍不足以满足向上攀登的目标。", "咲季整理了反省点并请求制作人给予辅导。", "咲季认为真正的快乐在于接下来不断勇往直前的时光。"], "relationship_facts": ["制作人是咲季的培育者及偶像导师。", "咲季视制作人为可信赖的辅导对象。", "咲季与制作人之间存在关于成长标准的观念差异。"], "worldbuilding_facts": ["咲季是刚成为偶像的新生。", "当前成绩被视为接近顶尖偶像的水平。", "偶像行业存在明确的向上攀登与自我超越的晋升路径。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00419", "scene_id": "scene-00419", "source_file": "CSV/pstory/hski/adv_pstory_001_hski_ending-normal-05.csv", "source_kind": "pstory", "chapter": "pstory/hski", "scene": "adv_pstory_001_hski_ending-normal-05", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "27", "line_count": 27}], "source_refs": ["CSV/pstory/hski/adv_pstory_001_hski_ending-normal-05.csv:1-27"], "line_count": 27, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "character_arc", "team_story"], "title": "咲季复活与重新出发", "summary": "咲季因比赛失利而崩溃，制作人抄近路找到她。制作人指出咲季乱跑导致受伤风险，并强调在她重新开始时必须在场支持。咲季接受教训，决心在制作人的视线范围内，带着不甘心的情绪共同商讨获胜策略，正式复活。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["哼", "制作人", "啦"], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "呜呜呜呜呜呜～～～～～～～～～！"}, {"source_row": "5", "speaker": "制作人", "text_zh": "因为你突然跑走了。……所以抄了近路。"}, {"source_row": "14", "speaker": "制作人", "text_zh": "花海咲季要重新开始的时候，需要制作人在场吧。"}, {"source_row": "27", "speaker": "咲季", "text_zh": "让我们一边不甘心着，一边讨论获胜的方法吧！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季因比赛结果不佳而情绪崩溃并乱跑。", "制作人抄近路找到咲季并指出其乱跑的危险性。", "咲季接受制作人的指导，决定在视线范围内重新开始。", "咲季与制作人约定带着不甘心的情绪共同商讨获胜方法。"], "relationship_facts": ["咲季是制作人的搭档与命运共同体。", "制作人在咲季低谷时提供支持与指导。", "咲季对制作人抱有信任并愿意接受其管教。"], "worldbuilding_facts": ["咲季作为担当偶像，在失败后需要重新开始。", "制作人在咲季重新开始时必须处于其视线范围内。", "咲季在情绪爆发后乱跑可能导致身体受伤。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00420", "scene_id": "scene-00420", "source_file": "CSV/pstory/hski/adv_pstory_001_hski_ending-true-01.csv", "source_kind": "pstory", "chapter": "pstory/hski", "scene": "adv_pstory_001_hski_ending-true-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "34", "line_count": 34}], "source_refs": ["CSV/pstory/hski/adv_pstory_001_hski_ending-true-01.csv:1-34"], "line_count": 34, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "character_arc", "plot"], "title": "咲季登顶偶像巅峰", "summary": "演出落幕后，咲季自信宣告自己成为未来顶级偶像，对观众与对手的胜利令她欣喜若狂。她感谢制作人的支持与理解，视其为专属搭档。咲季表达虽满足但目标更高，并深情告白希望永远同行，强调这是追逐梦想的羁绊而非恋爱，展现了其进取心与对伙伴的珍视。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "姐姐", "对手"], "worldbuilding_signals": ["学园", "偶像"], "dialogue_style_signals": ["当然", "真是的", "呵呵", "嘿嘿", "制作人", "啦"], "key_evidence": [{"source_row": "4", "speaker": "咲季", "text_zh": "我花海咲季才是未来的顶级偶像！"}, {"source_row": "26", "speaker": "咲季", "text_zh": "因为啊，你可是我的专属制作人！"}, {"source_row": "32", "speaker": "咲季", "text_zh": "不是恋爱那种意思哦……是想永远在一起的那种……"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季确信自己是最棒的演出，目标是成为未来顶级偶像。", "咲季认为制作人是其专属制作人，一直理解并支持她。", "咲季将两人关系定义为追逐共同梦想的搭档，希望永远在一起。"], "relationship_facts": ["咲季与制作人是追逐梦想的搭档关系。", "咲季视制作人为专属制作人，对其怀有深厚感激与依赖。", "咲季与制作人之间是超越普通恋爱的、希望永远同行的羁绊。"], "worldbuilding_facts": ["咲季所在的学园存在与其他学园的偶像对手。", "咲季拥有专属制作人的职位设定。", "咲季的目标是成为未来的顶级偶像。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00421", "scene_id": "scene-00421", "source_file": "CSV/pstory/hski/adv_pstory_001_hski_opening-normal-01.csv", "source_kind": "pstory", "chapter": "pstory/hski", "scene": "adv_pstory_001_hski_opening-normal-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "5", "line_count": 5}], "source_refs": ["CSV/pstory/hski/adv_pstory_001_hski_opening-normal-01.csv:1-5"], "line_count": 5, "speakers": ["制作人", "咲季"], "topics": ["dialogue_style", "relationships", "team_story"], "title": "咲季展示培育实力", "summary": "咲季在正式培育开始前，向制作人展示自身实力，并自信表示实力远超预期。制作人对此表示认可，随即提议开始旨在帮助咲季获胜的培育计划，双方确立了共同奋斗的关系。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["制作人"], "worldbuilding_signals": [], "dialogue_style_signals": ["当然", "制作人"], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "在开始培育之前，先让你看看我的实力吧。"}, {"source_row": "3", "speaker": "咲季", "text_zh": "呜呜……我的实力才不止这种程度呢！"}, {"source_row": "5", "speaker": "制作人", "text_zh": "来吧，让我们开始为了让你获胜的培育吧！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季在培育开始前主动展示实力。", "咲季自信地表示自己的实力远超当前表现。", "制作人决定开始帮助咲季获胜的培育。"], "relationship_facts": ["咲季与制作人之间是培育者与指导者的关系。", "咲季对制作人抱有信任与期待。", "制作人对咲季的实力与潜力给予肯定。"], "worldbuilding_facts": ["存在名为“培育”的特定活动或机制。", "咲季拥有某种可被量化的“实力”。", "咲季的目标是赢得相关比赛或挑战。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00422", "scene_id": "scene-00422", "source_file": "CSV/pstory/hski/adv_pstory_001_hski_opening-normal-02.csv", "source_kind": "pstory", "chapter": "pstory/hski", "scene": "adv_pstory_001_hski_opening-normal-02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "4", "line_count": 4}], "source_refs": ["CSV/pstory/hski/adv_pstory_001_hski_opening-normal-02.csv:1-4"], "line_count": 4, "speakers": ["制作人", "咲季"], "topics": ["dialogue_style", "relationships", "character_arc", "plot"], "title": "咲季立志成为世界第一偶像", "summary": "咲季向制作人问好，随即展现出成为世界第一偶像的坚定决心。她号召制作人一同全力以赴，展现了其作为偶像的自信与热情，开启了两人共同奋斗的日常篇章。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["制作人"], "key_evidence": [{"source_row": "3", "speaker": "咲季", "text_zh": "以成为世界第一的偶像为目标"}, {"source_row": "4", "speaker": "咲季", "text_zh": "我们要全力以赴哦！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季向制作人表达了早安的问候。", "咲季明确提出了成为世界第一偶像的目标。", "咲季邀请制作人一起全力以赴。"], "relationship_facts": ["咲季称呼对方为制作人。", "咲季称呼对方为咲季同学。", "咲季与制作人处于共同奋斗的关系。"], "worldbuilding_facts": ["咲季的终极目标是成为世界第一的偶像。", "咲季对待偶像事业的态度是全力以赴。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00423", "scene_id": "scene-00423", "source_file": "CSV/pstory/hski/adv_pstory_001_hski_opening-normal-03.csv", "source_kind": "pstory", "chapter": "pstory/hski", "scene": "adv_pstory_001_hski_opening-normal-03", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "5", "line_count": 5}], "source_refs": ["CSV/pstory/hski/adv_pstory_001_hski_opening-normal-03.csv:1-5"], "line_count": 5, "speakers": ["制作人", "咲季"], "topics": ["dialogue_style", "relationships"], "title": "咲季向制作人宣告梦想", "summary": "咲季见到干劲满满的制作人后，兴奋地表示要全力冲刺梦想。她强调这是自己的作风，并郑重要求制作人务必记住这一决心，展现了咲季积极热情且目标明确的性格特质。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人"], "worldbuilding_signals": [], "dialogue_style_signals": ["当然", "哼", "制作人", "啦"], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "制作人！今天要做什么呢？"}, {"source_row": "2", "speaker": "制作人", "text_zh": "干劲满满呢。"}, {"source_row": "4", "speaker": "咲季", "text_zh": "给我记好了，制作人！"}, {"source_row": "5", "speaker": "咲季", "text_zh": "向着梦想全力冲刺！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季见到制作人时情绪高涨。", "咲季确认制作人也充满干劲。", "咲季决定向着梦想全力冲刺。", "咲季要求制作人记住她的作风。"], "relationship_facts": ["咲季称呼对方为制作人。", "咲季与制作人关系亲密。", "咲季视制作人为梦想的见证者。"], "worldbuilding_facts": ["咲季拥有明确的个人梦想。", "咲季行事作风积极且充满干劲。", "咲季重视对他人的承诺与告知。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00424", "scene_id": "scene-00424", "source_file": "CSV/pstory/hski/adv_pstory_001_hski_opening-normal-04.csv", "source_kind": "pstory", "chapter": "pstory/hski", "scene": "adv_pstory_001_hski_opening-normal-04", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "5", "line_count": 5}], "source_refs": ["CSV/pstory/hski/adv_pstory_001_hski_opening-normal-04.csv:1-5"], "line_count": 5, "speakers": ["制作人", "咲季"], "topics": ["dialogue_style", "relationships", "worldbuilding"], "title": "咲季自信迎接制作人", "summary": "咲季向制作人问好，自信表示状态完美，甚至调侃天地倒转也无法影响她。她认为能培育出这样的偶像，制作人真是幸运儿，展现了其作为偶像的骄傲与对制作人的依赖。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["哼", "制作人", "啦"], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "制作人，早上好！"}, {"source_row": "3", "speaker": "咲季", "text_zh": "哼哼，一如既往地完美哦。"}, {"source_row": "5", "speaker": "咲季", "text_zh": "能培育花海咲季这样的偶像，"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季向制作人问好并询问其状态。", "咲季声称自己状态一如既往地完美。", "咲季认为能培育出她是制作人的幸运。"], "relationship_facts": ["咲季称呼对方为制作人。", "咲季自视为被培育的偶像。", "咲季与制作人关系亲密且带有调侃。"], "worldbuilding_facts": ["咲季拥有极高的自我认知和偶像自信。", "咲季认为自己的状态坚不可摧。", "制作人与咲季存在培育与被培育的关系。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00425", "scene_id": "scene-00425", "source_file": "CSV/pstory/hski/adv_pstory_001_hski_opening-normal-05.csv", "source_kind": "pstory", "chapter": "pstory/hski", "scene": "adv_pstory_001_hski_opening-normal-05", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "5", "line_count": 5}], "source_refs": ["CSV/pstory/hski/adv_pstory_001_hski_opening-normal-05.csv:1-5"], "line_count": 5, "speakers": ["制作人", "咲季"], "topics": ["dialogue_style", "relationships"], "title": "咲季自信展现活力", "summary": "咲季询问制作人对自己近况的看法，制作人称赞她可爱美丽且充满活力。咲季对此表示极度开心，认为制作人很了解自己，并自信地表示现在的自己感觉什么事都能做到，展现了积极向上的状态。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人"], "worldbuilding_signals": [], "dialogue_style_signals": ["嘿嘿", "制作人"], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "你觉得最近的我怎么样？"}, {"source_row": "2", "speaker": "制作人", "text_zh": "变得更加可爱美丽而且充满活力了呢。"}, {"source_row": "3", "speaker": "咲季", "text_zh": "对吧～～～～～～～！！"}, {"source_row": "5", "speaker": "咲季", "text_zh": "现在的我啊，感觉什么事都能做到呢♪"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季询问制作人对自己最近状态的看法。", "制作人评价咲季变得更加可爱美丽且充满活力。", "咲季对制作人的评价感到十分开心和认同。", "咲季自信地表示现在的自己感觉什么事都能做到。"], "relationship_facts": ["咲季与制作人关系亲密，咲季视制作人为能准确了解自己内心想法的人。", "制作人对咲季的状态给予积极正面的评价和关注。"], "worldbuilding_facts": [], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00426", "scene_id": "scene-00426", "source_file": "CSV/pstory/hski/adv_pstory_001_hski_opening-true-01.csv", "source_kind": "pstory", "chapter": "pstory/hski", "scene": "adv_pstory_001_hski_opening-true-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "8", "line_count": 8}], "source_refs": ["CSV/pstory/hski/adv_pstory_001_hski_opening-true-01.csv:1-8"], "line_count": 8, "speakers": ["制作人", "咲季", "选项"], "topics": ["dialogue_style", "relationships", "character_arc", "team_story"], "title": "咲季接受训练计划", "summary": "咲季在早晨向制作人问好，并欣然收下关于训练计划的文件。她自信地表示已牢记反复讨论过的内容，承诺会立即学会并全力以赴，展现了积极认真的态度。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人"], "worldbuilding_signals": ["训练"], "dialogue_style_signals": ["当然", "制作人", "啦"], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "制作人，早上好！"}, {"source_row": "5", "speaker": "咲季", "text_zh": "哎呀，真贴心呢。"}, {"source_row": "7", "speaker": "咲季", "text_zh": "当然都记在脑子里啦。"}, {"source_row": "8", "speaker": "咲季", "text_zh": "就交给我吧。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季在早晨与制作人见面。", "咲季收下了制作人关于训练计划的文件。", "咲季确认已记住之前讨论过的训练内容。", "咲季承诺会立即学会训练计划。"], "relationship_facts": ["咲季与制作人存在上下级或指导关系。", "咲季对制作人表现出亲近与信任。", "制作人负责指导咲季的训练。"], "worldbuilding_facts": ["咲季正在进行某种技能或体能训练。", "咲季与制作人之前已多次讨论过训练细节。", "咲季具备快速学习和掌握新技能的能力。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00427", "scene_id": "scene-00427", "source_file": "CSV/pstory/hski/adv_pstory_001_hski_opening-true-02.csv", "source_kind": "pstory", "chapter": "pstory/hski", "scene": "adv_pstory_001_hski_opening-true-02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "10", "line_count": 10}], "source_refs": ["CSV/pstory/hski/adv_pstory_001_hski_opening-true-02.csv:1-10"], "line_count": 10, "speakers": ["咲季", "选项"], "topics": ["dialogue_style", "character_arc", "plot", "relationships"], "title": "咲季感谢制作人支持", "summary": "咲季询问制作人对其近况的评价，得知对方发现她变得更美丽健康后欣喜不已。她感谢制作人提供的物品，并直言制作人非常喜欢自己。咲季表示锻炼从未懈怠，决心继续精进技能，朝着顶级偶像的目标全力迈进。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["当然", "真是的", "嘿嘿", "制作人", "啦"], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "制作人，你觉得最近的我怎么样？"}, {"source_row": "5", "speaker": "咲季", "text_zh": "不过呢，这也是多亏了你为我准备的各种物品。"}, {"source_row": "9", "speaker": "咲季", "text_zh": "每天的锻炼都没有懈怠哦！"}, {"source_row": "10", "speaker": "咲季", "text_zh": "我要继续精进技能，朝着顶级偶像的目标直线前进！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季询问制作人对其近期状态的看法。", "咲季确认自己每天都在坚持锻炼。", "咲季表达了成为顶级偶像的决心。", "咲季认为制作人非常喜欢她。"], "relationship_facts": ["咲季与制作人关系亲密。", "制作人对咲季非常关注。", "咲季视制作人为重要支持者。"], "worldbuilding_facts": ["咲季的目标是成为顶级偶像。", "咲季通过锻炼维持状态。", "制作人负责为咲季准备物品。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00428", "scene_id": "scene-00428", "source_file": "CSV/pstory/hski/adv_pstory_002_hski_after-audition-a-normal-02.csv", "source_kind": "pstory", "chapter": "pstory/hski", "scene": "adv_pstory_002_hski_after-audition-a-normal-02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "18", "line_count": 18}], "source_refs": ["CSV/pstory/hski/adv_pstory_002_hski_after-audition-a-normal-02.csv:1-18"], "line_count": 18, "speakers": ["制作人", "咲季"], "topics": ["dialogue_style", "relationships", "plot", "worldbuilding"], "title": "咲季合格后的实力探讨", "summary": "制作人告知咲季试镜合格，咲季自信归功于状态绝佳。制作人指出其稳定发挥源于持之以恒的努力与自我管理，肯定了咲季真正的实力。咲季对此表示认同，并自信地表示未来会让制作人见识到其真正的巅峰状态。", "saki_role": "同学/对手：咲季在群像关系中以好胜、直率和带头推进对话的姿态出现。", "relationship_signals": ["制作人", "对手"], "worldbuilding_signals": ["偶像", "试镜"], "dialogue_style_signals": ["当然", "哼", "嘿嘿", "制作人", "让你见识", "不是吗", "啦"], "key_evidence": [{"source_row": "2", "speaker": "制作人", "text_zh": "恭喜你合格了。"}, {"source_row": "4", "speaker": "咲季", "text_zh": "今天的我可是状态绝佳呢。"}, {"source_row": "13", "speaker": "制作人", "text_zh": "这就是咲季同学真正的『实力』啊。"}, {"source_row": "18", "speaker": "咲季", "text_zh": "我真正的巅峰状态——迟早会让你见识到的！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季通过了试镜。", "咲季认为自己的合格是因为状态绝佳。", "咲季平时保持最佳状态，除非发生严重事件。", "咲季缺乏爆发力，但拥有稳定的发挥。"], "relationship_facts": ["制作人与咲季是试镜评审与候选人的关系。", "制作人与咲季互相欣赏对方的实力。", "咲季视制作人为能理解自己的人。"], "worldbuilding_facts": ["咲季是一位偶像。", "咲季拥有持之以恒的努力与自我管理能力。", "咲季拥有真正的实力，且不止于稳定发挥。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00429", "scene_id": "scene-00429", "source_file": "CSV/pstory/hski/adv_pstory_002_hski_after-audition-a-normal-03.csv", "source_kind": "pstory", "chapter": "pstory/hski", "scene": "adv_pstory_002_hski_after-audition-a-normal-03", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "14", "line_count": 14}], "source_refs": ["CSV/pstory/hski/adv_pstory_002_hski_after-audition-a-normal-03.csv:1-14"], "line_count": 14, "speakers": ["制作人", "咲季"], "topics": ["dialogue_style", "plot", "relationships", "character_arc"], "title": "试镜合格后的庆祝", "summary": "咲季得知试镜合格，虽感叹不能松懈，但随即请求观看表演视频。她认真复盘后，决定庆祝这一成果，并誓言继续成长，向制作人展示自己不止于此的实力。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人"], "worldbuilding_signals": ["训练", "试镜"], "dialogue_style_signals": ["制作人", "让你见识"], "key_evidence": [{"source_row": "2", "speaker": "制作人", "text_zh": "合格了。"}, {"source_row": "5", "speaker": "咲季", "text_zh": "我今天表演的视频有吗？"}, {"source_row": "12", "speaker": "咲季", "text_zh": "真是好结果。让我们好好庆祝吧。"}, {"source_row": "14", "speaker": "咲季", "text_zh": "花海咲季可不止这种程度呢。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季通过了试镜。", "咲季请求观看表演视频。", "咲季决定庆祝试镜合格。", "咲季表示未来会继续成长。"], "relationship_facts": ["咲季与制作人是上下级关系。", "咲季与制作人是同事关系。", "咲季与制作人是朋友关系。"], "worldbuilding_facts": ["咲季正在进行演艺训练。", "咲季有表演视频记录。", "咲季是花海咲季。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00430", "scene_id": "scene-00430", "source_file": "CSV/pstory/hski/adv_pstory_002_hski_after-audition-b-normal-02.csv", "source_kind": "pstory", "chapter": "pstory/hski", "scene": "adv_pstory_002_hski_after-audition-b-normal-02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "18", "line_count": 18}], "source_refs": ["CSV/pstory/hski/adv_pstory_002_hski_after-audition-b-normal-02.csv:1-18"], "line_count": 18, "speakers": ["制作人", "咲季"], "topics": ["worldbuilding", "dialogue_style", "plot", "relationships"], "title": "咲季自信迎接试镜合格", "summary": "制作人宣布咲季试镜合格，咲季自信地表示作为未来顶级偶像绝不会落选。她强调保持最佳状态是偶像活动的前提，并列举自己可爱、健康、才艺出众等优点，自认是完美偶像。咲季坦言自己并非天生拥有世界第一的才能，但立志成为世界第一偶像，决心以最佳状态迎接所有挑战。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["制作人"], "worldbuilding_signals": ["偶像", "训练", "试镜", "演唱会"], "dialogue_style_signals": ["当然", "真是的", "呵呵", "制作人"], "key_evidence": [{"source_row": "2", "speaker": "制作人", "text_zh": "合格了。"}, {"source_row": "15", "speaker": "咲季", "text_zh": "并不是天生就拥有世界第一的『偶像才能』。"}, {"source_row": "16", "speaker": "咲季", "text_zh": "这样的我，可是要成为世界第一的偶像呢！"}, {"source_row": "18", "speaker": "咲季", "text_zh": "都要以最佳状态的我来迎接哦！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季通过了试镜。", "咲季认为自己并非天生拥有世界第一的偶像才能。", "咲季立志成为世界第一的偶像。", "咲季决定以最佳状态迎接训练、演唱会及试镜。"], "relationship_facts": ["制作人与咲季是试镜评审与被试者关系。", "咲季视自己为未来的顶级偶像。", "制作人与咲季之间存在关于咲季状态的互动。"], "worldbuilding_facts": ["咲季的目标是成为世界第一的偶像。", "保持最佳状态是咲季偶像活动的大前提。", "咲季具备唱歌跳舞等偶像才艺。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00431", "scene_id": "scene-00431", "source_file": "CSV/pstory/hski/adv_pstory_002_hski_after-audition-b-normal-03.csv", "source_kind": "pstory", "chapter": "pstory/hski", "scene": "adv_pstory_002_hski_after-audition-b-normal-03", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "12", "line_count": 12}], "source_refs": ["CSV/pstory/hski/adv_pstory_002_hski_after-audition-b-normal-03.csv:1-12"], "line_count": 12, "speakers": ["制作人", "咲季"], "topics": ["dialogue_style", "relationships", "plot", "character_arc"], "title": "咲季通过试镜", "summary": "制作人告知咲季试镜合格，咲季虽因刚才回答不佳而担忧，但随即自信表示只是紧张。她期待正式加入，并请求制作人好好培育自己，展现出对未来的期待与对制作人的信赖。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人"], "worldbuilding_signals": ["试镜"], "dialogue_style_signals": ["制作人", "啦"], "key_evidence": [{"source_row": "2", "speaker": "制作人", "text_zh": "合格了哦。"}, {"source_row": "4", "speaker": "咲季", "text_zh": "刚才的回答听起来不太妙呢。"}, {"source_row": "8", "speaker": "咲季", "text_zh": "今天只是……稍微、有一点点紧张而已。"}, {"source_row": "12", "speaker": "咲季", "text_zh": "要好好培育我才行哦！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季通过了试镜。", "咲季认为刚才的回答听起来不太妙。", "咲季表示只是稍微有点紧张。", "咲季请求制作人好好培育她。"], "relationship_facts": ["咲季与制作人是上下级或师徒关系。", "咲季对制作人抱有信赖感。", "咲季期待制作人的指导。"], "worldbuilding_facts": ["咲季正在参加偶像或演艺相关的试镜。", "咲季具备表演或回答问题的能力。", "咲季需要接受培育才能正式活动。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00432", "scene_id": "scene-00432", "source_file": "CSV/pstory/hski/adv_pstory_002_hski_after-audition-final-failure-01.csv", "source_kind": "pstory", "chapter": "pstory/hski", "scene": "adv_pstory_002_hski_after-audition-final-failure-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "11", "line_count": 11}], "source_refs": ["CSV/pstory/hski/adv_pstory_002_hski_after-audition-final-failure-01.csv:1-11"], "line_count": 11, "speakers": ["咲季"], "topics": ["relationships", "dialogue_style"], "title": "败者之约与重燃希望", "summary": "咲季在选拔最终失败后，认定今日为人生必败对决，拒绝原谅自己。但她决定履行败者义务去见佑芽，并请求陪伴，旨在从明天起重新站起来继续奔跑，展现了在绝望中寻求支持与重生的决心。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽"], "worldbuilding_signals": [], "dialogue_style_signals": ["制作人"], "key_evidence": [{"source_row": "3", "speaker": "咲季", "text_zh": "对我来说，那就是今天。"}, {"source_row": "7", "speaker": "咲季", "text_zh": "我要去见佑芽，履行败者的义务。"}, {"source_row": "11", "speaker": "咲季", "text_zh": "为了从明天开始……能重新站起来继续奔跑。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季在选拔最终对决中失败。", "咲季决定去见佑芽以履行败者义务。", "咲季请求陪伴以从明天开始重新奔跑。"], "relationship_facts": ["咲季与制作人存在工作关系。", "咲季与佑芽存在需要履行义务的关联。"], "worldbuilding_facts": ["存在选拔最终对决这一关键事件。", "败者需履行特定义务。", "角色面临人生必败对决的心理压力。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00433", "scene_id": "scene-00433", "source_file": "CSV/pstory/hski/adv_pstory_002_hski_after-audition-final-normal-01.csv", "source_kind": "pstory", "chapter": "pstory/hski", "scene": "adv_pstory_002_hski_after-audition-final-normal-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "14", "line_count": 14}], "source_refs": ["CSV/pstory/hski/adv_pstory_002_hski_after-audition-final-normal-01.csv:1-14"], "line_count": 14, "speakers": ["制作人", "咲季"], "topics": ["dialogue_style", "relationships", "plot", "team_story"], "title": "试镜胜利与正式演出", "summary": "花海咲季在试镜中夺得第一名，与制作人互相祝贺。咲季感谢制作人的培育，并意识到正式演出尚未开始。她决定振作精神，向观众展示未来顶级偶像花海咲季的英姿，展现了对未来的决心。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人"], "worldbuilding_signals": ["偶像", "试镜", "演唱会"], "dialogue_style_signals": ["当然", "制作人", "啦"], "key_evidence": [{"source_row": "2", "speaker": "咲季", "text_zh": "太～好～啦！我们做到了呢"}, {"source_row": "5", "speaker": "咲季", "text_zh": "这都是多亏了你的培育哦"}, {"source_row": "10", "speaker": "咲季", "text_zh": "还有正式演出在等着我们"}, {"source_row": "14", "speaker": "咲季", "text_zh": "未来顶级偶像花海咲季的英姿"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季在试镜中获得了第一名。", "咲季感谢制作人的培育与指导。", "咲季决定为正式演出重新打起精神。", "咲季立志向观众展示顶级偶像的英姿。"], "relationship_facts": ["咲季与制作人之间是培育与被培育的关系。", "咲季视制作人为重要的支持者。", "咲季与制作人共同面对未来的正式演出。"], "worldbuilding_facts": ["花海咲季的目标是成为未来顶级偶像。", "正式演出是试镜合格后的下一个重要阶段。", "咲季拥有向观众展示英姿的偶像身份。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00434", "scene_id": "scene-00434", "source_file": "CSV/pstory/hski/adv_pstory_002_hski_after-audition-mid-failure-01.csv", "source_kind": "pstory", "chapter": "pstory/hski", "scene": "adv_pstory_002_hski_after-audition-mid-failure-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "12", "line_count": 12}], "source_refs": ["CSV/pstory/hski/adv_pstory_002_hski_after-audition-mid-failure-01.csv:1-12"], "line_count": 12, "speakers": ["制作人", "咲季"], "topics": ["dialogue_style", "relationships", "plot", "character_arc"], "title": "咲季接受失败并立即复盘", "summary": "制作人告知咲季试镜不合格，咲季虽感措手不及但迅速调整心态。她认为制作人是为了让她快速转换心情，于是决定节省懊悔时间，立刻开始复盘会议，立志以最快速度复仇成功。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["制作人"], "worldbuilding_signals": [], "dialogue_style_signals": ["当然", "真是的", "制作人", "啦"], "key_evidence": [{"source_row": "1", "speaker": "制作人", "text_zh": "花海同学，不合格了。"}, {"source_row": "5", "speaker": "咲季", "text_zh": "这么轻描淡写地甩出残酷事实"}, {"source_row": "10", "speaker": "咲季", "text_zh": "就当是节省了时间吧。"}, {"source_row": "12", "speaker": "咲季", "text_zh": "要用最短时间最快速度复仇成功！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季在试镜中未能通过。", "咲季对制作人的直接告知感到意外。", "咲季决定跳过懊悔阶段直接进入复盘。", "咲季立誓要快速复仇成功。"], "relationship_facts": ["制作人与咲季是上下级或指导关系。", "制作人了解咲季的性格特点。", "咲季对制作人抱有信任。"], "worldbuilding_facts": ["试镜结果会直接影响后续安排。", "复盘会议是处理失败的标准流程。", "角色具备快速转换心情的能力。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00435", "scene_id": "scene-00435", "source_file": "CSV/pstory/hski/adv_pstory_002_hski_before-audition-a-normal-01.csv", "source_kind": "pstory", "chapter": "pstory/hski", "scene": "adv_pstory_002_hski_before-audition-a-normal-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "15", "line_count": 15}], "source_refs": ["CSV/pstory/hski/adv_pstory_002_hski_before-audition-a-normal-01.csv:1-15"], "line_count": 15, "speakers": ["制作人", "咲季"], "topics": ["dialogue_style", "worldbuilding", "relationships"], "title": "咲季赛前自我确认", "summary": "咲季在镜前完成各项准备，自信满满地邀请制作人观看。她坦言虽习惯竞技比赛的紧张感，但意识到偶像领域截然不同，决心重新认真适应。她正努力适应偶像身份，并准备展示成果。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["嘿嘿", "制作人", "啦"], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "照镜子啦～——脸蛋OK！声音OK！动作OK！"}, {"source_row": "7", "speaker": "咲季", "text_zh": "至今为止经历过各种竞技项目，参加过很多比赛。"}, {"source_row": "10", "speaker": "咲季", "text_zh": "但是……终究是不同的领域啊。不可能完全一样的。"}, {"source_row": "15", "speaker": "咲季", "text_zh": "现在就来展示这份成果吧。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季已完成脸蛋、声音、动作的准备工作。", "咲季认为竞技比赛的紧张感与偶像领域不同。", "咲季决心重新认真成为一名偶像。", "咲季正在逐渐适应偶像领域及自身身份。"], "relationship_facts": ["咲季与制作人是偶像与制作人的关系。", "咲季向制作人展示准备成果。"], "worldbuilding_facts": ["咲季曾参与多种竞技项目及比赛。", "咲季拥有自己独特的集中方式。", "咲季是偶像界的新人。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00436", "scene_id": "scene-00436", "source_file": "CSV/pstory/hski/adv_pstory_002_hski_before-audition-b-normal-01.csv", "source_kind": "pstory", "chapter": "pstory/hski", "scene": "adv_pstory_002_hski_before-audition-b-normal-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "15", "line_count": 15}], "source_refs": ["CSV/pstory/hski/adv_pstory_002_hski_before-audition-b-normal-01.csv:1-15"], "line_count": 15, "speakers": ["制作人", "咲季"], "topics": ["dialogue_style", "relationships", "team_story", "worldbuilding"], "title": "咲季面对粉丝期待的紧张", "summary": "演出前制作人提醒咲季时间将至，咲季坦言自己比平时更紧张，感受到舞台压力。她意识到粉丝支持越来越多，想要回应这份期待，因喜爱大家而决心跨越紧张，带着心情准备登场。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["制作人"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["制作人"], "key_evidence": [{"source_row": "6", "speaker": "咲季", "text_zh": "总觉得我啊，好像比平时更紧张了。"}, {"source_row": "9", "speaker": "咲季", "text_zh": "粉丝的分量吧。支持偶像·花海咲季的人越来越多了……"}, {"source_row": "15", "speaker": "咲季", "text_zh": "我一定要跨越过去。带着这份心情一起！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季在演出前感到比平时更紧张。", "咲季认为紧张源于粉丝日益增多的支持。", "咲季决心回应粉丝期待并跨越紧张。"], "relationship_facts": ["咲季与粉丝之间存在支持与回应的关系。", "制作人与咲季是指导与被指导的关系。"], "worldbuilding_facts": ["咲季是一名偶像。", "咲季即将站上大舞台进行演出。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00437", "scene_id": "scene-00437", "source_file": "CSV/pstory/hski/adv_pstory_002_hski_ending-normal-02.csv", "source_kind": "pstory", "chapter": "pstory/hski", "scene": "adv_pstory_002_hski_ending-normal-02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "7", "line_count": 7}], "source_refs": ["CSV/pstory/hski/adv_pstory_002_hski_ending-normal-02.csv:1-7"], "line_count": 7, "speakers": ["咲季"], "topics": ["dialogue_style", "relationships", "team_story", "plot"], "title": "咲季胜出试镜宣告正戏", "summary": "咲季向制作人汇报在选定的试镜中成功胜出，视此为热身运动。她指出真正的对手另有其人，并自信地表示即将开始的‘正戏’绝对会赢，邀请制作人一同见证胜利。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人", "对手"], "worldbuilding_signals": ["试镜"], "dialogue_style_signals": ["当然", "哼", "制作人"], "key_evidence": [{"source_row": "2", "speaker": "咲季", "text_zh": "在你选择的试镜中我成功胜出了呢。"}, {"source_row": "4", "speaker": "咲季", "text_zh": "我们真正该对决的对手另有其人。"}, {"source_row": "6", "speaker": "咲季", "text_zh": "差不多该进入正戏了。"}, {"source_row": "7", "speaker": "咲季", "text_zh": "我们绝对会赢的哦，制作人！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季在选定的试镜中成功胜出。", "咲季将试镜视为热身运动。", "咲季认为真正的对手是另有其人。", "咲季确信即将开始的‘正戏’会获胜。"], "relationship_facts": ["咲季与制作人存在工作合作关系。", "咲季向制作人汇报试镜结果。", "咲季邀请制作人共同面对真正的挑战。"], "worldbuilding_facts": ["存在名为‘试镜’的选拔环节。", "咲季将当前挑战定义为‘热身运动’。", "咲季将后续挑战定义为‘正戏’。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00438", "scene_id": "scene-00438", "source_file": "CSV/pstory/hski/adv_pstory_002_hski_opening-normal-02.csv", "source_kind": "pstory", "chapter": "pstory/hski", "scene": "adv_pstory_002_hski_opening-normal-02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "3", "line_count": 3}], "source_refs": ["CSV/pstory/hski/adv_pstory_002_hski_opening-normal-02.csv:1-3"], "line_count": 3, "speakers": ["咲季"], "topics": ["dialogue_style", "relationships", "worldbuilding"], "title": "咲季准备开启新活动", "summary": "咲季向制作人问好，确认准备工作就绪。她满怀信心地表示要让粉丝数量大幅增加，展现出积极投入工作的态度和对提升人气目标的坚定决心。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人"], "worldbuilding_signals": ["工作"], "dialogue_style_signals": ["制作人", "啦"], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "早上好，制作人！"}, {"source_row": "2", "speaker": "咲季", "text_zh": "好啦～准备工作都完成了吗？"}, {"source_row": "3", "speaker": "咲季", "text_zh": "我要让我的粉丝变得超级多哦！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季已确认所有准备工作完成。", "咲季的目标是让粉丝数量变得超级多。", "咲季正在与制作人进行对话。"], "relationship_facts": ["咲季与制作人存在工作关系。"], "worldbuilding_facts": ["咲季是偶像或艺人角色。", "咲季关注自身人气与粉丝数量。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00439", "scene_id": "scene-00439", "source_file": "CSV/pstory/hume/adv_pstory_001_hume_after-audition-final-failure-01.csv", "source_kind": "pstory", "chapter": "pstory/hume", "scene": "adv_pstory_001_hume_after-audition-final-failure-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "40", "line_count": 40}], "source_refs": ["CSV/pstory/hume/adv_pstory_001_hume_after-audition-final-failure-01.csv:1-40"], "line_count": 40, "speakers": ["佑芽", "制作人", "选项"], "topics": ["relationships", "dialogue_style", "character_arc", "plot"], "title": "咲季缺席的败北反省", "summary": "佑芽在选拔中落败，制作人虽肯定其精神但指出结果未变。佑芽因害怕面对咲季的责骂与鼓励而拒绝见面，认为这是通往胜利的最短捷径。制作人决定去叫咲季来给予佑芽所需的话语，佑芽随即陷入矛盾纠结。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "姐姐"], "worldbuilding_signals": [], "dialogue_style_signals": ["当然", "哼", "制作人", "啦"], "key_evidence": [{"source_row": "2", "speaker": "制作人", "text_zh": "……不合格。"}, {"source_row": "7", "speaker": "选项", "text_zh": "咲季同学来了哦"}, {"source_row": "28", "speaker": "制作人", "text_zh": "如果是咲季同学的话一定……"}, {"source_row": "37", "speaker": "佑芽", "text_zh": "因为这才是通往胜利的最短捷径啊。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["佑芽在选拔试镜中最终不合格。", "佑芽因害怕面对咲季而拒绝与其见面。", "制作人认为咲季能给予佑芽此刻最需要的话语。", "佑芽认为见到咲季是通往胜利的最短捷径。"], "relationship_facts": ["佑芽与咲季是姐妹关系（姐姐与妹妹）。", "制作人是佑芽的引导者及上司。", "咲季是佑芽在演艺道路上重要的精神支柱。"], "worldbuilding_facts": ["选拔试镜结果不合格意味着需要重新反省。", "面对失败，角色间存在复杂的鼓励与责骂机制。", "见到重要的人被视为克服失败、继续努力的捷径。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00440", "scene_id": "scene-00440", "source_file": "CSV/pstory/hume/adv_pstory_001_hume_after-audition-final-normal-02.csv", "source_kind": "pstory", "chapter": "pstory/hume", "scene": "adv_pstory_001_hume_after-audition-final-normal-02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "36", "line_count": 36}], "source_refs": ["CSV/pstory/hume/adv_pstory_001_hume_after-audition-final-normal-02.csv:1-36"], "line_count": 36, "speakers": ["佑芽", "制作人", "选项"], "topics": ["relationships", "dialogue_style", "character_arc", "plot"], "title": "咲季缺席的选拔后", "summary": "佑芽在选拔合格后，因不满未获第一而决心全力备战演唱会。制作人指出她这种‘只要做到这点’的极限努力方式，正是咲季的做法，并鼓励她继续逼近极限的训练，佑芽欣然接受并承诺献上最棒演出。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "姐姐"], "worldbuilding_signals": ["训练", "演唱会"], "dialogue_style_signals": ["当然", "真是的", "制作人", "啦"], "key_evidence": [{"source_row": "25", "speaker": "制作人", "text_zh": "咲季同学肯定也是这么做的哦。"}, {"source_row": "12", "speaker": "佑芽", "text_zh": "但是，我讨厌输的感觉。"}, {"source_row": "28", "speaker": "制作人", "text_zh": "今后也请继续参加逼近极限的训练吧。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["佑芽对选拔结果不满意，因讨厌输的感觉。", "制作人指出佑芽的极限努力方式与咲季相同。", "佑芽决定全力备战即将到来的演唱会。"], "relationship_facts": ["佑芽与咲季存在竞争或模仿关系。", "制作人与佑芽是指导与被指导关系。", "咲季是制作人提及的榜样人物。"], "worldbuilding_facts": ["选拔结果并非唯一标准，演唱会表现同样重要。", "角色们面临逼近体力的极限训练。", "‘只要做到这点’代表全力以赴的极限状态。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00441", "scene_id": "scene-00441", "source_file": "CSV/pstory/hume/adv_pstory_001_hume_after-audition-mid-normal-01.csv", "source_kind": "pstory", "chapter": "pstory/hume", "scene": "adv_pstory_001_hume_after-audition-mid-normal-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "27", "line_count": 27}], "source_refs": ["CSV/pstory/hume/adv_pstory_001_hume_after-audition-mid-normal-01.csv:1-27"], "line_count": 27, "speakers": ["佑芽", "制作人", "选项"], "topics": ["relationships", "dialogue_style", "character_arc", "plot"], "title": "佑芽初胜后的决心", "summary": "佑芽在培育活动中首次获胜，兴奋地向制作人分享喜悦。她认为这只是第一道关卡，未来将不断挑战更有趣的比赛。制作人认同胜利带来的快感，两人约定要持续获胜，共同加速前进。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "姐姐"], "worldbuilding_signals": [], "dialogue_style_signals": ["当然", "嘿嘿", "制作人", "啦"], "key_evidence": [{"source_row": "10", "speaker": "佑芽", "text_zh": "等告诉姐姐之后……"}, {"source_row": "13", "speaker": "佑芽", "text_zh": "只是突破了第一道关卡而已。"}, {"source_row": "23", "speaker": "制作人", "text_zh": "下一场，再下一场，我们都要赢。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["佑芽在培育活动中首次获得合格结果。", "佑芽认为目前只是突破了第一道关卡。", "佑芽计划等告诉姐姐（咲季）后再分享喜悦。", "制作人与佑芽都渴望不断获胜。"], "relationship_facts": ["佑芽称呼咲季为姐姐。", "佑芽与制作人关系亲密，互相鼓励。", "咲季是佑芽想要炫耀成果的对象。"], "worldbuilding_facts": ["存在名为“培育活动”的竞赛机制。", "获胜会带来上瘾般的快感。", "比赛结果分为合格与落败。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00442", "scene_id": "scene-00442", "source_file": "CSV/pstory/hume/adv_pstory_001_hume_after-audition-mid-normal-03.csv", "source_kind": "pstory", "chapter": "pstory/hume", "scene": "adv_pstory_001_hume_after-audition-mid-normal-03", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "35", "line_count": 35}], "source_refs": ["CSV/pstory/hume/adv_pstory_001_hume_after-audition-mid-normal-03.csv:1-35"], "line_count": 35, "speakers": ["佑芽", "制作人", "选项"], "topics": ["relationships", "dialogue_style", "plot", "character_arc"], "title": "佑芽的偶像第一步", "summary": "佑芽在制作人鼓励下通过选拔，意识到自己成长迅速。她回顾过去因起步慢而落后的痛苦循环，决心终结这种状态。制作人拉佑芽一把的恩情，佑芽誓要加倍报答，立志追赶目标。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["制作人", "啦"], "key_evidence": [{"source_row": "15", "speaker": "制作人", "text_zh": "不擅长起步的超级大器晚成型"}, {"source_row": "19", "speaker": "佑芽", "text_zh": "花海佑芽！作为偶像！成功迈出了最棒的第一步"}, {"source_row": "24", "speaker": "佑芽", "text_zh": "想要追赶的人，却早已不见踪影"}, {"source_row": "35", "speaker": "佑芽", "text_zh": "请做好觉悟吧！这份恩情，我一定会报答的"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["佑芽通过了偶像选拔，被评价为成长迅速。", "佑芽承认自己过去是慢半拍且容易在起跑时失败的人。", "制作人指出佑芽克服了最大的弱点，迈出了第一步。", "佑芽决心报答制作人的帮助，缩短与目标的差距。"], "relationship_facts": ["制作人与佑芽：指导者与受助者，制作人帮助佑芽起步。", "佑芽与花海咲季：被提及的关联人物，佑芽正在追赶的对象。", "佑芽与教练：存在竞技项目上的评价关系。"], "worldbuilding_facts": ["偶像新人需要克服起步慢的弱点。", "竞技项目中达到优秀评价通常需要很长时间。", "花海咲季是佑芽想要追赶的目标人物。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00443", "scene_id": "scene-00443", "source_file": "CSV/pstory/hume/adv_pstory_001_hume_ending-normal-01.csv", "source_kind": "pstory", "chapter": "pstory/hume", "scene": "adv_pstory_001_hume_ending-normal-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "25", "line_count": 25}], "source_refs": ["CSV/pstory/hume/adv_pstory_001_hume_ending-normal-01.csv:1-25"], "line_count": 25, "speakers": ["佑芽", "制作人", "选项"], "topics": ["relationships", "dialogue_style", "team_story"], "title": "咲季式休养与假期会议", "summary": "休息日里，佑芽提议外出游玩，制作人建议邀请咲季。佑芽吐槽咲季虽声称全力休养却纹丝不动，认为其风格难约。制作人认同咲季风格，佑芽随即提议召开制定快乐假期计划的会议，正式开启愉快假期。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "姐姐"], "worldbuilding_signals": [], "dialogue_style_signals": ["制作人", "啦"], "key_evidence": [{"source_row": "6", "speaker": "佑芽", "text_zh": "说什么要全力休养！结果一整天都纹丝不动呢！"}, {"source_row": "7", "speaker": "制作人", "text_zh": "很有咲季同学的风格呢。你不学她那样吗？"}, {"source_row": "19", "speaker": "佑芽", "text_zh": "没错！是为了让今天成为快乐假期的会议！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["咲季声称全力休养但一整天纹丝不动", "制作人认为咲季纹丝不动是其典型风格", "佑芽提议召开制定快乐假期计划的会议"], "relationship_facts": ["佑芽与咲季是亲密的同伴关系", "制作人与咲季存在风格上的共鸣", "佑芽与制作人共同策划假期活动"], "worldbuilding_facts": ["咲季在休养日表现出独特的静止状态", "角色间存在互相调侃的轻松氛围", "假期活动需要通过会议形式制定计划"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00444", "scene_id": "scene-00444", "source_file": "CSV/pstory/hume/adv_pstory_001_hume_ending-normal-02.csv", "source_kind": "pstory", "chapter": "pstory/hume", "scene": "adv_pstory_001_hume_ending-normal-02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "29", "line_count": 29}], "source_refs": ["CSV/pstory/hume/adv_pstory_001_hume_ending-normal-02.csv:1-29"], "line_count": 29, "speakers": ["佑芽", "制作人", "选项"], "topics": ["relationships", "dialogue_style", "worldbuilding", "character_arc"], "title": "佑芽的异常成长", "summary": "制作人总结佑芽的偶像活动结果虽好却过于突兀，形容其成长曲线不合常理，与咲季相似。佑芽对此感到困惑，认为这是制作人的功劳，并表达了从今以后请多多关照的决心。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "姐姐"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["当然", "制作人"], "key_evidence": [{"source_row": "22", "speaker": "制作人", "text_zh": "现在的佑芽同学，也和咲季同学一样奇怪呢。"}, {"source_row": "19", "speaker": "制作人", "text_zh": "成长本来应该是更平缓的上升曲线才对。"}, {"source_row": "24", "speaker": "佑芽", "text_zh": "如果真是这样的话……那都是制作人的功劳。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["佑芽的偶像水平在短时间内从门外汉达到舞台标准。", "佑芽的成长速度被描述为不合常理的突然蹿升。", "佑芽将自身能力的飞跃归功于制作人的指导。", "佑芽与咲季被制作人指出具有相似的奇怪特质。"], "relationship_facts": ["制作人与佑芽是指导与被指导的关系。", "佑芽与咲季被制作人进行类比。", "佑芽对制作人抱有强烈的依赖与感激之情。"], "worldbuilding_facts": ["普通偶像的成长通常遵循平缓的上升曲线。", "在偶像界，短时间内掌握高难度技能被视为不合常理的现象。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00445", "scene_id": "scene-00445", "source_file": "CSV/pstory/shro/adv_pstory_002_shro_before-audition-b-normal-01.csv", "source_kind": "pstory", "chapter": "pstory/shro", "scene": "adv_pstory_002_shro_before-audition-b-normal-01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "15", "line_count": 15}], "source_refs": ["CSV/pstory/shro/adv_pstory_002_shro_before-audition-b-normal-01.csv:1-15"], "line_count": 15, "speakers": ["制作人", "广"], "topics": ["team_story", "relationships", "dialogue_style", "character_arc"], "title": "广模仿咲季的决心", "summary": "广在选拔赛前模仿咲季，表达虽可能不敌强敌但能全力以赴的幸福感。制作人指出广与咲季内在相似，但外表不像。广承认自己与咲季有共同点，展现了面对挑战的积极心态。", "saki_role": "同学/对手：咲季在群像关系中以好胜、直率和带头推进对话的姿态出现。", "relationship_signals": ["制作人", "广", "对手"], "worldbuilding_signals": [], "dialogue_style_signals": ["呵呵", "制作人"], "key_evidence": [{"source_row": "4", "speaker": "广", "text_zh": "咲季。"}, {"source_row": "14", "speaker": "广", "text_zh": "我可能和咲季有点像。"}, {"source_row": "6", "speaker": "制作人", "text_zh": "内在方面，倒是有很多共同点呢。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["广在选拔赛前模仿咲季的心情。", "广认为对手都很强，即使全力以赴也可能落败。", "广觉得被强敌击败反而感到幸福。", "制作人认为广与咲季内在有很多共同点。"], "relationship_facts": ["广与咲季存在性格或心态上的相似性。", "制作人与广讨论咲季的性格特点。", "制作人与广讨论广与咲季的对比。"], "worldbuilding_facts": ["即将举行选拔赛。", "咲季是广的偶像或参照对象。", "广对选拔赛对手的实力有清晰认知。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00446", "scene_id": "scene-00446", "source_file": "CSV/unit/01-01/adv_unit_01-01_02.csv", "source_kind": "unit", "chapter": "unit/01-01", "scene": "adv_unit_01-01_02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "66", "line_count": 66}], "source_refs": ["CSV/unit/01-01/adv_unit_01-01_02.csv:1-66"], "line_count": 66, "speakers": ["众人", "佑芽", "制作人", "咲季", "选项", "？？？"], "topics": ["relationships", "dialogue_style", "worldbuilding", "character_arc"], "title": "咲季现身与宿敌宣言", "summary": "佑芽为战胜偶像前辈而来，制作人现身被拒。咲季突然登场自称制作人姐姐，引发佑芽震惊。制作人欲同时培育两人被众人反对，最终佑芽决定与咲季对决，并视制作人为宿敌，约定成为学园最棒偶像。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "妹妹", "姐姐", "对手"], "worldbuilding_signals": ["学园", "偶像"], "dialogue_style_signals": ["真是的", "哼", "制作人", "啦"], "key_evidence": [{"source_row": "33", "speaker": "咲季", "text_zh": "没错，是姐姐哦！"}, {"source_row": "39", "speaker": "咲季", "text_zh": "那个人，是我的制作人。"}, {"source_row": "52", "speaker": "咲季", "text_zh": "好啊，我来当你的对手！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季是制作人的姐姐。", "咲季是佑芽的姐姐。", "佑芽决定与咲季进行偶像对决。"], "relationship_facts": ["咲季与制作人是姐弟关系。", "咲季与佑芽是姐妹关系。", "佑芽与制作人是宿敌关系。"], "worldbuilding_facts": ["咲季是学园偶像。", "佑芽是学园偶像。", "制作人是两人的共同制作人。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00447", "scene_id": "scene-00447", "source_file": "CSV/unit/01-01/adv_unit_01-01_03.csv", "source_kind": "unit", "chapter": "unit/01-01", "scene": "adv_unit_01-01_03", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "77", "line_count": 77}], "source_refs": ["CSV/unit/01-01/adv_unit_01-01_03.csv:1-77"], "line_count": 77, "speakers": ["众人", "制作人", "咲季", "手毬", "琴音", "？？？"], "topics": ["relationships", "dialogue_style", "team_story", "character_arc"], "title": "咲季与制作人的事务所", "summary": "咲季与制作人确立教室为事务所，讨论妹妹佑芽的竞争关系。随后琴音与手毬出现，制作人宣布三人将组成组合参加夏日祭典，咲季对此感到震惊。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "琴音", "手毬", "妹妹", "姐姐", "对手"], "worldbuilding_signals": ["偶像", "制作人科"], "dialogue_style_signals": ["呵呵", "制作人", "不是吗", "啦"], "key_evidence": [{"source_row": "9", "speaker": "咲季", "text_zh": "这就是属于我们两个人的『偶像事务所』呢。"}, {"source_row": "28", "speaker": "制作人", "text_zh": "都把彼此视为命中注定的对手。"}, {"source_row": "76", "speaker": "制作人", "text_zh": "你们三人将组成组合，以夺冠为目标！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季与制作人将教室作为事务所据点。", "咲季与妹妹佑芽是命中注定的对手且关系亲密。", "制作人决定由咲季、琴音、手毬三人组成组合参加夏日祭典。"], "relationship_facts": ["咲季是花海佑芽的姐姐。", "咲季与制作人关系良好。", "琴音与手毬是被制作人召集的同伴。"], "worldbuilding_facts": ["制作人科学生可使用教室作为活动据点。", "咲季的目标是成为顶级偶像并建立霸业。", "即将举办名为『Hatsuboshi IDOL FESTIVAL』的夏日祭典。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00448", "scene_id": "scene-00448", "source_file": "CSV/unit/01-01/adv_unit_01-01_04.csv", "source_kind": "unit", "chapter": "unit/01-01", "scene": "adv_unit_01-01_04", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "63", "line_count": 63}], "source_refs": ["CSV/unit/01-01/adv_unit_01-01_04.csv:1-63"], "line_count": 63, "speakers": ["制作人", "咲季", "手毬", "旁白", "琴音"], "topics": ["relationships", "team_story", "dialogue_style", "worldbuilding"], "title": "咲季拒绝组建偶像组合", "summary": "初星学园IDOL FESTIVAL庆典上，制作人提议由咲季、手毬与琴音组成组合争夺冠军。咲季作为入学第一拒绝拖后腿，手毬则因反感与人组队而激烈反对。两人争执不下，琴音无奈调解，制作人仍坚信三人是最佳组合并决定继续说服。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人", "琴音", "手毬"], "worldbuilding_signals": ["学园", "偶像"], "dialogue_style_signals": ["当然", "哼", "制作人", "啦"], "key_evidence": [{"source_row": "18", "speaker": "咲季", "text_zh": "本小姐可是入学考试的第一名哦！"}, {"source_row": "20", "speaker": "咲季", "text_zh": "才不需要拖后腿的人呢！"}, {"source_row": "14", "speaker": "手毬", "text_zh": "我怎么可能……会和人组什么组合！"}, {"source_row": "56", "speaker": "制作人", "text_zh": "毕竟你们三人是相性最佳的组合。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季是入学考试第一名，目标是赢得胜利。", "咲季拒绝与手毬组成偶像组合，认为对方会拖后腿。", "手毬强烈反对与人组队，认为咲季是井底之蛙。", "琴音认为两人相性极差，但决定协助制作人说服她们。"], "relationship_facts": ["咲季与手毬因组队问题发生激烈争执。", "琴音作为调解人试图缓和咲季与手毬的矛盾。", "制作人对咲季和手毬的能力表示认可，坚持组建三人组合。"], "worldbuilding_facts": ["初星学园IDOL FESTIVAL是决定最强偶像的庆典。", "庆典设有个人部门和组合部门，最终通过投票选出冠军。", "咲季是初星学园入学考试的第一名新生。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00449", "scene_id": "scene-00449", "source_file": "CSV/unit/01-01/adv_unit_01-01_05.csv", "source_kind": "unit", "chapter": "unit/01-01", "scene": "adv_unit_01-01_05", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "79", "line_count": 79}], "source_refs": ["CSV/unit/01-01/adv_unit_01-01_05.csv:1-79"], "line_count": 79, "speakers": ["制作人", "咲季", "琴音"], "topics": ["relationships", "team_story", "dialogue_style", "character_arc"], "title": "咲季与制作人的舞蹈对决", "summary": "制作人欲说服咲季加入组合，决定以舞蹈比试证明自身价值。咲季自信全科目擅长且舞蹈最强，接受挑战：若制作人胜则加入组合，若咲季胜则制作人专属。琴音虽自知实力悬殊，仍被制作人信任所感动，决心全力以赴。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人", "琴音"], "worldbuilding_signals": ["学园", "偶像", "训练"], "dialogue_style_signals": ["哼", "呵呵", "制作人", "啦"], "key_evidence": [{"source_row": "37", "speaker": "咲季", "text_zh": "不过舞蹈是最强的。问这个干嘛？"}, {"source_row": "54", "speaker": "咲季", "text_zh": "有意思！这挑战我接下了！！"}, {"source_row": "58", "speaker": "咲季", "text_zh": "但反过来要是我赢了，你就得当我专属的制作人！"}, {"source_row": "75", "speaker": "琴音", "text_zh": "我会全力以赴试试看的！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季擅长所有科目，其中舞蹈最为出色。", "咲季与制作人约定后天在舞蹈室进行比试。", "比试结果将决定咲季是否加入组合或制作人是否专属。"], "relationship_facts": ["制作人与咲季：通过舞蹈比试建立专属制作人关系。", "制作人与琴音：制作人信任琴音实力，琴音视制作人为可利用工具人。", "咲季与琴音：咲季拒绝琴音加入组合，认为琴音是拖后腿。"], "worldbuilding_facts": ["学园设有舞蹈训练室供学生练习。", "入学考试中舞蹈是重要考核科目。", "组合组建需成员具备不拖后腿的实力。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00450", "scene_id": "scene-00450", "source_file": "CSV/unit/01-01/adv_unit_01-01_07.csv", "source_kind": "unit", "chapter": "unit/01-01", "scene": "adv_unit_01-01_07", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "73", "line_count": 73}], "source_refs": ["CSV/unit/01-01/adv_unit_01-01_07.csv:1-73"], "line_count": 73, "speakers": ["制作人", "旁白", "琴音", "选项"], "topics": ["relationships", "team_story", "dialogue_style", "character_arc"], "title": "咲季缺席的打工与奖金", "summary": "制作人告知琴音，只要不练习即可战胜咲季。为了解决琴音因无法请假打工而面临的生计问题，制作人提供了奖学金减免、提前发放及组合收入等方案。琴音深受鼓舞，决定全力配合制作人，甚至约定未来成为顶级偶像。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人", "琴音", "伙伴"], "worldbuilding_signals": ["偶像", "工作"], "dialogue_style_signals": ["当然", "嘿嘿", "制作人", "啦"], "key_evidence": [{"source_row": "5", "speaker": "制作人", "text_zh": "只要后天之前什么都不做，就能赢。"}, {"source_row": "21", "speaker": "制作人", "text_zh": "有制作人指导的学生可以放宽获得学院奖学金和补助金的申请条件。"}, {"source_row": "33", "speaker": "制作人", "text_zh": "还能获得一定收入"}, {"source_row": "70", "speaker": "琴音", "text_zh": "嘻嘻～约定好了哦～？"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["制作人建议琴音在决胜负前停止练习。", "制作人提供奖学金减免及提前发放方案。", "琴音决定寻找代班并全力配合制作人。", "琴音与制作人约定未来成为顶级偶像。"], "relationship_facts": ["制作人与琴音是指导与被指导关系。", "琴音视制作人为重要依靠。", "咲季是琴音需要战胜的对手。"], "worldbuilding_facts": ["有针对指导学生的奖学金减免政策。", "组合活动可获得额外收入。", "宿舍费用存在差额退还机制。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00451", "scene_id": "scene-00451", "source_file": "CSV/unit/01-01/adv_unit_01-01_08.csv", "source_kind": "unit", "chapter": "unit/01-01", "scene": "adv_unit_01-01_08", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "71", "line_count": 71}], "source_refs": ["CSV/unit/01-01/adv_unit_01-01_08.csv:1-71"], "line_count": 71, "speakers": ["制作人", "咲季", "旁白", "琴音", "选项"], "topics": ["relationships", "team_story", "dialogue_style", "character_arc"], "title": "咲季与琴音的舞蹈对决", "summary": "咲季与琴音迎来舞蹈对决，琴音因收入保障而状态神清气爽，咲季虽惊讶于对方变化但仍自信迎战。制作人担任评审，咲季先表演，获超出预期评价。随后琴音准备登场，两人约定遵守胜负规则，气氛热烈。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人", "琴音", "对手"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["哼", "呵呵", "制作人", "啦"], "key_evidence": [{"source_row": "1", "speaker": "旁白", "text_zh": "琴音和咲季决一胜负的日子终于到来了。"}, {"source_row": "16", "speaker": "琴音", "text_zh": "这一定就是收入增长得到保障的偶像之力！"}, {"source_row": "36", "speaker": "制作人", "text_zh": "将请咲季同学担任。"}, {"source_row": "58", "speaker": "制作人", "text_zh": "超出预期"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季与琴音进行舞蹈对决，由制作人担任评审。", "琴音因收入保障而状态极佳，自信能轻松获胜。", "咲季对琴音的状态变化感到惊讶，但表示会全力以赴。", "咲季完成舞蹈表演后，获得制作人超出预期的评价。"], "relationship_facts": ["咲季与琴音是竞争对手，约定进行舞蹈比拼。", "制作人是两人的评审，被咲季信任能公平裁决。", "琴音称呼咲季为小花海，两人关系亲密。"], "worldbuilding_facts": ["偶像的收入增长能带来神清气爽的状态。", "咲季入学前半年便以极高强度进行舞蹈练习。", "对决胜负由评审根据表演表现决定。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00452", "scene_id": "scene-00452", "source_file": "CSV/unit/01-01/adv_unit_01-01_09.csv", "source_kind": "unit", "chapter": "unit/01-01", "scene": "adv_unit_01-01_09", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "76", "line_count": 76}], "source_refs": ["CSV/unit/01-01/adv_unit_01-01_09.csv:1-76"], "line_count": 76, "speakers": ["众人", "制作人", "咲季", "琴音"], "topics": ["relationships", "team_story", "dialogue_style", "character_arc"], "title": "咲季与琴音结成组合", "summary": "咲季承认输给琴音后，两人从互相吐槽到坦诚相待。制作人指出琴音因过度劳累丧失自信，咲季则欣赏其好胜心。最终两人因相似的竞争理念决定组成偶像组合，并计划寻找第三位成员。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "琴音", "妹妹", "对手"], "worldbuilding_signals": ["偶像", "训练", "工作"], "dialogue_style_signals": ["当然", "哼", "制作人", "啦"], "key_evidence": [{"source_row": "11", "speaker": "咲季", "text_zh": "是我输了！！！"}, {"source_row": "46", "speaker": "制作人", "text_zh": "这种恶性循环，正是藤田同学丧失自信的原因。"}, {"source_row": "69", "speaker": "咲季", "text_zh": "我彻底爱上战胜我的琴音同学了呀！"}, {"source_row": "72", "speaker": "琴音", "text_zh": "总之！第二任组合成员就这么定了！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季承认自己输给了琴音，并感叹自己无法超越前辈。", "制作人解释琴音之前状态不佳是因为兼职过多导致身心俱疲。", "咲季和琴音因都渴望竞争和胜利而决定组成偶像组合。", "咲季表示要寻找第三个人加入组合，并开玩笑让琴音准备好。"], "relationship_facts": ["咲季与琴音是即将组成组合的搭档。", "咲季将琴音视为值得尊敬的偶像前辈。", "咲季与琴音被制作人指出是拥有相似竞争理念的同类。"], "worldbuilding_facts": ["偶像活动存在激烈的竞争，目标是成为世界第一。", "偶像需要同时兼顾训练、兼职工作以及保持身体状态。", "过度劳累和睡眠不足会导致偶像成绩下滑并丧失自信。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00453", "scene_id": "scene-00453", "source_file": "CSV/unit/01-01/adv_unit_01-01_10.csv", "source_kind": "unit", "chapter": "unit/01-01", "scene": "adv_unit_01-01_10", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "70", "line_count": 70}], "source_refs": ["CSV/unit/01-01/adv_unit_01-01_10.csv:1-70"], "line_count": 70, "speakers": ["众人", "制作人", "咲季", "手毬", "琴音", "舞蹈训练师"], "topics": ["relationships", "team_story", "dialogue_style", "character_arc"], "title": "咲季质疑手毬入团资格", "summary": "舞蹈训练开始，咲季与琴音欢迎制作人，手毬因被冷落而愤怒。咲季质疑手毬入团必要性，琴音透露手毬曾是顶级偶像候补，但因与制作人争吵导致组合解散，引发咲季对两人关系的猜测。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人", "琴音", "手毬"], "worldbuilding_signals": ["偶像", "训练"], "dialogue_style_signals": ["真是的", "制作人", "啦"], "key_evidence": [{"source_row": "48", "speaker": "咲季", "text_zh": "虽然现在才问，那个孩子有必要成为同伴吗？"}, {"source_row": "54", "speaker": "琴音", "text_zh": "比咲季你强～～～～～～～多了。"}, {"source_row": "70", "speaker": "琴音", "text_zh": "听说是因为那家伙的缘故，最后吵翻了。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["手毬因制作人未单独找她而情绪激动，拒绝沟通。", "咲季认为手毬拖后腿，质疑其入团必要性。", "手毬初中时曾是知名偶像组合成员，后因与制作人争吵解散。"], "relationship_facts": ["咲季与琴音关系亲密，琴音纠正咲季称呼。", "手毬对制作人怀有强烈不满与嫉妒。", "咲季与手毬存在入团资格与信任的潜在冲突。"], "worldbuilding_facts": ["手毬在初中部曾组建过知名偶像组合。", "手毬被评价为未来的顶级偶像候补。", "手毬组合解散的原因是与其制作人发生争吵。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00454", "scene_id": "scene-00454", "source_file": "CSV/unit/01-01/adv_unit_01-01_11.csv", "source_kind": "unit", "chapter": "unit/01-01", "scene": "adv_unit_01-01_11", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "70", "line_count": 70}], "source_refs": ["CSV/unit/01-01/adv_unit_01-01_11.csv:1-70"], "line_count": 70, "speakers": ["咲季", "手毬", "？？？"], "topics": ["team_story", "relationships", "dialogue_style", "character_arc"], "title": "咲季挑战手毬的跑步", "summary": "咲季偶遇正在跑步的手毬，得知其组合解散后，咲季质疑手毬关于成员是废物的谎言。咲季鼓励手毬更加努力追赶自己，手毬在愤怒与回忆中动摇，决心成为顶级偶像。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人", "琴音", "手毬"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["哼", "制作人", "啦"], "key_evidence": [{"source_row": "45", "speaker": "手毬", "text_zh": "因为除我以外的成员都是废物"}, {"source_row": "49", "speaker": "咲季", "text_zh": "那是谎话吧？"}, {"source_row": "64", "speaker": "咲季", "text_zh": "你要更加更加更加努力"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["手毬因不满成员能力而退出组合。", "咲季认为手毬的退队理由并非事实。", "咲季鼓励手毬继续奔跑并追赶自己。"], "relationship_facts": ["咲季与手毬是竞争对手关系。", "咲季试图激励手毬。", "手毬对咲季的介入感到烦躁。"], "worldbuilding_facts": ["咲季的目标是成为顶级偶像。", "手毬视自己为未来的顶级偶像。", "手毬曾经历过被鼓励但已遗忘的往事。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00455", "scene_id": "scene-00455", "source_file": "CSV/unit/01-01/adv_unit_01-01_12.csv", "source_kind": "unit", "chapter": "unit/01-01", "scene": "adv_unit_01-01_12", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "76", "line_count": 76}], "source_refs": ["CSV/unit/01-01/adv_unit_01-01_12.csv:1-76"], "line_count": 76, "speakers": ["咲季", "手毬", "旁白"], "topics": ["team_story", "relationships", "dialogue_style", "worldbuilding"], "title": "咲季邀请手毬组队", "summary": "咲季清晨找手毬道歉并提议组队，手毬因过往退队阴影拒绝。咲季阐述自己追求巅峰、渴望被超越的偶像理念，试图打破手毬的心结，最终邀请她加入自己的行列。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["琴音", "手毬"], "worldbuilding_signals": ["偶像", "训练", "演唱会"], "dialogue_style_signals": ["当然", "真是的", "哼", "呵呵", "啦"], "key_evidence": [{"source_row": "8", "speaker": "咲季", "text_zh": "我看了你们的演唱会视频！"}, {"source_row": "48", "speaker": "咲季", "text_zh": "在最有自信的舞蹈上……输给了琴音。"}, {"source_row": "71", "speaker": "咲季", "text_zh": "我想要的是能超越我、不断把我甩在身后的——"}, {"source_row": "76", "speaker": "咲季", "text_zh": "跟我来吧，月村手毬！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季观看手毬演唱会视频后，为之前态度道歉。", "咲季因体育特长曾轻视偶像行业，入学后输给琴音而改变认知。", "咲季认为偶像需要不断超越同伴，而非等待拖后腿的人。", "咲季主动邀请手毬组成偶像组合，手毬表示拒绝。"], "relationship_facts": ["咲季与手毬是同学及曾经的竞争对手。", "咲季视手毬为潜在的顶尖偶像同伴。", "手毬因过去同伴退队经历而对组建组合持消极态度。"], "worldbuilding_facts": ["成为顶级偶像需要付出比常人更多的努力。", "偶像行业内部存在升学组等精英群体。", "咲季在舞蹈方面曾输给琴音，意识到自身不足。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00456", "scene_id": "scene-00456", "source_file": "CSV/unit/01-01/adv_unit_01-01_13.csv", "source_kind": "unit", "chapter": "unit/01-01", "scene": "adv_unit_01-01_13", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "80", "line_count": 80}, {"block_index": 2, "start_row": "81", "end_row": "101", "line_count": 21}], "source_refs": ["CSV/unit/01-01/adv_unit_01-01_13.csv:1-101"], "line_count": 101, "speakers": ["咲季", "手毬", "琴音", "？？？"], "topics": ["team_story", "relationships", "dialogue_style", "character_arc"], "title": "咲季手毬组合重组", "summary": "咲季邀请手毬加入组合，手毬因过往谣言与任性性格拒绝。琴音直言讨厌手毬的精英姿态，却仍认定她是最佳人选。手毬被两人态度打动，决定放下包袱，以真实自我加入新组合，立志成为顶级偶像。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人", "琴音", "手毬", "朋友", "伙伴"], "worldbuilding_signals": ["偶像", "工作"], "dialogue_style_signals": ["真是的", "呵呵", "制作人", "啦"], "key_evidence": [{"source_row": "18", "speaker": "咲季", "text_zh": "所以，非你不可。"}, {"source_row": "59", "speaker": "琴音", "text_zh": "第三个人选，非你不可。"}, {"source_row": "93", "speaker": "手毬", "text_zh": "这个组合，我就加入吧。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季主动邀请手毬加入组合，无视其拒绝。", "琴音揭露手毬的精英姿态与谣言，但仍坚持选她。", "手毬最终决定加入，承诺展现真实自我。"], "relationship_facts": ["咲季与手毬：咲季欣赏手毬，主动邀请其加入。", "琴音与手毬：琴音表面讨厌手毬的作风，实则认可其才华。", "咲季与琴音：两人互相调侃，共同支持手毬。"], "worldbuilding_facts": ["手毬因过往谣言与任性行为被孤立。", "组合成员间存在竞争与过节，但可共存。", "手毬是练习狂魔，初中部时即为顶尖水平。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00457", "scene_id": "scene-00457", "source_file": "CSV/unit/01-01/adv_unit_01-01_14.csv", "source_kind": "unit", "chapter": "unit/01-01", "scene": "adv_unit_01-01_14", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "80", "line_count": 80}, {"block_index": 2, "start_row": "81", "end_row": "81", "line_count": 1}], "source_refs": ["CSV/unit/01-01/adv_unit_01-01_14.csv:1-81"], "line_count": 81, "speakers": ["制作人", "咲季", "手毬", "琴音", "选项"], "topics": ["relationships", "team_story", "dialogue_style", "character_arc"], "title": "咲季确认组合成立", "summary": "咲季向制作人报告组合成立，制作人肯定三人相性。咲季质疑选拔理由，制作人解释基于竞争意识、互相理解及偶像才能。咲季与琴音互怼，手毬虽口嫌体正直仍被接纳，咲季积极鼓励手毬，展现团队磨合。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人", "琴音", "手毬"], "worldbuilding_signals": ["学园", "偶像"], "dialogue_style_signals": ["当然", "嘿嘿", "制作人", "啦"], "key_evidence": [{"source_row": "2", "speaker": "咲季", "text_zh": "我有事情要报告！"}, {"source_row": "36", "speaker": "咲季", "text_zh": "——为什么，是我们呢？"}, {"source_row": "47", "speaker": "咲季", "text_zh": "这几天我已经见识到你们不少优点"}, {"source_row": "75", "speaker": "咲季", "text_zh": "既然制作人都说你有才能了"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季向制作人报告三人组合正式成立。", "制作人解释选拔条件为竞争意识、互相理解及偶像才能。", "咲季与琴音互相调侃，手毬口嫌体正直地加入组合。"], "relationship_facts": ["咲季与琴音关系亲密，常互相调侃。", "咲季与手毬关系微妙，咲季积极鼓励手毬。", "咲季与制作人关系信任，咲季对制作人评价感到惊讶。"], "worldbuilding_facts": ["组合选拔标准包含强烈的竞争意识。", "成员间需具备互相理解与发掘长处的关系。", "学园第一可爱是琴音的自信点。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00458", "scene_id": "scene-00458", "source_file": "CSV/unit/01-02/adv_unit_01-02_01.csv", "source_kind": "unit", "chapter": "unit/01-02", "scene": "adv_unit_01-02_01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "44", "line_count": 44}], "source_refs": ["CSV/unit/01-02/adv_unit_01-02_01.csv:1-44"], "line_count": 44, "speakers": ["众人", "制作人", "咲季", "手毬", "琴音"], "topics": ["relationships", "team_story", "dialogue_style", "plot"], "title": "咲季憧憬首次演唱会", "summary": "制作人宣布三人组合将挑战4月底的H.I.F选拔考试，这是通往大舞台的龙门。咲季对此充满期待，渴望在座无虚席的舞台上举办首次演唱会。手毬和琴音则提醒考试门槛极高，失败会有恶劣影响，众人随即下定决心要在首次考试中获胜。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["制作人", "琴音", "手毬"], "worldbuilding_signals": ["偶像", "演唱会", "工作"], "dialogue_style_signals": ["当然", "制作人", "啦"], "key_evidence": [{"source_row": "4", "speaker": "咲季", "text_zh": "是要说我们的首次演唱会的事对吧！"}, {"source_row": "14", "speaker": "制作人", "text_zh": "是的，就是4月底的选拔考试。"}, {"source_row": "24", "speaker": "咲季", "text_zh": "好想快点在座无虚席的舞台上举办演唱会啊！"}, {"source_row": "33", "speaker": "琴音", "text_zh": "啊～要是搞砸了会对今后的工作造成恶劣影响啊……"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["三人组合将参加4月底的H.I.F选拔考试。", "咲季渴望举办座无虚席的首次演唱会。", "H.I.F选拔考试是通往顶级偶像的道路。", "考试失败会对今后工作造成恶劣影响。"], "relationship_facts": ["咲季、手毬、琴音组成三人组合。", "咲季与手毬、琴音共同面对选拔考试。", "众人共同支持咲季的演唱会梦想。"], "worldbuilding_facts": ["H.I.F选拔考试是顶级偶像的选拔。", "考试分为4月底和5月底两次举办。", "只有志愿者才能参加实践形式考试。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00459", "scene_id": "scene-00459", "source_file": "CSV/unit/01-02/adv_unit_01-02_02.csv", "source_kind": "unit", "chapter": "unit/01-02", "scene": "adv_unit_01-02_02", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "75", "line_count": 75}], "source_refs": ["CSV/unit/01-02/adv_unit_01-02_02.csv:1-75"], "line_count": 75, "speakers": ["众人", "制作人", "咲季", "手毬", "琴音"], "topics": ["relationships", "team_story", "dialogue_style", "worldbuilding"], "title": "组合名与C位之争", "summary": "制作人提议先定C位再取组合名，引发手毬、琴音争执。咲季试图以资历调解，却被手毬指出琴音才是前辈。制作人宣布三人需共同生活以增进了解，并需在月底前决定C位与队长人选。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "琴音", "手毬", "姐姐", "伙伴"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["当然", "哼", "嘿嘿", "制作人", "不是吗", "啦"], "key_evidence": [{"source_row": "5", "speaker": "咲季", "text_zh": "名字啦——我们组合的名字。"}, {"source_row": "8", "speaker": "手毬", "text_zh": "是C位吧。"}, {"source_row": "41", "speaker": "咲季", "text_zh": "论资排辈！人生经验最丰富的本小姐，"}, {"source_row": "67", "speaker": "制作人", "text_zh": "你们三个人要一起生活。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["组合名需与C位风格相称。", "手毬自认实力最强应任C位。", "琴音主张最可爱者应任C位。", "制作人要求三人共同生活并决定分工。"], "relationship_facts": ["咲季自称为姐姐大人。", "手毬认为琴音是前辈。", "咲季与琴音、手毬为组合伙伴。"], "worldbuilding_facts": ["组合成员需决定C位与队长。", "咲季生日为4月2日。", "手毬因琴音留级而称其为前辈。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00460", "scene_id": "scene-00460", "source_file": "CSV/unit/01-02/adv_unit_01-02_03.csv", "source_kind": "unit", "chapter": "unit/01-02", "scene": "adv_unit_01-02_03", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "80", "line_count": 80}], "source_refs": ["CSV/unit/01-02/adv_unit_01-02_03.csv:1-80"], "line_count": 80, "speakers": ["众人", "咲季", "手毬", "琴音"], "topics": ["team_story", "relationships", "dialogue_style", "worldbuilding"], "title": "咲季主导的宿舍生活", "summary": "咲季宣布组合成员将共同生活，并坚持亲自为众人做饭以定制专属膳食。她解释食材来自自家农场，且因需凌晨四点起床，晚餐时间较早。手毬与琴音虽起初惊讶，但最终接受并称赞料理美味，咲季展现出对共同生活的认真态度。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "琴音", "手毬", "妹妹", "姐姐"], "worldbuilding_signals": ["偶像", "训练", "营业"], "dialogue_style_signals": ["当然", "哼", "嘿嘿", "制作人", "啦"], "key_evidence": [{"source_row": "21", "speaker": "咲季", "text_zh": "饭菜全部都由我来做！"}, {"source_row": "33", "speaker": "咲季", "text_zh": "成为顶尖偶像所需的专属膳食哦！"}, {"source_row": "51", "speaker": "咲季", "text_zh": "我爷爷在经营农场，会寄食材过来的。"}, {"source_row": "61", "speaker": "手毬", "text_zh": "意外地好吃。……对身体好像挺有益的。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季坚持为组合成员亲手做饭，拒绝食堂饮食。", "咲季声称其特制料理有助于塑造偶像身材。", "咲季表示晚餐时间较早是因为次日需凌晨四点起床。", "咲季的食材由经营农场的爷爷寄来，数量充足。"], "relationship_facts": ["咲季与手毬、琴音是组合成员及室友。", "咲季与妹妹（未在场）关系亲密，常一起食用特制料理。", "琴音对咲季表现出依赖与期待，手毬则较为务实。"], "worldbuilding_facts": ["组合成员需凌晨四点起床进行训练。", "宿舍配有食堂，但咲季认为其菜单无法定制。", "咲季拥有经营农场的爷爷，可供应大量食材。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00461", "scene_id": "scene-00461", "source_file": "CSV/unit/01-02/adv_unit_01-02_04.csv", "source_kind": "unit", "chapter": "unit/01-02", "scene": "adv_unit_01-02_04", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "45", "line_count": 45}], "source_refs": ["CSV/unit/01-02/adv_unit_01-02_04.csv:1-45"], "line_count": 45, "speakers": ["咲季", "手毬", "琴音"], "topics": ["relationships", "team_story", "dialogue_style"], "title": "咲季熟睡与手毬体寒", "summary": "咲季在房间内熟睡，手毬因体寒无法入睡，琴音调侃咲季后也准备休息。手毬因与前任室友冷战无法借用暖水袋，咲季在琴音玩笑下被手毬触碰脚部取暖，手毬解释体寒困扰，咲季全程处于无意识状态。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["琴音", "手毬"], "worldbuilding_signals": [], "dialogue_style_signals": ["啦"], "key_evidence": [{"source_row": "15", "speaker": "咲季", "text_zh": "……呼……"}, {"source_row": "32", "speaker": "手毬", "text_zh": "嗯。手脚冰凉会睡不着。"}, {"source_row": "40", "speaker": "手毬", "text_zh": "正在冷战……太尴尬了。"}, {"source_row": "45", "speaker": "琴音", "text_zh": "你根本完全没搞懂嘛！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "background", "saki_actions": [], "story_facts": ["咲季在房间内已经熟睡，对周围对话毫无反应。", "手毬因手脚冰凉导致无法入睡，需要外部热源。", "手毬因与前任室友冷战，无法借用其留下的暖水袋。", "手毬在琴音不知情的情况下触碰了咲季的脚部取暖。"], "relationship_facts": ["咲季与手毬、琴音同处一室，关系亲密。", "手毬与琴音是室友，琴音对咲季有调侃态度。", "手毬与前任室友处于冷战状态，关系紧张。"], "worldbuilding_facts": ["角色存在体寒体质，手脚冰凉会影响睡眠。", "角色使用暖水袋作为缓解体寒的辅助工具。", "宿舍环境允许角色在他人熟睡时进行轻微肢体接触。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00462", "scene_id": "scene-00462", "source_file": "CSV/unit/01-02/adv_unit_01-02_05.csv", "source_kind": "unit", "chapter": "unit/01-02", "scene": "adv_unit_01-02_05", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "71", "line_count": 71}], "source_refs": ["CSV/unit/01-02/adv_unit_01-02_05.csv:1-71"], "line_count": 71, "speakers": ["手毬", "琴音", "花海咲季"], "topics": ["relationships", "team_story", "worldbuilding", "dialogue_style"], "title": "咲季旁观手毬琴音谈心", "summary": "手毬与琴音深夜谈心，手毬因讨厌过去的自己而立志成为顶级偶像，琴音则因家庭贫困必须打工赚取学费。咲季在旁聆听，随后手毬主动分担琴音的学费压力，两人关系缓和。咲季全程作为背景人物存在，未直接参与对话。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "琴音", "手毬", "妹妹", "父母"], "worldbuilding_signals": ["学园", "偶像", "工作"], "dialogue_style_signals": ["哼", "呵呵", "制作人", "啦"], "key_evidence": [{"source_row": "54", "speaker": "手毬", "text_zh": "所以，要成为顶级偶像。"}, {"source_row": "35", "speaker": "琴音", "text_zh": "总之得先把明年的学费赚到手才行。"}, {"source_row": "61", "speaker": "手毬", "text_zh": "这也有我的责任。"}, {"source_row": "58", "speaker": "花海咲季", "text_zh": "……唔…………嗯…………"}], "summary_status": "llm_fast_scene_card", "saki_presence": "background", "saki_actions": [], "story_facts": ["手毬因讨厌过去的自己而立志成为顶级偶像。", "琴音因家庭贫困必须打工赚取学费。", "手毬主动表示若琴音付不起学费，自己会负责。"], "relationship_facts": ["手毬与琴音是室友兼竞争对手。", "手毬与琴音从互相讨厌到互相理解。", "咲季与手毬、琴音同处一室。"], "worldbuilding_facts": ["学园偶像需要支付高昂学费和开销。", "成为顶级偶像需要付出巨大努力。", "宿舍生活让角色间关系逐渐变化。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00463", "scene_id": "scene-00463", "source_file": "CSV/unit/01-02/adv_unit_01-02_06.csv", "source_kind": "unit", "chapter": "unit/01-02", "scene": "adv_unit_01-02_06", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "80", "line_count": 80}, {"block_index": 2, "start_row": "81", "end_row": "81", "line_count": 1}], "source_refs": ["CSV/unit/01-02/adv_unit_01-02_06.csv:1-81"], "line_count": 81, "speakers": ["咲季", "手毬", "清夏", "琴音", "莉莉娅"], "topics": ["team_story", "relationships", "dialogue_style", "worldbuilding"], "title": "咲季晨练与邻里初遇", "summary": "咲季清晨唤醒手毬与琴音进行晨练，手毬反思偶像实力不足。随后清夏与莉莉娅登场，咲季邀请她们加入晨跑，但二人因体力顾虑婉拒。咲季提醒琴音注意噪音，众人约定教室相见。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["琴音", "手毬", "清夏", "莉莉娅"], "worldbuilding_signals": ["偶像", "训练", "演唱会"], "dialogue_style_signals": ["当然", "才不是", "真是的", "哼", "啦"], "key_evidence": [{"source_row": "18", "speaker": "咲季", "text_zh": "喂～你们几个，大清早就别大喊大叫的。"}, {"source_row": "36", "speaker": "咲季", "text_zh": "是我们所有人哦！"}, {"source_row": "48", "speaker": "咲季", "text_zh": "你们明天开始要一起跑吗？"}, {"source_row": "79", "speaker": "咲季", "text_zh": "真是的～要好好反省啊，琴音。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季清晨叫醒手毬和琴音进行晨练。", "手毬承认自己体力不足，决心努力成为顶级偶像。", "清夏和莉莉娅因身体吃不消拒绝了加入晨练的邀请。", "咲季提醒琴音不要在早晨大声喧哗以免吵醒邻居。"], "relationship_facts": ["咲季是手毬和琴音的同伴及晨练组织者。", "清夏和莉莉娅是咲季等人的邻居。", "手毬是琴音的队友，两人互相调侃。"], "worldbuilding_facts": ["咲季等人是偶像团体成员，需进行严格的晨练。", "清夏和莉莉娅是咲季等人的邻居。", "手毬对成为顶级偶像有着极高的自我要求。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00464", "scene_id": "scene-00464", "source_file": "CSV/unit/01-02/adv_unit_01-02_07.csv", "source_kind": "unit", "chapter": "unit/01-02", "scene": "adv_unit_01-02_07", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "73", "line_count": 73}], "source_refs": ["CSV/unit/01-02/adv_unit_01-02_07.csv:1-73"], "line_count": 73, "speakers": ["咲季", "手毬", "琴音", "？？？"], "topics": ["relationships", "team_story", "dialogue_style"], "title": "咲季的全力睡眠宣言", "summary": "咲季宣称通过共同生活赢得尊敬并当选队长，手毬与琴音虽不认同但同意投票决定。咲季坚持全力睡眠，琴音为避手毬睡在咲季旁，却因咲季体温过高而受困扰。手毬提及组合解散原因，气氛微妙。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["琴音", "手毬", "姐姐"], "worldbuilding_signals": [], "dialogue_style_signals": ["真是的", "呵呵", "嘿嘿", "啦"], "key_evidence": [{"source_row": "6", "speaker": "咲季", "text_zh": "我预计会把C位宝座献给我的哦。"}, {"source_row": "13", "speaker": "琴音", "text_zh": "选出最适合担任C位和队长的人选"}, {"source_row": "56", "speaker": "手毬", "text_zh": "要是能明白的话……组合也不会解散了。"}, {"source_row": "68", "speaker": "琴音", "text_zh": "这家伙是暖炉吗……该不会生病了吧。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季声称共同生活后大家会尊敬她并让她当队长。", "琴音提议投票决定队长和C位人选，若无法决定则猜拳。", "咲季睡觉时体温极高，让睡在旁边的琴音感到烫。", "手毬提到若大家能互相理解，组合就不会解散。"], "relationship_facts": ["咲季、手毬、琴音为组合成员兼室友。", "琴音称呼咲季为姐姐，咲季是琴音的姐姐。", "手毬与咲季、琴音之间存在因性格或过往产生的隔阂。"], "worldbuilding_facts": ["组合成员需选举C位和队长。", "咲季认为生活中的一切都是练习，需全力以赴。", "咲季睡觉时体温异常高，像暖炉一样。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00465", "scene_id": "scene-00465", "source_file": "CSV/unit/01-02/adv_unit_01-02_08.csv", "source_kind": "unit", "chapter": "unit/01-02", "scene": "adv_unit_01-02_08", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "80", "line_count": 80}, {"block_index": 2, "start_row": "81", "end_row": "82", "line_count": 2}], "source_refs": ["CSV/unit/01-02/adv_unit_01-02_08.csv:1-82"], "line_count": 82, "speakers": ["佑芽", "咲季", "手毬", "琴音"], "topics": ["relationships", "team_story", "dialogue_style", "character_arc"], "title": "咲季与佑芽的姐妹日常", "summary": "佑芽因房间变动与咲季闹别扭，咲季安抚后解释两人小学相识的渊源。咲季展现姐姐风范，鼓励佑芽发掘偶像天赋，并提及制作人的神出鬼没。手毬与琴音对姐妹互动反应不一，咲季欲分享往事被手毬拒绝。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "琴音", "手毬", "妹妹", "姐姐", "伙伴"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["当然", "才不是", "真是的", "呵呵", "制作人", "啦"], "key_evidence": [{"source_row": "11", "speaker": "咲季", "text_zh": "是我的妹妹哦！"}, {"source_row": "43", "speaker": "咲季", "text_zh": "可是拥有超级厉害的偶像天赋呢！"}, {"source_row": "73", "speaker": "咲季", "text_zh": "那是在我们小学时候"}, {"source_row": "60", "speaker": "咲季", "text_zh": "便当。记得带上。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["佑芽因宿舍相邻房间变为空房而与咲季闹别扭。", "咲季担保佑芽拥有超级厉害的偶像天赋。", "咲季与佑芽在小学时期就已经相识。"], "relationship_facts": ["咲季是佑芽的姐姐。", "咲季与手毬、琴音是组合成员。", "咲季与佑芽是亲密的姐妹关系。"], "worldbuilding_facts": ["咲季会亲手为妹妹做便当。", "制作人在需要时总会恰到好处地出现。", "咲季与佑芽住在宿舍相邻的房间。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00466", "scene_id": "scene-00466", "source_file": "CSV/unit/01-02/adv_unit_01-02_09.csv", "source_kind": "unit", "chapter": "unit/01-02", "scene": "adv_unit_01-02_09", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "74", "line_count": 74}], "source_refs": ["CSV/unit/01-02/adv_unit_01-02_09.csv:1-74"], "line_count": 74, "speakers": ["咲季", "手毬", "琴音"], "topics": ["relationships", "team_story", "dialogue_style", "character_arc"], "title": "咲季与妹妹的宿敌日常", "summary": "咲季接受制作人邀请后，与琴音、手毬讨论按摩与训练。咲季透露为保持对妹妹手毬的绝对优势，提前练习了所有可能挑战的项目，甚至包括猜拳。手毬对此表示理解，三人互动展现了深厚的羁绊与咲季作为姐姐的执着。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "琴音", "手毬", "妹妹", "姐姐"], "worldbuilding_signals": ["训练"], "dialogue_style_signals": ["当然", "才不是", "嘿嘿", "制作人", "不是吗", "啦"], "key_evidence": [{"source_row": "2", "speaker": "咲季", "text_zh": "我决定接受制作人的发掘邀请了。"}, {"source_row": "66", "speaker": "咲季", "text_zh": "只要是那孩子可能会来挑战的比赛项目，我都提前练习过了。"}, {"source_row": "70", "speaker": "手毬", "text_zh": "是吗？我倒觉得能理解呢。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季决定接受制作人的发掘邀请。", "咲季为了不让妹妹手毬赢，提前练习了所有可能挑战的项目。", "手毬表示理解咲季作为姐姐不想输给妹妹的心态。", "咲季的手毬是未来的宿敌，两人关系亲密且咲季对妹妹习惯了如指掌。"], "relationship_facts": ["咲季是手毬的姐姐，手毬是咲季的妹妹。", "琴音是咲季的妹妹，咲季是琴音的姐姐。", "咲季与手毬是未来的宿敌，但关系亲密。"], "worldbuilding_facts": ["咲季从小就开始给妹妹按摩。", "咲季为手毬制定专属训练计划。", "咲季在决定C位的投票中如果靠猜拳决胜负，咲季能赢。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00467", "scene_id": "scene-00467", "source_file": "CSV/unit/01-02/adv_unit_01-02_10.csv", "source_kind": "unit", "chapter": "unit/01-02", "scene": "adv_unit_01-02_10", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "56", "line_count": 56}], "source_refs": ["CSV/unit/01-02/adv_unit_01-02_10.csv:1-56"], "line_count": 56, "speakers": ["咲季", "手毬", "琴音"], "topics": ["relationships", "team_story", "dialogue_style", "character_arc"], "title": "咲季与宿敌的羁绊", "summary": "咲季向队友透露妹妹是未来的劲敌，并解释全力培养对手源于姐姐的骄傲与渴望挑战。手毬提议若咲季输则换妹加入，咲季认同。咲季请求手毬直呼其名，展现对团队的依赖与对妹妹成长的期待。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["琴音", "手毬", "妹妹", "姐姐", "对手"], "worldbuilding_signals": [], "dialogue_style_signals": ["当然"], "key_evidence": [{"source_row": "12", "speaker": "咲季", "text_zh": "就会成长为最大的劲敌。"}, {"source_row": "25", "speaker": "咲季", "text_zh": "应该是我会输吧。"}, {"source_row": "34", "speaker": "手毬", "text_zh": "就把你开除换妹妹加入哦。"}, {"source_row": "49", "speaker": "咲季", "text_zh": "能不能……用名字来称呼我？"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季透露妹妹是半年后最大的劲敌。", "咲季承认在赛跑中可能会输给妹妹。", "手毬提议若咲季输给妹妹则开除咲季换妹加入。", "咲季请求手毬用名字称呼自己。"], "relationship_facts": ["咲季与妹妹是姐妹关系。", "咲季、手毬、琴音组成三人组合。", "咲季与手毬、琴音是队友关系。"], "worldbuilding_facts": ["咲季中学时是田径部成员。", "咲季从出生起从未输给过妹妹。", "咲季认为帮助妹妹是理所当然的。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00468", "scene_id": "scene-00468", "source_file": "CSV/unit/01-02/adv_unit_01-02_11.csv", "source_kind": "unit", "chapter": "unit/01-02", "scene": "adv_unit_01-02_11", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "76", "line_count": 76}], "source_refs": ["CSV/unit/01-02/adv_unit_01-02_11.csv:1-76"], "line_count": 76, "speakers": ["千奈", "咲季", "手毬", "琴音"], "topics": ["team_story", "relationships", "dialogue_style", "character_arc"], "title": "咲季的自制运动饮料", "summary": "咲季结束晨练后为队友手毬和琴音准备了特制运动饮料。手毬因味道难喝而崩溃，咲季却坚称有效。随后千奈加入，虽初感不适但最终被提神效果折服，咲季决定明日继续为她制作。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["琴音", "手毬", "姐姐"], "worldbuilding_signals": ["训练"], "dialogue_style_signals": ["啦"], "key_evidence": [{"source_row": "12", "speaker": "咲季", "text_zh": "是姐姐特制的SSD哦！！"}, {"source_row": "29", "speaker": "手毬", "text_zh": "你准备的所有食物饮料都！！"}, {"source_row": "53", "speaker": "咲季", "text_zh": "滋补强身、消除疲劳、还能提升训练效果哦！"}, {"source_row": "66", "speaker": "千奈", "text_zh": "这…这味道……非常提神呢。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季制作了特制的运动饮料（SSD）供队友饮用。", "手毬认为饮料味道极差，无法忍受。", "千奈起初抗拒，但喝完后表示味道非常提神。", "咲季声称饮料能消除疲劳并提升训练效果。"], "relationship_facts": ["咲季是手毬和琴音的姐姐。", "咲季与千奈是队友关系。", "手毬和琴音是咲季的队友。"], "worldbuilding_facts": ["咲季制作的饮料被称为'SSD'。", "该饮料具有滋补强身、消除疲劳及提升训练效果的功效。", "千奈所在的班级为二班。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00469", "scene_id": "scene-00469", "source_file": "CSV/unit/01-02/adv_unit_01-02_12.csv", "source_kind": "unit", "chapter": "unit/01-02", "scene": "adv_unit_01-02_12", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "71", "line_count": 71}], "source_refs": ["CSV/unit/01-02/adv_unit_01-02_12.csv:1-71"], "line_count": 71, "speakers": ["咲季", "手毬", "琴音", "麻央"], "topics": ["team_story", "relationships", "dialogue_style", "character_arc"], "title": "咲季料理引发的争执", "summary": "咲季与手毬因饮食观念冲突爆发争吵。咲季认为自家五年如一日的营养餐美味且均衡，而手毬抱怨食物难吃、菜单单调且缺乏美感。琴音指出这是戏剧排练，麻央则在一旁观察并试图调解，最终琴音请求继续排练。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["琴音", "手毬", "麻央"], "worldbuilding_signals": ["训练"], "dialogue_style_signals": ["当然", "啦"], "key_evidence": [{"source_row": "55", "speaker": "咲季", "text_zh": "在我家可是持续五年多都吃这个"}, {"source_row": "13", "speaker": "手毬", "text_zh": "干巴巴的鸡胸肉配西兰花"}, {"source_row": "31", "speaker": "咲季", "text_zh": "是我自制的特制托盘哦"}, {"source_row": "52", "speaker": "琴音", "text_zh": "这是反乌托邦的母体AI"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季与手毬因饮食喜好和观念差异发生激烈争吵。", "咲季声称自己家的营养餐已持续五年无人抱怨。", "琴音指出当前场景是戏剧排练中的决战场景。", "麻央作为舍长介入并允许琴音继续排练。"], "relationship_facts": ["咲季与手毬是关系紧张的同居或同学关系。", "琴音是咲季和手毬的前辈或队友。", "麻央是宿舍舍长，负责协调成员关系。"], "worldbuilding_facts": ["咲季家中长期提供严格控制分量的营养餐。", "咲季使用自制带刻度的特制托盘盛放糊状食物。", "手毬对咲季制作的料理（如干柴鸡胸肉）极度反感。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00470", "scene_id": "scene-00470", "source_file": "CSV/unit/01-02/adv_unit_01-02_13.csv", "source_kind": "unit", "chapter": "unit/01-02", "scene": "adv_unit_01-02_13", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "71", "line_count": 71}], "source_refs": ["CSV/unit/01-02/adv_unit_01-02_13.csv:1-71"], "line_count": 71, "speakers": ["众人", "咲季", "手毬", "琴音"], "topics": ["team_story", "relationships", "dialogue_style", "worldbuilding"], "title": "咲季料理风波与对决", "summary": "琴音严厉纠正咲季与手毬的吵闹行为，随后解释因咲季料理口味单一导致手毬不满的矛盾。咲季坚持料理质量，手毬抱怨口感，琴音调解后提议进行料理对决，三人关系在争执与和解中展现。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["琴音", "手毬"], "worldbuilding_signals": ["偶像", "训练"], "dialogue_style_signals": ["真是的", "嘿嘿", "啦"], "key_evidence": [{"source_row": "37", "speaker": "琴音", "text_zh": "小咲季做的饭菜，营养满分~，味道也好~"}, {"source_row": "49", "speaker": "手毬", "text_zh": "干巴巴的，口味变化又少，毫无食欲……"}, {"source_row": "71", "speaker": "琴音", "text_zh": "光用嘴说看来是没法说服你了。——那这样吧咲季，和我来场料理对决怎么样♪"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季的手艺被琴音评价为营养满分且能提升训练效果。", "手毬对咲季料理的干巴口感和单调口味表示无法忍受。", "琴音提议咲季与自己进行一场料理对决来解决分歧。"], "relationship_facts": ["咲季与手毬因料理口味问题经常发生争执。", "琴音作为调解人，既认可咲季的手艺也理解手毬的抱怨。", "咲季与手毬是组合成员，共同生活并面临解散危机。"], "worldbuilding_facts": ["偶像的饮食被视为训练的一部分。", "组合成员曾因吃饭问题差点导致解散。", "咲季认为料理口味变化少是手毬任性的表现。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00471", "scene_id": "scene-00471", "source_file": "CSV/unit/01-02/adv_unit_01-02_14.csv", "source_kind": "unit", "chapter": "unit/01-02", "scene": "adv_unit_01-02_14", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "66", "line_count": 66}], "source_refs": ["CSV/unit/01-02/adv_unit_01-02_14.csv:1-66"], "line_count": 66, "speakers": ["咲季", "手毬", "清夏", "琴音", "莉莉娅"], "topics": ["team_story", "relationships", "dialogue_style", "character_arc"], "title": "咲季料理的奇特评价", "summary": "咲季邀请众人品尝其自信之作，清夏与手毬直言料理味道神奇但难以下咽，形容为化学系料理或干巴巴糊状汤，咲季因此崩溃认输。莉莉娅则因长期食用而表示美味。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "琴音", "手毬", "清夏", "莉莉娅", "妹妹", "姐姐"], "worldbuilding_signals": [], "dialogue_style_signals": ["啦"], "key_evidence": [{"source_row": "17", "speaker": "咲季", "text_zh": "请用吧♪ 这可是我的自信之作！"}, {"source_row": "33", "speaker": "清夏", "text_zh": "咲季的料理是化学系的呢。"}, {"source_row": "56", "speaker": "手毬", "text_zh": "是味噌风味干巴巴糊状汤。"}, {"source_row": "66", "speaker": "咲季", "text_zh": "我认输！是我输了！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季准备了包含味噌汤在内的自信之作料理。", "清夏和手毬认为咲季的料理味道奇怪，难以再次食用。", "咲季因被评价为化学系料理而情绪崩溃并认输。", "莉莉娅因长期食用咲季料理，对其味道表示认可。"], "relationship_facts": ["咲季与清夏、手毬因料理口味差异产生争执。", "咲季与琴音是共同制作料理的伙伴。", "咲季与莉莉娅存在长期的饮食关系。"], "worldbuilding_facts": ["咲季的料理被评价为具有化学系特征。", "咲季的料理被描述为干巴巴的糊状汤。", "咲季的料理被形容为让人超级口渴。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00472", "scene_id": "scene-00472", "source_file": "CSV/unit/01-02/adv_unit_01-02_15.csv", "source_kind": "unit", "chapter": "unit/01-02", "scene": "adv_unit_01-02_15", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "59", "line_count": 59}], "source_refs": ["CSV/unit/01-02/adv_unit_01-02_15.csv:1-59"], "line_count": 59, "speakers": ["众人", "咲季", "手毬", "清夏", "琴音", "莉莉娅"], "topics": ["team_story", "relationships", "dialogue_style", "character_arc"], "title": "咲季败北与菜单改良", "summary": "咲季在料理对决中败给手毬，虽不甘心但承认失败并退出值班。琴音提议三人共同改良食堂菜单，咲季重拾干劲。手毬道歉并感谢咲季，咲季随即询问手毬喜好，手毬直言想吃高热量食物，引发咲季关于体脂率的吐槽，两人再次拌嘴。", "saki_role": "场景主导者：咲季直接参与对话，表达情绪、目标或判断。", "relationship_signals": ["琴音", "手毬", "清夏", "莉莉娅"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["哼", "啦"], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "我认输！是我输了！"}, {"source_row": "24", "speaker": "咲季", "text_zh": "食堂菜单改良计划，我一定会完成的！"}, {"source_row": "36", "speaker": "手毬", "text_zh": "对不起。是我说话方式不对。"}, {"source_row": "55", "speaker": "咲季", "text_zh": "也该有个限度吧！看看你的体脂率！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季在料理对决中输给手毬，决定退出做饭值班。", "琴音提议三人共同商讨改良食堂菜单，咲季接受挑战。", "手毬向咲季道歉并感谢其一直以来的照顾。", "咲季询问手毬喜好时，手毬要求高热量食物，导致咲季吐槽其体脂率。"], "relationship_facts": ["咲季与手毬是经常进行料理对决的竞争对手。", "琴音在咲季与手毬之间起到了调解和协调的作用。", "清夏作为旁观者，对咲季和琴音的互动表示关注。"], "worldbuilding_facts": ["咲季负责食堂的菜单改良计划。", "食堂菜单需要兼顾热量和营养均衡。", "手毬偏好猪骨背脂拉面、炸猪排咖喱等高热量食物。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00473", "scene_id": "scene-00473", "source_file": "CSV/unit/01-03/adv_unit_01-03_01.csv", "source_kind": "unit", "chapter": "unit/01-03", "scene": "adv_unit_01-03_01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "80", "line_count": 80}, {"block_index": 2, "start_row": "81", "end_row": "85", "line_count": 5}], "source_refs": ["CSV/unit/01-03/adv_unit_01-03_01.csv:1-85"], "line_count": 85, "speakers": ["众人", "制作人", "咲季", "手毬", "琴音", "选项"], "topics": ["relationships", "team_story", "dialogue_style", "worldbuilding"], "title": "咲季见证手毬成长", "summary": "咲季与手毬、琴音讨论组合事务。手毬提议不固定 Center 位，咲季对此表示赞同。随后手毬与咲季决定由琴音任队长，咲季因害羞拒绝亲自向制作人说明原因，仅在场见证并支持琴音。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人", "琴音", "手毬"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["当然", "嘿嘿", "制作人", "不是吗", "啦"], "key_evidence": [{"source_row": "11", "speaker": "手毬", "text_zh": "而咲季没有明显的短板。"}, {"source_row": "31", "speaker": "咲季", "text_zh": "这不是明摆着嘛！因为啊！"}, {"source_row": "50", "speaker": "手毬", "text_zh": "是我和咲季商量后决定的。"}, {"source_row": "82", "speaker": "咲季", "text_zh": "是因为信任琴音同学，"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["手毬提议不固定 Center 位，认为咲季无明显短板。", "咲季与手毬私下决定由琴音担任组合队长。", "咲季因害羞拒绝亲自向制作人说明队长人选原因。"], "relationship_facts": ["咲季与手毬关系亲密，能共同商量决定队长人选。", "咲季与琴音关系良好，咲季希望琴音能当队长。", "咲季与制作人关系融洽，能直接对话讨论提案。"], "worldbuilding_facts": ["组合成员拥有不同的特长，如唱歌、舞蹈等。", "组合选拔考试竞争激烈，需要提升胜率。", "组合未来可能获得『H.I.F』的参赛资格。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00474", "scene_id": "scene-00474", "source_file": "CSV/unit/01-03/adv_unit_01-03_05.csv", "source_kind": "unit", "chapter": "unit/01-03", "scene": "adv_unit_01-03_05", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "64", "line_count": 64}], "source_refs": ["CSV/unit/01-03/adv_unit_01-03_05.csv:1-64"], "line_count": 64, "speakers": ["佑芽", "制作人", "星南", "莉波"], "topics": ["relationships", "dialogue_style", "team_story", "worldbuilding"], "title": "佑芽挑战咲季加入组合", "summary": "佑芽请求加入组合，星南起初因名册未登记而质疑，后得知佑芽入学较晚。佑芽表明要战胜姐姐花海咲季的决心，请求会长培育。星南认可其态度，要求通过选拔考试证明实力，并承诺若成功将助其登顶。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "莉波", "星南", "姐姐", "对手"], "worldbuilding_signals": ["学园", "偶像"], "dialogue_style_signals": ["哼", "呵呵", "制作人", "啦"], "key_evidence": [{"source_row": "17", "speaker": "佑芽", "text_zh": "因为我是勉强以候补资格入学的呀！"}, {"source_row": "31", "speaker": "佑芽", "text_zh": "『H.I.F』大赛上，就不用输给我姐姐了！"}, {"source_row": "56", "speaker": "星南", "text_zh": "参加选拔考试并取得成绩。"}, {"source_row": "64", "speaker": "星南", "text_zh": "我会亲手将你、送上巅峰。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["佑芽以候补资格入学，名册登记较晚。", "佑芽的目标是战胜姐姐花海咲季。", "星南同意佑芽加入，但要求先参加选拔考试。", "星南承诺若佑芽成功将助其登上巅峰。"], "relationship_facts": ["佑芽是花海咲季的妹妹。", "星南是组合会长。", "星南与佑芽达成加入组合的初步协议。"], "worldbuilding_facts": ["『H.I.F』大赛在夏天举办。", "花海咲季是入学考试第一名。", "组合成员需通过选拔考试才能正式加入。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00475", "scene_id": "scene-00475", "source_file": "CSV/unit/01-03/adv_unit_01-03_06.csv", "source_kind": "unit", "chapter": "unit/01-03", "scene": "adv_unit_01-03_06", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "73", "line_count": 73}], "source_refs": ["CSV/unit/01-03/adv_unit_01-03_06.csv:1-73"], "line_count": 73, "speakers": ["众人", "佑芽", "制作人", "咲季", "手毬", "星南", "琴音", "选项"], "topics": ["relationships", "dialogue_style", "team_story", "worldbuilding"], "title": "咲季试吃会风波", "summary": "咲季鼓励佑芽挑战最强偶像，并宣布举办新菜单试吃会。面对对手星南的轻视与手毬对演出失误的担忧，咲季以自信态度安抚众人，邀请制作人品尝料理，展现其作为学园第一偶像的从容与对妹妹的宠爱。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "琴音", "手毬", "星南", "妹妹", "姐姐"], "worldbuilding_signals": ["学园", "偶像"], "dialogue_style_signals": ["哼", "嘿嘿", "制作人", "啦"], "key_evidence": [{"source_row": "28", "speaker": "咲季", "text_zh": "能被学园第一的偶像关注，不是很棒的事情吗？"}, {"source_row": "31", "speaker": "手毬", "text_zh": "被十王会长关注这件事，等同于受到整个学园的瞩目。"}, {"source_row": "45", "speaker": "咲季", "text_zh": "佑芽，你也来陪我试吃。"}, {"source_row": "73", "speaker": "咲季", "text_zh": "绝对要让你说出好吃两个字！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季宣布举办新菜单试吃会，邀请制作人品尝。", "咲季认为被学园第一偶像关注是好事，不认为佑芽有问题。", "手毬指出被咲季关注等同于受整个学园瞩目，演出失误后果严重。", "琴音表示新菜单设计也有她的帮忙。"], "relationship_facts": ["咲季是佑芽的姐姐，对妹妹非常宠爱。", "星南是咲季的竞争对手，认为咲季很强。", "手毬和琴音是咲季的队友，对咲季既担心又调侃。"], "worldbuilding_facts": ["咲季是学园最强的偶像，被称为学园第一。", "十王会长是学园偶像选拔的负责人。", "新菜单在保持营养价值基础上增加了调味变化。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00476", "scene_id": "scene-00476", "source_file": "CSV/unit/01-03/adv_unit_01-03_07.csv", "source_kind": "unit", "chapter": "unit/01-03", "scene": "adv_unit_01-03_07", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "72", "line_count": 72}], "source_refs": ["CSV/unit/01-03/adv_unit_01-03_07.csv:1-72"], "line_count": 72, "speakers": ["众人", "佑芽", "制作人", "咲季", "手毬", "星南", "琴音"], "topics": ["relationships", "team_story", "dialogue_style", "worldbuilding"], "title": "咲季与佑芽的选拔挑战", "summary": "咲季展示新料理获众人赞赏，并承诺考试后给手毬做炸猪排。佑芽决心参加选拔考试以战胜姐姐，手毬认可其毅力。制作人提议亲自培育佑芽，众人对此反应热烈。咲季作为姐姐与妹妹关系紧密，共同面对挑战。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "琴音", "手毬", "星南", "妹妹", "姐姐", "伙伴"], "worldbuilding_signals": ["学园", "偶像"], "dialogue_style_signals": ["当然", "哼", "呵呵", "嘿嘿", "制作人", "啦"], "key_evidence": [{"source_row": "20", "speaker": "咲季", "text_zh": "等考试结束后，就破例给你做一次炸猪排吧。"}, {"source_row": "49", "speaker": "佑芽", "text_zh": "因为我的目标就是要战胜姐姐啊。"}, {"source_row": "71", "speaker": "制作人", "text_zh": "请让我来培育你吧。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季承诺考试结束后给手毬做炸猪排作为交换。", "佑芽决定参加选拔考试，目标是战胜姐姐。", "制作人提议在半个月时间内亲自培育佑芽。", "手毬认可佑芽全力以赴、超越极限的决心。"], "relationship_facts": ["咲季是佑芽的姐姐，两人关系亲密。", "手毬与咲季、佑芽同为偶像团体成员。", "制作人是偶像团体的管理者，常提出特殊提议。"], "worldbuilding_facts": ["偶像团体成员需参加选拔考试以争取机会。", "偶像在当任期间需控制体重，避免食用油炸食品。", "学园偶像需展现出可能性并达到会长认可的水平。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00477", "scene_id": "scene-00477", "source_file": "CSV/unit/01-03/adv_unit_01-03_08.csv", "source_kind": "unit", "chapter": "unit/01-03", "scene": "adv_unit_01-03_08", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "75", "line_count": 75}], "source_refs": ["CSV/unit/01-03/adv_unit_01-03_08.csv:1-75"], "line_count": 75, "speakers": ["众人", "佑芽", "制作人", "咲季", "手毬", "琴音"], "topics": ["relationships", "dialogue_style", "team_story", "worldbuilding"], "title": "培育最强竞争对手计划", "summary": "制作人提议将佑芽作为对手进行特别培育，以助咲季等人通过选拔。咲季对此计划大加赞赏，认为能借此证明会长眼光蒙尘。众人随即分工，决定共同训练佑芽，将其打造为最强竞争者，并约定由咲季负责最终对决。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "琴音", "手毬", "姐姐", "对手"], "worldbuilding_signals": ["偶像", "训练"], "dialogue_style_signals": ["当然", "哼", "制作人"], "key_evidence": [{"source_row": "46", "speaker": "制作人", "text_zh": "让我们来培养吧，最强的竞争对手！"}, {"source_row": "54", "speaker": "咲季", "text_zh": "超~~~~~~~级合我胃口的作战计划呢！"}, {"source_row": "74", "speaker": "咲季", "text_zh": "就让我们打得她哭爹喊娘吧！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["制作人提出将佑芽作为竞争对手进行特别培育。", "咲季认为该计划有趣，并决定亲自负责最终对决。", "众人分工合作，手毬教唱歌，琴音教跳舞。", "咲季计划将训练好的佑芽送给会长以证明其眼光。"], "relationship_facts": ["咲季与佑芽是竞争对手关系。", "咲季与手毬、琴音是队友关系。", "咲季与会长是竞争关系。"], "worldbuilding_facts": ["存在选拔考试制度。", "偶像组合之间存在敌对竞争关系。", "特别训练比常规训练效果更好。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00478", "scene_id": "scene-00478", "source_file": "CSV/unit/01-03/adv_unit_01-03_09.csv", "source_kind": "unit", "chapter": "unit/01-03", "scene": "adv_unit_01-03_09", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "74", "line_count": 74}], "source_refs": ["CSV/unit/01-03/adv_unit_01-03_09.csv:1-74"], "line_count": 74, "speakers": ["众人", "佑芽", "制作人", "咲季", "手毬", "旁白", "琴音"], "topics": ["relationships", "team_story", "dialogue_style", "character_arc"], "title": "选拔特训与组合命名", "summary": "众人进行选拔考试特训，咲季指导佑芽呼吸并分享进步心得。佑芽立志要在选拔中向十王会长证明实力，咲季对此表示赞同。制作人随后公布新组合名称为『Re;IRIS』，众人充满干劲。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "琴音", "手毬", "妹妹"], "worldbuilding_signals": ["偶像", "训练"], "dialogue_style_signals": ["当然", "真是的", "哼", "制作人", "啦"], "key_evidence": [{"source_row": "14", "speaker": "咲季", "text_zh": "手毬的教学方式，你不觉得这几天进步神速吗？"}, {"source_row": "19", "speaker": "咲季", "text_zh": "这不是当然的吗？在妹妹面前怎么能丢脸。"}, {"source_row": "54", "speaker": "咲季", "text_zh": "———这才叫一决胜负。"}, {"source_row": "74", "speaker": "制作人", "text_zh": "『Re;IRIS』！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季指导佑芽用腹肌控制呼吸以进行特训。", "咲季表示在妹妹面前不能丢脸，因此进步神速。", "佑芽立志要在选拔考试中向十王会长认真较量。", "制作人正式公布新组合名称为『Re;IRIS』。"], "relationship_facts": ["咲季是佑芽的妹妹。", "咲季与琴音互相鼓励，琴音称赞咲季舞蹈突飞猛进。", "咲季与手毬同为接受特训的偶像成员。"], "worldbuilding_facts": ["选拔考试是偶像们的重要舞台，十王会长将现场观看。", "特训内容包括唱歌时的呼吸控制技巧。", "新组合被命名为『Re;IRIS』。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00479", "scene_id": "scene-00479", "source_file": "CSV/unit/01-03/adv_unit_01-03_10.csv", "source_kind": "unit", "chapter": "unit/01-03", "scene": "adv_unit_01-03_10", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "77", "line_count": 77}], "source_refs": ["CSV/unit/01-03/adv_unit_01-03_10.csv:1-77"], "line_count": 77, "speakers": ["众人", "制作人", "咲季", "手毬", "琴音", "选项"], "topics": ["relationships", "team_story", "dialogue_style", "worldbuilding"], "title": "Re;IRIS 组合名诞生", "summary": "众人讨论偶像组合名称，咲季提出由 Re;IRIS 组合而成的彩虹女神概念，手毬与琴音分别阐述坚韧与回馈希望的含义。制作人最终总结愿望，确立组合名寓意，众人共同决定由来，正式定名 Re;IRIS。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "琴音", "手毬", "姐姐"], "worldbuilding_signals": ["偶像", "工作"], "dialogue_style_signals": ["才不是", "呵呵", "制作人", "啦"], "key_evidence": [{"source_row": "30", "speaker": "咲季", "text_zh": "直截了当地说，就是彩虹女神的名字啦！"}, {"source_row": "45", "speaker": "手毬", "text_zh": "像菖蒲那样，强韧、坚毅……又顽强。"}, {"source_row": "58", "speaker": "琴音", "text_zh": "要好好给大伙儿『回礼』才行。"}, {"source_row": "74", "speaker": "制作人", "text_zh": "所以取名『Re;IRIS』。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["组合名称定为 Re;IRIS，由咲季主导提出彩虹女神概念。", "手毬将组合名解释为花瓣不凋零的坚韧象征。", "琴音希望组合能回馈粉丝支持，成为治愈系偶像。", "制作人总结愿望，希望偶像如花朵般坚韧歌唱。"], "relationship_facts": ["咲季、手毬、琴音为偶像组合成员。", "咲季与琴音互称姐姐，关系亲密。", "制作人是组合的负责人与命名者。"], "worldbuilding_facts": ["组合名 Re;IRIS 由 Re; 与 IRIS（鸢尾花）组成。", "鸢尾花象征坚韧，花瓣不会凋零。", "组合定位为治愈系偶像，受全人类崇拜。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00480", "scene_id": "scene-00480", "source_file": "CSV/unit/01-03/adv_unit_01-03_11.csv", "source_kind": "unit", "chapter": "unit/01-03", "scene": "adv_unit_01-03_11", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "80", "line_count": 80}], "source_refs": ["CSV/unit/01-03/adv_unit_01-03_11.csv:1-80"], "line_count": 80, "speakers": ["众人", "制作人", "咲季", "手毬", "旁白", "琴音", "选项"], "topics": ["relationships", "team_story", "dialogue_style", "plot"], "title": "Re;IRIS 首演与庆功宴", "summary": "Re;IRIS 组合顺利通过首次 H.I.F 选拔考试演唱会，成员间羁绊加深。咲季自信展现实力，并提议为佑芽庆功宴。众人决定共同准备料理，制作人亦受邀参加，团队氛围融洽且充满期待。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "琴音", "手毬", "妹妹", "姐姐"], "worldbuilding_signals": ["偶像", "演唱会"], "dialogue_style_signals": ["当然", "嘿嘿", "制作人", "不是吗", "啦"], "key_evidence": [{"source_row": "30", "speaker": "琴音", "text_zh": "我们的『Re;IRIS』首次演唱会！"}, {"source_row": "33", "speaker": "咲季", "text_zh": "怎么样，我们的演唱会！？"}, {"source_row": "57", "speaker": "咲季", "text_zh": "因为明天是佑芽的选拔考试呀。"}, {"source_row": "62", "speaker": "咲季", "text_zh": "手毬同学，说好的炸猪排明天给你做哦。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["Re;IRIS 组合成功通过首次 H.I.F 选拔考试演唱会。", "咲季提议为佑芽的选拔考试举办庆功宴。", "咲季承诺为手毬制作炸猪排作为奖励。", "制作人同意参加组合的庆功宴。"], "relationship_facts": ["咲季与手毬是组合成员，咲季照顾手毬。", "咲季与琴音是姐妹关系，咲季是姐姐。", "咲季与制作人关系融洽，制作人支持组合。"], "worldbuilding_facts": ["Re;IRIS 是正在参加 H.I.F 选拔考试的偶像组合。", "组合成员包括咲季、手毬、琴音及制作人。", "咲季是组合中的核心偶像，拥有压倒性实力。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00481", "scene_id": "scene-00481", "source_file": "CSV/unit/01-03/adv_unit_01-03_12.csv", "source_kind": "unit", "chapter": "unit/01-03", "scene": "adv_unit_01-03_12", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "80", "line_count": 80}, {"block_index": 2, "start_row": "81", "end_row": "88", "line_count": 8}], "source_refs": ["CSV/unit/01-03/adv_unit_01-03_12.csv:1-88"], "line_count": 88, "speakers": ["佑芽", "制作人", "咲季", "手毬", "星南", "琴音", "美铃"], "topics": ["relationships", "team_story", "dialogue_style", "character_arc"], "title": "咲季见证对手与旧友", "summary": "庆功宴上，手毬因炸猪排面衣被剥而闹情绪欲退团，咲季出面安抚并分享面衣。随后十王星南来访，认可佑芽才能并介绍前成员美铃。佑芽正式向咲季等人提出下月选拔考试的对战申请，咲季全程在场见证。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "琴音", "手毬", "星南", "美铃", "妹妹", "姐姐", "伙伴"], "worldbuilding_signals": ["学园", "偶像"], "dialogue_style_signals": ["才不是", "哼", "呵呵", "嘿嘿", "制作人", "啦"], "key_evidence": [{"source_row": "4", "speaker": "咲季", "text_zh": "手毬！别擅自说这种话！"}, {"source_row": "31", "speaker": "咲季", "text_zh": "连队长那份的面衣我也帮你剥好了哦。"}, {"source_row": "87", "speaker": "佑芽", "text_zh": "我们『Begrazia』要向『Re;IRIS』提出对战申请。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["手毬因咲季剥掉炸猪排面衣而闹情绪欲退出组合。", "咲季主动为手毬剥好面衣并分享琴音的面衣。", "十王星南来访并介绍前成员美铃加入 Re;IRIS。", "佑芽代表 Begrazia 向 Re;IRIS 提出下月选拔考试对战申请。"], "relationship_facts": ["咲季是佑芽的姐姐。", "琴音是 Re;IRIS 的队长。", "美铃是手毬的前组合成员。"], "worldbuilding_facts": ["Re;IRIS 是正在举办庆功宴的偶像组合。", "Begrazia 是向 Re;IRIS 提出挑战的另一个组合。", "十王星南是初星学园的学生会长。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00482", "scene_id": "scene-00482", "source_file": "CSV/unit/01-04/adv_unit_01-04_01.csv", "source_kind": "unit", "chapter": "unit/01-04", "scene": "adv_unit_01-04_01", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "62", "line_count": 62}], "source_refs": ["CSV/unit/01-04/adv_unit_01-04_01.csv:1-62"], "line_count": 62, "speakers": ["众人", "佑芽", "制作人", "咲季", "手毬", "星南", "琴音", "美铃"], "topics": ["relationships", "team_story", "dialogue_style", "character_arc"], "title": "咲季接受战书", "summary": "咲季因看到妹妹佑芽在 Begrazia 组合中的精彩表现而情绪高涨，欣然接受向该组合下战书的挑战。琴音对此感到无奈，手毬则分析对手阵容强大，认为这是成为顶级偶像的必经之路。众人最终决定以 Begrazia 为垫脚石，全力备战下个月的选拔考试。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "琴音", "手毬", "星南", "美铃", "妹妹", "对手"], "worldbuilding_signals": ["偶像", "训练"], "dialogue_style_signals": ["哼", "呵呵", "嘿嘿", "制作人", "啦"], "key_evidence": [{"source_row": "4", "speaker": "咲季", "text_zh": "正合我意～～～～～～～～～！"}, {"source_row": "5", "speaker": "咲季", "text_zh": "我们『Re;IRIS』接受挑战！"}, {"source_row": "51", "speaker": "咲季", "text_zh": "还有我命中注定的对手佑芽。"}, {"source_row": "61", "speaker": "琴音", "text_zh": "『一等星』我们要直线上升直到登顶"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季看到妹妹佑芽的舞台视频后情绪高涨，主动接受向 Begrazia 下战书。", "Begrazia 组合成员包括佑芽、美铃、星南及十王会长。", "Re;IRIS 决定将 Begrazia 视为垫脚石，目标是下个月选拔考试登顶。", "手毬认为面对顶级偶像组合是成为顶级偶像的必经之路。"], "relationship_facts": ["咲季是佑芽的妹妹。", "琴音是 Re;IRIS 的队长。", "手毬与美铃曾是同伴。"], "worldbuilding_facts": ["Begrazia 是十王会长所在的组合。", "星南被称为学院第一偶像。", "下个月将举行选拔考试。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00483", "scene_id": "scene-00483", "source_file": "CSV/unit/01-04/adv_unit_01-04_03.csv", "source_kind": "unit", "chapter": "unit/01-04", "scene": "adv_unit_01-04_03", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "70", "line_count": 70}], "source_refs": ["CSV/unit/01-04/adv_unit_01-04_03.csv:1-70"], "line_count": 70, "speakers": ["佑芽", "旁白", "星南", "美铃"], "topics": ["relationships", "worldbuilding", "team_story", "dialogue_style"], "title": "星南宣布新曲与方针", "summary": "会议结束后，星南宣布将佑芽和美铃纳入 Begrazia 组合，并展示新曲《Star-mine》。她提出理想组合需全员拥有压倒性实力，无需团队协作，要求两人练出能与自己比肩的实力，共同席卷业界。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "琴音", "手毬", "星南", "美铃"], "worldbuilding_signals": ["学园", "偶像"], "dialogue_style_signals": ["当然", "才不是", "呵呵", "制作人", "啦"], "key_evidence": [{"source_row": "28", "speaker": "星南", "text_zh": "我要让你们两个加入学生会。"}, {"source_row": "44", "speaker": "星南", "text_zh": "『我所憧憬的理想偶像组合』"}, {"source_row": "69", "speaker": "星南", "text_zh": "曲名是『Star-mine』"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["星南宣布将佑芽和美铃正式加入 Begrazia 组合。", "新曲《Star-mine》是 Begrazia 首次亮相的重要舞台用曲。", "星南要求成员在选拔考试前练出能与她比肩的个人实力。"], "relationship_facts": ["星南是 Begrazia 的会长及制作人。", "佑芽视星南为自己的专属制作人。", "星南、佑芽、美铃将共同演绎新曲。"], "worldbuilding_facts": ["Begrazia 是即将首次亮相的新偶像组合。", "选拔考试是与 Re;IRIS 的对决演出。", "星南认为理想偶像组合应由全员压倒性实力构成。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00484", "scene_id": "scene-00484", "source_file": "CSV/unit/01-04/adv_unit_01-04_04.csv", "source_kind": "unit", "chapter": "unit/01-04", "scene": "adv_unit_01-04_04", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "80", "line_count": 80}, {"block_index": 2, "start_row": "81", "end_row": "100", "line_count": 20}], "source_refs": ["CSV/unit/01-04/adv_unit_01-04_04.csv:1-100"], "line_count": 100, "speakers": ["众人", "制作人", "咲季", "手毬", "琴音", "选项"], "topics": ["relationships", "team_story", "dialogue_style", "character_arc"], "title": "咲季直面最强对手", "summary": "训练结束后，咲季鼓励手毬坚持，并告知制作人自己面对妹妹佑芽的对决感到前所未有的恐惧与骄傲。她深知若输给妹妹将再无胜算，但作为姐姐绝不逃避。众人随后收到决战曲目《雨过天晴的鸢尾花》，决心将其打造为 Re;IRIS 的代名词。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "琴音", "手毬", "美铃", "妹妹", "姐姐", "对手"], "worldbuilding_signals": ["偶像", "训练"], "dialogue_style_signals": ["当然", "呵呵", "制作人", "啦"], "key_evidence": [{"source_row": "81", "speaker": "咲季", "text_zh": "只要输给妹妹一次的话，就再也无法战胜她了。"}, {"source_row": "88", "speaker": "咲季", "text_zh": "因为我是那孩子的姐姐啊。"}, {"source_row": "98", "speaker": "制作人", "text_zh": "曲名是『雨过天晴的鸢尾花』"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季认为若输给妹妹佑芽，将再也无法战胜她。", "咲季面对与 Begrazia 的对决感到害怕但勇于挑战。", "制作人宣布决战前需掌握新曲《雨过天晴的鸢尾花》。"], "relationship_facts": ["咲季是佑芽的姐姐，视其为必须跨越的高墙。", "咲季与手毬关系亲密，咲季常以姐姐姿态鼓励手毬。", "咲季与制作人关系良好，制作人了解咲季的内心想法。"], "worldbuilding_facts": ["Re;IRIS 即将参加 H.I.F 正赛选拔。", "咲季的对手是 Begrazia 组合的佑芽。", "新曲《雨过天晴的鸢尾花》将作为 Re;IRIS 的代名词。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00485", "scene_id": "scene-00485", "source_file": "CSV/unit/01-04/adv_unit_01-04_05.csv", "source_kind": "unit", "chapter": "unit/01-04", "scene": "adv_unit_01-04_05", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "57", "line_count": 57}], "source_refs": ["CSV/unit/01-04/adv_unit_01-04_05.csv:1-57"], "line_count": 57, "speakers": ["众人", "制作人", "咲季", "手毬", "旁白", "琴音"], "topics": ["relationships", "team_story", "dialogue_style", "character_arc"], "title": "选拔考试前的誓言", "summary": "选拔考试当天，Re;IRIS 成员咲季、手毬与琴音在制作人见证下准备登台。咲季视对手为宿命，誓言若输将无颜面对大家；手毬为证明道路正确而必须胜利。琴音负责调节紧张气氛，强调这是雨后的鸢尾花首秀，众人即将出发。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "琴音", "手毬", "姐姐", "对手"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["真是的", "呵呵", "制作人", "啦"], "key_evidence": [{"source_row": "3", "speaker": "咲季", "text_zh": "与宿命对手 Begrazia 一决胜负的日子！"}, {"source_row": "28", "speaker": "咲季", "text_zh": "这次作为偶像要是输了的话……就真的不配当姐姐了。"}, {"source_row": "35", "speaker": "手毬", "text_zh": "把 Re;IRIS 视为眼中钉来挑战了。"}, {"source_row": "44", "speaker": "琴音", "text_zh": "『雨后的鸢尾花』首秀舞台呢。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["选拔考试当天是 Re;IRIS 与对手 Begrazia 对决的日子。", "咲季表示若作为偶像输了，就再也无颜面对大家。", "手毬认为必须彻底击溃对手，以证明自己的道路没有错。", "琴音指出这是『雨后的鸢尾花』的首秀舞台。"], "relationship_facts": ["咲季、手毬和琴音是 Re;IRIS 的队友。", "琴音是 Re;IRIS 的队长，负责调节成员心态。", "咲季和手毬都视 Begrazia 为宿敌或眼中钉。"], "worldbuilding_facts": ["Re;IRIS 是一支偶像团体，正在参加选拔考试。", "对手团体名为『一等星』或 Begrazia。", "Re;IRIS 的出道曲或主打舞台名为『雨后的鸢尾花』。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00486", "scene_id": "scene-00486", "source_file": "CSV/unit/01-04/adv_unit_01-04_06.csv", "source_kind": "unit", "chapter": "unit/01-04", "scene": "adv_unit_01-04_06", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "42", "line_count": 42}], "source_refs": ["CSV/unit/01-04/adv_unit_01-04_06.csv:1-42"], "line_count": 42, "speakers": ["佑芽", "旁白", "星南", "美铃"], "topics": ["relationships", "plot", "character_arc", "dialogue_style"], "title": "选拔战前的决意", "summary": "选拔考试当天，佑芽视战胜姐姐花海咲季为人生目标，却因缺乏后续思考而陷入迷茫。星南指出其成长潜力，鼓励她直面咲季以突破自我。佑芽决心只关注当下胜利，星南与美铃随即带领 Begrazia 成员奔赴 Re;IRIS 的演唱会现场，准备华丽开幕。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "星南", "美铃", "姐姐", "对手"], "worldbuilding_signals": ["偶像", "演唱会"], "dialogue_style_signals": ["呵呵", "啦"], "key_evidence": [{"source_row": "5", "speaker": "佑芽", "text_zh": "因为……战胜姐姐，对我来说可是人生目标啊。"}, {"source_row": "17", "speaker": "星南", "text_zh": "佑芽——去战胜花海咲季吧。"}, {"source_row": "33", "speaker": "美铃", "text_zh": "走吧，各位……去击败 Re;IRIS。"}, {"source_row": "34", "speaker": "星南", "text_zh": "嗯……我们 Begrazia 的首次演唱会。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "mentioned", "saki_actions": [], "story_facts": ["选拔考试当天，佑芽与 Re;IRIS 进行对决。", "佑芽将战胜姐姐花海咲季视为人生目标。", "星南鼓励佑芽通过战胜咲季来突破自我。", "Begrazia 即将开始首次演唱会。"], "relationship_facts": ["佑芽视花海咲季为宿敌与姐姐。", "星南是佑芽的学姐与前辈。", "星南与美铃同为 Begrazia 成员。"], "worldbuilding_facts": ["佑芽所在的团体名为 Begrazia。", "对手团体名为 Re;IRIS。", "当前场景为选拔考试当天的演唱会前。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00487", "scene_id": "scene-00487", "source_file": "CSV/unit/01-04/adv_unit_01-04_07.csv", "source_kind": "unit", "chapter": "unit/01-04", "scene": "adv_unit_01-04_07", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "78", "line_count": 78}], "source_refs": ["CSV/unit/01-04/adv_unit_01-04_07.csv:1-78"], "line_count": 78, "speakers": ["佑芽", "制作人", "咲季", "手毬", "琴音", "选项"], "topics": ["relationships", "team_story", "dialogue_style", "character_arc"], "title": "咲季面对佑芽胜利", "summary": "比赛结束后，咲季因输给佑芽而极度失落，认为无法再追上对方。手毬与琴音试图安慰，咲季在众人面前逞强，但独处时向制作人崩溃，承认自己再也追不上佑芽，展现了姐姐对妹妹成长的复杂心情。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "琴音", "手毬", "广", "妹妹", "姐姐"], "worldbuilding_signals": ["偶像"], "dialogue_style_signals": ["真是的", "呵呵", "嘿嘿", "制作人", "啦"], "key_evidence": [{"source_row": "7", "speaker": "咲季", "text_zh": "下次……怎么可能还有啊……"}, {"source_row": "41", "speaker": "咲季", "text_zh": "你可是超越了我哦。"}, {"source_row": "78", "speaker": "咲季", "text_zh": "我…………再也……追不上了。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季在绝对不想输的比赛中输给了佑芽。", "咲季认为佑芽已经超越了自己，无法再追上。", "咲季在制作人面前承认自己再也追不上佑芽。"], "relationship_facts": ["咲季是佑芽的姐姐。", "咲季与手毬、琴音是队友。", "咲季与制作人存在上下级或指导关系。"], "worldbuilding_facts": ["咲季和佑芽正在进行偶像对决。", "咲季和佑芽所属组合为 H.I.F。", "咲季和佑芽之间存在长期的竞争关系。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00488", "scene_id": "scene-00488", "source_file": "CSV/unit/01-04/adv_unit_01-04_09.csv", "source_kind": "unit", "chapter": "unit/01-04", "scene": "adv_unit_01-04_09", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "57", "line_count": 57}], "source_refs": ["CSV/unit/01-04/adv_unit_01-04_09.csv:1-57"], "line_count": 57, "speakers": ["众人", "咲季", "手毬", "旁白", "琴音"], "topics": ["relationships", "team_story", "character_arc", "dialogue_style"], "title": "咲季受挫后决定回老家", "summary": "选拔失利次日，咲季因被超越而陷入自我怀疑，手毬虽言语尖锐却以昔日鼓励回应，激励咲季振作。咲季最终决定回老家，手毬则誓言要追上并超越咲季，两人关系在冲突中深化。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "琴音", "手毬"], "worldbuilding_signals": ["偶像", "训练"], "dialogue_style_signals": ["不是吗", "啦"], "key_evidence": [{"source_row": "23", "speaker": "咲季", "text_zh": "被比我快的家伙超越一次的话…就再也追不上了不是吗…！"}, {"source_row": "44", "speaker": "手毬", "text_zh": "当我独自奔跑快要崩溃的时候，你笑着从我身边超了过去。"}, {"source_row": "57", "speaker": "咲季", "text_zh": "——我要回老家。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季因输给佑芽且被手毬超越而陷入自我否定。", "手毬通过回忆咲季曾经的鼓励来激励咲季重新站起。", "咲季在对话结束后决定离开众人回老家。"], "relationship_facts": ["咲季与手毬互为竞争对手且互相激励。", "手毬视咲季为需要追赶的目标。", "琴音与手毬均试图帮助受挫的咲季。"], "worldbuilding_facts": ["选拔考试次日是演出前的关键时期。", "角色之间存在明确的偶像竞争关系。", "手毬自称目标是成为未来的顶级偶像。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00489", "scene_id": "scene-00489", "source_file": "CSV/unit/01-04/adv_unit_01-04_10.csv", "source_kind": "unit", "chapter": "unit/01-04", "scene": "adv_unit_01-04_10", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "80", "line_count": 80}], "source_refs": ["CSV/unit/01-04/adv_unit_01-04_10.csv:1-80"], "line_count": 80, "speakers": ["咲季", "手毬", "琴音"], "topics": ["relationships", "team_story", "dialogue_style", "character_arc"], "title": "咲季归来与复仇之战", "summary": "咲季回归 Re;IRIS 发现队友在练习双人舞，因她曾欲回老家而误以为其放弃。咲季澄清是为强化实力，虽内心受挫但身体仍为胜利奔跑。队友虽言语刻薄实则支持，咲季决心为 Re;IRIS 向对手 Begrazia 复仇。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "琴音", "手毬", "朋友", "父母"], "worldbuilding_signals": ["偶像", "训练"], "dialogue_style_signals": ["当然", "哼", "制作人", "啦"], "key_evidence": [{"source_row": "1", "speaker": "咲季", "text_zh": "我回来了！大家！"}, {"source_row": "11", "speaker": "琴音", "text_zh": "因为你说要回老家……"}, {"source_row": "46", "speaker": "咲季", "text_zh": "身体不由自主地动起来了……"}, {"source_row": "80", "speaker": "咲季", "text_zh": "Re;IRIS 的复仇之战！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季因回老家征求意见而暂时离开，并非放弃偶像。", "队友在咲季缺席期间秘密准备了双人舞对策。", "咲季内心虽被击垮，但身体仍为胜利而行动。", "Re;IRIS 输掉比赛是因为对手 Begrazia 而非咲季个人。"], "relationship_facts": ["咲季、手毬、琴音是 Re;IRIS 组合成员。", "琴音和手毬因咲季擅自消失而决定独自练习。", "咲季视队友为必须超越的对手兼伙伴。"], "worldbuilding_facts": ["Re;IRIS 是咲季所在的偶像组合。", "对手组合名为 Begrazia。", "咲季在 Re;IRIS 活动了十五年。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00490", "scene_id": "scene-00490", "source_file": "CSV/unit/01-04/adv_unit_01-04_11.csv", "source_kind": "unit", "chapter": "unit/01-04", "scene": "adv_unit_01-04_11", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "56", "line_count": 56}], "source_refs": ["CSV/unit/01-04/adv_unit_01-04_11.csv:1-56"], "line_count": 56, "speakers": ["众人", "制作人", "咲季", "手毬", "琴音", "选项"], "topics": ["relationships", "dialogue_style", "team_story", "worldbuilding"], "title": "咲季误会与复出决心", "summary": "选考后咲季因制作人准备备选方案而误会其欲放弃自己，情绪激动。制作人澄清仅为未雨绸缪，并指出咲季内心虽碎但根基未断。咲季承认自己未能振作，最终在众人鼓励下重拾打倒对手的决心。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人", "琴音", "手毬"], "worldbuilding_signals": ["偶像", "训练"], "dialogue_style_signals": ["哼", "呵呵", "制作人", "啦"], "key_evidence": [{"source_row": "7", "speaker": "咲季", "text_zh": "已经准备好要放弃我了是吧？"}, {"source_row": "16", "speaker": "制作人", "text_zh": "我一直相信你能回来。"}, {"source_row": "47", "speaker": "咲季", "text_zh": "但内心早就碎得七零八落啦！"}, {"source_row": "55", "speaker": "众人", "text_zh": "打倒 Begrazia！！"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季因制作人准备备选方案而误会对方欲放弃自己。", "咲季承认自己内心破碎，但表示仍会全力以赴。", "制作人指出咲季内心驱动力已不再折断。", "众人一致决定打倒对手 Begrazia。"], "relationship_facts": ["咲季与制作人之间存在信任危机与和解过程。", "咲季与手毬、琴音同为 Re;IRIS 成员。", "咲季与 Begrazia 为敌对关系。"], "worldbuilding_facts": ["Re;IRIS 组合人数变更会导致配合困难。", "H.I.F 决赛是夏季的重要赛事。", "咲季曾因失败而长期无法重新振作。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00491", "scene_id": "scene-00491", "source_file": "CSV/unit/01-04/adv_unit_01-04_12.csv", "source_kind": "unit", "chapter": "unit/01-04", "scene": "adv_unit_01-04_12", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "64", "line_count": 64}], "source_refs": ["CSV/unit/01-04/adv_unit_01-04_12.csv:1-64"], "line_count": 64, "speakers": ["众人", "制作人", "咲季", "手毬", "琴音", "选项"], "topics": ["relationships", "dialogue_style", "team_story", "character_arc"], "title": "咲季重拾成长信心", "summary": "制作人指示咲季重新认识自己，肯定其持续成长的事实。咲季意识到与佑芽的竞技中自己仍在进步，并决心通过特别训练带领 Re;IRIS 全员成长，以制作人之间的较量对抗 Begrazia，誓要赢得胜利。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "琴音", "手毬", "星南", "美铃", "妹妹"], "worldbuilding_signals": ["偶像", "训练"], "dialogue_style_signals": ["当然", "制作人", "啦"], "key_evidence": [{"source_row": "22", "speaker": "制作人", "text_zh": "你现在依然……在一点点地成长着。"}, {"source_row": "55", "speaker": "咲季", "text_zh": "这么说来…………是 4 对 3 的较量呢。"}, {"source_row": "64", "speaker": "咲季", "text_zh": "要赢哦。我们四个人一起。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季曾认为自己的偶像成长陷入停滞，但在制作人鼓励下确认自己仍在进步。", "咲季意识到与佑芽的竞技是制作人之间的较量，Re;IRIS 为 4 对 3。", "咲季决心通过特别训练，带领 Re;IRIS 全员全力以赴，战胜 Begrazia。"], "relationship_facts": ["咲季与佑芽存在偶像成长上的竞争关系。", "咲季与手毬、琴音、月村同为 Re;IRIS 成员，共同面对挑战。", "咲季与制作人之间建立了深厚的信任关系。"], "worldbuilding_facts": ["Begrazia 是由十王星南会长亲自担任制作人培育的偶像团体。", "Re;IRIS 与 Begrazia 的对决不仅是偶像实力的比拼，更是制作人之间的较量。", "咲季曾从佑芽身上感受到成长停滞的焦虑，后在团队支持下重拾信心。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00492", "scene_id": "scene-00492", "source_file": "CSV/unit/01-04/adv_unit_01-04_13.csv", "source_kind": "unit", "chapter": "unit/01-04", "scene": "adv_unit_01-04_13", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "71", "line_count": 71}], "source_refs": ["CSV/unit/01-04/adv_unit_01-04_13.csv:1-71"], "line_count": 71, "speakers": ["众人", "佑芽", "制作人", "咲季", "手毬", "琴音"], "topics": ["relationships", "team_story", "dialogue_style", "worldbuilding"], "title": "咲季接受前辈影像鼓励", "summary": "演出后咲季因梦见佑芽离开而情绪低落，手毬与琴音安慰她。制作人赠送月村前辈的演唱会影像鼓励咲季挑战顶级偶像。咲季重拾信心，决心放手一搏，团队约定继续特训赚钱。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["制作人", "佑芽", "琴音", "手毬", "姐姐"], "worldbuilding_signals": ["偶像", "训练", "演唱会", "工作"], "dialogue_style_signals": ["当然", "制作人", "啦"], "key_evidence": [{"source_row": "12", "speaker": "咲季", "text_zh": "没什么。只是做了个超级讨厌的梦。"}, {"source_row": "50", "speaker": "制作人", "text_zh": "是月村同学曾经所属的 SyngUp! 的演唱会影像。"}, {"source_row": "64", "speaker": "咲季", "text_zh": "我想成为的可是世界第一的偶像哦？"}, {"source_row": "70", "speaker": "琴音", "text_zh": "虽然接下来会持续一段每天泡在演唱会里的日子"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季梦见佑芽决定离开并加入 Begrazia，导致情绪不稳定。", "制作人赠送了咲季已故前辈月村所属 SyngUp! 的演唱会影像。", "咲季表示想成为世界第一的偶像，并决定接受挑战。", "团队决定继续高强度特训以赚取更多资金。"], "relationship_facts": ["咲季是 Re;IRIS 的队长，负责支援队友。", "琴音是咲季的队员，曾受咲季培养。", "手毬是咲季的队友，对咲季有深厚的情谊。"], "worldbuilding_facts": ["Re;IRIS 正在进行与实力更强偶像同场演出的特训。", "Begrazia 是一个拥有多名顶级偶像的团体。", "SyngUp! 是咲季前辈月村曾经所属的偶像团体。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00493", "scene_id": "scene-00493", "source_file": "CSV/unit/01-04/adv_unit_01-04_15.csv", "source_kind": "unit", "chapter": "unit/01-04", "scene": "adv_unit_01-04_15", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "60", "line_count": 60}], "source_refs": ["CSV/unit/01-04/adv_unit_01-04_15.csv:1-60"], "line_count": 60, "speakers": ["咲季", "手毬", "琴音"], "topics": ["relationships", "team_story", "dialogue_style", "character_arc"], "title": "决赛前夜的焦虑与羁绊", "summary": "决赛前夕，咲季因害怕再次失败而失眠，手毬熟睡在一旁。琴音试图安慰咲季，坦言自己因梦想执念而陷入困境，最终被咲季等人的努力所拯救。咲季虽嘴上嫌弃琴音的鼓励，内心却充满期待，三人间深厚的羁绊在紧张氛围中愈发清晰。", "saki_role": "担当偶像/搭档：咲季与制作人围绕训练、胜利、信任和调侃展开互动。", "relationship_signals": ["制作人", "琴音", "手毬", "对手"], "worldbuilding_signals": [], "dialogue_style_signals": ["当然", "真是的", "制作人", "啦"], "key_evidence": [{"source_row": "14", "speaker": "咲季", "text_zh": "我很害怕啊。怕得不得了……所以睡不着。"}, {"source_row": "31", "speaker": "琴音", "text_zh": "但你们的这种执念，反而拯救了我哦。"}, {"source_row": "53", "speaker": "琴音", "text_zh": "说什么输了就要当一辈子奴隶之类的。"}, {"source_row": "59", "speaker": "咲季", "text_zh": "真期待天亮呢。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["咲季因害怕再次失败而失眠，担心失去不甘心。", "琴音坦言咲季等人的执念拯救了自己，决定回报。", "手毬在旁熟睡，似乎与敌人约定了输掉后的惩罚。", "咲季期待天亮，准备独自面对状态不佳的正式演出。"], "relationship_facts": ["咲季与琴音是队友，琴音视咲季为精神支柱。", "咲季与手毬是队友，手毬在咲季身边熟睡。", "咲季、琴音、手毬三人共同为了各自的梦想努力。"], "worldbuilding_facts": ["即将举行的是 H.I.F 决赛。", "咲季是队伍成员，琴音是队长。", "咲季因害怕再次失败而失眠。"], "character_arc": [], "dialogue_style": []}
{"summary_id": "scene-00494", "scene_id": "scene-00494", "source_file": "CSV/unit/01-04/adv_unit_01-04_16.csv", "source_kind": "unit", "chapter": "unit/01-04", "scene": "adv_unit_01-04_16", "dialogue_blocks": [{"block_index": 1, "start_row": "1", "end_row": "70", "line_count": 70}], "source_refs": ["CSV/unit/01-04/adv_unit_01-04_16.csv:1-70"], "line_count": 70, "speakers": ["咲季", "旁白", "星南"], "topics": ["worldbuilding", "dialogue_style", "relationships", "team_story"], "title": "咲季与星南的庆典对决", "summary": "初星学园偶像庆典当天，咲季与星南在会场独处。星南视咲季为理解其心境的镜像，决心争夺『一等星』称号，拒绝退让给佑芽或 Re;IRIS。咲季虽感压力与混乱，但作为姐姐和偶像，她决定全力以赴，要在庆典上赢给星南看。", "saki_role": "姐姐/竞争者：咲季与佑芽相关内容中常同时体现亲情、自豪和竞争意识。", "relationship_signals": ["佑芽", "星南", "美铃", "妹妹", "姐姐"], "worldbuilding_signals": ["学园", "偶像", "工作"], "dialogue_style_signals": ["当然", "才不是", "哼", "呵呵", "啦"], "key_evidence": [{"source_row": "41", "speaker": "星南", "text_zh": "能够理解你现在心情的，一定只有我。"}, {"source_row": "50", "speaker": "星南", "text_zh": "能成为『一等星』的，学园里只有一人。"}, {"source_row": "70", "speaker": "咲季", "text_zh": "绝对要赢给你看。"}], "summary_status": "llm_fast_scene_card", "saki_presence": "direct", "saki_actions": [], "story_facts": ["星南认为咲季是全世界最能理解她心情的人，两人如同照镜子。", "星南决定在庆典中争夺『一等星』称号，不会让给任何人。", "咲季虽然心情混乱，但承诺要在 Hatsuboshi IDOL FESTIVAL 上赢给星南看。"], "relationship_facts": ["咲季与星南是同学，星南是会长，咲季是后辈。", "咲季是佑芽的姐姐，星南是咲季的前辈。", "星南与佑芽、美铃及 Re;IRIS 成员存在竞争关系。"], "worldbuilding_facts": ["初星学园正在举办最大的庆典 Hatsuboshi IDOL FESTIVAL。", "星南是学园偶像社团 H.I.F 的会长，被称为『一等星』的争夺者。", "咲季入学仅半年，但已参与过踢馆传闻相关的活动。"], "character_arc": [], "dialogue_style": []}
